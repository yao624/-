<?php

namespace App\Models;

use App\Utils\Telegram;
use Illuminate\Database\Eloquent\Concerns\HasUlids;
use Illuminate\Database\Eloquent\Factories\HasFactory;
use Illuminate\Database\Eloquent\Model;
use Illuminate\Database\Eloquent\SoftDeletes;
use Illuminate\Support\Carbon;
use Illuminate\Support\Facades\Log;

/**
 * @property string id
 * @property string source_id
 * @property string currency
 */
class FbAdAccount extends BaseModel
{
    use HasFactory, HasUlids, SoftDeletes;

    protected $fillable = [
        'source_id',
        'adtrust_dsl',
        'account_status',
        'account_status_code',
        'adspaymentcycle',
        'age',
        'total_spent',
        'balance',
        'amount_spent',
        'assigned_partners',
        'business',
        'spend_cap',
        'business_restriction_reason',
        'created_time',
        'currency',
        'current_unbilled_spend',
        'disable_reason',
        'disable_reason_code',
        'max_billing_threshold',
        'name',
        'owner',
        'is_orignal',
        'timezone_id',
        'timezone_name',
        'enable_rule',
        'is_prepay_account',
        'fixed_balance',
        'notes',
        'original_adtrust_dsl',
        'original_balance',
        'original_amount_spent',
        'original_spend_cap',
        'auto_sync',
        'default_funding',
        'funding_type',
        'filters',
        'is_topup'
    ];

    protected $casts = [
        'adspaymentcycle' => 'array',
        'assigned_partners' => 'array',
        'business' => 'array',
        'current_unbilled_spend' => 'array',
        'max_billing_threshold' => 'array',
        'enable_rule' => 'boolean',
        'is_archived' => 'boolean',
        'auto_sync' => 'boolean',
        'filters' => 'array',
        'is_topup' => 'boolean'
    ];

    protected static function boot()
    {
        parent::boot();

        static::updated(function ($model) {
            // 检查 spend_cap 字段是否改变
            if ($model->isDirty('original_spend_cap')) {
                Log::info('spend_cap has changed:', [
                    'old' => $model->getOriginal('spend_cap'),
                    'new' => $model->spend_cap,
                ]);
                $msg = "Ad Account spend cap ({$model->currency}) changed: \r\n {$model->name}({$model->source_id}) \r\n old: {$model->getOriginal('original_spend_cap')} \r\n new: {$model->original_spend_cap}";
                Telegram::sendMessage($msg);
            }
        });
    }

    protected $searchAction = [
        'account_status' => 'in',
    ];

    public function tags() {
        return $this->morphToMany(Tag::class, 'taggable');
    }

    public function fbBms()
    {
        return $this->belongsToMany(FbBm::class, 'fb_ad_account_fb_bm')
            ->using(CustomPivot::class)
            ->withPivot('source_id', 'relation', 'tasks', 'role')
            ->withTimestamps();
    }

    public function fbAccounts()
    {
        return $this->belongsToMany(FbAccount::class, 'fb_account_fb_ad_account')
            ->using(CustomPivot::class)
            ->withPivot('source_id', 'relation')
            ->withTimestamps();
    }

    public function fbBusinessUsers()
    {
        return $this->belongsToMany(FbBusinessUser::class, 'fb_ad_account_fb_business_user')
            ->using(CustomPivot::class)
            ->withPivot('role')
            ->withTimestamps();
    }

    public function fbPixels()
    {
        return $this->belongsToMany(FbPixel::class, 'fb_pixel_fb_ad_account')
            ->using(CustomPivot::class)
            ->withTimestamps();
    }

    public function fbCampaigns()
    {
        return $this->hasMany(FbCampaign::class);
    }

    public function fbAdsets()
    {
        return $this->hasMany(FbAdset::class, 'account_id', 'source_id');
    }

    public function fbAds()
    {
        return $this->hasManyThrough(
            FbAd::class,
            FbCampaign::class,
            'fb_ad_account_id',  // FbCampaign 的外键
            'fb_campaign_id',    // FbAd 的外键
            'id',      // FbAdAccount 的本地键
            'id'              // FbCampaign 的本地键
        );
    }

    public function insights()
    {
//        return $this->hasMany(FbAccountInsight::class);
        return $this->hasMany(FbAdAccountInsight::class, 'account_id', 'source_id');
    }

    public function offerClicks()
    {
        return $this->hasManyThrough(
            Click::class,
            FbCampaign::class,
            'fb_ad_account_id', // 外键在FbCampaign模型上...
            'fb_campaign_source_id', // 外键在Click模型上...
            'id', // 主键在FbAdAccount模型上...
            'source_id' // 主键在FbCampaign模型上...
        );
    }

    public function offerConversions()
    {
        return $this->hasManyThrough(
            Conversion::class,
            FbCampaign::class,
            'fb_ad_account_id', // 外键在FbCampaign模型上...
            'fb_campaign_source_id', // 外键在Conversions模型上...
            'id', // 主键在FbAdAccount模型上...
            'source_id' // 主键在FbCampaign模型上...
        );
    }

    public function rules()
    {
        return $this->morphToMany(Rule::class, 'ruleable');
    }

    public function get_metrics($startDate, $endDate, $timezone)
    {
        $insights = $this->insights()->whereBetween('date_start', [$startDate, $endDate])->get();

        // 转换日期到 AdAccount 时区
        $startDateInTimeZone = Carbon::createFromFormat('Y-m-d', $startDate, 'UTC')
            ->setTimezone($timezone)
            ->startOfDay();

        $endDateInTimeZone = Carbon::createFromFormat('Y-m-d', $endDate, 'UTC')
            ->setTimezone($timezone)
            ->endOfDay();

        $offerClicksCount = $this->offerClicks()
            ->whereBetween('clicks.click_datetime', [$startDateInTimeZone, $endDateInTimeZone])
            ->count();

        $offerConversionEvent = $this->offerConversions()
            ->whereBetween('conversions.conversion_datetime', [$startDateInTimeZone, $endDateInTimeZone]);
        $offerConversionsCount = (clone $offerConversionEvent)->where('price', '>', 0)->count();
        $offerConversionsValue = (clone $offerConversionEvent)->where('price', '>', 0)->sum('price');
        $offerLeads = (clone $offerConversionEvent)->where('price', '=', 0)->count();

        $total_spend = $insights->sum('spend');

        if ($offerLeads==0) {
            $taken_rate = 0;
        } else {
            $taken_rate = $offerConversionsCount / $offerLeads * 100;
            $taken_rate = round($taken_rate, 2);
        }
        if ($offerClicksCount > 0) {
            $offer_cpc = round($total_spend / $offerClicksCount, 2);
            $offer_epc = round($offerConversionsValue / $offerClicksCount, 2);
        } else {
            $offer_cpc = $total_spend;
            $offer_epc = null;
        }


        $aggregated = [
            'ad_account_id' => $this->source_id,
            'ad_account_name' => $this->name,
            'account_status' => $this->account_status,
            'disable_reason' => $this->disable_reason,
            'adtrust_dsl' => $this->adtrust_dsl,
            'currency' => $this->currency,
            'timezone' => $this->timezone_name,
            'impressions' => $insights->sum('impressions'),
            'daily_budget' => $this->daily_budget,
            'reach' => $insights->sum('reach'),
            'spend' => round($total_spend, 2),
            'purchase_roas' => round($insights->avg('purchase_roas_value'), 2),
            'frequency' => round($insights->avg('frequency'), 2),
            'clicks' => $insights->sum('clicks'),
            'link_clicks' => $insights->sum('inline_link_clicks'),
            'cpm' => round($insights->avg('cpm'), 2),
            'cpc' => round($insights->avg('cpc'), 2),
            'ctr' => round($insights->avg('ctr'), 2),
            'link_ctr' => round($insights->avg('inline_link_click_ctr'), 2),
            'link_cpc' => round($insights->avg('cost_per_inline_link_click'), 2),
            'add_to_cart' => $insights->sum('add_to_cart'),
            'purchase' => $insights->sum('purchase'),
            'lead' => $insights->sum('lead'),
            'comment' => $insights->sum('comment'),
            'cost_per_purchase' => round($insights->avg('cost_per_purchase'), 2),
            'cost_per_lead' => round($insights->avg('cost_per_lead'), 2),
            'cost_to_add_to_cart' => round($insights->avg('cost_to_add_to_cart'), 2),
            'offer_clicks' => $offerClicksCount,
            'offer_leads' => $offerLeads,
            'offer_conversions' => $offerConversionsCount,
            'offer_conversions_value' => $offerConversionsValue,
            'taken_rate' => $taken_rate,
            'offer_cpc' => $offer_cpc,
            'offer_epc' => $offer_epc,
            'enable_rule' => $this->enable_rule
        ];

        return $aggregated;
    }

    public function apiTokens()
    {
//        return $this->belongsToMany(FbApiToken::class, 'fb_api_token_fb_ad_account');
        return $this->belongsToMany(FbApiToken::class, 'fb_api_token_fb_ad_account')
            ->using(CustomPivot::class)
            ->withPivot( ['tasks']) // 包含中间表的字段
            ->withTimestamps();
    }

    public function users()
    {
        return $this->belongsToMany(User::class)->using(CustomPivot::class);
    }

    // 与Card的多对多关联
    public function cards()
    {
        return $this->belongsToMany(Card::class, 'card_fb_ad_account')
                    ->withPivot('is_default')
                    ->withTimestamps();
    }

    // 获取默认卡片
    public function defaultCard()
    {
        return $this->cards()->wherePivot('is_default', true)->first();
    }

    // 获取所有默认卡片（一般只有一个）
    public function defaultCards()
    {
        return $this->cards()->wherePivot('is_default', true);
    }

    /**
     * FbAdAccount 与 FbApp 的多对多关系
     * FbAdAccount 可以订阅多个 FbApp
     */
    public function subscribedApps()
    {
        return $this->belongsToMany(FbApp::class, 'fb_app_fb_ad_account')
            ->using(CustomPivot::class)
            ->withTimestamps();
    }

}
