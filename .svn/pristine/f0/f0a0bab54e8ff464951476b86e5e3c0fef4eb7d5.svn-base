<template>
  <div class="create-rule-page">
    <div class="page-head">
      <a-breadcrumb>
        <a-breadcrumb-item>
          <a @click.prevent="goRuleManage">{{ t('pages.createRule.ruleManagement') }}</a>
        </a-breadcrumb-item>
        <a-breadcrumb-item>
          <a @click.prevent="goCreateRule">{{ pageTitle }}</a>
        </a-breadcrumb-item>
      </a-breadcrumb>
    </div>

    <div class="wizard-layout">
      <div class="wizard-steps-nav">
        <div class="wizard-step-item" :class="{ active: currentStep === 1 }">
          <span class="wizard-step-index">1</span>
          <span class="wizard-step-text">{{ t('pages.createRule.selectRuleType') }}</span>
        </div>
        <div class="wizard-step-item" :class="{ active: currentStep === 2 }">
          <span class="wizard-step-index">2</span>
          <span class="wizard-step-text">{{ t('pages.createRule.setRule') }}</span>
        </div>
      </div>

      <div class="wizard-main">
        <!-- 步骤1: 选择模板 -->
        <div v-show="currentStep === 1" class="step-content">
          <div class="step-header">
            <div class="step-title-wrap">
              <a-tooltip :title="t('pages.createRule.backToPrev')">
                <a-button shape="circle" class="back-icon-button" @click="onHeaderBackClick">
                  <arrow-left-outlined />
                </a-button>
              </a-tooltip>
              <div class="step-title-block">
                <div class="step-title">{{ t('pages.createRule.createRule') }}</div>
              </div>
            </div>
          </div>

          <!-- 监控设置 -->
          <div class="monitoring-settings">
            <div class="setting-item">
              <label>{{ t('pages.createRule.monitoringChannel') }}:</label>
              <a-select v-model:value="monitoringChannel" style="width: 150px">
                <a-select-option value="meta">Meta</a-select-option>
              </a-select>
            </div>
            <div class="setting-item">
              <label>{{ t('pages.createRule.monitoringObject') }}:</label>
              <a-tabs v-model:activeKey="monitoringObject" type="card">
                <a-tab-pane key="ad-account" :tab="t('pages.createRule.adAccount')" />
                <a-tab-pane key="campaign" :tab="t('pages.createRule.campaign')" />
                <a-tab-pane key="ad-group" :tab="t('pages.createRule.adGroup')" />
                <a-tab-pane key="ad" :tab="t('pages.createRule.ad')" />
                <a-tab-pane key="ad-material" :tab="t('pages.createRule.adMaterial')" />
                <a-tab-pane key="material" :tab="t('pages.createRule.material')" />
              </a-tabs>
            </div>
          </div>

          <div v-if="!isEditMode" class="template-hint">
            {{ t('pages.createRule.selectTemplateHint') }}
          </div>

          <!-- 规则模板卡片 -->
          <div v-if="!isEditMode" class="rule-templates">
            <div
              v-for="template in ruleTemplates"
              :key="template.id"
              class="template-card"
              @click="selectTemplate(template.id)"
            >
              <div class="template-icon" :style="{ background: template.color }">
                <component :is="template.icon" />
              </div>
              <div class="template-title">{{ template.title }}</div>
              <div v-if="template.description" class="template-desc">
                {{ template.description }}
              </div>
            </div>
          </div>
        </div>

        <!-- 步骤2: 配置规则 -->
        <div v-show="currentStep === 2" class="step-content">
          <div class="step-header">
            <div class="step-title-wrap">
              <a-tooltip :title="t('pages.createRule.backToPrev')">
                <a-button shape="circle" class="back-icon-button" @click="onHeaderBackClick">
                  <arrow-left-outlined />
                </a-button>
              </a-tooltip>
              <div class="step-title-block">
                <div class="step-title">
                  {{ pageTitle }}
                  <span class="step-title-type" v-if="selectedTemplateTitle">
                    {{ t('pages.createRule.ruleType') }}：{{ selectedTemplateTitle }}
                  </span>
                </div>
                <div class="step-subtitle">
                  {{ t('pages.createRule.networkDelayDisclaimer') }}
                </div>
              </div>
            </div>
          </div>

          <!-- 筛选 + 指标过滤（广告防盗刷模板不使用本区域） -->
          <div v-if="!isAntiFraudTemplate" class="rule-section">
            <div class="section-title">
              <filter-outlined />
              {{ t('pages.createRule.filter') }}
              <setting-outlined class="filter-settings-icon" @click="openCardFilterModal" />
            </div>

            <!-- 动态筛选行 -->
            <div class="filter-row">
              <template v-for="item in filterOptionsFromModal" :key="item.key">
                <div
                  v-if="item.disabled || item.enabled"
                  style="display: inline-flex; align-items: center; margin-right: 8px"
                >
                  <span style="margin-right: 4px">{{ item.label }}:</span>
                  <TagSelect
                    v-if="item.key === 'tagIds' && item.tagTreeData"
                    v-model="ruleConfig.filters[item.key]"
                    :tag-folders="item.tagTreeData.tagFolders || []"
                    :tags="item.tagTreeData.tags || []"
                    :tag-options="item.tagTreeData.tagOptions || []"
                    :placeholder="`请选择${item.label}`"
                    :creatable="false"
                    style="width: 200px"
                  />
                  <UserPicker
                    v-else-if="item.key === 'designer' && item.orgData"
                    v-model="ruleConfig.filters[item.key]"
                    :org-tree="item.orgData"
                    :dept-id="2"
                    :placeholder="`请选择${item.label}`"
                    style="width: 200px"
                  />
                  <UserPicker
                    v-else-if="item.key === 'creator' && item.orgData"
                    v-model="ruleConfig.filters[item.key]"
                    :org-tree="item.orgData"
                    :placeholder="`请选择${item.label}`"
                    style="width: 200px"
                  />
                  <a-select
                    v-else
                    v-model:value="(ruleConfig.filters ?? {})[item.key]"
                    :placeholder="`请选择${item.label}`"
                    style="width: 200px"
                    allow-clear
                  >
                    <a-select-option
                      v-for="opt in item.options"
                      :key="opt.value"
                      :value="opt.value"
                    >
                      {{ opt.label }}
                    </a-select-option>
                  </a-select>
                </div>
              </template>
            </div>

            <!-- 指标过滤 -->
            <div class="metric-filter">
              <div class="metric-title">
                {{ t('pages.createRule.metricFilter') }}
                <a-tooltip>
                  <template #title>
                    {{ t('pages.createRule.dataDelayDisclaimer') }}
                  </template>
                  <info-circle-outlined style="margin-left: 8px; color: #1890ff" />
                </a-tooltip>
              </div>
              <a-alert
                type="info"
                :message="t('pages.createRule.dataDelayDisclaimer')"
                show-icon
                style="margin-bottom: 16px"
              />
              <div
                v-for="(condition, index) in ruleConfig.metricConditions"
                :key="index"
                class="metric-condition"
              >
                <div class="condition-number">{{ index + 1 }}</div>
                <a-select
                  v-model:value="condition.metric"
                  style="width: 350px"
                  :options="metricOptions"
                />
                <a-select
                  v-model:value="condition.date"
                  :placeholder="t('pages.createRule.today')"
                  style="width: 150px"
                >
                  <a-select-option
                    v-for="date in dateOptions"
                    :key="date.value"
                    :value="date.value"
                  >
                    {{ date.label }}
                  </a-select-option>
                </a-select>
                <a-select
                  v-model:value="condition.operator"
                  style="width: 80px"
                  :options="operatorOptions"
                />
                <a-select
                  v-model:value="condition.valueType"
                  style="width: 100px"
                  :options="getValueTypeOptions(condition.metric)"
                />
                <!-- 单值：>,<,>=,<=,=；范围：介于/不介于 -->
                <template
                  v-if="condition.operator === 'between' || condition.operator === 'not_between'"
                >
                  <a-input-number
                    v-model:value="condition.valueMin"
                    :placeholder="t('pages.createRule.minValue')"
                    style="width: 120px"
                    required
                  />
                  <span style="margin: 0 6px; color: #666">~</span>
                  <a-input-number
                    v-model:value="condition.valueMax"
                    :placeholder="t('pages.createRule.maxValue')"
                    style="width: 120px"
                    required
                  />
                </template>
                <a-input-number
                  v-else
                  v-model:value="condition.value"
                  :placeholder="t('pages.createRule.value')"
                  style="width: 120px"
                  required
                />
                <a-select
                  v-if="condition.valueType === 'number'"
                  v-model:value="condition.valueUnit"
                  style="width: 80px"
                  :options="valueUnitOptions"
                />
                <a-select
                  v-else-if="condition.valueType === 'spend'"
                  v-model:value="condition.currency"
                  style="width: 80px"
                  :options="spendCurrencyOptions"
                />
                <a-select
                  v-else
                  v-model:value="condition.currency"
                  style="width: 80px"
                  :options="currencyOptions"
                />

                <a-button
                  type="link"
                  danger
                  @click="removeCondition(index)"
                  style="margin-left: 8px"
                >
                  {{ t('pages.createRule.delete') }}
                </a-button>
              </div>
              <a-button type="link" @click="addCondition" style="padding: 0">
                {{ t('pages.createRule.addCondition') }}
              </a-button>
            </div>
          </div>

          <!-- 广告防盗刷：专用条件（与参考产品一致，不走筛选/指标过滤） -->
          <div v-else class="rule-section anti-fraud-template-section">
            <div class="section-title">
              <safety-outlined />
              {{ t('pages.createRule.antiFraudCondition') }}
            </div>
            <anti-fraud-rule-section v-model="ruleConfig.antiFraud" />
          </div>

          <!-- 执行动作 -->
          <div class="rule-section">
            <div class="section-title">
              <play-circle-outlined />
              {{ t('pages.createRule.executeAction') }}
              <a-tooltip>
                <template #title>{{ t('pages.createRule.executeInOrder') }}</template>
                <info-circle-outlined style="margin-left: 8px; color: #1890ff" />
              </a-tooltip>
            </div>
            <a-checkbox v-model:checked="ruleConfig.executeInOrder">
              {{ t('pages.createRule.executeInOrder') }}
            </a-checkbox>
            <div class="action-list">
              <div v-for="(action, index) in ruleConfig.actions" :key="index" class="action-card">
                <div class="action-card-number">{{ index + 1 }}</div>
                <a-button
                  v-if="ruleConfig.actions.length > 1"
                  type="link"
                  danger
                  class="action-card-delete"
                  @click="removeAction(index)"
                >
                  {{ t('pages.createRule.delete') }}
                </a-button>

                <div class="action-card-content">
                  <div class="action-config">
                    <div class="action-top-row">
                      <a-select
                        v-model:value="action.type"
                        class="action-type-select"
                        @change="() => handleActionTypeChange(index)"
                      >
                        <a-select-option value="status">
                          {{ t('pages.createRule.status') }}
                        </a-select-option>
                        <a-select-option value="bid">
                          {{ t('pages.createRule.bid') }}
                        </a-select-option>
                        <a-select-option value="budget">
                          {{ t('pages.createRule.dailyBudget') }}
                        </a-select-option>
                        <a-select-option value="total-budget">
                          {{ t('pages.createRule.totalBudget') }}
                        </a-select-option>
                        <a-select-option value="roas-target">
                          {{ t('pages.createRule.roasTarget') }}
                        </a-select-option>
                        <a-select-option value="edit-tag">
                          {{ t('pages.createRule.editTag') }}
                        </a-select-option>
                        <a-select-option value="send-email">
                          {{ t('pages.createRule.sendEmail') }}
                        </a-select-option>
                        <a-select-option value="send-dingtalk">
                          {{ t('pages.createRule.sendDingtalk') }}
                        </a-select-option>
                        <a-select-option value="send-wecom">
                          {{ t('pages.createRule.sendWecom') }}
                        </a-select-option>
                        <a-select-option value="send-feishu">
                          {{ t('pages.createRule.sendFeishu') }}
                        </a-select-option>
                      </a-select>

                      <template v-if="action.type === 'send-email'">
                        <div class="primary-area">
                          <a-select
                            v-model:value="action.config.recipients"
                            mode="multiple"
                            :placeholder="t('pages.createRule.sendTarget')"
                            class="recipient-multi-select"
                            :options="getActionEmailOptions(index)"
                            allow-clear
                            show-search
                            :filter-option="filterSendTargetOption"
                          >
                            <template #dropdownRender="{ menuNode: menu }">
                              <VNodes :vnodes="menu" />
                              <a-divider style="margin: 4px 0" />
                              <a-space class="select-add-row">
                                <a-input
                                  v-model:value="actionEmailDrafts[index]"
                                  :placeholder="t('pages.createRule.enterToAdd')"
                                  @press-enter="() => addActionEmailRecipient(index)"
                                />
                                <a-button type="text" @click="() => addActionEmailRecipient(index)">
                                  <template #icon><PlusOutlined /></template>
                                </a-button>
                              </a-space>
                            </template>
                          </a-select>
                        </div>
                      </template>

                      <template v-if="action.type === 'status'">
                        <div class="primary-area">
                          <a-select v-model:value="action.config.status" class="primary-select">
                            <a-select-option value="pause">
                              {{ t('pages.createRule.pause') }}
                            </a-select-option>
                            <a-select-option value="enable">
                              {{ t('pages.createRule.enable') }}
                            </a-select-option>
                          </a-select>
                        </div>
                      </template>

                      <template v-if="action.type === 'bid'">
                        <div class="primary-area">
                          <a-select v-model:value="action.config.bidAction" class="primary-select">
                            <a-select-option value="increase">
                              {{ t('pages.createRule.increaseValue') }}
                            </a-select-option>
                            <a-select-option value="decrease">
                              {{ t('pages.createRule.decreaseValue') }}
                            </a-select-option>
                          </a-select>
                        </div>
                      </template>

                      <template v-if="action.type === 'budget' || action.type === 'total-budget'">
                        <div class="primary-area">
                          <a-select
                            v-model:value="action.config.budgetAction"
                            class="primary-select"
                          >
                            <a-select-option value="increase">
                              {{ t('pages.createRule.increaseValue') }}
                            </a-select-option>
                            <a-select-option value="decrease">
                              {{ t('pages.createRule.decreaseValue') }}
                            </a-select-option>
                          </a-select>
                        </div>
                      </template>

                      <template v-if="action.type === 'roas-target'">
                        <div class="primary-area">
                          <a-select v-model:value="action.config.roasAction" class="primary-select">
                            <a-select-option value="increase">
                              {{ t('pages.createRule.increaseValue') }}
                            </a-select-option>
                            <a-select-option value="decrease">
                              {{ t('pages.createRule.decreaseValue') }}
                            </a-select-option>
                          </a-select>
                        </div>
                      </template>

                      <template v-if="action.type === 'edit-tag'">
                        <div class="primary-area">
                          <tag-select
                            v-model="action.config.tag"
                            :tag-folders="tagTreeData[index]?.tagFolders || []"
                            :tags="tagTreeData[index]?.tags || []"
                            :tag-options="tagTreeData[index]?.tagOptions || []"
                            :placeholder="t('pages.createRule.selectTag')"
                            :creatable="true"
                            :create-option-api="
                              (tagId, name, parentId, isTagLevel) =>
                                handleCreateTagOption(tagId, name, parentId, isTagLevel, index)
                            "
                            class="primary-select"
                          />
                        </div>
                      </template>

                      <template
                        v-if="['send-dingtalk', 'send-wecom', 'send-feishu'].includes(action.type)"
                      >
                        <div class="primary-area">
                          <a-select
                            v-model:value="action.config.webhookUrls"
                            mode="multiple"
                            :placeholder="t('pages.createRule.sendTarget')"
                            class="recipient-multi-select"
                            :options="getActionImOptions(index)"
                            allow-clear
                            show-search
                            :filter-option="filterSendTargetOption"
                          >
                            <template #dropdownRender="{ menuNode: menu }">
                              <VNodes :vnodes="menu" />
                              <a-divider style="margin: 4px 0" />
                              <a-space class="select-add-row">
                                <a-input
                                  v-model:value="actionImDrafts[index]"
                                  :placeholder="t('pages.createRule.enterToAdd')"
                                  @press-enter="() => addActionImTarget(index)"
                                />
                                <a-button type="text" @click="() => addActionImTarget(index)">
                                  <template #icon><PlusOutlined /></template>
                                </a-button>
                              </a-space>
                            </template>
                          </a-select>
                        </div>
                      </template>
                    </div>

                    <div class="action-details">
                      <template v-if="action.type === 'send-email'">
                        <a-input
                          v-model:value="action.config.subject"
                          :placeholder="t('pages.createRule.emailSubject')"
                          class="full-width-input"
                        />
                        <a-textarea
                          v-model:value="action.config.body"
                          :placeholder="t('pages.createRule.emailBody')"
                          :rows="3"
                          class="full-width-textarea"
                        />
                        <div class="action-help-row">
                          <a href="#" class="action-help-link" @click.prevent>
                            {{ t('pages.createRule.howToFindParams') }}
                          </a>
                        </div>
                      </template>

                      <template v-if="action.type === 'bid'">
                        <div class="detail-stack">
                          <a-input-number
                            v-model:value="action.config.bidValue"
                            :placeholder="t('pages.createRule.value')"
                            class="full-width-input-number"
                          />
                          <div class="detail-text-row">
                            <span>
                              {{
                                action.config.bidAction === 'increase'
                                  ? t('pages.createRule.maxNoMoreThan')
                                  : t('pages.createRule.minNoLessThan')
                              }}
                            </span>
                          </div>
                          <div class="detail-row">
                            <a-input-number
                              v-model:value="action.config.bidLimit"
                              :placeholder="t('pages.createRule.value')"
                              class="detail-input-number"
                            />
                            <span class="detail-suffix">USD</span>
                          </div>
                        </div>
                      </template>

                      <template v-if="action.type === 'budget' || action.type === 'total-budget'">
                        <div class="detail-stack">
                          <a-input-number
                            v-model:value="action.config.budgetValue"
                            :placeholder="t('pages.createRule.value')"
                            class="full-width-input-number"
                          />
                          <div class="detail-text-row">
                            <span>
                              {{
                                action.config.budgetAction === 'increase'
                                  ? t('pages.createRule.maxNoMoreThan')
                                  : t('pages.createRule.minNoLessThan')
                              }}
                            </span>
                          </div>
                          <div class="detail-row">
                            <a-input-number
                              v-model:value="action.config.budgetLimit"
                              :placeholder="t('pages.createRule.value')"
                              class="detail-input-number"
                            />
                            <span class="detail-suffix">USD</span>
                          </div>
                          <div v-if="action.type === 'budget'" class="budget-strategy">
                            <div class="strategy-title">
                              {{ t('pages.createRule.nextDayBudgetStrategy') }}:
                            </div>
                            <a-radio-group v-model:value="action.config.budgetStrategy">
                              <a-radio value="continue">
                                {{ t('pages.createRule.continueAdjustedBudget') }}
                              </a-radio>
                              <a-radio value="restore">
                                {{ t('pages.createRule.restoreOriginalBudget') }}
                              </a-radio>
                            </a-radio-group>
                          </div>
                        </div>
                      </template>

                      <template v-if="action.type === 'roas-target'">
                        <div class="detail-stack">
                          <a-input-number
                            v-model:value="action.config.roasValue"
                            :placeholder="t('pages.createRule.value')"
                            class="full-width-input-number"
                            :min="0"
                            :step="0.01"
                          />
                          <div class="detail-text-row">
                            <span>
                              {{
                                action.config.roasAction === 'increase'
                                  ? t('pages.createRule.maxNoMoreThan')
                                  : t('pages.createRule.minNoLessThan')
                              }}
                            </span>
                          </div>
                          <div class="detail-row">
                            <a-input-number
                              v-model:value="action.config.roasLimit"
                              :placeholder="t('pages.createRule.value')"
                              class="detail-input-number"
                              :min="0"
                              :step="0.01"
                            />
                          </div>
                        </div>
                      </template>

                      <template v-if="action.type === 'edit-tag'">
                        <div class="detail-stack">
                          <a-select
                            v-model:value="action.config.tagAction"
                            :placeholder="t('pages.createRule.setMethod')"
                            class="full-width-select"
                          >
                            <a-select-option value="add">
                              {{ t('pages.createRule.addTag') }}
                            </a-select-option>
                            <a-select-option value="remove">
                              {{ t('pages.createRule.removeTag') }}
                            </a-select-option>
                            <a-select-option value="replace">
                              {{ t('pages.createRule.replaceTag') }}
                            </a-select-option>
                          </a-select>
                          <div v-if="action.config.tagAction === 'replace'">
                            <div class="detail-label">{{ t('pages.createRule.setTagAs') }}</div>
                            <tag-select
                              v-model="action.config.newTag"
                              :tag-folders="tagTreeData[index]?.tagFolders || []"
                              :tags="tagTreeData[index]?.tags || []"
                              :tag-options="tagTreeData[index]?.tagOptions || []"
                              :placeholder="t('pages.createRule.selectTag')"
                              :creatable="true"
                              :create-option-api="
                                (tagId, name, parentId, isTagLevel) =>
                                  handleCreateTagOption(tagId, name, parentId, isTagLevel, index)
                              "
                              class="full-width-select"
                            />
                          </div>
                        </div>
                      </template>

                      <template
                        v-if="['send-dingtalk', 'send-wecom', 'send-feishu'].includes(action.type)"
                      >
                        <a-input
                          v-model:value="action.config.imSubject"
                          :placeholder="t('pages.createRule.messageSubject')"
                          class="full-width-input"
                        />
                        <a-textarea
                          v-model:value="action.config.imMessage"
                          :placeholder="t('pages.createRule.messageContent')"
                          :rows="3"
                          class="full-width-textarea"
                        />
                      </template>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <a-button type="link" class="add-action-link" @click="addAction">
              <plus-outlined />
              {{ t('pages.createRule.addAction') }}
            </a-button>
          </div>

          <!-- 执行频次 -->
          <div class="rule-section">
            <div class="section-title">
              <clock-circle-outlined />
              {{ t('pages.createRule.executeFrequency') }}
            </div>
            <div class="frequency-setting">
              <span>
                {{ t('pages.createRule.ifConditionMetMultipleTimes') }}
              </span>
              <a-select
                v-model:value="ruleConfig.executionInterval"
                style="width: 100px; margin-left: 8px"
              >
                <a-select-option value="24h">24h</a-select-option>
                <a-select-option value="12h">12h</a-select-option>
                <a-select-option value="6h">6h</a-select-option>
              </a-select>
            </div>
            <div class="check-time-setting">
              <div class="setting-row">
                <label>{{ t('pages.createRule.useTimezone') }}:</label>
                <a-select v-model:value="ruleConfig.timezone" style="width: 150px">
                  <a-select-option value="UTC+8">UTC+8</a-select-option>
                  <a-select-option value="UTC+0">UTC+0</a-select-option>
                </a-select>
                <span class="help-text">
                  {{ t('pages.createRule.selectTimezoneHint') }}
                </span>
              </div>
              <div class="setting-row flex-wrap">
                <label>{{ t('pages.createRule.effectivePeriod') }}:</label>
                <a-radio-group v-model:value="ruleConfig.effectivePeriod" button-style="solid">
                  <a-radio-button value="long-term">
                    {{ t('pages.createRule.longTerm') }}
                  </a-radio-button>
                  <a-radio-button value="custom">{{ t('pages.createRule.custom') }}</a-radio-button>
                </a-radio-group>
              </div>
              <div class="setting-row flex-wrap">
                <label>{{ t('pages.createRule.checkFrequency') }}:</label>
                <a-radio-group v-model:value="ruleConfig.checkFrequency" button-style="solid">
                  <a-radio-button value="15min">
                    {{ t('pages.createRule.every15min') }}
                  </a-radio-button>
                  <a-radio-button value="30min">
                    {{ t('pages.createRule.every30min') }}
                  </a-radio-button>
                  <a-radio-button value="1h">{{ t('pages.createRule.everyHour') }}</a-radio-button>
                  <a-radio-button value="daily">
                    {{ t('pages.createRule.everyDay') }}
                  </a-radio-button>
                  <a-radio-button value="weekly">
                    {{ t('pages.createRule.everyWeek') }}
                  </a-radio-button>
                  <a-radio-button value="custom">{{ t('pages.createRule.custom') }}</a-radio-button>
                </a-radio-group>
              </div>
              <div v-if="ruleConfig.checkFrequency === 'custom'" class="custom-time-slots">
                <div
                  v-for="(time, index) in ruleConfig.customCheckTimes"
                  :key="index"
                  class="time-slot-row"
                >
                  <a-date-picker
                    v-model:value="ruleConfig.customCheckTimes[index]"
                    format="YYYY-MM-DD HH:mm"
                    value-format="YYYY-MM-DD HH:mm:ss"
                    show-time
                    :placeholder="t('pages.createRule.selectDateTime')"
                    style="width: 180px"
                    :disabled-date="
                      (current: dayjs.Dayjs) => current && current < dayjs().startOf('day')
                    "
                  />
                  <a-button
                    v-if="ruleConfig.customCheckTimes.length > 1"
                    type="text"
                    danger
                    @click="removeTimeSlot(index)"
                  >
                    <close-outlined />
                  </a-button>
                </div>
                <a-button
                  v-if="ruleConfig.customCheckTimes.length < 10"
                  type="link"
                  @click="addTimeSlot"
                  class="add-time-slot-btn"
                >
                  <plus-outlined />
                  {{ t('pages.createRule.add') }}
                </a-button>
              </div>
            </div>
          </div>

          <!-- 基础信息 -->
          <div class="rule-section">
            <div class="section-title">
              <file-text-outlined />
              {{ t('pages.createRule.basicInfo') }}
            </div>
            <a-form :model="ruleConfig.basicInfo" layout="vertical">
              <a-form-item :label="t('pages.createRule.ruleName')">
                <a-input
                  v-model:value="ruleConfig.basicInfo.ruleName"
                  :placeholder="t('pages.createRule.enterRuleName')"
                />
              </a-form-item>
              <a-form-item :label="t('pages.createRule.ruleDescription')">
                <a-textarea
                  v-model:value="ruleConfig.basicInfo.description"
                  :placeholder="t('pages.createRule.enterRuleDescription')"
                  :rows="3"
                />
              </a-form-item>
              <a-form-item :label="t('pages.createRule.ruleStatus')">
                <a-radio-group v-model:value="ruleConfig.basicInfo.status" button-style="solid">
                  <a-radio-button value="enabled">
                    {{ t('pages.createRule.enabled') }}
                  </a-radio-button>
                  <a-radio-button value="disabled">
                    {{ t('pages.createRule.disabled') }}
                  </a-radio-button>
                </a-radio-group>
              </a-form-item>
              <a-form-item :label="t('pages.createRule.currencyUnit')">
                <a-radio-group v-model:value="ruleConfig.basicInfo.currency" button-style="solid">
                  <a-radio-button value="USD">{{ t('pages.createRule.usd') }}</a-radio-button>
                  <a-radio-button value="CNY">{{ t('pages.createRule.cny') }}</a-radio-button>
                </a-radio-group>
              </a-form-item>
            </a-form>
          </div>
        </div>
      </div>
    </div>

    <div v-if="currentStep === 2" class="footer-actions">
      <a-button type="primary" size="large" :loading="submitLoading" @click="handleSubmit">
        {{ t('pages.createRule.submit') }}
      </a-button>
      <a-button size="large" @click="onCancelClick">{{ t('pages.createRule.cancel') }}</a-button>
    </div>
    <a-modal
      v-model:open="cancelConfirmVisible"
      :title="t('pages.createRule.hint')"
      :ok-text="t('pages.createRule.confirm')"
      :cancel-text="t('pages.createRule.continueEditing')"
      @ok="confirmCancelBack"
    >
      <p>{{ t('pages.createRule.confirmCancel') }}</p>
    </a-modal>

    <!-- 筛选设置弹窗 -->
    <FilterModal
      v-model="cardFilterModalVisible"
      :filter-options="filterOptionsFromModal"
      :initial-values="ruleConfig.filters"
      :visible-filters="visibleFilters"
      @confirm="handleFilterConfirm"
    />
  </div>
</template>

<script lang="ts" setup>
import { ref, watch, onMounted, nextTick, computed, defineComponent } from 'vue';
import { useI18n } from 'vue-i18n';
import dayjs from 'dayjs';
import {
  ArrowLeftOutlined,
  PlusOutlined,
  CloseOutlined,
  BellOutlined,
  StopOutlined,
  SafetyOutlined,
  ReloadOutlined,
  RiseOutlined,
  FallOutlined,
  FileAddOutlined,
  MinusOutlined,
  TagOutlined,
  FilterOutlined,
  PlayCircleOutlined,
  ClockCircleOutlined,
  FileTextOutlined,
  InfoCircleOutlined,
  FolderOutlined,
  SettingOutlined,
} from '@ant-design/icons-vue';
import { message } from 'ant-design-vue';
import AntiFraudRuleSection from './components/anti-fraud-rule-section.vue';
import { FilterModal } from '@/components/filter-modal';
import TagSelect from '@/components/tag-select/index.vue';
import { UserPicker } from '@/components/user-picker';
import {
  getRuleTemplates,
  getMetaTagsTree,
  getFilterOptionData,
  createRule,
  updateRule,
  createTagOption,
} from '@/api/promotion/index';
import metricFilterOptionsRaw from './metric-filter-options.json';

const { t } = useI18n();
const emit = defineEmits<{
  (e: 'close'): void;
}>();

const props = defineProps<{
  editData?: any;
  mode?: 'create' | 'edit' | 'copy';
}>();

const isEditMode = computed(() => props.mode === 'edit');
const isCopyMode = computed(() => props.mode === 'copy');
const pageTitle = computed(() =>
  isEditMode.value ? t('pages.createRule.editRule') : t('pages.createRule.createRule'),
);

// 编辑模式加载数据期间，跳过 monitoringObject watch 的重置逻辑
const isLoadingEditData = ref(false);

const currentStep = ref(1);
const monitoringChannel = ref('meta');
const monitoringObject = ref('ad-account');
const selectedTemplate = ref<string | null>(null);

/** 与后端 RuleTemplatesController 中「广告防盗刷」模板 id 一致 */
const ANTI_FRAUD_TEMPLATE_ID = 'anti-fraud';
const isAntiFraudTemplate = computed(() => selectedTemplate.value === ANTI_FRAUD_TEMPLATE_ID);

const selectedTemplateTitle = computed(() => {
  if (!selectedTemplate.value) return '';
  return (
    ruleTemplates.value.find(tpl => tpl.id === selectedTemplate.value)?.title ??
    t('pages.createRule.createDirectly')
  );
});
const agreedToDisclaimer = ref(false);
const headerBackConfirmVisible = ref(false);
const cancelConfirmVisible = ref(false);
const cardFilterModalVisible = ref(false);
const visibleFilters = ref<string[]>(['adAccount', 'channel']);
const submitLoading = ref(false);

// 存储从Modal接收的筛选选项配置（包含 value 字段，v-model 直接绑定）
const filterOptionsFromModal = ref<any[]>([]);

// 打开筛选弹窗
const openCardFilterModal = () => {
  cardFilterModalVisible.value = true;
};

// 加载筛选项数据
const loadFilterOptions = async () => {
  try {
    const res = await getFilterOptionData({
      keys: [
        'adAccount',
        'channel',
        'campaign',
        'adGroup',
        'designer',
        'creator',
        'accountStatus',
        'authorizationStatus',
        'timezone',
      ],
      language: 'zh',
    });
    const data = Array.isArray(res?.data) ? res.data : Array.isArray(res) ? res : [];
    filterOptionsFromModal.value = data;
  } catch (e) {
    console.error('加载筛选项失败', e);
  }
};

type RuleTemplateApi = {
  id: string;
  title: string;
  description: string;
  icon: string;
  color: string;
  config?: {
    template_type?: string;
    default_action?: string;
  };
};

type RuleTemplateCard = {
  id: string;
  title: string;
  description: string;
  icon: any; // @ant-design/icons-vue 图标组件
  color: string;
  config?: {
    template_type?: string;
    default_action?: string;
  };
};

type ValueTypeRule = {
  includes: string[];
  excludes?: string[];
  options: string[];
};

type DateOption = { label: string; value: string };
type OperatorOption = { label: string; value: string };

type MetricFilterOptionsConfig = {
  dateOptions: DateOption[];
  operatorOptions: OperatorOption[];
  valueTypeDefaults: string[];
  valueTypeRules: ValueTypeRule[];
  currencyOptions: string[];
  metrics: string[];
};

const iconComponentByName: Record<string, any> = {
  BellOutlined,
  StopOutlined,
  SafetyOutlined,
  ReloadOutlined,
  RiseOutlined,
  FallOutlined,
  FileAddOutlined,
  MinusOutlined,
  TagOutlined,
  PlusOutlined,
};

const ruleTemplates = ref<RuleTemplateCard[]>([]);
const loadingRuleTemplates = ref(false);

const loadRuleTemplates = async () => {
  loadingRuleTemplates.value = true;
  try {
    const apiTemplates = await getRuleTemplates(monitoringObject.value);
    ruleTemplates.value = (apiTemplates ?? []).map((tpl: RuleTemplateApi) => ({
      id: tpl.id,
      title: tpl.title,
      description: tpl.description,
      color: tpl.color,
      icon: iconComponentByName[tpl.icon] ?? iconComponentByName.PlusOutlined,
      config: tpl.config,
    }));
  } finally {
    loadingRuleTemplates.value = false;
  }
};

const metricFilterOptionsConfig = metricFilterOptionsRaw as MetricFilterOptionsConfig;

const metricOptions = metricFilterOptionsConfig.metrics.map(m => ({
  label: m.label,
  value: m.value,
}));

const DEFAULT_METRIC = metricOptions[0]?.value ?? 'bid';

// 指标映射：前端英文值 -> 中文显示标签（用于值类型匹配）
const metricEnglishToLabel: Record<string, string> = Object.fromEntries(
  metricFilterOptionsConfig.metrics.map(m => [m.value, m.label]),
);

// 值类型映射：中文标签 -> 英文值
const valueTypeChineseToEnglish: Record<string, string> = {
  花费: 'spend',
  百分比: 'percentage',
  数值: 'number',
  点击率: 'ctr',
  单次点击费用: 'cpc',
  广告支出回报率: 'roas',
};

// 值类型映射：英文值 -> 中文标签（用于显示）
const valueTypeEnglishToChinese: Record<string, string> = Object.fromEntries(
  Object.entries(valueTypeChineseToEnglish).map(([cn, en]) => [en, cn]),
);

onMounted(async () => {
  await loadFilterOptions();
  if (!isEditMode.value) {
    loadRuleTemplates();
  }
  if ((isEditMode.value || isCopyMode.value) && props.editData) {
    isLoadingEditData.value = true;
    const data = props.editData;
    monitoringChannel.value = data.channel || 'meta';
    monitoringObject.value = data.monitoring_object || 'ad-account';

    // 等待模板加载完成后，再填充编辑数据
    await loadRuleTemplates();
    selectedTemplate.value = data.template_id || null;

    // 使用 Object.assign 替换整个对象以保持响应式
    Object.assign(ruleConfig.value, {
      filters: {
        adAccount: data.filters?.ad_account_ids?.[0]?.toString() || undefined,
        channel: data.filters?.channel?.[0]?.toString() || undefined,
        campaign: data.filters?.campaign_ids?.[0]?.toString() || undefined,
        adGroup: data.filters?.ad_group_ids?.[0]?.toString() || undefined,
        product: data.filters?.status?.[0]?.toLowerCase(),
        tagIds: data.filters?.tag_ids ?? undefined,
        designer: data.filters?.designer ?? undefined,
        creator: data.filters?.creator ?? undefined,
        accountStatus: data.filters?.account_status ?? undefined,
        authorizationStatus: data.filters?.authorization_status ?? undefined,
        timezone: data.filters?.timezone ?? undefined,
      },
      metricConditions: (data.metric_conditions?.conditions || []).map((c: any) => {
        const mappedValueType = valueTypeChineseToEnglish[c.value_type] || c.value_type || 'number';
        return {
          metric: c.metric || 'spend',
          date: c.date_preset || 'today',
          operator: c.operator || '>',
          valueType: mappedValueType,
          value: c.value,
          valueMin: c.value_min,
          valueMax: c.value_max,
          valueUnit:
            mappedValueType === 'number' ? valueUnitEnglishToChinese[c.value_unit] || '个' : '个',
          currency: mappedValueType === 'spend' ? c.value_unit || 'USD' : 'USD',
        };
      }),
      actions: (data.actions?.actions || []).map((a: any) => ({
        type: a.type,
        enabled: a.enabled,
        config: a.config || {},
      })),
      executeInOrder: !!data.execute_in_order,
      executionInterval: data.execution_interval || '24h',
      timezone: data.timezone || 'Asia/Shanghai',
      effectivePeriod: data.effective_period || 'long-term',
      checkFrequency: data.check_frequency || '1h',
      customCheckTimes:
        data.check_frequency === 'custom' && data.custom_check_times?.length
          ? data.custom_check_times.map((t: string) =>
              t.length === 8 ? `${dayjs().format('YYYY-MM-DD')} ${t}` : t,
            )
          : [dayjs().format('YYYY-MM-DD 00:00:00')],
      basicInfo: {
        ruleName: data.name || '',
        description: data.description || '',
        status: data.status === 1 ? 'enabled' : 'disabled',
        currency: data.currency || 'USD',
      },
      antiFraud: data.anti_fraud_config || { enabled: false },
    });

    // 编辑模式下，同步 visibleFilters 和 filterOptionsFromModal.enabled
    const filledFilters = [];
    filterOptionsFromModal.value.forEach(item => {
      const filterKey = item.key;
      if (!['adAccount', 'channel'].includes(filterKey) && (ruleConfig.value.filters as any)[filterKey] !== undefined) {
        item.enabled = true;
        filledFilters.push(filterKey);
      }
    });
    visibleFilters.value = ['adAccount', 'channel', ...filledFilters];

    // 编辑模式下，加载 edit-tag 动作的标签树
    ruleConfig.value.actions.forEach((action, index) => {
      if (action.type === 'edit-tag') {
        loadTagTree(index);
      }
    });

    isLoadingEditData.value = false;

    nextTick(() => {
      currentStep.value = 2;
    });
  }
});

const createDefaultRuleConfig = (defaultAction?: string) => {
  const buildDefaultActionConfig = (action: string) => {
    const baseConfig = {
      recipients: [],
      subject: '',
      body: '',
      status: 'pause',
      bidAction: 'increase',
      bidValue: undefined,
      bidLimit: undefined,
      budgetAction: 'increase',
      budgetValue: undefined,
      budgetLimit: undefined,
      budgetStrategy: 'continue',
      roasAction: 'increase',
      roasValue: undefined,
      roasLimit: undefined,
      tag: undefined,
      tagAction: 'add',
      newTag: undefined,
      webhookUrls: [],
      imSubject: '',
      imMessage: '',
    };
    switch (action) {
      case 'add_tag':
        return { type: 'edit-tag', enabled: true, config: { ...baseConfig, tagAction: 'add' } };
      case 'send_email':
        return {
          type: 'send-email',
          enabled: true,
          config: { ...baseConfig, recipients: [], subject: '', body: '' },
        };
      case 'decrease_budget':
        return {
          type: 'budget',
          enabled: true,
          config: { ...baseConfig, budgetAction: 'decrease' },
        };
      case 'increase_budget':
        return {
          type: 'budget',
          enabled: true,
          config: { ...baseConfig, budgetAction: 'increase' },
        };
      default:
        return { type: 'send-email', enabled: true, config: { ...baseConfig } };
    }
  };

  const defaultAct = buildDefaultActionConfig(defaultAction ?? '');
  return {
    filters: {
      adAccount: undefined,
      channel: undefined,
      campaign: undefined,
      adGroup: undefined,
      tagIds: undefined,
      designer: undefined,
      creator: undefined,
      accountStatus: undefined,
      authorizationStatus: undefined,
      timezone: undefined,
    },
    metricConditions: [
      {
        metric: DEFAULT_METRIC,
        date: 'today',
        operator: '>',
        valueType: 'number',
        value: 50,
        valueMin: undefined,
        valueMax: undefined,
        valueUnit: '个',
        currency: 'USD',
      },
    ],
    actions: [defaultAct],
    executeInOrder: true,
    executionInterval: '24h',
    timezone: 'UTC+8',
    effectivePeriod: 'long-term',
    checkFrequency: '1h',
    customCheckTimes: [dayjs().format('YYYY-MM-DD 00:00:00')] as string[],
    basicInfo: {
      ruleName: '',
      description: '',
      status: 'enabled',
      currency: 'USD',
    },
    antiFraud: {
      enabled: false,
      accountScope: 'all' as const,
      specifiedAccountIds: [] as string[],
      conditionMatch: 'all' as const,
      notCreatedInAdsPolar: false,
      nonWorkingHours: false,
      nonWorkingHourSlotIds: [] as string[],
    },
  };
};

// 表单数据：跨步骤切换不丢；切换规则模板或监控对象时会重置
const ruleConfig = ref(createDefaultRuleConfig());

// VNodes 组件：用于渲染 ant-design dropdown 菜单节点
const VNodes = defineComponent({
  props: {
    vnodes: { type: Object, required: true },
  },
  render() {
    return this.vnodes;
  },
});

// action 内联相关类型
type ActionType =
  | 'status'
  | 'bid'
  | 'budget'
  | 'total-budget'
  | 'roas-target'
  | 'edit-tag'
  | 'send-email'
  | 'send-dingtalk'
  | 'send-wecom'
  | 'send-feishu';

type ActionConfigInline = {
  recipients: string[];
  subject: string;
  body: string;
  status: string;
  bidAction: string;
  bidValue?: number;
  bidLimit?: number;
  budgetAction: string;
  budgetValue?: number;
  budgetLimit?: number;
  budgetStrategy: string;
  roasAction: string;
  roasValue?: number;
  roasLimit?: number;
  tag?: string;
  tagAction: string;
  newTag?: string;
  webhookUrls: string[];
  imSubject: string;
  imMessage: string;
};

type ActionInline = {
  type: ActionType;
  enabled: boolean;
  config: ActionConfigInline;
};

// action 内联辅助 ref 和函数
const actionEmailOptions = ref<Record<number, string[]>>({});
const actionImOptions = ref<Record<number, string[]>>({});
const actionEmailDrafts = ref<Record<number, string>>({});
const actionImDrafts = ref<Record<number, string>>({});
const tagTreeData = ref<Record<number, { tagFolders: any[]; tags: any[]; tagOptions: any[] }>>({});

const filterSendTargetOption = (input: string, option: { label?: string; value?: string }) => {
  const q = (input || '').toLowerCase();
  const label = String(option?.label ?? option?.value ?? '');
  return label.toLowerCase().includes(q);
};

const getActionEmailOptions = (index: number) => {
  const pool = actionEmailOptions.value[index] ?? [];
  return pool.map(o => ({ value: o, label: o }));
};

const getActionImOptions = (index: number) => {
  const pool = actionImOptions.value[index] ?? [];
  return pool.map(o => ({ value: o, label: o }));
};

const syncActionEmailOptions = (index: number, recipients: string[]) => {
  if (!actionEmailOptions.value[index]) {
    actionEmailOptions.value[index] = [];
  }
  recipients.forEach(r => {
    if (r && !actionEmailOptions.value[index].includes(r)) {
      actionEmailOptions.value[index].push(r);
    }
  });
};

const syncActionImOptions = (index: number, urls: string[]) => {
  if (!actionImOptions.value[index]) {
    actionImOptions.value[index] = [];
  }
  urls.forEach(u => {
    if (u && !actionImOptions.value[index].includes(u)) {
      actionImOptions.value[index].push(u);
    }
  });
};

const addActionEmailRecipient = (index: number) => {
  const raw = actionEmailDrafts.value[index]?.trim();
  if (!raw) return;
  const action = ruleConfig.value.actions[index];
  syncActionEmailOptions(index, [raw]);
  if (!action.config.recipients.includes(raw)) {
    action.config.recipients = [...action.config.recipients, raw];
  }
  actionEmailDrafts.value[index] = '';
};

const addActionImTarget = (index: number) => {
  const raw = actionImDrafts.value[index]?.trim();
  if (!raw) return;
  const action = ruleConfig.value.actions[index];
  syncActionImOptions(index, [raw]);
  if (!action.config.webhookUrls.includes(raw)) {
    action.config.webhookUrls = [...action.config.webhookUrls, raw];
  }
  actionImDrafts.value[index] = '';
};

const handleActionTypeChange = (index: number) => {
  const action = ruleConfig.value.actions[index];
  const prev = action.config;
  action.config = {
    recipients: prev.recipients ?? [],
    subject: prev.subject ?? '',
    body: prev.body ?? '',
    status: prev.status ?? 'pause',
    bidAction: prev.bidAction ?? 'increase',
    bidValue: prev.bidValue,
    bidLimit: prev.bidLimit,
    budgetAction: prev.budgetAction ?? 'increase',
    budgetValue: prev.budgetValue,
    budgetLimit: prev.budgetLimit,
    budgetStrategy: prev.budgetStrategy ?? 'continue',
    roasAction: prev.roasAction ?? 'increase',
    roasValue: prev.roasValue,
    roasLimit: prev.roasLimit,
    tag: prev.tag ?? [],
    tagAction: prev.tagAction ?? 'add',
    newTag: prev.newTag ?? [],
    webhookUrls: prev.webhookUrls ?? [],
    imSubject: prev.imSubject ?? '',
    imMessage: prev.imMessage ?? '',
  };
  syncActionEmailOptions(index, prev.recipients ?? []);
  syncActionImOptions(index, prev.webhookUrls ?? []);
  if (action.type === 'edit-tag' && !tagTreeData.value[index]?.tagOptions?.length) {
    loadTagTree(index);
  }
};

const loadTagTree = async (index: number) => {
  try {
    const res = await getMetaTagsTree();
    const { tagFolders = [], tags = [], tagOptions = [] } = res?.data ?? {};
    tagTreeData.value[index] = { tagFolders, tags, tagOptions };
  } catch (error) {
    console.error(t('pages.createRule.loadTagTreeFailed'), error);
    tagTreeData.value[index] = { tagFolders: [], tags: [], tagOptions: [] };
  }
};

const handleCreateTagOption = async (
  tagId: number,
  name: string,
  parentId: number,
  isTagLevel: boolean,
  actionIndex: number,
) => {
  const payload = isTagLevel
    ? { tag_id: tagId, name, parent_id: 0 }
    : { name, parent_id: parentId };
  await createTagOption(payload);
  await loadTagTree(actionIndex);
};

// 监听 actions 数组变化，为新 action 初始化下拉选项
watch(
  () => ruleConfig.value.actions.map(a => a.config),
  configs => {
    configs.forEach((config, i) => {
      if (config) {
        syncActionEmailOptions(i, config.recipients ?? []);
        syncActionImOptions(i, config.webhookUrls ?? []);
      }
    });
    // 为 edit-tag 类型加载标签树
    ruleConfig.value.actions.forEach((action, i) => {
      if (action.type === 'edit-tag' && !tagTreeData.value[i]?.tagOptions?.length) {
        loadTagTree(i);
      }
    });
  },
  { deep: true },
);

watch(monitoringObject, (newVal, oldVal) => {
  // 编辑模式由 onMounted 负责加载，跳过 watch 中的加载逻辑避免数据被覆盖
  if (isLoadingEditData.value) return;
  loadRuleTemplates();
  // 监控对象切换后模板列表变化，清空「设置规则」与已选模板，避免沿用上一对象下的配置
  ruleConfig.value = createDefaultRuleConfig();
  tagTreeData.value = {};
  selectedTemplate.value = null;
  agreedToDisclaimer.value = false;
});

const dateOptions = metricFilterOptionsConfig.dateOptions;

const operatorOptions = metricFilterOptionsConfig.operatorOptions.map(op => ({
  label: op.label === '介于' || op.label === '不介于' ? t(op.label) : op.label,
  value: op.value,
}));

const toSelectOptions = (values: string[]) => values.map(value => ({ label: t(value), value }));

const valueTypeDefaultOptions = toSelectOptions(metricFilterOptionsConfig.valueTypeDefaults);

const getValueTypeValuesByMetric = (metric: string) => {
  if (!metric) return metricFilterOptionsConfig.valueTypeDefaults;
  // 使用中文标签进行匹配（valueTypeRules 使用中文关键词）
  const chineseLabel = metricEnglishToLabel[metric] || metric;
  const matchedRule = metricFilterOptionsConfig.valueTypeRules.find(rule => {
    const includeOk = rule.includes.some(keyword => chineseLabel.includes(keyword));
    if (!includeOk) return false;
    const excludeOk = (rule.excludes ?? []).every(keyword => !chineseLabel.includes(keyword));
    return excludeOk;
  });
  // 返回英文值而非中文标签
  const chineseOptions = matchedRule?.options ?? metricFilterOptionsConfig.valueTypeDefaults;
  return chineseOptions.map(opt => valueTypeChineseToEnglish[opt] || opt);
};

const getValueTypeOptions = (metric: string) => {
  const values = getValueTypeValuesByMetric(metric);
  if (values.length) {
    return values.map(v => ({ label: valueTypeEnglishToChinese[v] || v, value: v }));
  }
  return valueTypeDefaultOptions;
};

const currencyOptions = metricFilterOptionsConfig.currencyOptions.map(value => ({
  label: value,
  value,
}));

const normalizeConditionValueType = (condition: { metric: string; valueType: string }) => {
  const availableValueTypes = getValueTypeValuesByMetric(condition.metric);
  if (!availableValueTypes.includes(condition.valueType)) {
    condition.valueType = availableValueTypes[0] ?? 'number';
  }
};

const valueUnitOptions = [
  { label: '个', value: '个' },
  { label: '次', value: '次' },
  { label: '%', value: '%' },
];

// 值单位映射：英文 -> 中文（单向，提交时用 Object.fromEntries 反转）
const valueUnitEnglishToChinese: Record<string, string> = {
  count: '个',
  time: '次',
  percent: '%',
  USD: 'USD',
};

// 反转映射用于提交
const valueUnitChineseToEnglish = Object.fromEntries(
  Object.entries(valueUnitEnglishToChinese).map(([en, cn]) => [cn, en]),
);

const spendCurrencyOptions = [{ label: 'USD', value: 'USD' }];

const normalizeConditionUnits = (condition: {
  valueType: string;
  valueUnit?: string;
  currency?: string;
}) => {
  if (condition.valueType === 'number') {
    const allowed = valueUnitOptions.map(o => o.value);
    if (!condition.valueUnit || !allowed.includes(condition.valueUnit)) {
      condition.valueUnit = allowed[0] ?? '个';
    }
  }

  if (condition.valueType === 'spend') {
    condition.currency = 'USD';
  }
};

const normalizeConditionOperatorValues = (condition: {
  operator: string;
  value?: number;
  valueMin?: number;
  valueMax?: number;
}) => {
  const isRange = condition.operator === 'between' || condition.operator === 'not_between';

  if (isRange) {
    // 从单值切换过来时，尽可能把旧值迁移到 valueMin。
    if (condition.valueMin === undefined && condition.value !== undefined) {
      condition.valueMin = condition.value;
    }
  } else {
    // 非范围时，隐藏字段不参与提交，清掉避免残留脏值。
    if (condition.value === undefined && condition.valueMin !== undefined) {
      condition.value = condition.valueMin;
    }
    condition.valueMin = undefined;
    condition.valueMax = undefined;
  }
};

watch(
  () => ruleConfig.value.metricConditions.map(condition => condition.metric),
  () => {
    ruleConfig.value.metricConditions.forEach(condition => {
      normalizeConditionValueType(condition);
      normalizeConditionUnits(condition);
    });
  },
  { immediate: true },
);

watch(
  () => ruleConfig.value.metricConditions.map(condition => condition.valueType),
  () => {
    ruleConfig.value.metricConditions.forEach(condition => normalizeConditionUnits(condition));
  },
  { immediate: true },
);

watch(
  () => ruleConfig.value.metricConditions.map(condition => condition.operator),
  () => {
    ruleConfig.value.metricConditions.forEach(condition =>
      normalizeConditionOperatorValues(condition),
    );
  },
  { immediate: true },
);

const selectTemplate = (templateId: string) => {
  const previousTemplateId = selectedTemplate.value;
  selectedTemplate.value = templateId;

  // 切换规则类型（含首次从「未选」点到某一模板）时重置「设置规则」表单
  if (previousTemplateId !== templateId) {
    const template = ruleTemplates.value.find(t => t.id === templateId);
    const defaultAction = template?.config?.default_action;
    ruleConfig.value = createDefaultRuleConfig(defaultAction);
    tagTreeData.value = {};
    agreedToDisclaimer.value = false;
  }

  currentStep.value = 2;
};

const switchStep = (step: number) => {
  currentStep.value = step === 1 ? 1 : 2;
};

const addCondition = () => {
  const defaultValueType = getValueTypeValuesByMetric(DEFAULT_METRIC)[0] ?? 'number';
  ruleConfig.value.metricConditions.push({
    metric: DEFAULT_METRIC,
    date: 'today',
    operator: '>',
    valueType: defaultValueType,
    value: undefined,
    valueMin: undefined,
    valueMax: undefined,
    valueUnit: '个',
    currency: 'USD',
  });
};

const removeCondition = (index: number) => {
  ruleConfig.value.metricConditions.splice(index, 1);
};

const addAction = () => {
  ruleConfig.value.actions.push({
    type: 'send-email',
    enabled: true,
    config: {
      recipients: [],
      subject: '',
      body: '',
      status: 'pause',
      bidAction: 'increase',
      bidValue: undefined,
      bidLimit: undefined,
      budgetAction: 'increase',
      budgetValue: undefined,
      budgetLimit: undefined,
      budgetStrategy: 'continue',
      roasAction: 'increase',
      roasValue: undefined,
      roasLimit: undefined,
      tag: undefined,
      tagAction: 'add',
      newTag: undefined,
      webhookUrls: [],
      imSubject: '',
      imMessage: '',
    },
  });
};

const removeAction = (index: number) => {
  ruleConfig.value.actions.splice(index, 1);
};

const addTimeSlot = () => {
  ruleConfig.value.customCheckTimes.push(dayjs().format('YYYY-MM-DD 00:00:00'));
};

const removeTimeSlot = (index: number) => {
  ruleConfig.value.customCheckTimes.splice(index, 1);
};

const hasUnsavedChanges = () => {
  // 仅将“第2步设置规则”视为可丢失内容：
  // 第1步切换模板/监控对象不触发返回确认。
  return JSON.stringify(ruleConfig.value) !== JSON.stringify(createDefaultRuleConfig());
};

const goRuleManage = () => {
  emit('close');
};

const goCreateRule = () => {
  // 单页父子组件模式下，当前即为创建页，不需要路由跳转。
  return;
};

/** 离开创建页：由父组件切换列表，不走路由跳转 */
const navigateBackWithState = () => {
  emit('close');
};

const onHeaderBackClick = (e: Event) => {
  e.stopPropagation();
  // 编辑/复制模式：直接返回列表页
  if (isEditMode.value || isCopyMode.value) {
    navigateBackWithState();
    return;
  }
  // 第2步点击返回，仅回到”选择规则类型”步骤，不离开当前页面。
  if (currentStep.value === 2) {
    switchStep(1);
    return;
  }

  // 第1步点击返回，才离开创建页返回上一级。
  if (!hasUnsavedChanges()) {
    navigateBackWithState();
    return;
  }
  headerBackConfirmVisible.value = true;
};

const onCancelClick = (e: Event) => {
  e.stopPropagation();
  cancelConfirmVisible.value = true;
};

const confirmHeaderBack = () => {
  headerBackConfirmVisible.value = false;
  navigateBackWithState();
};

const confirmCancelBack = () => {
  cancelConfirmVisible.value = false;
  navigateBackWithState();
};

const handleFilterConfirm = (filterOptions: any[]) => {
  // 直接 in-place 修改原数组元素的属性，保持响应式引用
  filterOptions.forEach(newItem => {
    const oldItem = filterOptionsFromModal.value.find(item => item.key === newItem.key);
    if (oldItem) {
      oldItem.enabled = newItem.enabled;
      oldItem.value = newItem.value;
      oldItem.options = newItem.options ? [...newItem.options] : newItem.options;
      oldItem.tagTreeData = newItem.tagTreeData;
      oldItem.orgData = newItem.orgData;
    }
  });
  // 同步选中值到 ruleConfig.filters（取消勾选的清空值）
  filterOptions.forEach(item => {
    if (item.key in ruleConfig.value.filters) {
      (ruleConfig.value.filters as any)[item.key] = item.enabled ? (item.value ?? undefined) : undefined;
    }
  });
  // 同步 visibleFilters，确保再次打开 Modal 时勾选状态正确回显
  visibleFilters.value = filterOptions.filter(item => item.enabled).map(item => item.key);
};

/** 构建提交数据 */
const buildSubmitData = () => {
  const config = ruleConfig.value;

  console.log('=========config data=========', config);

  // 处理指标条件
  const conditions = config.metricConditions.map(cond => ({
    metric: cond.metric,
    date_preset: cond.date,
    operator: cond.operator,
    value_type: cond.valueType,
    value: cond.operator === 'between' || cond.operator === 'not_between' ? undefined : cond.value,
    value_min:
      cond.operator === 'between' || cond.operator === 'not_between' ? cond.valueMin : undefined,
    value_max:
      cond.operator === 'between' || cond.operator === 'not_between' ? cond.valueMax : undefined,
    value_unit:
      valueUnitChineseToEnglish[
        cond.valueType === 'number'
          ? (cond.valueUnit ?? '个')
          : cond.valueType === 'spend'
            ? (cond.currency ?? 'USD')
            : ''
      ] ?? undefined,
  }));

  // 处理执行动作
  const actions = config.actions.map(action => {
    const cfg = { ...(action.config || {}) };
    return { type: action.type, enabled: true, config: cfg };
  });

  // 构建提交数据
  return {
    name: config.basicInfo.ruleName,
    description: config.basicInfo.description,
    channel: monitoringChannel.value,
    monitoring_object: monitoringObject.value,
    template_id: selectedTemplate.value || '',
    status: config.basicInfo.status === 'enabled' ? 1 : 0,
    currency: config.basicInfo.currency,
    timezone: config.timezone,
    effective_period: config.effectivePeriod,
    check_frequency: config.checkFrequency,
    custom_check_times:
      config.checkFrequency === 'custom'
        ? config.customCheckTimes.map((t: dayjs.Dayjs | string) => {
            const time = typeof t === 'string' ? dayjs(t) : t;
            return time.format('YYYY-MM-DD HH:mm:ss');
          })
        : undefined,
    execution_interval: config.executionInterval,
    execute_in_order: config.executeInOrder ? 1 : 0,
    filters: {
      channel: config.filters.channel ? [config.filters.channel] : [],
      campaign_ids: config.filters.campaign ? [config.filters.campaign] : [],
      ad_account_ids: config.filters.adAccount ? [config.filters.adAccount] : [],
      ad_group_ids: config.filters.adGroup ? [config.filters.adGroup] : [],
      tag_ids: config.filters.tagIds,
      designer: config.filters.designer,
      creator: config.filters.creator,
      account_status: config.filters.accountStatus,
      authorization_status: config.filters.authorizationStatus,
      timezone: config.filters.timezone,
    },
    metric_conditions: {
      logic: 'and',
      conditions,
    },
    anti_fraud_config: config.antiFraud?.enabled ? config.antiFraud : { enabled: false },
    actions: {
      execute_in_order: config.executeInOrder,
      actions,
    },
  };
};

// 校验表单所有必填字段
const validateForm = (): boolean => {
  if (!ruleConfig.value.basicInfo.ruleName) {
    message.warning(t('pages.createRule.enterRuleNameWarning'));
    return false;
  }

  for (let i = 0; i < ruleConfig.value.metricConditions.length; i++) {
    const cond = ruleConfig.value.metricConditions[i];
    const idx = i + 1;
    if (cond.operator === 'between' || cond.operator === 'not_between') {
      if (cond.valueMin === null || cond.valueMin === undefined) {
        message.warning(t('pages.createRule.fillMinValueWarning', { index: idx }));
        return false;
      }
      if (cond.valueMax === null || cond.valueMax === undefined) {
        message.warning(t('pages.createRule.fillMaxValueWarning', { index: idx }));
        return false;
      }
    } else {
      if (cond.value === null || cond.value === undefined) {
        message.warning(t('pages.createRule.fillValueWarning', { index: idx }));
        return false;
      }
    }
  }

  for (let i = 0; i < ruleConfig.value.actions.length; i++) {
    const action = ruleConfig.value.actions[i];
    const idx = i + 1;
    if (action.type === 'send-email') {
      if (!action.config.recipients || action.config.recipients.length === 0) {
        message.warning(t('pages.createRule.fillRecipientsWarning', { index: idx }));
        return false;
      }
      if (!action.config.subject) {
        message.warning(t('pages.createRule.fillEmailSubjectWarning', { index: idx }));
        return false;
      }
    } else if (action.type === 'bid') {
      if (!action.config.bidAction) {
        message.warning(t('pages.createRule.selectActionTypeWarning', { index: idx }));
        return false;
      }
      if (action.config.bidValue === null || action.config.bidValue === undefined) {
        message.warning(t('pages.createRule.fillValueNumberWarning', { index: idx }));
        return false;
      }
      if (action.config.bidLimit === null || action.config.bidLimit === undefined) {
        message.warning(t('pages.createRule.fillLimitValueWarning', { index: idx }));
        return false;
      }
    } else if (action.type === 'budget' || action.type === 'total-budget') {
      if (!action.config.budgetAction) {
        message.warning(t('pages.createRule.selectActionTypeWarning', { index: idx }));
        return false;
      }
      if (action.config.budgetValue === null || action.config.budgetValue === undefined) {
        message.warning(t('pages.createRule.fillValueNumberWarning', { index: idx }));
        return false;
      }
      if (action.config.budgetLimit === null || action.config.budgetLimit === undefined) {
        message.warning(t('pages.createRule.fillLimitValueWarning', { index: idx }));
        return false;
      }
    } else if (action.type === 'roas-target') {
      if (!action.config.roasAction) {
        message.warning(t('pages.createRule.selectActionTypeWarning', { index: idx }));
        return false;
      }
      if (action.config.roasValue === null || action.config.roasValue === undefined) {
        message.warning(t('pages.createRule.fillValueNumberWarning', { index: idx }));
        return false;
      }
      if (action.config.roasLimit === null || action.config.roasLimit === undefined) {
        message.warning(t('pages.createRule.fillLimitValueWarning', { index: idx }));
        return false;
      }
    } else if (action.type === 'edit-tag') {
      if (!action.config.tagAction) {
        message.warning(t('pages.createRule.selectSetMethodWarning', { index: idx }));
        return false;
      }
      if (action.config.tagAction === 'replace' && !action.config.newTag) {
        message.warning(t('pages.createRule.selectTargetTagWarning', { index: idx }));
        return false;
      }
    } else if (['send-dingtalk', 'send-wecom', 'send-feishu'].includes(action.type)) {
      if (!action.config.imSubject) {
        message.warning(t('pages.createRule.fillMessageSubjectWarning', { index: idx }));
        return false;
      }
      if (!action.config.imMessage) {
        message.warning(t('pages.createRule.fillMessageContentWarning', { index: idx }));
        return false;
      }
    }
  }

  return true;
};

const handleSubmit = async () => {
  if (!validateForm()) return;

  submitLoading.value = true;
  try {
    const submitData = buildSubmitData();
    if (isEditMode.value) {
      await updateRule(props.editData.id, submitData);
      message.success(t('pages.createRule.ruleUpdateSuccess'));
    } else {
      await createRule(submitData);
      message.success(
        isCopyMode.value
          ? t('pages.createRule.ruleCopySuccess')
          : t('pages.createRule.ruleCreateSuccess'),
      );
    }
    emit('close');
  } catch (error) {
    console.error(
      isEditMode.value ? t('pages.createRule.updateFailed') : t('pages.createRule.createFailed'),
      error,
    );
    message.error(
      t(isEditMode.value ? 'pages.createRule.updateFailed' : 'pages.createRule.createFailed'),
    );
  } finally {
    submitLoading.value = false;
  }
};

const handleConfirm = () => {
  if (!agreedToDisclaimer.value) {
    message.warning(t('pages.createRule.readAndAgreeDisclaimer'));
    return;
  }
  handleSubmit();
};

const handleSaveTemplate = () => {
  message.success(t('pages.createRule.templateSaveSuccess'));
};
</script>

<style lang="less" scoped>
.create-rule-page {
  min-height: 100%;
  .page-head {
    margin-bottom: 12px;
  }

  .wizard-layout {
    display: flex;
    gap: 24px;
    background: #fff;
    padding: 24px;
    border-radius: 4px;
  }

  .wizard-steps-nav {
    width: 200px;
    flex-shrink: 0;
    background: #fafafa;
    border: 1px solid #f0f0f0;
    border-radius: 8px;
    padding: 8px;
  }

  .wizard-step-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 12px;
    border-radius: 8px;
    cursor: pointer;
    color: #666;
    transition: all 0.2s;
    user-select: none;

    &:hover {
      background: #f0f7ff;
      color: #1890ff;
    }

    &.active {
      background: #e6f7ff;
      color: #1890ff;
      font-weight: 600;
    }
  }

  .wizard-step-index {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #d9d9d9;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    flex-shrink: 0;
    transition: all 0.2s;
  }

  .wizard-step-item.active {
    .wizard-step-index {
      background: #1890ff;
      color: #fff;
    }
  }

  .wizard-main {
    flex: 1;
    min-width: 0;
  }

  .step-content {
    background: #fff;
    padding: 24px;
    border-radius: 4px;
    margin-bottom: 16px;

    .step-header {
      margin-bottom: 24px;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;

      .step-title-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .step-title-block {
        display: flex;
        flex-direction: column;
      }

      .back-icon-button {
        border-color: #d9d9d9;
        color: #595959;
      }

      .back-icon-button:hover {
        border-color: #40a9ff;
        color: #1890ff;
      }

      .step-title {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 8px;
      }

      .step-title-type {
        font-size: 14px;
        font-weight: 500;
        color: #1890ff;
        margin-left: 10px;
        vertical-align: middle;
        display: inline-flex;
        align-items: center;
        padding: 2px 10px;
        border-radius: 999px;
        border: 1px solid rgba(24, 144, 255, 0.25);
        background: rgba(24, 144, 255, 0.08);
        box-shadow: 0 2px 8px rgba(24, 144, 255, 0.08);
      }

      .step-subtitle {
        color: #666;
      }
    }

    .monitoring-settings {
      margin-bottom: 24px;
      padding-bottom: 24px;
      border-bottom: 1px solid #e8e8e8;

      .setting-item {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 16px;

        label {
          min-width: 80px;
          font-weight: 500;
        }
      }
    }

    .template-hint {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 16px;
    }

    .rule-templates {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;

      .template-card {
        padding: 24px;
        border: 1px solid #e8e8e8;
        border-radius: 4px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;

        &:hover {
          border-color: #1890ff;
          box-shadow: 0 2px 8px rgba(24, 144, 255, 0.2);
        }

        .template-icon {
          width: 64px;
          height: 64px;
          border-radius: 8px;
          display: flex;
          align-items: center;
          justify-content: center;
          margin: 0 auto 12px;
          font-size: 32px;
          color: #fff;
        }

        .template-title {
          font-size: 16px;
          font-weight: 500;
          margin-bottom: 8px;
        }

        .template-desc {
          font-size: 12px;
          color: #666;
          line-height: 1.5;
        }
      }
    }

    .rule-section {
      margin-bottom: 24px;
      padding-bottom: 24px;
      border-bottom: 1px solid #e8e8e8;

      &:last-child {
        border-bottom: none;
      }

      .section-title {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .filter-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 16px;
      }

      .metric-filter {
        .metric-title {
          font-size: 14px;
          font-weight: 500;
          margin-bottom: 16px;
          display: flex;
          align-items: center;
        }

        .metric-condition {
          display: flex;
          align-items: center;
          gap: 8px;
          margin-bottom: 12px;

          .condition-number {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: #1890ff;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            flex-shrink: 0;
          }
        }
      }

      .action-list {
        margin-top: 12px;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .action-card {
        background: #f7f8fa;
        border-radius: 10px;
        padding: 16px;
        position: relative;
      }

      .action-card-number {
        position: absolute;
        top: 14px;
        left: 14px;
        width: 26px;
        height: 26px;
