<?php

namespace App\Models;

use Illuminate\Database\Eloquent\Relations\BelongsTo;
use Illuminate\Database\Eloquent\Relations\HasMany;

/**
 * Meta 文案库单条文案（primary_text / headline / description + remark）。
 *
 * @property string $id
 * @property string $library_id
 * @property string $folder_id
 * @property string|null $primary_text
 * @property string|null $headline
 * @property string|null $description
 * @property string|null $remark
 * @property string $status
 * @property string|null $created_by
 */
class MetaCopyItem extends BaseModel
{
    protected $table = 'meta_copy_items';

    protected $fillable = [
        'library_id',
        'folder_id',
        'primary_text',
        'headline',
        'description',
        'remark',
        'status',
        'created_by',
    ];

    public function library(): BelongsTo
    {
        return $this->belongsTo(MetaCopyLibrary::class, 'library_id');
    }

    public function folder(): BelongsTo
    {
        return $this->belongsTo(MetaCopyFolder::class, 'folder_id');
    }

    public function creator(): BelongsTo
    {
        return $this->belongsTo(User::class, 'created_by');
    }

    public function performanceDaily(): HasMany
    {
        return $this->hasMany(MetaCopyPerformanceDaily::class, 'copy_item_id');
    }
}
