        gap: 16px;
        margin-bottom: 16px;

        label {
          min-width: 80px;
          font-weight: 500;
        }
      }
    }

    .rule-templates {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;

      .template-card {
        padding: 24px;
