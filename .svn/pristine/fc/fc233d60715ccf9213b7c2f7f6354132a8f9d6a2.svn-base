    Route::get('/reject-reason-options', [XmpOptionsController::class, 'rejectReasonOptions']);
    Route::get('/system-tags', [XmpOptionsController::class, 'systemTags']);
    Route::get('/material-groups', [XmpMaterialGroupsController::class, 'index']);
    Route::post('/material-groups', [XmpMaterialGroupsController::class, 'store']);
    Route::put('/material-groups/{id}', [XmpMaterialGroupsController::class, 'update']);
    Route::delete('/material-groups/{id}', [XmpMaterialGroupsController::class, 'destroy']);
});

