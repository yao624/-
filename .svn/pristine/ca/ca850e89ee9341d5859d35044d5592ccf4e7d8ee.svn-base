<?php

namespace App\Models;

use Illuminate\Database\Eloquent\Relations\HasMany;
use Illuminate\Database\Eloquent\Concerns\HasUlids;
use Illuminate\Database\Eloquent\Factories\HasFactory;
use Illuminate\Database\Eloquent\SoftDeletes;

class Link extends BaseModel
{
    use HasFactory, HasUlids, SoftDeletes;

    protected $fillable = [
        'link',
        'notes',
        'user_id',
        'default_locale',
        'language_variants',
        'import_source',
    ];

    protected $casts = [
        'language_variants' => 'array',
    ];

    public function tags()
    {
        return $this->hasMany(LinkTag::class, 'link_id');
    }

    public function user()
    {
        return $this->belongsTo(User::class);
    }

    public function adLogs(): HasMany
    {
        return $this->hasMany(AdLog::class, 'link_id');
    }

    public function sharedWith()
    {
        return $this->belongsToMany(User::class, 'link_shares')->using(CustomPivot::class)
            ->withTimestamps();
    }

    public function isSharedWith($userId)
    {
        return $this->sharedWith()->where('id', $userId)->exists();
    }

}
