// 获取文件夹列表
export async function getFolders() {
  await new Promise((resolve) => setTimeout(resolve, 200));

  return [
    { id: 'default', name: '默认素材库', path: '我的素材库/默认素材库' },
    { id: 'default2', name: '默认素材库', path: '我的素材库/默认素材库' },
    { id: 'enterprise1', name: '企业素材库1', path: '企业素材库/企业素材库1' },
    { id: 'enterprise2', name: '企业素材库2', path: '企业素材库/企业素材库2' },
    { id: 'dept1', name: '部门素材库1', path: '我的部门/部门素材库1' },
    { id: 'dept2', name: '部门素材库2', path: '我的部门/部门素材库2' },
  ];
}

