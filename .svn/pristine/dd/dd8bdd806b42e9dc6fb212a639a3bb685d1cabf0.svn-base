      localId: 'MAT-20250101-002',
      tags: ['产品介绍'],
      cost: '2500.00',
      impressions: '250000',
      cpm: '10.00',
      clicks: '2500',
      ctr: '1.00%',
      conversions: '250',
    },
    {
      id: '4',
      type: 'image',
      name: 'ad_creative_001.png',
      localId: 'MAT-20250101-003',
      tags: ['品牌', '推广'],
      cost: '850.30',
      impressions: '85000',
      cpm: '10.00',
      clicks: '850',
      ctr: '1.00%',
      conversions: '85',
      thumbnail: 'https://via.placeholder.com/150',
    },
    {
      id: '5',
