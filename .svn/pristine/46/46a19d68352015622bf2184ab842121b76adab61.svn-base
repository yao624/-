<template>
  <div class="material-table">
    <a-table
      :columns="columns"
      :data-source="dataSource"
      :loading="loading"
      :pagination="pagination"
      :row-selection="rowSelection"
      :scroll="{ x: 2000 }"
      row-key="id"
      @change="handleTableChange"
    >
      <template #bodyCell="{ column, record }">
        <!-- 名称 -->
        <template v-if="column.dataIndex === 'name'">
          <div class="name-cell">
            <a-image
              v-if="record.thumbnail"
              :src="record.thumbnail"
              :width="40"
              :height="40"
              class="thumbnail"
            />
            <span class="name-text">{{ record.name }}</span>
          </div>
        </template>

        <!-- 渠道 -->
        <template v-else-if="column.dataIndex === 'platform'">
          <div class="platform-cell">
            <component :is="getPlatformIcon(record.platform)" class="platform-icon" />
            <span>{{ getPlatformLabel(record.platform) }}</span>
          </div>
        </template>

        <!-- 使用账户 -->
        <template v-else-if="column.dataIndex === 'usedAccounts'">
          <a-tooltip v-if="record.usedAccounts.length > 0" :title="record.usedAccounts.join(', ')">
            <span>{{ record.usedAccounts.slice(0, 2).join(', ') }}</span>
            <span v-if="record.usedAccounts.length > 2">
              ... (+{{ record.usedAccounts.length - 2 }})
            </span>
          </a-tooltip>
          <span v-else>-</span>
        </template>

        <!-- 形状 -->
        <template v-else-if="column.dataIndex === 'shape'">
          <a-tag :color="getShapeColor(record.shape)">
            {{ t(`pages.channelManage.shape.${record.shape}`) }}
          </a-tag>
        </template>

        <!-- 格式 -->
        <template v-else-if="column.dataIndex === 'format'">
          <a-tag>{{ record.format.toUpperCase() }}</a-tag>
        </template>

        <!-- 来源 -->
        <template v-else-if="column.dataIndex === 'source'">
          {{ t(`pages.channelManage.source.${record.source}`) }}
        </template>

        <!-- 素材备注 -->
        <template v-else-if="column.dataIndex === 'remark'">
          <a-tooltip v-if="record.remark" :title="record.remark">
            <span class="ellipsis-text">{{ record.remark }}</span>
          </a-tooltip>
          <span v-else>-</span>
        </template>

        <!-- 拒审信息 -->
        <template v-else-if="column.dataIndex === 'rejectionInfo'">
          <a-tooltip v-if="record.rejectionInfo" :title="record.rejectionInfo">
            <a-tag color="error">{{ t('pages.channelManage.status.rejected') }}</a-tag>
          </a-tooltip>
          <span v-else>-</span>
        </template>

        <!-- 操作 -->
        <template v-else-if="column.key === 'action'">
          <a-popconfirm
            :title="t('pages.channelManage.messages.deleteConfirm')"
            :ok-text="t('pages.common.confirm')"
            :cancel-text="t('pages.common.cancel')"
            @confirm="handleDelete(record)"
          >
            <a class="danger-text">{{ t('pages.common.delete') }}</a>
          </a-popconfirm>
        </template>
      </template>
    </a-table>
  </div>
</template>

<script setup lang="ts">
import { computed } from 'vue';
import { useI18n } from 'vue-i18n';
import type { TableProps } from 'ant-design-vue';
import {
  FacebookOutlined,
  GoogleOutlined,
  // TikTokOutlined,
  ThunderboltOutlined,
} from '@ant-design/icons-vue';
import type { Material, PlatformType } from '../types';

const props = defineProps<{
  dataSource: Material[];
  loading: boolean;
  pagination: {
    current: number;
    pageSize: number;
    total: number;
    showSizeChanger: boolean;
    showQuickJumper: boolean;
    showTotal: (total: number) => string;
  };
  selectedRowKeys?: string[];
}>();

const emit = defineEmits<{
  (e: 'update:selectedRowKeys', keys: string[]): void;
  (e: 'delete', record: Material): void;
  (e: 'pageChange', page: number, pageSize: number): void;
}>();

const { t, locale } = useI18n();

const isZh = computed(() => locale.value.startsWith('zh'));

const columns = computed(() => [
  {
    title: t('pages.channelManage.table.name'),
    dataIndex: 'name',
    key: 'name',
    width: 200,
    fixed: 'left' as const,
    ellipsis: true,
  },
  {
    title: t('pages.channelManage.table.materialId'),
    dataIndex: 'id',
    key: 'id',
    width: 120,
  },
  {
    title: t('pages.channelManage.table.channel'),
    dataIndex: 'platform',
    key: 'platform',
    width: 100,
  },
  {
    title: t('pages.channelManage.table.usedAccounts'),
    dataIndex: 'usedAccounts',
    key: 'usedAccounts',
    width: 150,
    ellipsis: true,
  },
  {
    title: t('pages.channelManage.table.ownerAccount'),
    dataIndex: 'ownerAccount',
    key: 'ownerAccount',
    width: 120,
  },
  {
    title: t('pages.channelManage.table.size'),
    dataIndex: 'size',
    key: 'size',
    width: 100,
    align: 'center' as const,
  },
  {
    title: t('pages.channelManage.table.duration'),
    dataIndex: 'duration',
    key: 'duration',
    width: 80,
    align: 'center' as const,
  },
  {
    title: t('pages.channelManage.table.shape'),
    dataIndex: 'shape',
    key: 'shape',
    width: 100,
    align: 'center' as const,
  },
  {
    title: t('pages.channelManage.table.format'),
    dataIndex: 'format',
    key: 'format',
    width: 80,
    align: 'center' as const,
  },
  {
    title: t('pages.channelManage.table.source'),
    dataIndex: 'source',
    key: 'source',
    width: 100,
    align: 'center' as const,
  },
  {
    title: t('pages.channelManage.table.remark'),
    dataIndex: 'remark',
    key: 'remark',
    width: 150,
    ellipsis: true,
  },
  {
    title: t('pages.channelManage.table.createdAt'),
    dataIndex: 'createdAt',
    key: 'createdAt',
    width: 160,
  },
  {
    title: t('pages.channelManage.table.rejectionInfo'),
    dataIndex: 'rejectionInfo',
    key: 'rejectionInfo',
    width: 100,
    align: 'center' as const,
  },
  {
    title: t('pages.channelManage.table.actions'),
    key: 'action',
    width: 120,
    fixed: 'right' as const,
  },
]);

const rowSelection = computed(() => ({
  selectedRowKeys: props.selectedRowKeys || [],
  onChange: (selectedRowKeys: string[]) => {
    emit('update:selectedRowKeys', selectedRowKeys);
  },
}));

const getPlatformLabel = (platform: PlatformType) => {
  const labels: Record<PlatformType, { zh: string; en: string }> = {
    meta: { zh: 'Meta', en: 'Meta' },
    google: { zh: 'Google', en: 'Google' },
    tiktok: { zh: 'TikTok', en: 'TikTok' },
    kwai: { zh: '快手', en: 'Kwai' },
  };
  return isZh.value ? labels[platform].zh : labels[platform].en;
};

const getPlatformIcon = (platform: PlatformType) => {
  const icons: Record<PlatformType, any> = {
    meta: FacebookOutlined,
    google: GoogleOutlined,
    // tiktok: TikTokOutlined,
    kwai: ThunderboltOutlined,
  };
  return icons[platform] || FacebookOutlined;
};

const getShapeColor = (shape: string): string => {
  const colorMap: Record<string, string> = {
    square: 'blue',
    landscape: 'green',
    portrait: 'orange',
    unknown: 'default',
  };
  return colorMap[shape] || 'default';
};

const handleDelete = (record: Material) => {
  emit('delete', record);
};

const handleTableChange: TableProps['onChange'] = (pagination) => {
  emit('pageChange', pagination.current, pagination.pageSize);
};
</script>

<style scoped lang="less">
.material-table {
  .name-cell {
    display: flex;
    align-items: center;
    gap: 8px;

    .thumbnail {
      flex-shrink: 0;
      border-radius: 4px;
    }

    .name-text {
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  }

  .platform-cell {
    display: flex;
    align-items: center;
    gap: 8px;

    .platform-icon {
      font-size: 16px;
    }
  }

  .ellipsis-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    display: block;
  }

  .danger-text {
    color: #ff4d4f;

    &:hover {
      color: #ff7875;
    }
  }
}
</style>
