 * @Description: 阴影
-->

<template>
  <div class="box attr-item-box" v-if="isOne">
    <!-- <h3>阴影</h3> -->
    <Divider plain orientation="left"><h4>{{ $t('attributes.shadow') }}</h4></Divider>
    <!-- 通用属性 -->
    <div>
      <Row :gutter="10">
        <Col flex="1">
          <div class="ivu-col__box">
            <span class="label">{{ $t('color') }}</span>
            <div class="content">
              <ColorPicker v-model="baseAttr.shadow.color" @on-active-change="changeCanvasOnly" @on-change="changeCommon" alpha />
            </div>
          </div>
        </Col>
        <Col flex="1">
          <div class="ivu-col__box">
            <span class="label">{{ $t('attributes.blur') }}:</span>
            <InputNumber
              v-model="baseAttr.shadow.blur"
              :defaultValue="0"
              @on-change="changeCommon"
              :append="$t('attributes.blur')"
              :min="0"
            ></InputNumber>
          </div>
        </Col>
      </Row>
      <div>
        <Row :gutter="10">
          <Col flex="1">
            <div class="ivu-col__box">
              <span class="label">{{ $t('attributes.axisX') }}:</span>
              <InputNumber
                v-model="baseAttr.shadow.offsetX"
                :defaultValue="0"
                @on-change="changeCommon"
                :append="$t('attributes.offset_x')"
              ></InputNumber>
            </div>
          </Col>
          <Col flex="1">
            <div class="ivu-col__box">
              <span class="label">{{ $t('attributes.axisY') }}:</span>
              <InputNumber
                v-model="baseAttr.shadow.offsetY"
                :defaultValue="0"
                @on-change="changeCommon"
                :append="$t('attributes.offset_y')"
              ></InputNumber>
            </div>
          </Col>
        </Row>
      </div>
    </div>
    <!-- <Divider plain></Divider> -->
  </div>
</template>

<script setup name="AttrBute">
import { reactive, getCurrentInstance, onMounted, onBeforeUnmount } from 'vue';
import useSelect from '@/hooks/select.js';
import InputNumber from '@/components/inputNumber/index.vue';
import {ColorPicker} from 'view-ui-plus';

const update = getCurrentInstance();
const { fabric, isOne, canvasEditor } = useSelect();

// 属性值
const baseAttr = reactive({
  shadow: {},
});

// 属性获取
const getObjectAttr = (e) => {
  const activeObject = canvasEditor.canvas.getActiveObject();
  // 不是当前obj，跳过
  if (e && e.target && e.target !== activeObject) return;
  if (activeObject) {
    baseAttr.shadow = activeObject.get('shadow') || {};
  }
};

// 实时更新画布（不触发重渲染）
const changeCanvasOnly = (c) => {
  const activeObject = canvasEditor.canvas.getActiveObjects()[0];
  if (activeObject) {
    const shadow = new fabric.Shadow({ ...baseAttr.shadow, color: c });
    activeObject.set('shadow', shadow);
    canvasEditor.canvas.renderAll();
  }
};

// 确认后同步
const changeCommon = () => {
  const activeObject = canvasEditor.canvas.getActiveObjects()[0];
  if (activeObject) {
    activeObject.set('shadow', new fabric.Shadow(baseAttr.shadow));
    canvasEditor.canvas.renderAll();
  }
};

const selectCancel = () => {
  update?.proxy?.$forceUpdate();
};

onMounted(() => {
  // 获取字体数据
  getObjectAttr();
  canvasEditor.on('selectCancel', selectCancel);
  canvasEditor.on('selectOne', getObjectAttr);
  canvasEditor.canvas.on('object:modified', getObjectAttr);
});

onBeforeUnmount(() => {
  canvasEditor.off('selectCancel', selectCancel);
  canvasEditor.off('selectOne', getObjectAttr);
  canvasEditor.canvas.off('object:modified', getObjectAttr);
});
</script>

<style scoped lang="less">
:deep(.ivu-input-number) {
  display: block;
  width: 100%;
}

:deep(.ivu-color-picker) {
  display: block;
}
:deep(.ivu-color-picker-confirm) {
  display: none;
}
.box {
  width: 100%;
}

.ivu-row {
  margin-bottom: 8px;
  .ivu-col {
    position: inherit;
    &__box {
      display: flex;
      align-items: center;
      background: #f8f8f8;
      border-radius: 4px;
      gap: 8px;
    }
  }

  .label {
    padding-left: 8px;
    font-size: 12px;
    color: #666;
    white-space: nowrap;
  }
  .content {
    flex: 1;
    :deep(.--input),
    :deep(.ivu-select-selection) {
      background-color: transparent;
      border: none !important;
      box-shadow: none !important;
    }
  }
}
</style>
