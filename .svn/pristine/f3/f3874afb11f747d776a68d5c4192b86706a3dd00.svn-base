// 广告模板管理页面类型定义

export type PlatformType = 'meta' | 'google' | 'tiktok' | 'kwai';
export type TemplateStatus = 'active' | 'inactive' | 'draft' | 'archived';
export type TemplateType = 'campaign' | 'adset' | 'ad' | 'creative';

export interface AdTemplate {
  id: string;
  name: string;
  description?: string;
  platform: PlatformType;
  type: TemplateType;
  status: TemplateStatus;
  createdBy: string;
  createdAt: string;
  updatedAt: string;
  isOwner: boolean;
  tags?: string[];
  thumbnail?: string;
}

export interface TemplateListParams {
  page?: number;
  pageSize?: number;
  keyword?: string;
  platform?: PlatformType;
  status?: TemplateStatus;
  type?: TemplateType;
}

export interface TemplateListResponse {
  data: AdTemplate[];
  total: number;
}
