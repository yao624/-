import type { ConfigEnv, UserConfig } from 'vite';
import { loadEnv } from 'vite';
import vue from '@vitejs/plugin-vue';
import vueJsx from '@vitejs/plugin-vue-jsx';
import path, { resolve } from 'path';
import legacy from '@vitejs/plugin-legacy';
import UnoCss from 'unocss/vite';
// const mock = require('./build/mock/createMockServer');

export default ({ mode }: ConfigEnv): UserConfig => {
  const root = process.cwd();
  const env = loadEnv(mode, root);
  // 开发代理目标：由各 mode 对应 .env* 中的 VITE_API_PROXY_TARGET 决定（如 .env.development）
  const apiProxyTarget =
    String(env.VITE_API_PROXY_TARGET || '').trim() || 'https://ads.freeadspay.com';
  // 默认关闭 @vitejs/plugin-legacy（更快）；需兼容旧浏览器时：.env 设 VITE_BUILD_LEGACY=true 或 npm run build:legacy
  const enableLegacy =
    String(process.env.VITE_BUILD_LEGACY ?? env.VITE_BUILD_LEGACY ?? 'false').toLowerCase() === 'true';
  return {
    base: env.VITE_APP_PUBLIC_PATH,
    // 兼容 Cli
    define: {
      __VUE_I18N_FULL_INSTALL__: 'true',
      __VUE_I18N_LEGACY_API__: 'true',
      __VUE_I18N_PROD_DEVTOOLS__: 'false',
      'process.env.VUE_APP_API_BASE_URL': JSON.stringify(env.VITE_APP_API_BASE_URL),
      'process.env.VUE_APP_PUBLIC_PATH': JSON.stringify(env.VITE_APP_PUBLIC_PATH),
    },
    plugins: [
      ...(enableLegacy
        ? [
            legacy({
              targets: ['defaults', 'not IE 11', 'Chrome 63', 'Firefox > 20'],
              modernPolyfills: true,
            }),
          ]
        : []),
      vue(),
      vueJsx(),
      UnoCss(),
      // mock({
      //   watch: true,
      //   mockUrlList: [/api/],
      //   cwd: process.cwd(),
      //   enable: env.VITE_HTTP_MOCK === 'true' && process.env.NODE_ENV !== 'production',
      // }),
    ],
    build: {
      // 测试环境（--mode preview 或 --mode test，对应 npm run build:test）输出到 dist-test
      outDir: mode === 'preview' || mode === 'test' ? 'dist-test' : 'dist',
      assetsDir: 'assets',
      cssCodeSplit: false,
      chunkSizeWarningLimit: 2048,
      // 跳过各 chunk 的 gzip 体积计算，可节省大量构建尾部时间
      reportCompressedSize: false,
      minify: 'esbuild',
      rollupOptions: {
        input: {
          main: resolve(__dirname, 'index.html'),
          subpage: resolve(__dirname, 'pages/index.html'),
        },
        output: {
          // 确保所有 JS/CSS/资源都落到 dist/assets
          entryFileNames: 'assets/[name]-[hash].js',
          chunkFileNames: 'assets/[name]-[hash].js',
          assetFileNames: 'assets/[name]-[hash][extname]',
          manualChunks: {
            vue: ['vue', 'pinia', 'vue-router'],
            antdv: ['ant-design-vue', '@ant-design/icons-vue'],
          },
        },
      },
    },
    resolve: {
      // @ / ~@ 均指向 ./src：业务页面请放在 src/views，API 在 src/api。项目根目录下的 views/、api/ 为历史副本，勿作为唯一维护源。
      alias: {
        '~@': path.join(__dirname, './src'),
        '@': path.join(__dirname, './src'),
        '~': path.join(__dirname, './src/assets'),
        vue: 'vue/dist/vue.esm-bundler.js',
        dayjs: resolve(__dirname, 'node_modules', 'dayjs'),
        'ant-design-vue': resolve(__dirname, 'node_modules', 'ant-design-vue'),
      },
    },
    optimizeDeps: {
      include: [
        'ant-design-vue/es/locale/en_US',
        'ant-design-vue/es/locale/zh_CN',
        'store/plugins/expire',
        'ant-design-vue/es/form',
        'dayjs',
        'dayjs/locale/en',
        'dayjs/locale/zh-cn',
        '@ant-design/icons-vue',
        'lodash-es',
        'pinia',
        'vue-router',
        'vue',
        'vue-i18n',
        '@vueuse/core',
      ],
    },
    css: {
      preprocessorOptions: {
        less: {
          modifyVars: {
            hack: 'true; @import "~/styles/variables.less";',
          },
          // DO NOT REMOVE THIS LINE
          javascriptEnabled: true,
        },
      },
    },
    server: {
      host: true,
      proxy:
        env.VITE_HTTP_MOCK === 'true'
          ? undefined
          : {
              '/api': {
                target: apiProxyTarget,
                ws: false,
                changeOrigin: true,
              },
            },
    },
  };
};
