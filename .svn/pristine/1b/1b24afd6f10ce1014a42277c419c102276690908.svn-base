<?php

namespace App\Http\Controllers;

use App\Http\Resources\LinkResource;
use App\Http\Resources\TagResource;
use App\Models\Link;
use App\Models\LinkTag;
use App\Models\User;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\DB;
use Illuminate\Validation\Rule;

class LinkController extends Controller
{
    private function isOwner(Link $link, $userId): bool
    {
        return (string) $link->user_id !== '' && (string) $link->user_id === (string) $userId;
    }

    private function normalizeTagNames($tags): array
    {
        return collect(is_array($tags) ? $tags : [])
            ->map(fn ($tag) => trim((string) $tag))
            ->filter()
            ->unique()
            ->values()
            ->all();
    }

    private function normalizeLanguageVariants($variants): array
    {
        return collect(is_array($variants) ? $variants : [])
            ->map(function ($item) {
                if (!is_array($item)) {
                    return null;
                }

                $locale = trim((string) ($item['locale'] ?? ''));
                $url = trim((string) ($item['url'] ?? ''));
                $notes = trim((string) ($item['notes'] ?? ''));

                if ($locale === '' || $url === '') {
                    return null;
                }

                return [
                    'locale' => $locale,
                    'url' => $url,
                    'notes' => $notes,
                ];
            })
            ->filter()
            ->unique(fn ($item) => $item['locale'] . '|' . $item['url'])
            ->values()
            ->all();
    }

    private function syncTagsForLink(Link $link, string $userId, array $tagNames): void
    {
        $tagNamesCollection = collect($tagNames)->unique()->values();
        $existingTags = $link->tags()
            ->where('user_id', $userId)
            ->get()
            ->keyBy('name');

        $toDelete = $existingTags->keys()->diff($tagNamesCollection);
        if ($toDelete->isNotEmpty()) {
            $link->tags()
                ->where('user_id', $userId)
                ->whereIn('name', $toDelete->all())
                ->delete();
        }

        $toCreate = $tagNamesCollection->diff($existingTags->keys());
        foreach ($toCreate as $tagName) {
            LinkTag::create([
                'link_id' => $link->id,
                'user_id' => (string) $userId,
                'name' => $tagName,
            ]);
        }
    }

    private function addTagsToLink(Link $link, string $userId, array $tagNames): void
    {
        $tagNames = $this->normalizeTagNames($tagNames);
        $existingNames = $link->tags()
            ->where('user_id', $userId)
            ->whereIn('name', $tagNames)
            ->pluck('name');

        foreach (collect($tagNames)->diff($existingNames) as $tagName) {
            LinkTag::create([
                'link_id' => $link->id,
                'user_id' => (string) $userId,
                'name' => $tagName,
            ]);
        }
    }

    private function removeTagsFromLink(Link $link, string $userId, array $tagNames): void
    {
        $tagNames = $this->normalizeTagNames($tagNames);
        if (empty($tagNames)) {
            return;
        }

        $link->tags()
            ->where('user_id', $userId)
            ->whereIn('name', $tagNames)
            ->delete();
    }

    private function buildLinksQuery(Request $request)
    {
        $tagNames = $request->filled('tags')
            ? explode(',', (string) $request->query('tags'))
            : [];

        $searchableFields = [
            'link' => $request->get('link'),
            'notes' => $request->get('notes') ?? $request->get('name'),
            'date_start' => $request->get('date_start'),
            'date_end' => $request->get('date_end'),
        ];

        $linksQuery = Link::search($searchableFields)
            ->where(function ($query) {
                $query->where('user_id', auth()->id())
                    ->orWhereHas('sharedWith', function ($subQuery) {
                        $subQuery->where('user_id', auth()->id());
                    });
            });

        if (!empty($tagNames)) {
            $linksQuery->whereHas('tags', function ($query) use ($tagNames) {
                $query->whereIn('name', $tagNames);
            });
        }

        if ($request->filled('locale')) {
            $locale = (string) $request->get('locale');
            $linksQuery->where(function ($query) use ($locale) {
                $query->where('default_locale', $locale)
                    ->orWhereJsonContains('language_variants', [['locale' => $locale]]);
            });
        }

        return $linksQuery;
    }

    private function extractImportRows(Request $request): array
    {
        $rows = [];
        $rawText = trim((string) $request->input('raw_text', ''));

        if ($rawText !== '') {
            foreach (preg_split('/\r\n|\r|\n/', $rawText) as $line) {
                $line = trim($line);
                if ($line === '') {
                    continue;
                }

                $parts = str_getcsv($line);
                $rows[] = [
                    'link' => trim((string) ($parts[0] ?? '')),
                    'notes' => trim((string) ($parts[1] ?? '')),
                    'tags' => trim((string) ($parts[2] ?? '')),
                ];
            }
        }

        if ($request->hasFile('file')) {
            $file = $request->file('file');
            $handle = fopen($file->getRealPath(), 'r');
            if ($handle !== false) {
                $header = null;
                while (($data = fgetcsv($handle)) !== false) {
                    if ($header === null) {
                        $normalizedHeader = array_map(fn ($item) => strtolower(trim((string) $item)), $data);
                        if (in_array('link', $normalizedHeader, true)) {
                            $header = $normalizedHeader;
                            continue;
                        }
                    }

                    if ($header) {
                        $row = [];
                        foreach ($header as $index => $key) {
                            $row[$key] = trim((string) ($data[$index] ?? ''));
                        }
                        $rows[] = $row;
                    } else {
                        $rows[] = [
                            'link' => trim((string) ($data[0] ?? '')),
                            'notes' => trim((string) ($data[1] ?? '')),
                            'tags' => trim((string) ($data[2] ?? '')),
                        ];
                    }
                }
                fclose($handle);
            }
        }

        return $rows;
    }

    public function listTagOptions(Request $request)
    {
        $userId = (string) $request->user()->id;

        $tags = LinkTag::query()
            ->with('user')
            ->where('user_id', $userId)
            ->select('name', DB::raw('MIN(id) as id'), DB::raw('MIN(created_at) as created_at'), 'user_id')
            ->groupBy('name', 'user_id')
            ->orderBy('name')
            ->get();

        return response()->json(['data' => TagResource::collection($tags)]);
    }

    public function updateTags(Request $request, Link $link)
    {
        $userId = (string) $request->user()->id;
        if (!$this->isOwner($link, $userId)) {
            return response()->json(['message' => 'Forbidden'], 403);
        }

        $validated = $request->validate([
            'action' => 'required|in:add,delete',
            'names' => 'required|array|min:1',
            'names.*' => 'required|string|max:191',
        ], [
            'action.required' => '请选择标签操作类型',
            'action.in' => '标签操作类型不正确',
            'names.required' => '请至少填写一个标签',
            'names.array' => '标签格式不正确',
            'names.min' => '请至少填写一个标签',
            'names.*.required' => '标签不能为空',
        ]);

        if ($validated['action'] === 'add') {
            $this->addTagsToLink($link, $userId, $validated['names']);
        } else {
            $this->removeTagsFromLink($link, $userId, $validated['names']);
        }

        $link->load(['tags.user', 'user'])->loadCount('adLogs as ad_usage_count');

        return new LinkResource($link);
    }

    public function index(Request $request)
    {
        $sortField = $request->get('sortField', 'created_at');
        $sortDirection = $request->get('sortOrder', 'desc');
        $pageSize = $request->get('pageSize', 10);
        $pageNo = $request->get('pageNo', 1);

        $allowedSortFields = ['created_at', 'updated_at', 'link', 'notes', 'default_locale'];
        if (!in_array($sortField, $allowedSortFields, true)) {
            $sortField = 'created_at';
        }

        $links = $this->buildLinksQuery($request)
            ->with(['tags.user', 'sharedWith', 'user'])
            ->withCount('adLogs as ad_usage_count')
            ->addSelect([
                'last_used_at' => DB::table('ad_logs')
                    ->selectRaw('MAX(created_at)')
                    ->whereColumn('ad_logs.link_id', 'links.id'),
            ])
            ->orderBy($sortField, $sortDirection)
            ->paginate($pageSize, ['*'], 'page', $pageNo);

        return [
            'data' => LinkResource::collection($links->items()),
            'pageSize' => $links->perPage(),
            'pageNo' => $links->currentPage(),
            'totalPage' => $links->lastPage(),
            'totalCount' => $links->total(),
        ];
    }

    public function store(Request $request)
    {
        $userId = (string) auth()->id();
        $request->validate([
            'link' => [
                'required',
                'url',
                Rule::unique('links')->where(function ($query) use ($userId) {
                    return $query->where('user_id', $userId)->whereNull('deleted_at');
                }),
            ],
            'notes' => 'nullable|string',
            'tags' => 'array|distinct|nullable',
            'default_locale' => 'nullable|string|max:32',
            'language_variants' => 'nullable|array',
            'language_variants.*.locale' => 'required_with:language_variants|string|max:32',
            'language_variants.*.url' => 'required_with:language_variants|url',
            'language_variants.*.notes' => 'nullable|string',
            'import_source' => 'nullable|string|max:32',
        ]);

        $link = Link::create([
            'link' => $request->input('link'),
            'notes' => $request->input('notes', ''),
            'user_id' => $userId,
            'default_locale' => $request->input('default_locale'),
            'language_variants' => $this->normalizeLanguageVariants($request->input('language_variants', [])),
            'import_source' => $request->input('import_source', 'manual'),
        ]);

        $this->syncTagsForLink($link, $userId, $this->normalizeTagNames($request->get('tags', [])));

        $link->load(['tags.user', 'user'])->loadCount('adLogs as ad_usage_count');
        return new LinkResource($link);
    }

    public function show(Link $link)
    {
        $currentUserId = auth()->id();
        if (!$this->isOwner($link, $currentUserId) && !$link->isSharedWith($currentUserId)) {
            return response()->json(['message' => 'Forbidden'], 403);
        }

        $link->load(['tags.user', 'user'])->loadCount('adLogs as ad_usage_count');
        return new LinkResource($link);
    }

    public function update(Request $request, Link $link)
    {
        $userId = (string) auth()->id();
        if (!$this->isOwner($link, $userId)) {
            return response()->json(['message' => 'Forbidden'], 403);
        }

        $validatedData = $request->validate([
            'link' => [
                'required',
                'url',
                Rule::unique('links')->ignore($link->id)->where(function ($query) use ($userId) {
                    return $query->where('user_id', $userId)->whereNull('deleted_at');
                }),
            ],
            'notes' => 'nullable|string',
            'tags' => 'array|distinct|nullable',
            'default_locale' => 'nullable|string|max:32',
            'language_variants' => 'nullable|array',
            'language_variants.*.locale' => 'required_with:language_variants|string|max:32',
            'language_variants.*.url' => 'required_with:language_variants|url',
            'language_variants.*.notes' => 'nullable|string',
        ]);

        $link->update([
            'link' => $validatedData['link'],
            'notes' => $validatedData['notes'] ?? null,
            'default_locale' => $request->input('default_locale'),
            'language_variants' => $this->normalizeLanguageVariants($request->input('language_variants', [])),
        ]);

        $this->syncTagsForLink($link, $userId, $this->normalizeTagNames($request->get('tags', [])));

        $link->load(['tags.user', 'user'])->loadCount('adLogs as ad_usage_count');
        return new LinkResource($link);
    }

    public function destroy(Link $link)
    {
        if (!$this->isOwner($link, auth()->id())) {
            return response()->json(['message' => 'Forbidden'], 403);
        }

        $link->tags()->delete();
        $link->delete();
        return response()->json(null, 204);
    }

    public function share(Request $request)
    {
        $request->validate([
            'user_emails' => 'required|array',
            'user_emails.*' => 'exists:users,email',
            'resource_ids' => 'required|array',
            'resource_ids.*' => 'exists:links,id',
        ], [
            'user_emails.required' => '请至少填写一个分享邮箱',
            'user_emails.array' => '分享邮箱格式不正确',
            'user_emails.*.exists' => '分享邮箱不存在于系统用户中',
            'resource_ids.required' => '请选择要分享的链接',
            'resource_ids.array' => '链接参数格式不正确',
            'resource_ids.*.exists' => '所选链接不存在',
        ]);

        $userIds = User::whereIn('email', $request->user_emails)->pluck('id');

        foreach ($request->resource_ids as $resourceId) {
            $resource = Link::findOrFail($resourceId);
            if (!$this->isOwner($resource, $request->user()->id)) {
                return response()->json(['error' => 'Unauthorized'], 403);
            }
            $resource->sharedWith()->syncWithoutDetaching($userIds);
        }

        return response()->json(['message' => 'Resource shared successfully.']);
    }

    public function unshare(Request $request)
    {
        $request->validate([
            'user_emails' => 'required|array',
            'user_emails.*' => 'exists:users,email',
            'resource_ids' => 'required|array',
            'resource_ids.*' => 'exists:links,id',
        ], [
            'user_emails.required' => '请至少填写一个邮箱',
            'user_emails.array' => '邮箱格式不正确',
            'user_emails.*.exists' => '该邮箱不存在于系统用户中',
            'resource_ids.required' => '请选择要取消分享的链接',
            'resource_ids.array' => '链接参数格式不正确',
            'resource_ids.*.exists' => '所选链接不存在',
        ]);

        $userIds = User::whereIn('email', $request->user_emails)->pluck('id');

        foreach ($request->resource_ids as $resourceId) {
            $resource = Link::findOrFail($resourceId);
            if (!$this->isOwner($resource, $request->user()->id)) {
                return response()->json(['error' => 'Unauthorized'], 403);
            }
            $resource->sharedWith()->detach($userIds);
        }

        return response()->json(['message' => 'Resource unshared successfully.']);
    }

    public function import(Request $request)
    {
        $request->validate([
            'raw_text' => 'nullable|string',
            'file' => 'nullable|file|mimes:csv,txt',
            'default_tags' => 'nullable|array',
            'default_tags.*' => 'string',
            'default_notes' => 'nullable|string',
            'default_locale' => 'nullable|string|max:32',
        ]);

        $userId = (string) auth()->id();
        $rows = $this->extractImportRows($request);
        $defaultTags = $this->normalizeTagNames($request->input('default_tags', []));
        $defaultNotes = trim((string) $request->input('default_notes', ''));
        $defaultLocale = $request->input('default_locale');

        $created = 0;
        $updated = 0;
        $skipped = 0;
        $ids = [];

        foreach ($rows as $row) {
            $linkValue = trim((string) ($row['link'] ?? ''));
            if ($linkValue === '' || !filter_var($linkValue, FILTER_VALIDATE_URL)) {
                $skipped++;
                continue;
            }

            $rowNotes = trim((string) ($row['notes'] ?? ''));
            $rowTags = $this->normalizeTagNames(array_merge(
                $defaultTags,
                preg_split('/[,\|，]/', (string) ($row['tags'] ?? '')) ?: []
            ));

            $link = Link::query()
                ->where('user_id', $userId)
                ->where('link', $linkValue)
                ->first();

            if ($link) {
                $link->update([
                    'notes' => $rowNotes !== '' ? $rowNotes : ($defaultNotes !== '' ? $defaultNotes : $link->notes),
                    'default_locale' => $defaultLocale ?: $link->default_locale,
                    'import_source' => 'import',
                ]);
                $updated++;
            } else {
                $link = Link::create([
                    'link' => $linkValue,
                    'notes' => $rowNotes !== '' ? $rowNotes : $defaultNotes,
                    'user_id' => $userId,
                    'default_locale' => $defaultLocale,
                    'language_variants' => [],
                    'import_source' => 'import',
                ]);
                $created++;
            }

            $this->syncTagsForLink($link, $userId, $rowTags);
            $ids[] = $link->id;
        }

        $links = Link::query()
            ->whereIn('id', $ids)
            ->with(['tags.user', 'user'])
            ->withCount('adLogs as ad_usage_count')
            ->get();

        return response()->json([
            'status' => true,
            'message' => 'Links imported successfully',
            'data' => LinkResource::collection($links),
            'summary' => [
                'created' => $created,
                'updated' => $updated,
                'skipped' => $skipped,
            ],
        ]);
    }
}
