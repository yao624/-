        margin-bottom: 16px;

        label {
          min-width: 80px;
          font-weight: 500;
        }
      }
    }

    .template-hint {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 16px;
    }

    .rule-templates {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;

      .template-card {
        padding: 24px;
        border: 1px solid #e8e8e8;
        border-radius: 4px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;

        &:hover {
          border-color: #1890ff;
          box-shadow: 0 2px 8px rgba(24, 144, 255, 0.2);
        }

        .template-icon {
          width: 64px;
          height: 64px;
          border-radius: 8px;
          display: flex;
          align-items: center;
