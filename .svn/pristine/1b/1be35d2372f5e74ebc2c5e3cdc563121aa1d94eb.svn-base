          }
        }

        .detail-label {
          color: #666;
          font-size: 12px;
          margin-bottom: 6px;
        }

        .action-help-row {
          margin-top: -6px;
        }

        .action-help-link {
          font-size: 12px;
          color: #999;
          text-decoration: none;

          &:hover {
            color: #666;
            text-decoration: underline;
          }
