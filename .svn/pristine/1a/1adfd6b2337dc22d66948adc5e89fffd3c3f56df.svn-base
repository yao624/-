<template>
  <div class="auto-optimization">
    <create-rule v-if="showCreateRule" :edit-data="['edit', 'copy'].includes(showCreateRule.mode) ? showCreateRule.data : null" :mode="showCreateRule.mode" @close="exitCreateRule" />

    <template v-else>
      <!-- 顶部统计卡片 -->
      <div class="summary-cards">
        <div class="summary-title">{{ t('pages.autoOptimization.summaryTitle') }}</div>
        <div class="cards-grid">
          <div class="summary-card">
            <div class="card-icon" style="background: #e6f7ff; color: #1890ff">
              <bell-outlined />
            </div>
            <div class="card-content">
              <div class="card-value">{{ summaryData.sendNotification }}</div>
              <div class="card-label">{{ t('pages.autoOptimization.sendNotification') }}</div>
              <div class="card-saved">{{ t('pages.autoOptimization.hoursSaved', { hours: summaryData.sendNotificationHours }) }}</div>
            </div>
          </div>
          <div class="summary-card">
            <div class="card-icon" style="background: #f6ffed; color: #52c41a">
              <poweroff-outlined />
            </div>
            <div class="card-content">
              <div class="card-value">{{ summaryData.toggleAds }}</div>
              <div class="card-label">{{ t('pages.autoOptimization.toggleAds') }}</div>
              <div class="card-saved">{{ t('pages.autoOptimization.hoursSaved', { hours: summaryData.toggleAdsHours }) }}</div>
            </div>
          </div>
          <div class="summary-card">
            <div class="card-icon" style="background: #fff7e6; color: #fa8c16">
              <edit-outlined />
            </div>
            <div class="card-content">
              <div class="card-value">{{ summaryData.modifyBid }}</div>
              <div class="card-label">{{ t('pages.autoOptimization.modifyBid') }}</div>
              <div class="card-saved">{{ t('pages.autoOptimization.hoursSaved', { hours: summaryData.modifyBidHours }) }}</div>
            </div>
          </div>
          <div class="summary-card">
            <div class="card-icon" style="background: #fff1f0; color: #ff4d4f">
              <dollar-outlined />
            </div>
            <div class="card-content">
              <div class="card-value">{{ summaryData.modifyBudget }}</div>
              <div class="card-label">{{ t('pages.autoOptimization.modifyBudget') }}</div>
              <div class="card-saved">{{ t('pages.autoOptimization.hoursSaved', { hours: summaryData.modifyBudgetHours }) }}</div>
            </div>
          </div>
          <div class="summary-card">
            <div class="card-icon" style="background: #f0f5ff; color: #2f54eb">
              <check-circle-outlined />
            </div>
            <div class="card-content">
              <div class="card-value">{{ summaryData.allActions }}</div>
              <div class="card-label">{{ t('pages.autoOptimization.allActions') }}</div>
              <div class="card-saved">{{ t('pages.autoOptimization.hoursSaved', { hours: summaryData.allActionsHours }) }}</div>
            </div>
          </div>
        </div>
        <div class="create-rule-btn">
          <a-button type="primary" size="large" @click="goToCreateRule">
            {{ t('pages.autoOptimization.createRule') }}
          </a-button>
        </div>
      </div>

      <!-- 筛选和操作栏 -->
      <div class="filter-bar">
        <a-input
          v-model:value="filters.keyword"
          :placeholder="t('pages.autoOptimization.searchPlaceholder')"
          style="width: 200px"
          allow-clear
        />
        <a-select
          v-model:value="filters.channel"
          :placeholder="t('pages.autoOptimization.channelPlaceholder')"
          style="width: 150px"
          allow-clear
        >
          <a-select-option value="meta">Meta</a-select-option>
        </a-select>
        <a-select
          v-model:value="filters.monitoring_object"
          :placeholder="t('pages.autoOptimization.monitoringObjectPlaceholder')"
          style="width: 150px"
          allow-clear
        >
          <a-select-option value="ad-account">{{ t('pages.autoOptimization.adAccount') }}</a-select-option>
          <a-select-option value="campaign">{{ t('pages.autoOptimization.campaign') }}</a-select-option>
          <a-select-option value="ad-group">{{ t('pages.autoOptimization.adGroup') }}</a-select-option>
          <a-select-option value="ad">{{ t('pages.autoOptimization.ad') }}</a-select-option>
        </a-select>
        <a-select
          v-model:value="filters.user_id"
          :placeholder="t('pages.autoOptimization.creatorPlaceholder')"
          style="width: 150px"
          allow-clear
        >
          <a-select-option v-for="creator in creators" :key="creator.id" :value="creator.id">
            {{ creator.name }}
          </a-select-option>
        </a-select>
        <a-button type="primary" @click="handleFilter">{{ t('pages.autoOptimization.filter') }}</a-button>
        <a-button @click="handleReset">{{ t('pages.autoOptimization.reset') }}</a-button>
        <a-dropdown :disabled="selectedRowKeys.length === 0">
          <template #overlay>
            <a-menu>
              <a-menu-item
                @click="
                  () => {
                    confirmAction = 'active';
                    confirmVisible = true;
                  }
                "
              >
                {{ t('pages.autoOptimization.enable') }}
              </a-menu-item>
              <a-menu-item
                @click="
                  () => {
                    confirmAction = 'inactive';
                    confirmVisible = true;
                  }
                "
              >
                {{ t('pages.autoOptimization.pause') }}
              </a-menu-item>
              <a-menu-item
                danger
                @click="
                  () => {
                    confirmAction = 'delete';
                    confirmVisible = true;
                  }
                "
              >
                {{ t('pages.autoOptimization.delete') }}
              </a-menu-item>
            </a-menu>
          </template>
          <a-button>
            {{ t('pages.autoOptimization.batchOperation') }}
            <down-outlined />
          </a-button>
        </a-dropdown>
        <a-modal
          v-model:open="confirmVisible"
          :title="confirmTitle"
          :mask-closable="false"
          @ok="handleConfirmBatch"
        >
          <p>{{ t('pages.autoOptimization.confirmBatchRules', { count: selectedRowKeys.length }) }}</p>
        </a-modal>
        <a-modal
          v-model:open="auditVisible"
          :title="t('pages.autoOptimization.auditRule')"
          :mask-closable="false"
          @ok="handleConfirmAudit"
        >
          <p>{{ t('pages.autoOptimization.confirmAudit') }}</p>
          <a-radio-group v-model:value="auditAction" style="margin-top: 16px">
            <a-radio value="approve">{{ t('pages.autoOptimization.approve') }}</a-radio>
            <a-radio value="reject">{{ t('pages.autoOptimization.reject') }}</a-radio>
          </a-radio-group>
          <a-input
            v-if="auditAction === 'reject'"
            v-model:value="auditReason"
            :placeholder="t('pages.autoOptimization.rejectReasonPlaceholder')"
            style="margin-top: 16px"
          />
        </a-modal>
      </div>

      <!-- 信息提示 -->
      <a-alert
        type="info"
        :message="t('pages.autoOptimization.ruleLimitAlert', { count: rulesData.length, limit: ruleLimit })"
        show-icon
        style="margin-bottom: 16px"
      />

      <!-- 数据表格 -->
      <a-table
        :loading="loading"
        :columns="columns"
        :data-source="rulesData"
        :pagination="{
          current: pagination.current,
          pageSize: pagination.pageSize,
          total: pagination.total,
          showSizeChanger: true,
          pageSizeOptions: ['10', '20', '50', '100'],
          showTotal: (total: number) => t('pages.autoOptimization.total', { total }),
        }"
        :row-key="record => record.id"
        :row-selection="rowSelection"
        @change="handleTableChange"
      >
        <template #emptyText>
          <a-empty :description="t('pages.autoOptimization.noData')" />
        </template>
        <template #bodyCell="{ column, record }">
          <template v-if="column.dataIndex === 'status'">
            <a-badge :status="record.status === 1 ? 'success' : 'default'" />
            {{ record.status === 1 ? t('pages.autoOptimization.statusEnable') : t('pages.autoOptimization.statusPause') }}
          </template>
          <template v-else-if="column.dataIndex === 'operation'">
            <a-space>
              <a-button type="link" size="small" @click="handleEdit(record)">
                {{ t('pages.autoOptimization.edit') }}
              </a-button>
              <a-button type="link" size="small" @click="handleCopy(record)">
                {{ t('pages.autoOptimization.copy') }}
              </a-button>

              <a-popconfirm :title="t('pages.autoOptimization.confirmDelete')" @confirm="handleDelete(record)">
                <a-button type="link" size="small" danger>{{ t('pages.autoOptimization.delete') }}</a-button>
              </a-popconfirm>
              <a-button
                v-if="record.audit_status === 0 && isSuperAdmin"
                type="link"
                size="small"
                @click="handleAudit(record)"
              >
                {{ t('pages.autoOptimization.audit') }}
              </a-button>
            </a-space>
          </template>
        </template>
      </a-table>
    </template>
  </div>
</template>

<script lang="ts" setup>
import { ref, computed, onMounted, watch, h } from 'vue';
import { useUserStore } from '@/store/user';
import { useRoute } from 'vue-router';
import dayjs from 'dayjs';
import { useI18n } from 'vue-i18n';
import {
  BellOutlined,
  PoweroffOutlined,
  EditOutlined,
  DollarOutlined,
  CheckCircleOutlined,
  DownOutlined,
} from '@ant-design/icons-vue';
import { message, Badge as ABadge, Tooltip as ATooltip } from 'ant-design-vue';
import {
  getRulesList,
  getSummaryData,
  getCreators,
  batchActiveRule,
  batchInactiveRule,
  batchDeleteRule,
  auditRule,
} from '@/api/promotion/index';
import CreateRule from './create-rule.vue';

const { t } = useI18n();
const userStore = useUserStore();
const route = useRoute();
const isSuperAdmin = computed(() => userStore.is_super === 1);

/** 父子组件切换：不通过路由 query，仅本地状态 */
const showCreateRule = ref(false);

/** 路由切换时重置为列表页 */
watch(
  () => route.path,
  () => {
    showCreateRule.value = false;
  },
);

const summaryData = ref({
  sendNotification: 0,
  sendNotificationHours: 0,
  toggleAds: 0,
  toggleAdsHours: 0,
  modifyBid: 0,
  modifyBidHours: 0,
  modifyBudget: 0,
  modifyBudgetHours: 0,
  allActions: 0,
  allActionsHours: 0,
});

const filters = ref({
  keyword: '',
  channel: undefined,
  monitoring_object: undefined,
  user_id: undefined,
});

const creators = ref<any[]>([]);
const creatorsMap = computed(() => {
  const map: Record<string, string> = {};
  creators.value.forEach(c => {
    map[c.id] = c.name;
  });
  return map;
});
const ruleLimit = ref(15);

const loading = ref(false);
const rulesData = ref<any[]>([]);
const selectedRowKeys = ref<string[]>([]);
const confirmVisible = ref(false);
const confirmAction = ref<'active' | 'inactive' | 'delete'>('active');
const confirmTitle = computed(() => {
  const map = {
    active: t('pages.autoOptimization.enable'),
    inactive: t('pages.autoOptimization.pause'),
    delete: t('pages.autoOptimization.delete'),
  };
  return t('pages.autoOptimization.confirmBatch', { action: map[confirmAction.value] });
});

// 审核相关
const auditRecord = ref<any>(null);
const auditVisible = ref(false);
const auditAction = ref<'approve' | 'reject'>('approve');
const auditReason = ref('');
const pagination = ref({
  current: 1,
  pageSize: 20,
  total: 0,
});

const columns = ref([
  {
    title: t('pages.autoOptimization.status'),
    dataIndex: 'status',
    key: 'status',
    width: 100,
    customRender: ({ text }: { text: number }) =>
      text === 1 ? t('pages.autoOptimization.statusEnable') : t('pages.autoOptimization.statusPause'),
  },
  { title: t('pages.autoOptimization.channel'), dataIndex: 'channel', key: 'channel', width: 100 },
  {
    title: t('pages.autoOptimization.monitoringObject'),
    dataIndex: 'monitoring_object',
    key: 'monitoring_object',
    width: 120,
    customRender: ({ text }: { text: string }) => {
      const map: Record<string, string> = {
        'ad-account': t('pages.autoOptimization.adAccount'),
        campaign: t('pages.autoOptimization.campaign'),
        'ad-group': t('pages.autoOptimization.adGroup'),
        ad: t('pages.autoOptimization.ad'),
        'ad-material': t('pages.autoOptimization.adMaterial'),
        material: t('pages.autoOptimization.material'),
      };
      return map[text] || text;
    },
  },
  { title: t('pages.autoOptimization.ruleName'), dataIndex: 'name', key: 'name', width: 200 },
  { title: t('pages.autoOptimization.ruleDescription'), dataIndex: 'description', key: 'description', width: 250 },
  {
    title: t('pages.autoOptimization.creator'),
    dataIndex: 'user_id',
    key: 'user_id',
    width: 100,
    customRender: ({ text }: { text: string | number }) => creatorsMap.value[String(text)] || text,
  },
  {
    title: t('pages.autoOptimization.lastExecuteTime'),
    dataIndex: 'updated_at',
    key: 'updated_at',
    width: 180,
    customRender: ({ text }: { text: string }) => {
      if (!text) return '-';
      return dayjs(text).format('YYYY-MM-DD HH:mm:ss');
    },
  },
  {
    title: t('pages.autoOptimization.editTime'),
    dataIndex: 'updated_at',
    key: 'updated_at',
    width: 180,
    customRender: ({ text }: { text: string }) => {
      if (!text) return '-';
      return dayjs(text).format('YYYY-MM-DD HH:mm:ss');
    },
  },
  {
    title: t('pages.autoOptimization.auditStatus'),
    dataIndex: 'audit_status',
    key: 'audit_status',
    width: 100,
    customRender: ({ text, record }: { text: number; record: any }) => {
      const statusMap: Record<number, { text: string; status: 'default' | 'success' | 'error' }> = {
        0: { text: t('pages.autoOptimization.pendingAudit'), status: 'default' },
        1: { text: t('pages.autoOptimization.auditPassed'), status: 'success' },
        2: { text: t('pages.autoOptimization.rejected'), status: 'error' },
      };
      const { text: labelText, status } = statusMap[text] || { text, status: 'default' };
      if (text === 2 && record.audit_reason) {
        return h('span', [
          h(
            ATooltip,
            { title: record.audit_reason },
            { default: () => h(ABadge, { status, text: labelText }) },
          ),
        ]);
      }
      return h(ABadge, { status, text: labelText });
    },
  },
  {
    title: t('pages.autoOptimization.operation'),
    dataIndex: 'operation',
    key: 'operation',
    width: 180,
    fixed: 'right',
  },
]);

const rowSelection = computed(() => ({
  selectedRowKeys: selectedRowKeys.value,
  onChange: (keys: string[]) => {
    selectedRowKeys.value = keys;
  },
}));

const loadData = async () => {
  loading.value = true;
  try {
    const result = await getRulesList({
      page: pagination.value.current,
      pageSize: pagination.value.pageSize,
      ...filters.value,
    });
    rulesData.value = result.data ?? [];
    pagination.value.total = result.total ?? 0;
  } catch (error) {
    console.error(t('pages.autoOptimization.loadDataFailed'), error);
  } finally {
    loading.value = false;
  }
};

const loadSummary = async () => {
  try {
    const data = await getSummaryData();
    summaryData.value = data;
  } catch (error) {
    console.error(t('pages.autoOptimization.loadSummaryFailed'), error);
  }
};

const loadCreators = async () => {
  try {
    creators.value = await getCreators();
  } catch (error) {
    console.error(t('pages.autoOptimization.loadCreatorsFailed'), error);
  }
};

const handleTableChange = (pag: any) => {
  pagination.value.current = pag.current;
  pagination.value.pageSize = pag.pageSize;
  loadData();
};

const handleFilter = () => {
  pagination.value.current = 1;
  loadData();
};

const handleReset = () => {
  filters.value = {
    keyword: '',
    channel: undefined,
    monitoring_object: undefined,
    user_id: undefined,
  };
  pagination.value.current = 1;
  loadData();
};

const handleEdit = (record: any) => {
  showCreateRule.value = { mode: 'edit', data: record };
};

const handleCopy = (record: any) => {
  if (rulesData.value.length >= ruleLimit.value) {
    message.warning(t('pages.autoOptimization.ruleLimitReached'));
    return;
  }
  showCreateRule.value = { mode: 'copy', data: record };
};

const handleDelete = async (record: any) => {
  try {
    await batchDeleteRule([record.id]);
    message.success(t('pages.autoOptimization.deleteSuccess'));
    loadData();
  } catch (error) {
    console.error(t('pages.autoOptimization.deleteFailed'), error);
    message.error(t('pages.autoOptimization.deleteFailed'));
  }
};

const handleAudit = (record: any) => {
  auditRecord.value = record;
  auditAction.value = 'approve';
  auditReason.value = '';
  auditVisible.value = true;
};

const handleConfirmAudit = async () => {
  if (!auditRecord.value) return;
  if (auditAction.value === 'reject' && !auditReason.value) {
    message.warning(t('pages.autoOptimization.rejectReasonPlaceholder'));
    return;
  }
  const auditStatus = auditAction.value === 'approve' ? 1 : 2;
  try {
    await auditRule(auditRecord.value.id, auditStatus, auditReason.value || undefined);
    message.success(
      auditAction.value === 'approve'
        ? t('pages.autoOptimization.auditPassedMsg')
        : t('pages.autoOptimization.auditRejectedMsg'),
    );
    auditVisible.value = false;
    auditReason.value = '';
    loadData();
  } catch (error) {
    console.error(t('pages.autoOptimization.auditFailed'), error);
    message.error(t('pages.autoOptimization.auditFailed'));
  }
};

const handleConfirmBatch = async () => {
  confirmVisible.value = false;
  try {
    if (confirmAction.value === 'active') {
      await batchActiveRule(selectedRowKeys.value as unknown as number[]);
      message.success(t('pages.autoOptimization.enableSuccess'));
    } else if (confirmAction.value === 'inactive') {
      await batchInactiveRule(selectedRowKeys.value as unknown as number[]);
      message.success(t('pages.autoOptimization.disableSuccess'));
    } else if (confirmAction.value === 'delete') {
      await batchDeleteRule(selectedRowKeys.value as unknown as number[]);
      message.success(t('pages.autoOptimization.deleteSuccess'));
    }
    selectedRowKeys.value = [];
    loadData();
  } catch (error) {
    console.error(t('pages.autoOptimization.operationFailed'), error);
    message.error(t('pages.autoOptimization.operationFailed'));
  }
};

const goToCreateRule = () => {
  if (rulesData.value.length >= ruleLimit.value) {
    message.warning(t('pages.autoOptimization.ruleLimitReached'));
    return;
  }
  showCreateRule.value = true;
};

const exitCreateRule = () => {
  showCreateRule.value = false;
  loadData();
};

onMounted(() => {
  showCreateRule.value = false;
  loadData();
  loadSummary();
  loadCreators();
});
</script>

<style lang="less" scoped>
.auto-optimization {
  overflow: auto;
  min-height: 100%;

  .summary-cards {
    background: #fff;
    padding: 24px;
    border-radius: 4px;
    margin-bottom: 16px;

    .summary-title {
      font-size: 16px;
      font-weight: 500;
      margin-bottom: 16px;
      color: #333;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
      margin-bottom: 16px;

      .summary-card {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px;
        background: #fafafa;
        border-radius: 4px;
        border: 1px solid #e8e8e8;

        .card-icon {
          width: 48px;
          height: 48px;
          border-radius: 4px;
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 24px;
          flex-shrink: 0;
        }

        .card-content {
          flex: 1;

          .card-value {
            font-size: 24px;
            font-weight: 600;
            color: #333;
            line-height: 1.2;
          }

          .card-label {
            font-size: 14px;
            color: #666;
            margin-top: 4px;
          }

          .card-saved {
            font-size: 12px;
            color: #999;
            margin-top: 4px;
          }
        }
      }
    }

    .create-rule-btn {
      text-align: left;
    }
  }

  .filter-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
    align-items: center;
    flex-wrap: wrap;
  }
}
</style>
