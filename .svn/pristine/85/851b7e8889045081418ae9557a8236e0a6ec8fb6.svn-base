<!--
 * @Author: Claude
 * @Date: 2024-04-07
 * @Description: 保存模版（包含动态变量信息）
 * 支持编辑模式（从模版管理编辑过来，直接保存）和复制模式（需要填写新名称）
-->
<template>
  <div class="save-template-box">
    <Button type="primary" @click="showSaveModal">
      <Icon type="ios-cloud-upload" />
      {{ isEditMode ? t('saveTemplate.updateTemplate') : t('saveTemplate.saveTemplate') }}
    </Button>

    <Modal
      v-model="saveModalVisible"
      :title="isEditMode ? t('saveTemplate.updateTemplate') : t('saveTemplate.saveTemplate')"
      @on-ok="handleSave"
      :loading="saving"
      :ok-text="t('ok')"
      :cancel-text="t('cancel')"
    >
      <Form :label-width="80" :model="templateForm">
        <FormItem v-if="!isEditMode" :label="t('saveTemplate.templateName')">
          <Input v-model="templateForm.name" :placeholder="t('saveTemplate.templateNamePlaceholder')" />
        </FormItem>
        <FormItem v-else :label="t('saveTemplate.templateName')">
          <span>{{ templateForm.name }}</span>
        </FormItem>
        <FormItem :label="t('saveTemplate.templateDesc')">
          <Input
            v-model="templateForm.description"
            type="textarea"
            :rows="3"
            :placeholder="t('saveTemplate.templateDescPlaceholder')"
          />
        </FormItem>
        <FormItem :label="t('saveTemplate.canvasSize')">
          <span>{{ canvasWidth }} × {{ canvasHeight }}</span>
        </FormItem>
        <FormItem :label="t('saveTemplate.dynamicVariables')">
          <div v-if="dynamicVariables.length > 0" class="variables-preview">
            <Tag
              v-for="variable in dynamicVariables"
              :key="variable.variableName"
              :color="variable.variableType === 'text' ? 'blue' : 'green'"
            >
              {{ variable.variableName }} ({{ variable.variableType === 'text' ? t('saveTemplate.text') : t('saveTemplate.image') }})
            </Tag>
          </div>
          <div v-else>
            <span class="no-variables">{{ t('saveTemplate.noVariables') }}</span>
            <Button size="small" @click="refreshDynamicVariables" style="margin-left: 10px">
              {{ t('saveTemplate.refresh') }}
            </Button>
          </div>
        </FormItem>
      </Form>
    </Modal>
  </div>
</template>

<script name="SaveTemplate" setup lang="ts">
import { ref, inject, watch, computed } from 'vue';
import { Modal, Message } from 'view-ui-plus';
import type { IEditor, DynamicVariable } from '@kuaitu/core';
import * as creativeApi from '@/api/creative';
import { useI18n } from 'vue-i18n';
import { log } from 'console';

const { t } = useI18n();
const canvasEditor = inject<IEditor>('canvasEditor');

// Props - 接收当前编辑的模版信息
const props = defineProps<{
  /** 当前编辑的模版ID（如果有表示编辑模式） */
  editingTemplateId?: string;
  /** 原始模版数据（用于编辑模式） */
  originalTemplate?: {
    id: string;
    name: string;
    description: string;
  };
  /** 强制指定模式：'edit' 编辑模式 | 'copy' 复制模式 */
  saveMode?: 'edit' | 'copy';
}>();

// 状态
const saveModalVisible = ref(false);
const saving = ref(false);

// 表单数据
const templateForm = ref({
  name: '',
  description: '',
});

// 判断是否为编辑模式
// 有 editingTemplateId 或 saveMode 为 'edit' 时为编辑模式
const isEditMode = computed(() => {
  if (props.saveMode === 'copy') {
    return false;
  }
  return !!(props.editingTemplateId || props.saveMode === 'edit');
});

// 画布尺寸（响应式变量，在弹窗打开时更新）
const canvasWidth = ref(900);
const canvasHeight = ref(1200);

// 获取动态变量列表
const dynamicVariables = ref<DynamicVariable[]>([]);

// 刷新画布尺寸
const refreshCanvasSize = () => {
  if (!canvasEditor?.fabricCanvas) {
    console.warn('canvasEditor 或 fabricCanvas 不存在');
    return;
  }

  const workspace = canvasEditor.fabricCanvas.getObjects().find((obj: any) => obj.id === 'workspace');
  if (workspace && typeof workspace.width === 'number' && typeof workspace.height === 'number') {
    canvasWidth.value = workspace.width;
    canvasHeight.value = workspace.height;
    console.log('刷新画布尺寸:', workspace.width, '×', workspace.height);
  } else {
    console.warn('未找到 workspace 对象或尺寸无效');
  }
};

// 刷新动态变量列表
const refreshDynamicVariables = () => {
  if (!canvasEditor) return;
  const variables = canvasEditor.getDynamicVariables();
  console.log('保存模版 - 动态变量列表:', variables);
  dynamicVariables.value = variables;
};

// 监听模态框显示，刷新变量列表和画布尺寸
watch(saveModalVisible, (visible) => {
  if (visible) {
    // 使用 nextTick 确保 DOM 更新后再获取数据
    setTimeout(() => {
      refreshCanvasSize();
      refreshDynamicVariables();
    }, 50);
  }
});

// 显示保存对话框
const showSaveModal = () => {
  if (!canvasEditor) return;

  console.log('打开保存模版对话框, 当前模式:', isEditMode.value ? '编辑模式' : '复制模式');

  // 编辑模式：直接保存，不弹窗
  if (isEditMode.value) {
    // 先刷新尺寸和变量，然后再保存
    refreshCanvasSize();
    refreshDynamicVariables();
    handleSave();
    return;
  }

  // 复制模式：显示对话框，用户需要填写名称
  const dateStr = new Date().toISOString().slice(0, 10);
  templateForm.value.name = `${t('saveTemplate.templateCopy')}_${dateStr}`;
  templateForm.value.description = '';

  saveModalVisible.value = true;
};

// 处理保存
const handleSave = async () => {
  if (!canvasEditor) return Promise.reject();

  // 复制模式下必须填写名称
  if (!isEditMode.value && !templateForm.value.name) {
    Message.warning(t('saveTemplate.pleaseEnterTemplateName'));
    return Promise.reject();
  }

  try {
    saving.value = true;

    // 获取画布 JSON 数据 - 使用 getJson() 以包含 dynamicConfig 等自定义属性
    const canvasJson = canvasEditor.getJson();

    console.log('保存的 JSON 数据:', canvasJson);

    if (isEditMode.value && props.editingTemplateId) {
      // 编辑模式：更新现有模版
      refreshDynamicVariables();

      const updateData = {
        id: props.editingTemplateId,
        template_name: props.originalTemplate?.name || '',
        canvas_width: canvasWidth.value,
        canvas_height: canvasHeight.value,
        canvas_json: canvasJson,
        dynamic_variables: dynamicVariables.value,
        description: props.originalTemplate?.description || '',
      };

      const response = await creativeApi.updateImageTemplate(updateData);

      if (response.status) {
        console.log('模版已更新，包含动态变量:', dynamicVariables.value);
        Message.success(t('saveTemplate.updateSuccess'));
      } else {
        Message.error(response.message || t('saveTemplate.updateFailed'));
        return Promise.reject();
      }
    } else {
      // 复制/新建模式：创建新模版
      const createData = {
        template_name: templateForm.value.name,
        canvas_width: canvasWidth.value,
        canvas_height: canvasHeight.value,
        canvas_json: canvasJson,
        dynamic_variables: dynamicVariables.value,
        description: templateForm.value.description,
      };

      const response = await creativeApi.createImageTemplate(createData);

      if (response.status) {
        console.log('模版已保存，包含动态变量:', dynamicVariables.value);
        Message.success(t('saveTemplate.saveSuccess'));
      } else {
        Message.error(response.message || t('saveTemplate.saveFailed'));
        return Promise.reject();
      }
    }

    saveModalVisible.value = false;

    return Promise.resolve();
  } catch (error: any) {
    console.error('保存模版失败:', error);
    const errorMsg = error?.response?.data?.message || error?.message || t('saveTemplate.saveTemplateFailed');
    Message.error(errorMsg);
    return Promise.reject();
  } finally {
    saving.value = false;
  }
};
</script>

<style scoped lang="less">
.save-template-box {
  display: inline-block;
  margin-left: 10px;
}

.variables-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.no-variables {
  color: #999;
  font-size: 14px;
}
</style>
