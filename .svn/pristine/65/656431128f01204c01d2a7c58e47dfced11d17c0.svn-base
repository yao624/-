              >
                <div class="tile-item-header">{{ item.date }}</div>
                <div class="tile-item-content">
                  <div v-for="(m, midx) in item.metrics" :key="midx" class="tile-metric-row">
                    <span class="tile-metric-label">{{ m.label }}</span>
                    <span class="tile-metric-value">{{ m.value }}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </template>
        <template v-else-if="card.chartType === 'card-stat'">
          <div class="card-stat-container">
            <div class="card-stat-header">
              <span class="card-stat-title">{{ t('今日花费') }}</span>
            </div>
            <div class="card-stat-body">
              <span class="card-stat-value">56,954,491.433</span>
              <span class="card-stat-unit">USD</span>
            </div>
          </div>
        </template>
        <template v-else-if="card.chartType === 'scatter'">
          <div class="card-filter-row pie-card-filters" :class="{ compact: card.shape === 'large' }">
            <div class="filter-box date-box">
              <div class="label">
                <span>{{ t('日') }}</span>
                <span>{{ t('期') }}</span>
              </div>
              <a-range-picker
                v-model:value="card.dateRange"
