// 初始化渠道分布图
const initChannelChart = async () => {
  if (!channelChart.value) return;
  
  channelChartInstance = echarts.init(channelChart.value);
  const channelData = await getChannelDistributionData();
  
  const option: echarts.EChartOption = {
    tooltip: {
      trigger: 'item',
      formatter: '{a} <br/>{b}: {c} ({d}%)',
    },
    legend: {
      orient: 'vertical',
      left: 'left',
      data: channelData.map(item => item.name),
    },
    series: [
      {
        name: t('花费'),
        type: 'pie',
        radius: ['40%', '70%'],
        avoidLabelOverlap: false,
        itemStyle: {
          borderRadius: 10,
          borderColor: '#fff',
          borderWidth: 2,
        },
        label: {
          show: false,
          position: 'center',
        },
        emphasis: {
          label: {
            show: true,
            fontSize: 20,
            fontWeight: 'bold' as any,
          },
        },
        labelLine: {
          show: false,
        },
        data: channelData.map(item => ({
          value: item.value,
          name: item.name,
          itemStyle: { color: item.color },
        })),
      },
    ],
  };
  
  channelChartInstance.setOption(option);
};

// 初始化地区分布图
const initRegionChart = async () => {
  if (!regionChart.value) return;
  
  regionChartInstance = echarts.init(regionChart.value);
  const regionData = await getRegionDistributionData();
  
  const option: echarts.EChartOption = {
    tooltip: {
      trigger: 'axis',
      axisPointer: {
        type: 'shadow',
      },
    },
    grid: {
      left: '3%',
      right: '4%',
      bottom: '3%',
      containLabel: true,
    },
    xAxis: {
      type: 'category',
      data: regionData.map(item => item.name),
      axisLabel: {
        rotate: 45,
      },
    },
    yAxis: {
      type: 'value',
      name: t('花费'),
      axisLabel: {
        formatter: (value: number) => {
          return (value / 10000).toFixed(0) + t('万');
        },
      },
    },
    series: [
      {
        name: t('花费'),
        type: 'bar',
        data: regionData.map(item => item.spend),
        itemStyle: {
          color: '#1890ff',
        },
      },
    ],
  };
  
  regionChartInstance.setOption(option);
};

// 初始化优化师分布图
const initOptimizerChart = async () => {
  if (!optimizerChart.value) return;
  
  optimizerChartInstance = echarts.init(optimizerChart.value);
  const optimizerData = await getOptimizerDistributionData();
  
  const option: echarts.EChartOption = {
    tooltip: {
      trigger: 'axis',
      axisPointer: {
        type: 'shadow',
      },
    },
    grid: {
      left: '3%',
      right: '4%',
      bottom: '3%',
      containLabel: true,
    },
    xAxis: {
      type: 'value',
      name: t('花费'),
      axisLabel: {
        formatter: (value: number) => {
          return (value / 10000).toFixed(0) + t('万');
        },
      },
    },
    yAxis: {
      type: 'category',
      data: optimizerData.map(item => item.name),
    },
    series: [
      {
        name: t('花费'),
        type: 'bar',
        data: optimizerData.map(item => item.spend),
        itemStyle: {
          color: '#1890ff',
        },
      },
    ],
  };
  
  optimizerChartInstance.setOption(option);
};

// 初始化所有图表
const initCharts = async () => {
  await nextTick();
  await Promise.all([
    initSpendTrendChart(),
    initChannelChart(),
    initRegionChart(),
    initOptimizerChart(),
  ]);
  
  // 监听窗口大小变化，自动调整图表大小
  window.addEventListener('resize', handleResize);
};

const handleResize = () => {
  spendTrendChartInstance?.resize();
  channelChartInstance?.resize();
  regionChartInstance?.resize();
  optimizerChartInstance?.resize();
  previewChartInstance?.resize();
};

// 销毁图表
const disposeCharts = () => {
  spendTrendChartInstance?.dispose();
  channelChartInstance?.dispose();
  regionChartInstance?.dispose();
  optimizerChartInstance?.dispose();
  previewChartInstance?.dispose();
  window.removeEventListener('resize', handleResize);
};

onMounted(() => {
  loadFoldersAndDashboards();
  // Initial load based on default selectedReport
  if (selectedReport.value === 'summary') {
    loadSummaryData();
  } else if (selectedReport.value === 'quality-materials') {
    loadMaterialsData();
  } else if (selectedReport.value === 'overall-performance') {
    loadData();
  } else if (selectedReport.value === 'top-accounts') {
    loadTopAccountsData();
  } else if (selectedReport.value === 'top-materials') {
    loadTopMaterialsData();
  }
  // Charts are only initialized for 'overall-performance'
  if (selectedReport.value === 'overall-performance') {
    setTimeout(() => {
      initCharts();
    }, 100);
  }
});

onUnmounted(() => {
  disposeCharts();
});
</script>

