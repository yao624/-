          <!-- 素材网格 -->
          <div class="materials-grid-view">
            <div
              v-for="material in leftMaterialsData"
              :key="material.id"
              class="material-card-grid"
              :class="{ active: selectedMaterialId === material.id }"
              @click="selectMaterial(material.id)"
            >
              <div class="material-thumbnail-grid">
                <img v-if="material.thumbnail" :src="material.thumbnail" :alt="material.name" />
                <div v-else class="material-placeholder">
                  <play-circle-outlined v-if="material.type === 'video'" />
                  <exclamation-circle-outlined v-else />
                </div>
              </div>
              <div class="material-name-grid">{{ material.name }}</div>
              <div class="material-cost-grid">{{ formatCurrency(material.spend) }}</div>
            </div>
          </div>

          <!-- 素材表格 -->
          <div class="materials-table-view">
            <div class="table-actions-bar">
              <a-dropdown>
                <template #overlay>
                  <a-menu>
                    <a-menu-item>{{ t('批量操作') }}</a-menu-item>
                  </a-menu>
                </template>
                <a-button size="small">{{ t('批量操作') }}</a-button>
              </a-dropdown>
              <a-button size="small">{{ t('指标设置') }}</a-button>
              <a-dropdown>
                <template #overlay>
                  <a-menu>
                    <a-menu-item>{{ t('导出') }}</a-menu-item>
                    <a-menu-item>{{ t('刷新') }}</a-menu-item>
                  </a-menu>
                </template>
                <a-button size="small">{{ t('更多') }}</a-button>
              </a-dropdown>
            </div>
            <s-table
              :loading="materialsLoading"
