              </div>
              <div class="material-name-grid">{{ material.name }}</div>
              <div class="material-cost-grid">{{ formatCurrency(material.spend) }}</div>
            </div>
          </div>

          <!-- 数据表格 -->
          <div class="materials-table-view">
            <div class="table-actions-bar">
              <a-dropdown>
                <template #overlay>
                  <a-menu>
                    <a-menu-item>{{ t('批量操作') }}</a-menu-item>
                  </a-menu>
                </template>
                <a-button size="small">{{ t('批量操作') }}</a-button>
              </a-dropdown>
              <a-button size="small">
                {{ t('指标设置') }}
                <setting-outlined />
              </a-button>
              <a-dropdown>
                <template #overlay>
                  <a-menu>
                    <a-menu-item>{{ t('导出') }}</a-menu-item>
                    <a-menu-item>{{ t('刷新') }}</a-menu-item>
                  </a-menu>
                </template>
                <a-button size="small">{{ t('更多') }}</a-button>
              </a-dropdown>
            </div>
            <s-table
              :loading="topMaterialsLoading"
              :columns="topMaterialsColumns"
              :data-source="topMaterialsTableData"
              :pagination="topMaterialsPagination"
              :row-key="record => record.id"
              size="small"
              @change="handleTopMaterialsTableChange"
            >
              <template #bodyCell="{ column, record }">
                <template v-if="column.dataIndex === 'materialName'">
                  <span>{{ record.materialName }}</span>
                </template>
                <template v-else-if="column.dataIndex === 'spend'">
                  <span :class="getTopMaterialsValueClass(record.spend, 'spend')">
                    {{ formatCurrency(record.spend) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'impressions'">
                  <span :class="getTopMaterialsValueClass(record.impressions, 'impressions')">
                    {{ formatNumber(record.impressions) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'cpm'">
                  <span :class="getTopMaterialsValueClass(record.cpm, 'cpm', true)">
                    {{ formatCurrency(record.cpm) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'clicks'">
                  <span :class="getTopMaterialsValueClass(record.clicks, 'clicks')">
                    {{ formatNumber(record.clicks) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'ctr'">
                  <span :class="getTopMaterialsValueClass(record.ctr, 'ctr')">
                    {{ formatPercent(record.ctr) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'conversions'">
                  <span :class="getTopMaterialsValueClass(record.conversions, 'conversions')">
                    {{ formatNumber(record.conversions) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'conversionRate'">
                  <span :class="getTopMaterialsValueClass(record.conversionRate, 'conversionRate')">
                    {{ formatPercent(record.conversionRate) }}
                  </span>
                </template>
              </template>
            </s-table>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script lang="ts" setup>
import { ref, onMounted, nextTick, onUnmounted, computed, h, watch } from 'vue';
