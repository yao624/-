} from './mock-data';

const { t } = useI18n();
const userStore = useUserStore();

const dashboardMetricPermissionMap: Record<string, string> = {
  cost: 'promotion-dashboard:metric:cost',
  impressions: 'promotion-dashboard:metric:impressions',
  cpm: 'promotion-dashboard:metric:cpm',
  clicks: 'promotion-dashboard:metric:clicks',
  cpc: 'promotion-dashboard:metric:cpc',
  ctr: 'promotion-dashboard:metric:ctr',
  conversions: 'promotion-dashboard:metric:conversions',
  cpa: 'promotion-dashboard:metric:cpa',
  conversionRate: 'promotion-dashboard:metric:conversionRate',
  register: 'promotion-dashboard:metric:register',
  payOrder: 'promotion-dashboard:metric:payOrder',
};

const collectUserPermissionSlugs = (permissions: unknown): string[] => {
  if (!Array.isArray(permissions)) {
    return [];
  }

  const slugSet = new Set<string>();

  permissions.forEach((item) => {
    if (typeof item === 'string') {
      slugSet.add(item);
      return;
    }

    if (item && typeof item === 'object') {
      const permissionItem = item as { slug?: unknown; actions?: unknown };
      if (typeof permissionItem.slug === 'string' && permissionItem.slug) {
        slugSet.add(permissionItem.slug);
      }
      if (Array.isArray(permissionItem.actions)) {
        permissionItem.actions.forEach((action) => {
          if (typeof action === 'string' && action) {
            slugSet.add(action);
          }
        });
      }
    }
  });

  return [...slugSet];
};

const buildSvgPlaceholder = (label: string, bg = '#2563eb', fg = '#ffffff') => {
  const svg = `<svg xmlns='http://www.w3.org/2000/svg' width='240' height='120' viewBox='0 0 240 120'><rect width='240' height='120' rx='14' fill='${bg}'/><text x='120' y='68' text-anchor='middle' font-size='28' font-family='Arial' fill='${fg}'>${label}</text></svg>`;
  return `data:image/svg+xml;utf8,${encodeURIComponent(svg)}`;
};

const homeChannelLogos = [
  {
