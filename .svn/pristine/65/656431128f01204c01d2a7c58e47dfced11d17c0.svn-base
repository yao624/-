              >
                <a-select-option value="summary">{{ t('汇总') }}</a-select-option>
                <a-select-option value="meta">Meta</a-select-option>
                <a-select-option value="google">Google</a-select-option>
              </a-select>
            </div>
            <template v-for="item in getCardEnabledFiltersWithoutChannel(card)" :key="`${card.id}-${item.key}`">
              <div class="filter-box" style="min-width: 140px;">
                <div class="label">
                  <span>{{ item.label }}</span>
                </div>
                <a-select
                  v-model:value="item.value"
                  size="small"
                  :bordered="false"
                  style="width: 140px"
                  show-search
                  :filter-option="(input, option) => String(option?.label || '').toLowerCase().includes(input.toLowerCase())"
                  :options="item.options"
                  @change="handleCardFilterChange(card)"
                />
              </div>
            </template>
            <a-button size="small" class="card-filter-action-btn" @click="openCardFilterModal(card)">
              <filter-outlined />
            </a-button>
          </div>
          <div class="scatter-chart-container">
            <div class="scatter-plot-area">
              <div class="axis-label-x">{{ addCardMetricOptions.find(o => o.value === (card.queryConfigRaw?.x_axis_metric || 'impressions'))?.label }}</div>
              <div class="axis-label-y">{{ addCardMetricOptions.find(o => o.value === (card.queryConfigRaw?.y_axis_metric || 'cost'))?.label }}</div>
              <div class="axis-ticks-x">
                <span>0</span>
                <span>10,000,000</span>
                <span>20,000,000</span>
                <span>30,000,000</span>
                <span>40,000,000</span>
              </div>
              <div class="axis-ticks-y">
                <span>0</span>
                <span>180万</span>
                <span>210万</span>
                <span>240万</span>
                <span>270万</span>
                <span>300万</span>
                <span>330万</span>
                <span>360万</span>
              </div>
              <div
                v-for="i in 5"
                :key="i"
                class="scatter-point"
                :style="{
                  left: `${15 + i * 15}%`,
                  bottom: `${20 + (Math.sin(i) + 1) * 30}%`
                }"
              ></div>
            </div>
          </div>
        </template>
        <template v-else-if="card.chartType === 'pie'">
          <div class="card-filter-row pie-card-filters" :class="{ compact: card.shape === 'large' }">
            <div class="filter-box date-box">
              <div class="label">
                <span>{{ t('日') }}</span>
                <span>{{ t('期') }}</span>
              </div>
              <a-range-picker
                v-model:value="card.dateRange"
                format="YYYY/MM/DD"
                size="small"
                :bordered="false"
                :separator="'→'"
