    .custom-board-title-wrap {
      min-width: 0;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .custom-board-title-line {
      display: flex;
      align-items: center;

      h2 {
        margin: 0;
        font-size: 30px;
        font-weight: 600;
        color: #273142;
