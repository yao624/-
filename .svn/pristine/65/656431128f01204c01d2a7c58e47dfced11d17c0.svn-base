const sumCharCodes = (s: string) =>
  String(s ?? '')
    .split('')
    .reduce((acc, ch) => acc + ch.charCodeAt(0), 0);

const buildDateLabels = (range: [Dayjs, Dayjs], maxPoints = 7) => {
  const start = range?.[0] ? dayjs(range[0]) : dayjs().subtract(6, 'day');
  const end = range?.[1] ? dayjs(range[1]) : dayjs();
  const days = Math.max(1, end.startOf('day').diff(start.startOf('day'), 'day') + 1);
  const points = Math.min(maxPoints, days);
  const step = points <= 1 ? 0 : (days - 1) / (points - 1);
  return Array.from({ length: points }, (_, i) => start.add(Math.round(i * step), 'day').format('MM/DD'));
};

const getTrendXAxis = (card: any) => {
  if (Array.isArray(card?.xAxisLabels) && card.xAxisLabels.length) return card.xAxisLabels;
  if (Array.isArray(card?.dateRange) && card.dateRange.length === 2) return buildDateLabels(card.dateRange as [Dayjs, Dayjs]);
  return buildDateLabels([dayjs().subtract(6, 'day'), dayjs()] as [Dayjs, Dayjs]);
};

const getTrendSeries = (card: any) => {
  const xAxis = getTrendXAxis(card);
  const seed = sumCharCodes(String(card?.id ?? ''));
  const isBar = ['bar', 'stack-bar', 'percent-stack-bar', 'horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(card?.chartType);
  const isArea = ['area', 'stack-area', 'percent-stack-area'].includes(card?.chartType);
  const isStack = ['stack-area', 'percent-stack-area', 'stack-bar', 'percent-stack-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(card?.chartType);
  const isPercent = ['percent-stack-area', 'percent-stack-bar', 'percent-stack-horizontal-bar'].includes(card?.chartType);

  if (isStack) {
    const names = [1, 2, 3, 4, 5].map((i) => `${t('部门名称')}_${i * 4}`).concat([t('其他')]);
    const base = [0.32, 0.2, 0.16, 0.12, 0.11, 0.09];
    return names.map((name, si) => {
      const data = xAxis.map((_, xi) => {
        const wobble = ((seed + si * 17 + xi * 13) % 9) - 4; // -4..4
        if (isPercent) {
          const totalBase = base.reduce((a, b) => a + b, 0);
          const v = ((base[si] ?? 0) / totalBase) * 100 + wobble * 0.6;
          return Math.max(1, Math.min(99, Math.round(v)));
        }
        return 20 + (si + 1) * 8 + xi * 6 + wobble * 2;
      });
      return {
        name,
        type: isBar ? 'bar' : 'line',
        stack: 'total',
        area: isArea,
        data,
      };
    });
  }

  const metricKeys = Array.isArray(card?.metrics) && card.metrics.length ? card.metrics.slice(0, 2) : ['cost'];
  return metricKeys.map((mKey: string, mi: number) => {
    const name = getMetricLabel?.(mKey) ?? mKey;
    const data = xAxis.map((_, xi) => {
      const wobble = ((seed + mi * 29 + xi * 11) % 11) - 5; // -5..5
      return 30 + mi * 10 + xi * 8 + wobble * 2;
    });
    return {
      name,
      type: isBar ? 'bar' : 'line',
      area: isArea,
      data,
    };
  });
};

