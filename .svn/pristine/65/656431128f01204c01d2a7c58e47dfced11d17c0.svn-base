const initTopAccountsChart = (trendData: any) => {
  if (!topAccountsChart.value) return;
  
  if (topAccountsChartInstance) {
    topAccountsChartInstance.dispose();
  }
  
  topAccountsChartInstance = echarts.init(topAccountsChart.value);
  
  const colors = ['#1890ff', '#fa8c16', '#52c41a', '#722ed1', '#eb2f96', '#13c2c2', '#f5222d', '#faad14'];
  const series = trendData.accounts
    .filter((_account: any, index: number) => topAccountsLegend.value[index]?.checked)
    .map((account: any, index: number) => ({
      name: account.name,
      type: 'line',
      smooth: true,
      data: account.data,
      itemStyle: {
        color: colors[index % colors.length],
      },
    }));
  
  const option: echarts.EChartOption = {
    tooltip: {
      trigger: 'axis',
      axisPointer: {
        type: 'cross',
      },
    },
    legend: {
      show: false,
    },
    grid: {
      left: '3%',
      right: '25%',
      bottom: '3%',
      containLabel: true,
    },
    xAxis: {
      type: 'category',
      boundaryGap: false,
      data: trendData.dates.map((date: string) => dayjs(date).format('MM/DD')),
    },
    yAxis: {
      type: 'value',
      name: t('花费'),
      axisLabel: {
        formatter: (value: number) => {
          return (value / 10000).toFixed(0) + t('万');
        },
      },
    },
    series,
  };
  
  topAccountsChartInstance.setOption(option);
};

