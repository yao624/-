    font-size: 13px;
  }

  .card-manager-table {
    min-width: 780px;
  }

  .card-manager-head,
  .card-manager-row {
    display: grid;
    grid-template-columns: 2.2fr 1.2fr 1fr 1fr 1.8fr;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-bottom: 1px solid #edf1f7;
  }

  .card-manager-head {
    position: sticky;
