/* 指标设置弹窗样式 */
.metric-setting-content {
  display: flex;
  height: 500px;
  border: 1px solid #f0f0f0;

  .metric-setting-left {
    flex: 1;
    padding: 16px;
    border-right: 1px solid #f0f0f0;
    overflow-y: auto;

    .metric-group {
      .group-title {
        font-weight: bold;
        margin-bottom: 12px;
        padding-left: 8px;
        border-left: 3px solid #1890ff;
      }
      .group-items {
        .metric-checkbox-group {
          width: 100%;
        }
      }
    }
  }

  .metric-setting-right {
    width: 240px;
    padding: 16px;
    background: #fafafa;
    display: flex;
    flex-direction: column;

    .right-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
      font-weight: bold;
