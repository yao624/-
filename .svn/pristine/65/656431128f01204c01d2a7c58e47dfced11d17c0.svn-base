const toLocalBoard = (row: MetaReportDashboardRow) => {
  return {
    key: row.id,
    label: row.name,
    boardType: (row.board_type === 'custom' ? 'custom' : 'comprehensive') as 'comprehensive' | 'custom',
    folderId: row.folder_id ?? null,
  };
};

const mapCardRowToLocal = (row: MetaReportCardRow) => {
  const queryConfig = (row.query_config ?? {}) as Record<string, any>;
  const iconName = String(queryConfig.icon_name ?? '').trim() || row.title;
  const dataSource = String(queryConfig.data_source ?? '').trim() || t('综合报表');
  const channel = String(queryConfig.channel ?? '').trim() || t('汇总');
  const shape = (row.shape as 'large' | 'medium' | 'small') || 'small';

  const dateRange = (
    queryConfig.date_range && Array.isArray(queryConfig.date_range) && queryConfig.date_range.length === 2
      ? [dayjs(queryConfig.date_range[0]), dayjs(queryConfig.date_range[1])]
      : [dayjs().subtract(6, 'day'), dayjs()]
  ) as [Dayjs, Dayjs];

  const local: CustomBoardCard = {
    id: row.id,
    title: row.title,
    iconName,
    dataSource,
    channel,
    chartType: row.chart_type,
    typeLabel: getChartTypeLabel(row.chart_type),
    shape,
    metrics: (queryConfig.metrics as string[]) ?? [],
    dateRangeLabel: '',
    startDate: '',
    endDate: '',
    xAxisLabels: [],
    dateRange,
    chartPreviewData: Array.from({ length: 10 }, (_, idx) => idx + 1),
    queryConfigRaw: row.query_config ?? null,
    filterOptions: Array.isArray(queryConfig.filter_options)
      ? (queryConfig.filter_options as any[])
      : buildDefaultCardFilterOptions(),
  };

  applyCardDateRangeToDisplayFields(local);

  return local;
};

const loadFoldersAndDashboards = async () => {
  try {
    const [folderRes, dashboardRes] = await Promise.all([
      fetchMetaReportFolders(),
      fetchMetaReportDashboards(),
    ]);
    customFolders.value = flattenFolders(folderRes?.data ?? []);
    expandedTreeKeys.value = [SIDEBAR_ROOT_KEY, ...customFolders.value.map((item) => `folder:${item.id}`)];
    myDashboards.value = (dashboardRes?.data ?? []).map(toLocalBoard);
  } catch (error) {
    console.error('加载看板数据失败:', error);
    message.error(t('加载看板数据失败'));
  }
};

const handleCreateMenuClick = (info: any) => {
  const key = String(info.key);
  if (key === 'new-dashboard') {
    // 顶部入口创建看板时，通过“看板位置”手动选择放置文件夹
    createDashboardForm.value.folderId = null;
    showCreateDashboardModal.value = true;
    return;
  }
  if (key === 'new-folder') {
    // 顶部入口创建的是“我的看板”下的一级文件夹
    selectedSidebarNode.value = { type: 'mine', folderId: null };
    if (!expandedTreeKeys.value.includes(SIDEBAR_ROOT_KEY)) {
      expandedTreeKeys.value = [...expandedTreeKeys.value, SIDEBAR_ROOT_KEY];
    }
    showCreateFolderModal.value = true;
  }
};

const handleCreateDashboardInFolder = (folderId: string) => {
  const folderKey = `folder:${folderId}`;
  if (!expandedTreeKeys.value.includes(SIDEBAR_ROOT_KEY)) {
    expandedTreeKeys.value = [...expandedTreeKeys.value, SIDEBAR_ROOT_KEY];
  }
  if (!expandedTreeKeys.value.includes(folderKey)) {
    expandedTreeKeys.value = [...expandedTreeKeys.value, folderKey];
  }
  selectedSidebarNode.value = {
    type: 'folder',
    folderId,
  };
  createDashboardForm.value.folderId = folderId;
  showCreateDashboardModal.value = true;
};

const handleFolderMenuClick = (folderId: string, key: string) => {
  const folder = customFolders.value.find((item) => item.id === folderId);
  if (!folder) {
    return;
  }
  if (key === 'rename') {
    renameFolderForm.value = {
      id: folderId,
      name: folder.name,
    };
    showRenameFolderModal.value = true;
    return;
  }
  if (key === 'delete') {
    deleteFolderId.value = folderId;
    showDeleteFolderModal.value = true;
  }
};

const handleBoardMenuClick = (boardId: string, key: string) => {
  const target = myDashboards.value.find((item) => item.key === boardId);
  if (!target) {
    return;
  }
  selectedCreatedBoard.value = {
    key: target.key,
    label: target.label,
    boardType: target.boardType,
  };
  selectedSidebarNode.value = {
    type: 'board',
    folderId: target.folderId,
  };
  handleCreatedBoardMenuClick({ key } as any);
};

const resetCreateDashboardForm = () => {
  showCreateDashboardModal.value = false;
  createDashboardForm.value = {
    name: '',
    folderId: null,
    channel: 'summary',
    boardType: 'comprehensive',
    groupCompare: false,
  };
};

const resetCreateFolderForm = () => {
  showCreateFolderModal.value = false;
  createFolderForm.value = {
    name: '',
  };
};

const submitCreateDashboard = async () => {
  const name = createDashboardForm.value.name.trim();
  if (!name) {
    message.error(t('请输入看板名称'));
    return;
  }

  try {
    const res = await createMetaReportDashboard({
      name,
      folder_id: createDashboardForm.value.folderId,
      channel: createDashboardForm.value.channel,
      board_type: createDashboardForm.value.boardType === 'custom' ? 'custom' : 'comprehensive',
      group_compare: createDashboardForm.value.groupCompare,
    });
    const row = res?.data;
    if (!row) {
      throw new Error('empty dashboard response');
    }
    const board = toLocalBoard(row);
    myDashboards.value.unshift(board);
    selectedCreatedBoard.value = {
      key: board.key,
      label: board.label,
      boardType: board.boardType,
    };
    selectedSidebarNode.value = {
      type: 'board',
      folderId: board.folderId,
    };
    selectedReport.value = board.boardType === 'comprehensive' ? 'created-comprehensive' : 'created-custom';
    customBoardCards.value = [];
    message.success(t('创建成功'));
    resetCreateDashboardForm();
  } catch (error) {
    console.error('创建看板失败:', error);
    message.error(t('创建看板失败'));
  }
};

const submitCreateFolder = async () => {
  const name = createFolderForm.value.name.trim();
  if (!name) {
    message.error(t('请输入文件夹名称'));
    return;
  }
  try {
    const res = await createMetaReportFolder({
      name,
      parent_id: null,
    });
    if (res?.data) {
      customFolders.value.unshift({
        id: res.data.id,
        name: res.data.name,
      });
      const folderKey = `folder:${res.data.id}`;
      if (!expandedTreeKeys.value.includes(SIDEBAR_ROOT_KEY)) {
        expandedTreeKeys.value = [...expandedTreeKeys.value, SIDEBAR_ROOT_KEY];
      }
      if (!expandedTreeKeys.value.includes(folderKey)) {
        expandedTreeKeys.value = [...expandedTreeKeys.value, folderKey];
      }
      selectedSidebarNode.value = { type: 'folder', folderId: res.data.id };
      message.success(t('创建成功'));
      resetCreateFolderForm();
    }
  } catch (error) {
    console.error('创建文件夹失败:', error);
    message.error(t('创建文件夹失败'));
  }
};

const resetRenameFolderForm = () => {
  showRenameFolderModal.value = false;
  renameFolderForm.value = {
    id: '',
    name: '',
  };
};

const submitRenameFolder = async () => {
  const name = renameFolderForm.value.name.trim();
  if (!name || !renameFolderForm.value.id) {
    message.error(t('请输入文件夹名称'));
    return;
  }
  try {
    await updateMetaReportFolder(renameFolderForm.value.id, { name });
    const target = customFolders.value.find((item) => item.id === renameFolderForm.value.id);
    if (target) {
      target.name = name;
    }
    message.success(t('重命名成功'));
    resetRenameFolderForm();
  } catch (error) {
    console.error('重命名文件夹失败:', error);
    message.error(t('重命名文件夹失败'));
  }
};

const resetDeleteFolderModal = () => {
  showDeleteFolderModal.value = false;
  deleteFolderId.value = null;
  folderDeleteLoading.value = false;
};

const confirmDeleteFolder = async () => {
  const folderId = deleteFolderId.value;
  if (!folderId) return;
  folderDeleteLoading.value = true;
  try {
    const ok = await submitDeleteFolder(folderId);
    if (ok) {
      resetDeleteFolderModal();
    }
  } finally {
    folderDeleteLoading.value = false;
  }
};

const submitDeleteFolder = async (folderId: string): Promise<boolean> => {
  try {
    await deleteMetaReportFolder(folderId);
    await loadFoldersAndDashboards();
    if (selectedSidebarNode.value.type === 'folder' && selectedSidebarNode.value.folderId === folderId) {
      selectedSidebarNode.value = { type: 'mine', folderId: null };
    }
    if (selectedCreatedBoard.value && !myDashboards.value.find((d) => d.key === selectedCreatedBoard.value?.key)) {
      selectedCreatedBoard.value = null;
      selectedReport.value = 'summary';
    }
    message.success(t('删除成功'));
    return true;
  } catch (error) {
    console.error('删除文件夹失败:', error);
    message.error(t('删除文件夹失败'));
    return false;
  }
};

const resetDeleteDashboardModal = () => {
  showDeleteDashboardModal.value = false;
  deleteDashboardId.value = null;
  dashboardDeleteLoading.value = false;
};

const confirmDeleteDashboard = async () => {
  const dashboardId = deleteDashboardId.value;
  if (!dashboardId) return;
  dashboardDeleteLoading.value = true;

  try {
    await deleteMetaReportDashboard(dashboardId);
    myDashboards.value = myDashboards.value.filter((item) => item.key !== dashboardId);
    selectedCreatedBoard.value = null;
    selectedReport.value = 'summary';
    message.success(t('删除成功'));
    resetDeleteDashboardModal();
  } catch (error) {
    console.error('删除看板失败:', error);
    message.error(t('删除看板失败'));
  } finally {
    dashboardDeleteLoading.value = false;
  }
};

const handleCreatedBoardSave = async () => {
  if (!selectedCreatedBoard.value) return;
  try {
    const res = await saveMetaReportDashboard(selectedCreatedBoard.value.key);
    createdBoardLastSaveTime.value = res?.data?.last_saved_at || dayjs().format('YYYY-MM-DD HH:mm:ss');
    message.success(t('保存成功'));
  } catch (error) {
    console.error('保存看板失败:', error);
    message.error(t('保存看板失败'));
  }
};

const handleCreatedBoardShare = () => {
  message.success(t('分享链接已生成'));
};

/** 将接口里保存的渠道字段还原为表单 value */
const parseChannelForForm = (stored: unknown): string => {
  const s = String(stored ?? '').trim().toLowerCase();
  if (s === 'meta' || s.includes('meta')) return 'meta';
  if (s === 'google' || s.includes('google')) return 'google';
  return 'summary';
};

const fillAddCardFormFromCard = (card: CustomBoardCard) => {
  const qc = (card.queryConfigRaw ?? {}) as Record<string, any>;
  const dr =
    qc.date_range && Array.isArray(qc.date_range) && qc.date_range.length === 2
      ? ([dayjs(qc.date_range[0]), dayjs(qc.date_range[1])] as [Dayjs, Dayjs])
      : ([dayjs().subtract(6, 'day'), dayjs()] as [Dayjs, Dayjs]);
  let chartSize: 'large' | 'small' = 'small';
  if (qc.chart_size === 'large') chartSize = 'large';
  else if (qc.chart_size === 'small' || qc.chart_size === 'medium') chartSize = 'small';
  else if (card.shape === 'large') chartSize = 'large';

  const maxRows = [5, 10, 20].includes(Number(qc.max_rows)) ? Number(qc.max_rows) : 5;

  const dimension = qc.dimension;
  let dimensionArray: string[] = ['date'];
  if (Array.isArray(dimension)) {
    dimensionArray = [...dimension];
  } else if (typeof dimension === 'string') {
    dimensionArray = dimension.split(',').filter(Boolean);
  }

  addCardForm.value = {
    name: card.title,
    channel: parseChannelForForm(qc.channel ?? card.channel),
    dataSource: qc.data_source || '综合报表',
    chartType: card.chartType,
    compareMode: qc.compare_mode ?? 'none',
    dateRange: dr,
    dimension: dimensionArray,
    xAxisMetric: qc.x_axis_metric || getAvailableMetricOptions()[0]?.value || 'cost',
    yAxisMetric: qc.y_axis_metric || getAvailableMetricOptions()[1]?.value || getAvailableMetricOptions()[0]?.value || 'impressions',
    metrics: Array.isArray(qc.metrics) && qc.metrics.length ? [...qc.metrics] : (card.chartType === 'scatter' ? [qc.y_axis_metric || 'cost'] : ['cost']),
    groupAggregation: qc.group_aggregation,
    chartSize,
    tableColor: qc.table_color ?? '#1890ff',
    sortField: typeof qc.sort_field === 'string' ? qc.sort_field : 'cost',
    sortOrder: qc.sort_order === 'asc' || qc.sort_order === 'desc' ? qc.sort_order : 'desc',
    maxRows,
  };

  // 编辑时：高级筛选区域只展示卡片现有的筛选
  if (Array.isArray(qc.filter_options)) {
    addFormFilterOptions.value = JSON.parse(JSON.stringify(qc.filter_options));
  } else {
    addFormFilterOptions.value = [];
  }
  handleAddFormFilterChange();
};

const handleAddCustomCard = () => {
  editingCardId.value = null;
  addCardForm.value = {
    name: `${t('卡片')} ${customBoardCards.value.length + 1}`,
    channel: 'summary',
    dataSource: '综合报表',
    chartType: 'table',
    compareMode: 'none',
    dateRange: [dayjs().subtract(6, 'day'), dayjs()] as [Dayjs, Dayjs],
    dimension: ['date'] as string[],
    xAxis: 'date',
    xAxisMetric: getAvailableMetricOptions()[0]?.value ?? 'cost',
    yAxisMetric: getAvailableMetricOptions()[1]?.value ?? getAvailableMetricOptions()[0]?.value ?? 'impressions',
    filterChannel: 'summary',
    metrics: ['cost'] as string[],
    groupAggregation: undefined,
    chartSize: 'small' as 'small' | 'large',
    tableColor: '#1890ff',
    sortField: 'cost',
    sortOrder: 'desc',
    maxRows: 5,
  };
  // 新建卡片时使用默认筛选配置
  addFormFilterOptions.value = buildDefaultCardFilterOptions();
  handleAddFormFilterChange();
  showAddCardDrawer.value = true;
};

const closeAddCardDrawer = () => {
  showAddCardDrawer.value = false;
  editingCardId.value = null;
};

const handleChartMouseMove = (e: MouseEvent, card: CustomBoardCard) => {
  const svg = e.currentTarget as SVGSVGElement;
  const rect = svg.getBoundingClientRect();
  const x = e.clientX - rect.left;
  const y = e.clientY - rect.top;
  
  // 计算当前鼠标位置对应的数据索引 (根据 x 坐标在 0-100 范围内平分)
  const percentX = (x / rect.width) * 100;
  const dataCount = card.xAxisLabels?.length || 7;
  const index = Math.round((percentX / 100) * (dataCount - 1));
  const safeIndex = Math.max(0, Math.min(index, dataCount - 1));
  
  card.activeIndex = safeIndex;
  
  // 模拟数据展示
  const isGroupedBar = card.chartType === 'bar' && card.groupAggregation;
  const colors = ['#1890ff', '#faad14', '#52c41a', '#722ed1', '#13c2c2', '#91d5ff'];
  let labels = [t('部门名称') + '_1', t('部门名称') + '_2', t('部门名称') + '_3', t('部门名称') + '_4', t('部门名称') + '_5', t('其他')];
  
  if (isGroupedBar) {
    labels = ['优化师_29', '优化师_66', '优化师_63', '优化师_73', '优化师_75'];
  }

  card.tooltip = {
    show: true,
    x: x,
    y: y,
    title: `2026-03-${String(21 + safeIndex).padStart(2, '0')} 00:00`,
    items: labels.map((label, i) => ({
      color: colors[i],
      label: label,
      value: isGroupedBar 
        ? `${(Math.random() * 500000 + 100000).toLocaleString(undefined, { minimumFractionDigits: 3, maximumFractionDigits: 3 })} USD`
        : (i === 2 ? '198%' : (Math.random() > 0.5 ? '1%' : '0%'))
    }))
  };
};

const handleChartMouseLeave = (card: CustomBoardCard) => {
  card.activeIndex = null;
  if (card.tooltip) {
    card.tooltip.show = false;
  }
};
const handleTrendCardFilterClick = () => {
  message.info(t('已应用筛选条件'));
};

const cardFilterModalVisible = ref(false);
const currentFilterCardId = ref<string | null>(null);
const cardFilterOptionsDraft = ref<any[]>([]);
const isAddFormFilter = ref(false);

const openCardFilterModal = (card: CustomBoardCard) => {
  if (card.chartType === 'card-stat') return;
  currentFilterCardId.value = card.id;
  isAddFormFilter.value = false;
  cardFilterOptionsDraft.value = JSON.parse(
    JSON.stringify(card.filterOptions && card.filterOptions.length > 0 ? card.filterOptions : buildDefaultCardFilterOptions()),
  );
  cardFilterModalVisible.value = true;
};

const addFormFilterOptions = ref(buildDefaultCardFilterOptions());

const openCardFilterModalForAddForm = () => {
  isAddFormFilter.value = true;
  currentFilterCardId.value = null;
  cardFilterOptionsDraft.value = JSON.parse(JSON.stringify(addFormFilterOptions.value));
  cardFilterModalVisible.value = true;
};

const getAddFormActiveFilters = () => addFormFilterOptions.value.filter((item) => item.enabled);

const handleAddFormFilterChange = () => {
  const channelFilter = addFormFilterOptions.value.find((item) => item.key === 'channel' && item.enabled);
  addCardForm.value.filterChannel = (channelFilter && channelFilter.value) || undefined;
};

// 同步一次初始默认筛选，确保不手动点“筛选设置”也能提交 filter_channel
handleAddFormFilterChange();

const removeAddFormFilter = (key: string) => {
  const item = addFormFilterOptions.value.find((f) => f.key === key);
  if (!item) return;
  item.enabled = false;
  item.value = undefined;
  handleAddFormFilterChange();
};

const getCardEnabledFilters = (card: CustomBoardCard) =>
  (card.filterOptions ?? []).filter((item) => item.enabled);

const getCardEnabledFiltersWithoutChannel = (card: CustomBoardCard) =>
  getCardEnabledFilters(card).filter((item) => item.key !== 'channel');

const hasChannelFilter = (card: CustomBoardCard) =>
  getCardEnabledFilters(card).some((item) => item.key === 'channel');

const handleCardFilterModalOk = async () => {
  if (isAddFormFilter.value) {
    addFormFilterOptions.value = JSON.parse(JSON.stringify(cardFilterOptionsDraft.value));
    handleAddFormFilterChange();
    cardFilterModalVisible.value = false;
    return;
  }

  const cardId = currentFilterCardId.value;
  if (!cardId) {
    cardFilterModalVisible.value = false;
    return;
  }
  const idx = customBoardCards.value.findIndex((c) => c.id === cardId);
  if (idx < 0) {
    cardFilterModalVisible.value = false;
    return;
  }

  const target = customBoardCards.value[idx];
  target.filterOptions = JSON.parse(JSON.stringify(cardFilterOptionsDraft.value));
  customBoardCards.value = [...customBoardCards.value];
  cardFilterModalVisible.value = false;

  try {
    const queryConfig = {
      ...((target.queryConfigRaw ?? {}) as Record<string, unknown>),
      filter_options: target.filterOptions,
    };
    await updateMetaReportCard(target.id, { query_config: queryConfig });
    target.queryConfigRaw = queryConfig;
  } catch (error) {
    console.error('更新卡片筛选失败:', error);
    message.warning(t('筛选已在页面生效，保存到服务器失败'));
  }
};

const clearCardFilterDraft = () => {
  cardFilterOptionsDraft.value.forEach((item) => {
    item.enabled = false;
    item.value = undefined;
  });

  if (isAddFormFilter.value) {
    addFormFilterOptions.value = buildDefaultCardFilterOptions();
    handleAddFormFilterChange();
  }
};

const scatterMetricTarget = ref<'xAxis' | 'yAxis'>('xAxis');
const getScatterMetricPool = () => getAvailableMetricOptions().map((opt) => opt.value).filter(Boolean);
const getScatterDefaultMetrics = () => {
  const pool = getScatterMetricPool();
  const first = pool[0] ?? 'cost';
  const second = pool.find((item) => item !== first) ?? first;
  return { first, second };
};
const getNextScatterMetric = (exclude: string) => {
  const pool = getScatterMetricPool();
  return pool.find((item) => item !== exclude) ?? exclude;
};
const ensureScatterMetrics = () => {
  const { first, second } = getScatterDefaultMetrics();
  let xMetric = addCardForm.value.xAxisMetric || first;
  let yMetric = addCardForm.value.yAxisMetric || second;
  if (xMetric === yMetric) {
    yMetric = getNextScatterMetric(xMetric);
  }
  addCardForm.value.xAxisMetric = xMetric;
  addCardForm.value.yAxisMetric = yMetric;
};
const handleSingleMetricClick = () => {
  // 模拟饼图逻辑，只能选一个
  showMetricSettingModal.value = true;
};

const handleScatterMetricClick = (target: 'xAxis' | 'yAxis') => {
  scatterMetricTarget.value = target;
  ensureScatterMetrics();
  // 为弹窗准备初始选中的指标
  if (target === 'xAxis') {
    addCardForm.value.metrics = addCardForm.value.xAxisMetric ? [addCardForm.value.xAxisMetric] : [];
  } else {
    addCardForm.value.metrics = addCardForm.value.yAxisMetric ? [addCardForm.value.yAxisMetric] : [];
  }
  showMetricSettingModal.value = true;
};

const handleTrendCardMetricClick = () => {
  showMetricSettingModal.value = true;
};

watch(
  () => addCardForm.value.chartType,
  (ct) => {
    // 切换图表类型时，处理维度数据格式
    const isSingleSelectChart = ['pie', 'tile', 'bar', 'stack-bar', 'percent-stack-bar', 'horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(ct);
    if (isSingleSelectChart) {
      if (Array.isArray(addCardForm.value.dimension)) {
        addCardForm.value.dimension = addCardForm.value.dimension[0] || 'date';
      }
    } else {
      if (!Array.isArray(addCardForm.value.dimension)) {
        addCardForm.value.dimension = [addCardForm.value.dimension || 'date'];
      }
    }

    if (ct === 'tile') {
      addCardForm.value.chartSize = 'large';
      addCardForm.value.compareMode = 'none';
    }

    // 堆积柱状图：默认选中“分组聚合”的第一个，从而让排序/最大行数直接显示
    if (['stack-bar', 'percent-stack-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(ct)) {
      const firstGroup = groupAggregationOptions[0]?.value;
      if (!addCardForm.value.groupAggregation && firstGroup) {
        addCardForm.value.groupAggregation = firstGroup;
      }
      // 防止从 bar 切换到堆积柱状图时指标数量不一致
      if (addCardForm.value.metrics.length > 1) {
        addCardForm.value.metrics = addCardForm.value.metrics.slice(0, 1);
      }
      // 排序字段兜底：保证排序下拉可用
      if (!addCardForm.value.sortField) {
        addCardForm.value.sortField = addCardForm.value.metrics[0] ?? 'cost';
      }
    }
  },
);

// 堆积柱状图（stack-bar / %堆积柱状图）只能展示一个指标
watch(
  () => [addCardForm.value.chartType, addCardForm.value.metrics],
  ([ct, metrics]) => {
    if (!['stack-bar', 'percent-stack-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(ct)) return;
    if (!Array.isArray(metrics)) return;
    if (metrics.length <= 1) return;
    addCardForm.value.metrics = metrics.slice(0, 1);
  },
  { immediate: true },
);

const getChartTypeLabel = (chartType: string) => {
  return cardChartTypeOptions.find((item) => item.value === chartType)?.label ?? t('图表');
};

/** 趋势图预览横轴标签（大图展示更多刻度，避免与设计稿一样完全重叠） */
const trendXLabelsLarge = ['03/01', '03/06', '03/11', '03/16', '03/21', '03/26', '03/31'];

const getMetricLabel = (value: string) => {
  const opt = addCardMetricOptions.find((o) => o.value === value);
  if (opt) return opt.label;
  if (value === 'cost') return t('花费');
  if (value === 'spend') return t('花费');
  return value;
};

type TableMetricColumn = {
  key: string;
  title: string;
  field: string;
};

/** 表格卡片：根据用户选择的 metrics 动态决定展示哪些列（仅日期固定在最前面） */
const getTableMetricColumns = (card: CustomBoardCard): TableMetricColumn[] => {
  const metrics = card.metrics && card.metrics.length ? card.metrics : ['cost'];
  const colMap: Record<string, TableMetricColumn> = {
    cost: { key: 'cost', title: t('花费'), field: 'spend' },
    spend: { key: 'cost', title: t('花费'), field: 'spend' },
    impressions: { key: 'impressions', title: t('展示数'), field: 'impressions' },
    cpm: { key: 'cpm', title: t('千次展示成本'), field: 'cpm' },
    clicks: { key: 'clicks', title: t('点击数'), field: 'clicks' },
    cpc: { key: 'cpc', title: t('点击成本'), field: 'cpc' },
    ctr: { key: 'ctr', title: t('点击率'), field: 'ctr' },
    conversions: { key: 'conversions', title: t('转化数'), field: 'conversions' },
  };

  return metrics.map((mKey) => colMap[mKey]).filter(Boolean);
};

const getTableGridTemplate = (card: CustomBoardCard, variant: 'small' | 'large') => {
  const columns = getTableMetricColumns(card);
  if (variant === 'small') {
    // 1.2fr + N * 1fr
    return `1.2fr repeat(${columns.length}, 1fr)`;
  }
  // 1fr + N * minmax(52px, 1fr)
  return `1fr repeat(${columns.length}, minmax(52px, 1fr))`;
};

const formatTableCellValue = (row: any, field: string) => {
  const v = row?.[field];
  if (v === undefined || v === null) return '--';
  return v;
};

/** 饼图大图外圈标签位置（最多展示前 4 段） */
const pieOverlayLabelStyles: Record<string, string>[] = [
  { top: '20%', right: '-20%' },
  { top: '70%', right: '-15%' },
  { bottom: '10%', left: '0%' },
  { top: '10%', left: '-10%' },
];

const buildXAxisLabelsFromDateRange = (dateRange: [Dayjs, Dayjs] | undefined): string[] => {
  if (!dateRange || dateRange.length !== 2) return [];
  const s = dayjs(dateRange[0]).startOf('day');
  const e = dayjs(dateRange[1]).startOf('day');
  const diffDays = Math.max(0, e.diff(s, 'day'));
  const labels: string[] = [];
  for (let i = 0; i <= diffDays; i++) {
    labels.push(s.add(i, 'day').format('MM/DD'));
  }
  return labels;
};

/** 表格卡片：筛选范围内每一天一行，日期列与筛选一致（数值仍为本地 mock） */
const buildMockTableRowsForDateRange = (cardId: string, dateRange: [Dayjs, Dayjs]): any[] => {
  if (!dateRange || dateRange.length !== 2) return [];
  const s = dayjs(dateRange[0]).startOf('day');
  const e = dayjs(dateRange[1]).startOf('day');
  const diffDays = Math.max(0, e.diff(s, 'day'));
  const idPart = String(cardId).split('').reduce((acc, ch, i) => acc + ch.charCodeAt(0) * (i + 1), 0);
  return Array.from({ length: diffDays + 1 }, (_, idx) => {
    const d = s.add(idx, 'day');
    const seed = (d.valueOf() % 100000) + idx * 17000 + idPart;
    return {
      key: `row-${cardId}-${d.format('YYYY-MM-DD')}`,
      date: d.format('YYYY/MM/DD'),
      spend: ((seed % 10000) + (seed % 97)).toFixed(2),
      spendPlatform: ((seed % 5000) + (seed % 89)).toFixed(2),
      impressions: Math.floor((seed * 13) % 100000) + 1000,
      cpm: (((seed % 5000) / 100) + 0.01).toFixed(2),
      clicks: Math.floor((seed * 7) % 5000) + 10,
      cpc: (((seed % 200) / 100) + 0.01).toFixed(2),
      ctr: (((seed % 500) / 100) + 0.01).toFixed(2) + '%',
      conversions: Math.floor((seed * 3) % 100),
    };
  });
};

type PieTableRow = { date: string; ratio: string; value: string; color: string };

const PIE_ROW_COLORS = ['#1890ff', '#faad14', '#52c41a', '#722ed1', '#eb2f96', '#13c2c2', '#fa8c16', '#2f54eb'];

const getPieTableRows = (card: CustomBoardCard): PieTableRow[] => {
  const dr = card.dateRange;
  if (!dr || dr.length !== 2) return [];
  const s = dayjs(dr[0]).startOf('day');
  const e = dayjs(dr[1]).startOf('day');
  const n = Math.max(1, e.diff(s, 'day') + 1);
  let hash = 0;
  const idStr = String(card.id);
  for (let i = 0; i < idStr.length; i++) hash = (hash + idStr.charCodeAt(i) * (i + 1)) % 997;
  const weights = Array.from({ length: n }, (_, i) => 0.3 + 0.7 * Math.abs(Math.sin((hash + i * 13) * 0.17)));
  const sum = weights.reduce((a, b) => a + b, 0) || 1;
  return weights.map((w, idx) => {
    const pct = (w / sum) * 100;
    const d = s.add(idx, 'day');
    const rv = Math.floor(((hash + idx * 7919) % 90000000) + 10000000);
    return {
      date: d.format('YYYY-MM-DD'),
      ratio: `${pct.toFixed(2)}%`,
      value: `${rv.toLocaleString('en-US')} USD`,
      color: PIE_ROW_COLORS[idx % PIE_ROW_COLORS.length],
    };
  });
};

const getPieChartData = (card: CustomBoardCard) => {
  // 表格里 ratio 是形如 "12.34%" 的字符串，这里转成 number 作为 pie 的 value
  return getPieTableRows(card).map((r) => ({
    name: r.date,
    value: Number.parseFloat(String(r.ratio).replace('%', '')) || 0,
    color: r.color,
  }));
};

/**
 * 将卡片上的日期相关展示与 card.dateRange 对齐：横轴刻度、散点/表格文案、表格按日一行等。
 */
const applyCardDateRangeToDisplayFields = (card: CustomBoardCard) => {
  const dr = card.dateRange;
  if (!dr || dr.length !== 2) return;
  const s = dayjs(dr[0]).startOf('day');
  const e = dayjs(dr[1]).startOf('day');
  const rangeTuple = [s, e] as [Dayjs, Dayjs];
  card.startDate = s.format('MM/DD');
  card.endDate = e.format('MM/DD');
  card.dateRangeLabel = `${s.format('YYYY/MM/DD')} - ${e.format('YYYY/MM/DD')}`;
  card.xAxisLabels = buildXAxisLabelsFromDateRange(rangeTuple);
  if (card.chartType === 'table') {
    card.tableData = buildMockTableRowsForDateRange(card.id, rangeTuple);
  }
};

const getTileMetricLabel = (metricKey: string) => {
  const map: Record<string, string> = {
    cost: t('花费'),
    spend: t('花费'),
    impressions: t('展示数'),
    cpm: t('千次展示成本'),
    clicks: t('点击数'),
    cpc: t('点击成本'),
    ctr: t('点击率'),
    conversions: t('转化数'),
  };
  return map[metricKey] || metricKey;
};

const getTileMetricValue = (metricKey: string, seed: number) => {
  const n = Math.abs(seed);
  if (metricKey === 'cost' || metricKey === 'spend') return `${(n * 173.21).toFixed(3)} USD`;
  if (metricKey === 'cpm' || metricKey === 'cpc') return `${(n % 300 / 3 + 0.1).toFixed(3)} USD`;
  if (metricKey === 'ctr') return `${((n % 700) / 100).toFixed(2)}%`;
  return Math.floor(n * 91.7).toLocaleString('en-US');
};

const getTileCardItems = (card: CustomBoardCard) => {
  const dr = card.dateRange;
  if (!dr || !Array.isArray(dr) || dr.length !== 2) return [];

  const start = dayjs(dr[0]).startOf('day');
  const end = dayjs(dr[1]).startOf('day');
  const dayCount = Math.max(1, end.diff(start, 'day') + 1);
  const metrics = (card.metrics && card.metrics.length ? card.metrics : ['cost', 'impressions', 'clicks', 'cpm', 'conversions']).slice(0, 10);

  return Array.from({ length: dayCount }, (_, idx) => {
    const date = start.add(idx, 'day');
    return {
      date: date.format('YYYY-MM-DD'),
      metrics: metrics.map((metricKey, midx) => {
        const seed = (idx + 1) * (midx + 3) * 97 + date.date();
        return {
          label: getTileMetricLabel(metricKey),
          value: getTileMetricValue(metricKey, seed),
        };
      }),
    };
  });
};

const trendYLabels = (isLarge: boolean) => {
  if (isLarge) {
    return ['140%', '120%', '100%', '80%', '60%', '40%', '20%', '0%'];
  }
  return ['150%', '120%', '90%', '60%', '30%', '0%'];
};

/**
 * 柱状图/堆积柱状图（单柱）在 SVG viewBox(0~100) 内的柱子中心坐标换算成百分比。
 * 用它来定位日期标签，避免从第 3 根开始“柱子漂移”导致日期不对齐。
 */
const getStackBarCenterPercent = (index: number, total: number) => {
  const n = Number(total) || 0;
  if (n <= 1) return 50;
  return 10 + (index / (n - 1)) * 80;
};

/**
 * 双指标柱状图（bar + metrics.length>1）的两根柱：
 * 根据 xAxis 刻度间距动态计算柱宽和左右偏移，避免刻度过密时左右柱互相挤压，
 * 导致后面的柱子视觉上“跑偏”。
 */
const getTwoBarLayout = (total: number, shape: 'large' | 'small' | 'medium') => {
  const n = Number(total) || 0;
  const safeN = n <= 1 ? 2 : n;
  const step = 80 / (safeN - 1); // 每个刻度中心之间的距离（viewBox 坐标系）

  // 大图稍微宽一点，小图稍微窄一点
  const widthFactor = shape === 'large' ? 0.35 : 0.3;
  let barWidth = Math.max(2, Math.min(6.5, step * widthFactor));
  let gap = Math.max(1, step * (shape === 'large' ? 0.08 : 0.07));

  // 保底：确保两根柱 + 中间间隙不会超过当前刻度 step 的 90%
  const maxGroupWidth = step * 0.9;
  const minGap = gap;
  const minBarWidthAllowed = Math.max(2, (maxGroupWidth - minGap) / 2);
  if (barWidth > minBarWidthAllowed) barWidth = minBarWidthAllowed;

  // rect 的 x 是左边界坐标：
  // 左柱左边界 = center - barWidth - gap/2
  // 右柱左边界 = center + gap/2
  const leftOffset = -barWidth - gap / 2;
  const rightOffset = gap / 2;

  return { barWidth, gap, leftOffset, rightOffset };
};

const getTwoBarWidth = (total: number, shape: 'large' | 'small' | 'medium') => getTwoBarLayout(total, shape).barWidth;
const getTwoBarLeftOffset = (total: number, shape: 'large' | 'small' | 'medium') => getTwoBarLayout(total, shape).leftOffset;
const getTwoBarRightOffset = (total: number, shape: 'large' | 'small' | 'medium') => getTwoBarLayout(total, shape).rightOffset;

/**
 * 双指标柱状图中：左/右柱中心相对“刻度中心”的水平偏移量（viewBox 单位）。
 * 由于 trend mock 的 viewBox 宽度为 100，所以这个值可以直接当作百分比使用（0~100）。
 */
const getTwoBarMonthDayOffsetPercent = (total: number, shape: 'large' | 'small' | 'medium') => {
  const { barWidth, gap } = getTwoBarLayout(total, shape);
  const centerOffset = (barWidth + gap) / 2; // 左/右柱中心到刻度中心的水平偏移
  return Math.max(0, centerOffset);
};

/**
 * 双指标柱状图中：第 index 个刻度中心在 viewBox 0~100 坐标系的百分比位置。
 */
const getTwoBarTickCenterPercent = (index: number, total: number) => {
  const n = Number(total) || 0;
  // 只有 1 天时：不应该用 (n-1) 推导，直接居中到 50%
  if (n <= 1) return 50;
  const safeN = n <= 1 ? 2 : n;
  // SVG mock 的“柱子中心”分布在 x=10..90（viewBox）
  const x = 10 + (index / (safeN - 1)) * 80;
  return Math.max(0, Math.min(100, x));
};

const clampToPercentRange = (v: number) => Math.max(0, Math.min(100, v));

/**
 * 用 rect 的真实几何中心对齐 labels：
 * - 左柱 rect 的 x = tickCenter + leftOffset
 * - 右柱 rect 的 x = tickCenter + rightOffset
 * 再加上 barWidth/2 得到两根柱的中心坐标。
 */
const getTwoBarLeftCenterPercent = (index: number, total: number, shape: 'large' | 'small' | 'medium') => {
  const tickCenter = getTwoBarTickCenterPercent(index, total);
  const { barWidth, leftOffset } = getTwoBarLayout(total, shape);
  return clampToPercentRange(tickCenter + leftOffset + barWidth / 2);
};

const getTwoBarRightCenterPercent = (index: number, total: number, shape: 'large' | 'small' | 'medium') => {
  const tickCenter = getTwoBarTickCenterPercent(index, total);
  const { barWidth, rightOffset } = getTwoBarLayout(total, shape);
  return clampToPercentRange(tickCenter + rightOffset + barWidth / 2);
};

const getTwoBarMonthLabelLeftPercent = (index: number, total: number, shape: 'large' | 'small' | 'medium') => {
  return getTwoBarLeftCenterPercent(index, total, shape);
};

const getTwoBarDayLabelLeftPercent = (index: number, total: number, shape: 'large' | 'small' | 'medium') => {
  return getTwoBarRightCenterPercent(index, total, shape);
};

// ==============================
// 横向条形图（horizontal-bar）的 mock 布局与换算
// ==============================
const HORIZONTAL_MAX_VALUE = 6000; // 6000万
const HORIZONTAL_VISIBLE_DAYS = 7;
const BAR_VISIBLE_DAYS = 7;

const isHorizontalBarChartType = (chartType: string) =>
  ['horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(chartType);

const getHorizontalScrollSvgHeightUnits = (total: number, shape: 'large' | 'small' | 'medium') => {
  const n = Math.max(0, Number(total) || 0);
  // 视觉设计：<=7 天时维持 viewBox=0~64 的原布局（不做缩放/溢出）
  if (n <= HORIZONTAL_VISIBLE_DAYS) return 64;

  // 通过增大内部可用高度，让“日期行”间距更舒展（不足 7 天时不缩放，但行距仍会更大）
  const yMin = shape === 'large' ? 7 : 9;
  const yMax = 57;
  const rowStep = (yMax - yMin) / (HORIZONTAL_VISIBLE_DAYS - 1);
  const bottomPadding = 64 - yMax;

  return yMin + (n - 1) * rowStep + bottomPadding;
};

const shouldHorizontalScroll = (card: CustomBoardCard) =>
  isHorizontalBarChartType(card.chartType) && (card.xAxisLabels?.length || 0) > HORIZONTAL_VISIBLE_DAYS;

const isVerticalBarChartType = (chartType: string) => ['bar', 'stack-bar', 'percent-stack-bar'].includes(chartType);

const shouldBarXScroll = (card: CustomBoardCard) =>
  isVerticalBarChartType(card.chartType) && (card.xAxisLabels?.length || 0) > BAR_VISIBLE_DAYS;

const getBarXScrollScale = (card: CustomBoardCard) => {
  const total = card.xAxisLabels?.length || 0;
  if (total <= BAR_VISIBLE_DAYS) return 1;
  return total / BAR_VISIBLE_DAYS;
};

const getHorizontalScrollBoxStyle = (card: CustomBoardCard) => {
  if (!shouldHorizontalScroll(card)) return undefined;

  const total = card.xAxisLabels?.length || 0;
  const svgHeight = getHorizontalScrollSvgHeightUnits(total, card.shape);
  const scale = svgHeight / 64;

  return { height: `calc(100% * ${scale})` };
};

const getBarXScrollBoxStyle = (card: CustomBoardCard) => {
  if (!shouldBarXScroll(card)) return undefined;
  return { minWidth: `calc(100% * ${getBarXScrollScale(card)})` };
};

const getVerticalBarXAxisInnerStyle = (card: CustomBoardCard) => {
  if (!shouldBarXScroll(card)) return undefined;
  return { width: `calc((100% - 46px) * ${getBarXScrollScale(card)})` };
};

const barXScrollSyncingIds = new Set<string>();

const getBarScrollTargetEl = (kind: 'body' | 'axis', cardId: string) => {
  const attr = kind === 'body' ? 'data-bar-scroll-body' : 'data-bar-scroll-axis';
  const nodes = Array.from(document.querySelectorAll<HTMLElement>(`[${attr}]`));
  return nodes.find(node => node.getAttribute(attr) === cardId);
};

const handleBarXScroll = (
  card: CustomBoardCard,
  source: 'body' | 'axis',
  event: Event
) => {
  if (!shouldBarXScroll(card)) return;
  const cardId = String(card.id ?? '');
  if (!cardId) return;
  if (barXScrollSyncingIds.has(cardId)) return;

  const sourceEl = event.target as HTMLElement | null;
  if (!sourceEl) return;
  const targetEl = getBarScrollTargetEl(source === 'body' ? 'axis' : 'body', cardId);
  if (!targetEl) return;

  barXScrollSyncingIds.add(cardId);
  targetEl.scrollLeft = sourceEl.scrollLeft;
  requestAnimationFrame(() => barXScrollSyncingIds.delete(cardId));
};

const getTrendChartMockSvgViewBox = (card: CustomBoardCard) => {
  if (!isHorizontalBarChartType(card.chartType)) return '0 0 100 64';
  const total = card.xAxisLabels?.length || 0;
  return `0 0 100 ${getHorizontalScrollSvgHeightUnits(total, card.shape)}`;
};

const getTrendChartMockSvgHeight = (card: CustomBoardCard) => {
  if (!isHorizontalBarChartType(card.chartType)) return 64;
  const total = card.xAxisLabels?.length || 0;
  return getHorizontalScrollSvgHeightUnits(total, card.shape);
};

const getHorizontalValueToX = (value: number) => {
  const v = Math.max(0, Math.min(HORIZONTAL_MAX_VALUE, Number(value) || 0));
  // viewBox: x 轴可用宽度 0~100（与 trend-grid--horizontal 的等间距网格一致）
  return (v / HORIZONTAL_MAX_VALUE) * 100;
};

const getHorizontalRowY = (index: number, total: number, shape: 'large' | 'small' | 'medium') => {
  const n = Math.max(1, Number(total) || 1);
  const yMin = shape === 'large' ? 7 : 9;
  const yMax = 57;

  // 日期行超出 7 天：保持“7 天的行距”，通过拉伸 viewBox 实现滚动，而不是把行压得更矮。
  if (n > HORIZONTAL_VISIBLE_DAYS) {
    const rowStep = (yMax - yMin) / (HORIZONTAL_VISIBLE_DAYS - 1);
    return yMin + index * rowStep;
  }

  const safeN = n <= 1 ? 1 : n;
  if (safeN === 1) return (yMin + yMax) / 2;
  return yMin + (index / (safeN - 1)) * (yMax - yMin);
};

const getHorizontalBarHeight = (shape: 'large' | 'small' | 'medium', total: number) => {
  const n = Math.max(1, Number(total) || 1);

  const yMin = shape === 'large' ? 7 : 9;
  const yMax = 57;
  const span = yMax - yMin; // 44 (large) / 42 (small)

  // 日期行超出 7 天：保持 7 天时的行高（避免视觉压扁），让滚动条处理“显示更多日期”。
  if (n > HORIZONTAL_VISIBLE_DAYS) {
    const rowStep = span / (HORIZONTAL_VISIBLE_DAYS - 1);
    // 行间距变大时，适当降低柱子高度系数，让空隙更明显
    const heightByStep = rowStep * 0.7;

    const base = shape === 'large' ? 10 : 8;
    const maxHeight = base * 1.25;
    const minHeight = shape === 'large' ? 2.5 : 2;

    return Math.max(minHeight, Math.min(maxHeight, heightByStep));
  }

  const safeN = n <= 1 ? 1 : n;

  const base = shape === 'large' ? 10 : 8;
  const maxHeight = base * 1.25; // 日期少时允许“更高”

  if (safeN === 1) return maxHeight;

  const step = span / (safeN - 1); // 相邻行中心的间距
  // 日期多时自动“变矮”，同时保留更大的上下留白
  const heightByStep = step * 0.7;

  const minHeight = shape === 'large' ? 2.5 : 2;
  return Math.max(minHeight, Math.min(maxHeight, heightByStep));
};

const getHorizontalRowTopPercent = (index: number, total: number, shape: 'large' | 'small' | 'medium') => {
  const y = getHorizontalRowY(index, total, shape);
  const svgHeight = getHorizontalScrollSvgHeightUnits(total, shape);
  return (y / svgHeight) * 100;
};

const getHorizontalMockTotal = (rowIndex: number) => {
  // 用行号生成稳定的“总值”，用于 mock 展示
  const base = 900 + rowIndex * 750;
  return Math.min(HORIZONTAL_MAX_VALUE, base + (rowIndex % 3) * 250);
};

const horizontalStackFractions = [0.65, 0.15, 0.1, 0.08, 0.02];
const horizontalStackPrefix = horizontalStackFractions.reduce<number[]>((acc, f, i) => {
  const next = (acc[i - 1] ?? 0) + f;
  acc.push(next);
  return acc;
}, []);

const getHorizontalStackValue = (rowIndex: number, segmentIndex: number) => {
  const total = getHorizontalMockTotal(rowIndex);
  const f = horizontalStackFractions[segmentIndex] ?? 0;
  return total * f;
};

const getHorizontalStackCumBefore = (rowIndex: number, segmentIndex: number) => {
  // segmentIndex=0 时 cumBefore=0
  if (segmentIndex <= 0) return 0;
  const total = getHorizontalMockTotal(rowIndex);
  const prefix = horizontalStackPrefix[segmentIndex - 1] ?? 0;
  return total * prefix;
};

const resolveCardShape = (chartType: string): 'large' | 'medium' | 'small' => {
  if (addCardForm.value.chartSize === 'large') return 'large';
  if (chartType === 'table' || chartType === 'line' || chartType === 'card-stat') return 'small';
  return 'medium';
};

const filterChartTypeOption = (input: string, option: any) => {
  const value = String(option?.value ?? '');
  const label = getChartTypeLabel(value);
  return label.toLowerCase().includes(input.toLowerCase());
};

const submitAddCard = async () => {
  const name = addCardForm.value.name.trim();
  if (!name) {
    message.error(t('请输入卡片名称'));
    return;
  }
  if (!selectedCreatedBoard.value) {
    message.warning(t('请先选择看板'));
    return;
  }

  const chartType = addCardForm.value.chartType;
  if (
    !editingCardId.value &&
    chartType === 'card-stat' &&
    countTrailingCardStats(customBoardCards.value) >= STAT_GROUP_MAX
  ) {
    message.warning(
      t('同一区域最多添加4张统计数字卡片，请先插入其他类型卡片或调整顺序后再试'),
    );
    return;
  }
  if (chartType === 'scatter') {
    ensureScatterMetrics();
    if (!addCardForm.value.xAxisMetric || !addCardForm.value.yAxisMetric) {
      message.error(t('请先选择横轴和纵轴指标'));
      return;
    }
  }
  if (chartType === 'line' && (!addCardForm.value.metrics || addCardForm.value.metrics.length === 0)) {
    message.error(t('请选择纵轴指标'));
    return;
  }

  const dimensionValue =
    chartType === 'line' ? addCardForm.value.xAxis : (Array.isArray(addCardForm.value.dimension) ? addCardForm.value.dimension.join(',') : addCardForm.value.dimension);

  const queryConfig = {
    icon_name: name,
    data_source: addCardForm.value.dataSource,
    channel: addCardForm.value.channel === 'summary' ? t('汇总') : addCardForm.value.channel,
    compare_mode: addCardForm.value.compareMode,
    date_range: addCardForm.value.dateRange.map((item) => item.format('YYYY-MM-DD')),
    dimension: dimensionValue,
    x_axis_metric: chartType === 'scatter' ? addCardForm.value.xAxisMetric : undefined,
    y_axis_metric: chartType === 'scatter' ? addCardForm.value.yAxisMetric : undefined,
    x_axis: chartType === 'line' ? addCardForm.value.xAxis : undefined,
    filter_channel: addCardForm.value.filterChannel,
    // 这里必须把“筛选设置弹窗”勾选的条件一起保存下来，否则看板卡片无法显示已启用筛选
    filter_options: addFormFilterOptions.value,
    metrics: addCardForm.value.metrics,
    table_color: chartType === 'line' ? undefined : addCardForm.value.tableColor,
    chart_size: addCardForm.value.chartSize,
    group_aggregation: chartType === 'line' ? addCardForm.value.groupAggregation : undefined,
  };

  try {
    if (editingCardId.value) {
      const res = await updateMetaReportCard(editingCardId.value, {
        title: name,
        chart_type: chartType,
        shape: resolveCardShape(chartType),
        query_config: queryConfig,
      });
      const card = res?.data;
      if (!card) {
        throw new Error('empty card response');
      }
      const local = mapCardRowToLocal(card);
      const idx = customBoardCards.value.findIndex((c) => c.id === editingCardId.value);
      if (idx >= 0) {
        customBoardCards.value[idx] = local;
      } else {
        customBoardCards.value.push(local);
      }
      editingCardId.value = null;
      showAddCardDrawer.value = false;
      message.success(t('卡片已更新'));
      return;
    }

    const res = await createMetaReportCard(selectedCreatedBoard.value.key, {
      title: name,
      chart_type: chartType,
      shape: resolveCardShape(chartType),
      sort_order: customBoardCards.value.length,
      query_config: queryConfig,
    });
    const card = res?.data;
    if (!card) {
      throw new Error('empty card response');
    }
    customBoardCards.value.push(mapCardRowToLocal(card));
    showAddCardDrawer.value = false;
    message.success(t('卡片添加成功'));
  } catch (error) {
    console.error('保存卡片失败:', error);
    message.error(editingCardId.value ? t('更新卡片失败') : t('添加卡片失败'));
  }
};

const handleCardFilterChange = (card: CustomBoardCard) => {
  console.log('Filter changed for card:', card.id, card.dateRange, card.channel);
  message.loading({ content: t('数据加载中...'), key: 'card-load' });

  // 找到该卡片在数组中的索引
  const cardIndex = customBoardCards.value.findIndex(c => c.id === card.id);
  if (cardIndex === -1) return;

  // 创建一个新对象来触发 Vue 的响应式更新
  const updatedCard = JSON.parse(JSON.stringify(customBoardCards.value[cardIndex]));
  
  // 处理日期范围 (JSON 序列化会把 dayjs 转为字符串，这里需要转回来)
  if (card.dateRange && Array.isArray(card.dateRange)) {
    updatedCard.dateRange = [dayjs(card.dateRange[0]), dayjs(card.dateRange[1])];
  }

  applyCardDateRangeToDisplayFields(updatedCard as CustomBoardCard);

  // 替换原数组中的对象，触发响应式
  customBoardCards.value[cardIndex] = updatedCard;
  customBoardCards.value = [...customBoardCards.value];

  setTimeout(() => {
    message.success({ content: t('数据已更新'), key: 'card-load', duration: 2 });
  }, 500);
};

const handleRefreshCustomBoardCardsBtn = (e: MouseEvent) => {
  handleRefreshCustomBoardCards(true);
};

const handleRefreshCustomBoardCards = async (showToast = false) => {
  if (!selectedCreatedBoard.value || selectedCreatedBoard.value.boardType !== 'custom') {
    return;
  }
  cardManagerLoading.value = true;
  try {
    const res = await fetchMetaReportCards(selectedCreatedBoard.value.key);
    customBoardCards.value = (res?.data ?? []).map(mapCardRowToLocal);
    if (showToast) {
      message.success(t('刷新成功'));
    }
  } catch (error) {
    console.error('刷新卡片失败:', error);
    message.error(t('刷新失败'));
  } finally {
    cardManagerLoading.value = false;
  }
};

const handleCardManagerDrop = async (dropResult: any) => {
  if (cardManagerLoading.value) return;

  const { removedIndex, addedIndex } = dropResult ?? {};
  if (typeof removedIndex !== 'number' || typeof addedIndex !== 'number') return;
  if (removedIndex === addedIndex) return;

  // 先更新前端显示顺序
  const next = [...customBoardCards.value];
  const [moved] = next.splice(removedIndex, 1);
  if (!moved) return;
  next.splice(addedIndex, 0, moved);
  customBoardCards.value = next;

  // 再同步后端 sort_order
  cardManagerLoading.value = true;
  try {
    await Promise.all(
      next.map((card, idx) =>
        updateMetaReportCard(card.id, {
          sort_order: idx,
        }),
      ),
    );
    message.success(t('排序已更新'));
  } catch (error) {
    console.error('保存卡片排序失败:', error);
    message.error(t('保存排序失败'));
    await handleRefreshCustomBoardCards();
  } finally {
    cardManagerLoading.value = false;
  }
};

const openCardManagerModal = async () => {
  if (!selectedCreatedBoard.value || selectedCreatedBoard.value.boardType !== 'custom') {
    message.warning(t('请先选择自定义看板'));
    return;
  }
  showCardManagerModal.value = true;
  await handleRefreshCustomBoardCards();
};

const updateCardShape = async (card: CustomBoardCard, shape: 'large' | 'small') => {
  try {
    const queryConfig = { ...((card.queryConfigRaw ?? {}) as Record<string, unknown>), chart_size: shape };
    const res = await updateMetaReportCard(card.id, {
      shape,
      query_config: queryConfig,
    });
    const row = res?.data;
    if (!row) {
      throw new Error('empty card response');
    }
    const nextCard = mapCardRowToLocal(row);
    const idx = customBoardCards.value.findIndex((c) => c.id === card.id);
    if (idx >= 0) {
      customBoardCards.value[idx] = nextCard;
    }
    message.success(shape === 'large' ? t('已设为大图') : t('已设为小图'));
  } catch (error) {
    console.error('更新卡片尺寸失败:', error);
    message.error(t('操作失败'));
  }
};

const handleCardQuickMenuClick = (key: string, card: CustomBoardCard) => {
  if (key === 'to-large') {
    updateCardShape(card, 'large');
    return;
  }
  if (key === 'to-small') {
    updateCardShape(card, 'small');
    return;
  }
  if (key === 'copy' || key === 'push' || key === 'delete') {
    handleCardManagerAction(key, card);
  }
};

const handleCardManagerAction = (action: 'edit' | 'copy' | 'push' | 'delete', card: CustomBoardCard) => {
  if (action === 'edit') {
    editingCardId.value = card.id;
    fillAddCardFormFromCard(card);
    showAddCardDrawer.value = true;
    return;
  }
  if (action === 'copy') {
    message.info(t('复制功能开发中'));
    return;
  }
  if (action === 'push') {
    message.info(t('推送功能开发中'));
    return;
  }
  if (action === 'delete') {
    Modal.confirm({
      title: t('删除卡片'),
      content: t('确认删除该卡片？删除后不可恢复。'),
      okText: t('删除'),
      okType: 'danger',
      cancelText: t('取消'),
      async onOk() {
        try {
          await deleteMetaReportCard(card.id);
          customBoardCards.value = customBoardCards.value.filter((c) => c.id !== card.id);
          message.success(t('删除成功'));
        } catch (error) {
          console.error('删除卡片失败:', error);
          message.error(t('删除失败'));
          return Promise.reject(error);
        }
      },
    });
  }
};

const handleCreatedBoardMenuClick = (info: any) => {
  const key = String(info.key);
  if (!selectedCreatedBoard.value) {
    message.warning(t('请先选择看板'));
    return;
  }

  if (key === 'delete') {
    deleteDashboardId.value = selectedCreatedBoard.value.key;
    showDeleteDashboardModal.value = true;
    return;
  }

  if (key === 'rename') {
    renameDashboardForm.value.name = selectedCreatedBoard.value.label;
    showRenameDashboardModal.value = true;
    return;
  }

  if (key === 'save-as') {
    saveAsDashboardForm.value = {
      name: `${selectedCreatedBoard.value.label}-${t('副本')}`,
      folder: 'mine',
    };
    showSaveAsDashboardModal.value = true;
  }
};

const resetRenameDashboardForm = () => {
  showRenameDashboardModal.value = false;
  renameDashboardForm.value = {
    name: '',
  };
};

const submitRenameDashboard = async () => {
  if (!selectedCreatedBoard.value) {
    resetRenameDashboardForm();
    return;
  }
  const name = renameDashboardForm.value.name.trim();
  if (!name) {
    message.error(t('请输入看板名称'));
    return;
  }
  try {
    await updateMetaReportDashboard(selectedCreatedBoard.value.key, { name });
    const target = myDashboards.value.find((item) => item.key === selectedCreatedBoard.value?.key);
    if (target) {
      target.label = name;
    }
    selectedCreatedBoard.value = {
      ...selectedCreatedBoard.value,
      label: name,
    };
    message.success(t('重命名成功'));
    resetRenameDashboardForm();
  } catch (error) {
    console.error('重命名看板失败:', error);
    message.error(t('重命名看板失败'));
  }
};

const resetSaveAsDashboardForm = () => {
  showSaveAsDashboardModal.value = false;
  saveAsDashboardForm.value = {
    name: '',
    folder: 'mine',
  };
};

const submitSaveAsDashboard = async () => {
  if (!selectedCreatedBoard.value) {
    resetSaveAsDashboardForm();
    return;
  }
  const name = saveAsDashboardForm.value.name.trim();
  if (!name) {
    message.error(t('请输入看板名称'));
    return;
  }

  try {
    const sourceFolderId = myDashboards.value.find((item) => item.key === selectedCreatedBoard.value?.key)?.folderId ?? null;
    const res = await duplicateMetaReportDashboard(selectedCreatedBoard.value.key, {
      name,
      folder_id: sourceFolderId,
    });
    const row = res?.data;
    if (!row) {
      throw new Error('empty duplicate response');
    }
    const board = toLocalBoard(row);
    myDashboards.value.unshift(board);
    selectedCreatedBoard.value = {
      key: board.key,
      label: board.label,
      boardType: board.boardType,
    };
    selectedSidebarNode.value = {
      type: 'board',
      folderId: board.folderId,
    };
    selectedReport.value = board.boardType === 'comprehensive' ? 'created-comprehensive' : 'created-custom';
    customBoardCards.value = (row.cards ?? []).map(mapCardRowToLocal);
    message.success(t('另存为成功'));
    resetSaveAsDashboardForm();
  } catch (error) {
    console.error('另存为失败:', error);
    message.error(t('另存为失败'));
  }
};

const openDashboard = (key: string) => {
  const target = myDashboards.value.find((item) => item.key === key) ?? null;
  if (target) {
    if (target.folderId) {
      const folderKey = `folder:${target.folderId}`;
      if (!expandedTreeKeys.value.includes(SIDEBAR_ROOT_KEY)) {
        expandedTreeKeys.value = [...expandedTreeKeys.value, SIDEBAR_ROOT_KEY];
      }
      if (!expandedTreeKeys.value.includes(folderKey)) {
        expandedTreeKeys.value = [...expandedTreeKeys.value, folderKey];
      }
    }
    selectedCreatedBoard.value = target;
    selectedSidebarNode.value = {
      type: 'board',
      folderId: target.folderId ?? null,
    };
    selectedReport.value = target.boardType === 'comprehensive' ? 'created-comprehensive' : 'created-custom';
    if (target.boardType === 'custom') {
      fetchMetaReportCards(key)
        .then((res) => {
          customBoardCards.value = (res?.data ?? []).map(mapCardRowToLocal);
        })
        .catch((error) => {
          console.error('加载卡片失败:', error);
          customBoardCards.value = [];
        });
    }
    return;
  }
  selectReport(key);
};

