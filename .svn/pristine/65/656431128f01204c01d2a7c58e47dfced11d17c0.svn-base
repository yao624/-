            <template v-for="item in getCardEnabledFiltersWithoutChannel(card)" :key="`${card.id}-${item.key}`">
              <div class="filter-box" style="min-width: 140px;">
                <div class="label">
                  <span>{{ item.label }}</span>
                </div>
                <a-select
                  v-model:value="item.value"
                  size="small"
                  :bordered="false"
                  style="width: 140px"
                  show-search
                  :filter-option="(input, option) => String(option?.label || '').toLowerCase().includes(input.toLowerCase())"
                  :options="item.options"
                  @change="handleCardFilterChange(card)"
                />
              </div>
            </template>
            <a-button size="small" class="card-filter-action-btn" @click="openCardFilterModal(card)">
              <filter-outlined />
            </a-button>
          </div>
          <div class="pie-chart-container" :class="[`pie-size-${card.shape}`]">
            <div class="pie-chart-left">
              <div class="pie-mock-wrap">
                <DonutChart
                  :data="getPieChartData(card)"
                  :height="card.shape === 'large' ? 360 : 260"
                  :show-legend="false"
                />
                <svg v-if="false" viewBox="0 0 100 100" class="pie-svg">
                  <!-- 模拟环形图 -->
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#1890ff" stroke-width="20" stroke-dasharray="80 200" stroke-dashoffset="0" />
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#faad14" stroke-width="20" stroke-dasharray="60 200" stroke-dashoffset="-80" />
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#52c41a" stroke-width="20" stroke-dasharray="40 200" stroke-dashoffset="-140" />
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#722ed1" stroke-width="20" stroke-dasharray="30 200" stroke-dashoffset="-180" />
                  <circle cx="50" cy="50" r="50" fill="white" />
                  <circle cx="50" cy="50" r="30" fill="white" />
                  <!-- 内部环形 -->
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#1890ff" stroke-width="20" stroke-dasharray="80 251" stroke-dashoffset="0" />
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#faad14" stroke-width="20" stroke-dasharray="60 251" stroke-dashoffset="-80" />
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#52c41a" stroke-width="20" stroke-dasharray="40 251" stroke-dashoffset="-140" />
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#722ed1" stroke-width="20" stroke-dasharray="71 251" stroke-dashoffset="-180" />
                  <circle cx="50" cy="50" r="25" fill="white" />
                </svg>
                <div v-if="card.shape === 'large'" class="pie-labels-overlay">
                  <div
                    v-for="(item, oidx) in getPieTableRows(card).slice(0, 4)"
                    :key="`pie-ol-${card.id}-${item.date}`"
                    class="pie-label-item"
                    :style="pieOverlayLabelStyles[oidx] || pieOverlayLabelStyles[0]"
                  >
                    {{ item.date }}
                  </div>
                </div>
              </div>
            </div>
            <div class="pie-chart-right">
              <div class="pie-table-mock">
                <div class="pie-table-head">
                  <span class="col-date">{{ t('日期') }}</span>
                  <span class="col-ratio">{{ t('占比') }}</span>
                  <span v-if="card.shape === 'large'" class="col-value">{{ getMetricLabel(card.metrics[0]) }}</span>
                </div>
                <div class="pie-table-body">
                  <div v-for="(item, idx) in getPieTableRows(card)" :key="`pie-tr-${card.id}-${item.date}-${idx}`" class="pie-table-row">
                    <span class="col-date">
                      <i class="color-dot" :style="{ backgroundColor: item.color }"></i>
                      {{ item.date }}
                    </span>
                    <span class="col-ratio">{{ item.ratio }}</span>
                    <span v-if="card.shape === 'large'" class="col-value">{{ item.value }}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </template>
        <template
          v-else-if="[
            'line',
            'area',
            'stack-area',
            'percent-stack-area',
            'bar',
            'stack-bar',
            'percent-stack-bar',
            'horizontal-bar',
            'stack-horizontal-bar',
            'percent-stack-horizontal-bar'
          ].includes(card.chartType)"
        >
          <div class="card-filter-row line-card-filters" :class="{ compact: card.shape === 'large' }">
            <div class="filter-box date-box">
              <div class="label">
                <span>{{ t('日') }}</span>
                <span>{{ t('期') }}</span>
              </div>
              <a-range-picker
                v-model:value="card.dateRange"
                format="YYYY/MM/DD"
                size="small"
                :bordered="false"
                :separator="'→'"
                @change="handleCardFilterChange(card)"
              />
            </div>
            <div v-if="hasChannelFilter(card)" class="filter-box channel-box">
              <div class="label">
                <span>{{ t('渠') }}</span>
                <span>{{ t('道') }}</span>
              </div>
              <a-select
                v-model:value="card.channel"
                size="small"
                :bordered="false"
                style="width: 100px"
                @change="handleCardFilterChange(card)"
              >
                <a-select-option value="summary">{{ t('汇总') }}</a-select-option>
                <a-select-option value="meta">Meta</a-select-option>
                <a-select-option value="google">Google</a-select-option>
              </a-select>
            </div>
            <template v-for="item in getCardEnabledFiltersWithoutChannel(card)" :key="`${card.id}-${item.key}`">
              <div class="filter-box" style="min-width: 140px;">
                <div class="label">
                  <span>{{ item.label }}</span>
                </div>
                <a-select
                  v-model:value="item.value"
                  size="small"
                  :bordered="false"
                  style="width: 140px"
                  show-search
                  :filter-option="(input, option) => String(option?.label || '').toLowerCase().includes(input.toLowerCase())"
                  :options="item.options"
                  @change="handleCardFilterChange(card)"
                />
              </div>
            </template>
            <a-button size="small" class="card-filter-action-btn" @click="openCardFilterModal(card)">
              <filter-outlined />
            </a-button>
          </div>
          <TrendChart
            :x-axis="getTrendXAxis(card)"
            :series="getTrendSeries(card)"
            :height="card.shape === 'large' ? 500 : 320"
            :show-legend="true"
            :horizontal="['horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(card.chartType)"
            :percent-stack="['percent-stack-area', 'percent-stack-bar', 'percent-stack-horizontal-bar'].includes(card.chartType)"
          />
            <div v-if="false"
              class="trend-chart-mock"
              :class="[
                card.shape === 'large' ? 'trend-chart-mock--large' : 'trend-chart-mock--small',
                {
                  'trend-chart-mock--area': ['area', 'stack-area', 'percent-stack-area'].includes(card.chartType),
                  'trend-chart-mock--bar': ['bar', 'stack-bar', 'percent-stack-bar', 'horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(card.chartType)
                }
              ]"
            >
              <div class="trend-chart-watermark" aria-hidden="true">{{ t('示例数据看板') }}</div>
              <div
                class="trend-chart-body"
                :class="{
                  'trend-horizontal': isHorizontalBarChartType(card.chartType),
                  'trend-horizontal-scroll': shouldHorizontalScroll(card),
                }"
              >
                <div
                  class="trend-y-axis"
                  :class="{ 'trend-y-axis--horizontal': ['horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(card.chartType) }"
                  :style="getHorizontalScrollBoxStyle(card)"
                >
                  <template v-if="['horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(card.chartType)">
                    <span
                      v-for="(lab, yi) in card.xAxisLabels || []"
                      :key="`y-${card.id}-${yi}`"
                      style="position: absolute; left: 0; right: 0; transform: translateY(-50%); text-align: right;"
                      :style="{ top: `${getHorizontalRowTopPercent(yi, (card.xAxisLabels || []).length || 7, card.shape)}%` }"
                    >
                      {{ lab }}
                    </span>
                  </template>
                  <template v-else>
                    <span v-for="(lab, yi) in trendYLabels(card.shape === 'large')" :key="`y-${card.id}-${yi}`">{{
                      lab
                    }}</span>
                  </template>
                </div>
                <div
                  class="trend-plot-wrap"
                  :class="{
                    'trend-plot-wrap--large': card.shape === 'large',
                    'trend-plot-wrap--horizontal': ['horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(card.chartType),
                    'trend-bar-x-scroll': shouldBarXScroll(card),
                  }"
                  :style="getHorizontalScrollBoxStyle(card)"
                  :data-bar-scroll-body="card.id"
                  @scroll="handleBarXScroll(card, 'body', $event)"
                >
                  <div class="trend-plot-inner" :style="getBarXScrollBoxStyle(card)">
                    <div
                      class="trend-grid"
                      :class="{
                        'trend-grid--horizontal': ['horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(card.chartType)
                      }"
                    />
                    <svg
                      class="trend-line-svg"
                      :viewBox="getTrendChartMockSvgViewBox(card)"
                      preserveAspectRatio="none"
                      @mousemove="e => handleChartMouseMove(e, card)"
                      @mouseleave="handleChartMouseLeave(card)"
                    >
                    <line
                      v-if="card.activeIndex !== null && card.activeIndex !== undefined"
                      :x1="getTwoBarTickCenterPercent(card.activeIndex, card.xAxisLabels?.length || 7)"
                      y1="0"
                      :x2="getTwoBarTickCenterPercent(card.activeIndex, card.xAxisLabels?.length || 7)"
                      :y2="getTrendChartMockSvgHeight(card)"
                      stroke="#94a3b8"
                      stroke-width="0.5"
                      stroke-dasharray="2,2"
                    />
                    <template v-if="card.chartType === 'percent-stack-area'">
                      <!-- %堆积面积图：分段堆叠绘制 -->
                      <g v-for="i in [0, 1, 2, 3, 4, 5]" :key="`ps-${i}`">
                        <path
                          :d="[
                            'M0,64 L0,58 L25,62 L50,60 L75,64 L100,58 L100,64 Z',
                            'M0,58 L0,50 L25,55 L50,52 L75,58 L100,50 L100,58 Z',
                            'M0,50 L0,40 L25,45 L50,42 L75,48 L100,40 L100,50 Z',
                            'M0,40 L0,30 L25,35 L50,32 L75,38 L100,30 L100,40 Z',
                            'M0,30 L0,20 L25,25 L50,22 L75,28 L100,20 L100,30 Z',
                            'M0,20 L0,10 L25,15 L50,12 L75,18 L100,10 L100,20 Z'
                          ][i]"
                          :fill="['#1890ff', '#faad14', '#52c41a', '#722ed1', '#13c2c2', '#91d5ff'][i]"
                          fill-opacity="0.3"
                        />
                        <path
                          :d="[
                            'M0,58 L25,62 L50,60 L75,64 L100,58',
                            'M0,50 L25,55 L50,52 L75,58 L100,50',
                            'M0,40 L25,45 L50,42 L75,48 L100,40',
                            'M0,30 L25,35 L50,32 L75,38 L100,30',
                            'M0,20 L25,25 L50,22 L75,28 L100,20',
                            'M0,10 L25,15 L50,12 L75,18 L100,10'
                          ][i]"
                          fill="none"
                          :stroke="['#1890ff', '#faad14', '#52c41a', '#722ed1', '#13c2c2', '#91d5ff'][i]"
                          stroke-width="1.5"
                          vector-effect="non-scaling-stroke"
                        />
                      </g>
                    </template>
                    <template v-else-if="card.chartType === 'stack-area'">
                      <!-- 堆积面积图：分段堆叠绘制 -->
                      <g v-for="i in [0, 1, 2, 3, 4]" :key="`s-${i}`">
                        <path
                          :d="[
                            'M0,64 L0,55 L16.6,10 L33.3,20 L50,5 L66.6,10 L83.3,5 L100,10 L100,64 Z',
                            'M0,55 L0,45 L16.6,20 L33.3,30 L50,15 L66.6,20 L83.3,15 L100,20 L100,55 Z',
                            'M0,45 L0,35 L16.6,30 L33.3,40 L50,25 L66.6,30 L83.3,25 L100,30 L100,45 Z',
                            'M0,35 L0,25 L16.6,40 L33.3,50 L50,35 L66.6,40 L83.3,35 L100,40 L100,35 Z',
                            'M0,25 L0,15 L16.6,50 L33.3,60 L50,45 L66.6,50 L83.3,45 L100,50 L100,25 Z'
                          ][i]"
                          :fill="['#1890ff', '#faad14', '#52c41a', '#722ed1', '#13c2c2'][i]"
                          fill-opacity="0.3"
                        />
                        <path
                          :d="[
                            'M0,55 L16.6,10 L33.3,20 L50,5 L66.6,10 L83.3,5 L100,10',
                            'M0,45 L16.6,20 L33.3,30 L50,15 L66.6,20 L83.3,15 L100,20',
                            'M0,35 L16.6,30 L33.3,40 L50,25 L66.6,30 L83.3,25 L100,30',
                            'M0,25 L16.6,40 L33.3,50 L50,35 L66.6,40 L83.3,35 L100,40',
                            'M0,15 L16.6,50 L33.3,60 L50,45 L66.6,50 L83.3,45 L100,50'
                          ][i]"
                          fill="none"
                          :stroke="['#1890ff', '#faad14', '#52c41a', '#722ed1', '#13c2c2'][i]"
                          stroke-width="1.5"
                          vector-effect="non-scaling-stroke"
                        />
                      </g>
                    </template>
                    <template v-else-if="['stack-bar', 'percent-stack-bar'].includes(card.chartType)">
                      <!-- 堆积柱状图 / %堆积柱状图：精准对齐刻度线中心 (斜杠处) -->
                      <g v-for="(label, gi) in (card.xAxisLabels || [0, 1, 2, 3, 4, 5, 6])" :key="`sbg-${gi}`">
                        <rect
                          v-for="bi in [0, 1, 2, 3, 4, 5]"
                          :key="`sb-${gi}-${bi}`"
                          :x="getTwoBarTickCenterPercent(gi, card.xAxisLabels?.length || 7) - 4"
                          :y="[
                            // 从底部开始堆叠：保证每一段都正确累加到底部 64
                            54, 44, 38, 26, 18, 8
                          ][bi]"
                          :width="8"
                          :height="[10, 10, 6, 12, 8, 10][bi]"
                          :fill="['#1890ff', '#faad14', '#52c41a', '#722ed1', '#13c2c2', '#91d5ff'][bi]"
                          rx="0"
                        />
                      </g>
                    </template>
                    <template v-else-if="['horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(card.chartType)">
                      <!-- 横向条形图：y 轴为日期，x 轴为数值刻度（mock：0~6000万） -->
                      
                      <g
                        v-for="(label, gi) in (card.xAxisLabels || ['03/05', '03/06', '03/07', '03/08', '03/09', '03/10', '03/11', '03/12', '03/13'])"
                        :key="`hb-row-${gi}`"
                      >
                        <rect
                          :x="0"
                          :y="getHorizontalRowY(gi, (card.xAxisLabels || []).length || 7, card.shape) - getHorizontalBarHeight(card.shape, (card.xAxisLabels || []).length || 7) / 2"
                          :width="getHorizontalValueToX(1) - 0"
                          :height="getHorizontalBarHeight(card.shape, (card.xAxisLabels || []).length || 7)"
                          fill="transparent"
                        />

                        <!-- 单指标横向条形图：两根指标则按 y 方向上下错开 -->
                        <template v-if="card.chartType === 'horizontal-bar'">
                          <template v-if="card.metrics && card.metrics.length > 1">
                            <rect
                              :x="0"
                              :y="getHorizontalRowY(gi, (card.xAxisLabels || []).length || 7, card.shape) - getHorizontalBarHeight(card.shape, (card.xAxisLabels || []).length || 7) / 2"
                              :width="getHorizontalValueToX(getHorizontalMockTotal(gi) * 0.85) - 0"
                              :height="getHorizontalBarHeight(card.shape, (card.xAxisLabels || []).length || 7) / 2"
                              fill="#1890ff"
                              rx="0"
                            />
                            <rect
                              :x="0"
                              :y="getHorizontalRowY(gi, (card.xAxisLabels || []).length || 7, card.shape)"
                              :width="getHorizontalValueToX(getHorizontalMockTotal(gi) * 0.55) - 0"
                              :height="getHorizontalBarHeight(card.shape, (card.xAxisLabels || []).length || 7) / 2"
                              fill="#faad14"
                              rx="0"
                            />
                          </template>
                          <template v-else>
                            <rect
                              :x="0"
                              :y="getHorizontalRowY(gi, (card.xAxisLabels || []).length || 7, card.shape) - getHorizontalBarHeight(card.shape, (card.xAxisLabels || []).length || 7) / 2"
                              :width="getHorizontalValueToX(getHorizontalMockTotal(gi)) - 0"
                              :height="getHorizontalBarHeight(card.shape, (card.xAxisLabels || []).length || 7)"
                              fill="#1890ff"
                              rx="0"
                            />
                          </template>
                        </template>

                        <!-- 堆积横向条形图：分段沿 x 方向堆叠 -->
                        <template v-else>
                          <rect
                            :x="0"
                            :y="getHorizontalRowY(gi, (card.xAxisLabels || []).length || 7, card.shape) - getHorizontalBarHeight(card.shape, (card.xAxisLabels || []).length || 7) / 2"
                            :width="getHorizontalValueToX(0) - 0"
                            :height="getHorizontalBarHeight(card.shape, (card.xAxisLabels || []).length || 7)"
                            fill="none"
                          />
                          <template v-for="bi in [0, 1, 2, 3, 4, 5]" :key="`hb-seg-${gi}-${bi}`">
                            <rect
                              :x="
                                getHorizontalValueToX(
                                  card.chartType === 'percent-stack-horizontal-bar'
                                    ? HORIZONTAL_MAX_VALUE * (horizontalStackPrefix[bi - 1] ?? 0)
                                    : getHorizontalStackCumBefore(gi, bi)
                                )
                              "
                              :y="getHorizontalRowY(gi, (card.xAxisLabels || []).length || 7, card.shape) - getHorizontalBarHeight(card.shape, (card.xAxisLabels || []).length || 7) / 2"
                              :height="getHorizontalBarHeight(card.shape, (card.xAxisLabels || []).length || 7)"
                              :width="
                                getHorizontalValueToX(
                                  card.chartType === 'percent-stack-horizontal-bar'
                                    ? HORIZONTAL_MAX_VALUE * horizontalStackPrefix[bi]
                                    : getHorizontalStackCumBefore(gi, bi) + getHorizontalStackValue(gi, bi)
                                ) - getHorizontalValueToX(
                                  card.chartType === 'percent-stack-horizontal-bar'
                                    ? HORIZONTAL_MAX_VALUE * (horizontalStackPrefix[bi - 1] ?? 0)
                                    : getHorizontalStackCumBefore(gi, bi)
                                )
                              "
                              :fill="['#1890ff', '#faad14', '#52c41a', '#722ed1', '#13c2c2', '#91d5ff'][bi]"
                              rx="0"
                            />
                          </template>
                        </template>
                      </g>
                    </template>
                    <template v-else-if="card.chartType === 'bar'">
                      <!-- 柱状图：双指标模式下，左柱中心对准“月”，右柱中心对准“日” -->
                      <g v-for="(label, gi) in (card.xAxisLabels || [0, 1, 2, 3, 4, 5, 6])" :key="`bg-${gi}`">
                        <template v-if="card.groupAggregation">
                          <!-- 分组聚合多柱：以中心对齐 -->
                          <rect
                            v-for="bi in [0, 1, 2, 3, 4]"
                            :key="`b-${gi}-${bi}`"
                            :x="getTwoBarTickCenterPercent(gi, card.xAxisLabels?.length || 7) - 10 + bi * 4"
                            :y="64 - (Math.random() * 40 + 10)"
                            width="3"
                            height="40"
                            :fill="['#1890ff', '#faad14', '#52c41a', '#722ed1', '#13c2c2'][bi]"
                            rx="0"
                          />
                        </template>
                        <template v-else-if="card.metrics && card.metrics.length > 1">
                          <!-- 双指标模式：两根柱在“同一个日期中心”左右对称显示（柱宽随刻度密度自适应） -->
                          <rect
                            :x="getTwoBarTickCenterPercent(gi, card.xAxisLabels?.length || 7) + getTwoBarLeftOffset(card.xAxisLabels?.length || 7, card.shape)"
                            :y="64 - 45"
                            :width="getTwoBarWidth(card.xAxisLabels?.length || 7, card.shape)"
                            :height="45"
                            fill="#1890ff"
                            rx="0"
                          />
                          <rect
                            :x="getTwoBarTickCenterPercent(gi, card.xAxisLabels?.length || 7) + getTwoBarRightOffset(card.xAxisLabels?.length || 7, card.shape)"
                            :y="64 - 25"
                            :width="getTwoBarWidth(card.xAxisLabels?.length || 7, card.shape)"
                            :height="25"
                            fill="#faad14"
                            rx="0"
                          />
                        </template>
                        <template v-else>
                          <!-- 单指标单柱：居中对齐 -->
                          <rect :x="getTwoBarTickCenterPercent(gi, card.xAxisLabels?.length || 7) - 4" :y="24" width="8" height="40" fill="#1890ff" rx="0" />
                        </template>
                      </g>
                    </template>
                    <template v-else>
                      <g v-for="(mKey, mi) in (card.metrics || []).slice(0, 2)" :key="`tg-${mi}`">
                        <path
                          v-if="card.chartType === 'area'"
                          :d="['M0,40 L16.6,35 L33.3,45 L50,30 L66.6,35 L83.3,20 L100,25 L100,64 L0,64 Z', 'M0,50 L16.6,45 L33.3,55 L50,40 L66.6,45 L83.3,30 L100,35 L100,64 L0,64 Z'][mi % 2]"
                          :fill="['rgba(24, 144, 255, 0.2)', 'rgba(250, 173, 20, 0.2)'][mi % 2]"
                        />
                        <path
                          :d="['M0,40 L16.6,35 L33.3,45 L50,30 L66.6,35 L83.3,20 L100,25', 'M0,50 L16.6,45 L33.3,55 L50,40 L66.6,45 L83.3,30 L100,35'][mi % 2]"
                          fill="none"
                          :stroke="['#1890ff', '#faad14'][mi % 2]"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          vector-effect="non-scaling-stroke"
                        />
                      </g>
                    </template>
                    </svg>
                  </div>
                </div>
              </div>
              <div
                v-if="card.shape === 'large'"
                class="trend-x-axis"
                :class="{ 'trend-x-axis-scroll': shouldBarXScroll(card) }"
                style="padding: 0; display: block; margin-top: 4px;"
                :data-bar-scroll-axis="card.id"
                @scroll="handleBarXScroll(card, 'axis', $event)"
              >
                <template v-if="['horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(card.chartType)">
                  <!-- 横向条形图：底部为数值刻度（0/1000万...），左侧 y 轴为日期 -->
                  <div class="trend-x-axis-abs-wrap" style="position: relative; margin-left: 46px; width: calc(100% - 46px); height: 18px;" :style="getVerticalBarXAxisInnerStyle(card)">
                    <template v-if="card.chartType === 'percent-stack-horizontal-bar'">
                      <span
                        v-for="(tick, idx) in [0, 30, 60, 90, 120, 150]"
                        :key="`x-${card.id}-${idx}`"
                        style="position: absolute; transform: translateX(-50%); font-size: 12px; color: #94a3b8;"
                        :style="{ left: `${(tick / 150) * 100}%` }"
                      >
                        {{ tick }}%
                      </span>
                    </template>
                    <template v-else>
                      <span
                        v-for="(tick, idx) in [0, 1000, 2000, 3000, 4000, 5000, 6000]"
                        :key="`x-${card.id}-${idx}`"
                        style="position: absolute; transform: translateX(-50%); font-size: 12px; color: #94a3b8;"
                        :style="{ left: `${(tick / 6000) * 100}%` }"
                      >
                        {{ tick === 0 ? '0' : (tick >= 1000 ? (tick / 1000) + t('千万') : tick) }}
                      </span>
                    </template>
                  </div>
                </template>
                <template v-else-if="['stack-bar', 'percent-stack-bar'].includes(card.chartType)">
                  <div style="position: relative; margin-left: 46px; width: calc(100% - 46px); height: 18px;" :style="getVerticalBarXAxisInnerStyle(card)">
                    <span
                      v-for="(label, idx) in card.xAxisLabels"
                      :key="label"
                      class="trend-x-axis-abs-item"
                      :style="{ left: `${getStackBarCenterPercent(idx, card.xAxisLabels.length)}%` }"
                      style="position: absolute; top: 0; transform: translateX(-50%); text-align: center; white-space: nowrap; font-size: 11px; color: #94a3b8; display: flex; justify-content: center; align-items: center;"
                    >
                      <span style="display: inline-block; width: 18px; text-align: center;">{{ label.split('/')[0] }}</span>
                      <span style="width: 6px; text-align: center; color: #cbd5e1;">/</span>
                      <span style="display: inline-block; width: 18px; text-align: center;">{{ label.split('/')[1] }}</span>
                    </span>
                  </div>
                </template>
                <template v-else>
                  <div style="position: relative; height: 18px; margin-left: 46px; width: calc(100% - 46px); box-sizing: border-box;" :style="getVerticalBarXAxisInnerStyle(card)">
                    <template v-if="card.chartType === 'bar' && card.metrics && card.metrics.length > 1">
                      <template v-for="(label, gi) in (card.xAxisLabels || [])" :key="`${label}-${gi}`">
                        <span
                          style="position: absolute; top: 50%; transform: translate(-50%, -50%); width: 18px; text-align: center; display: inline-block; font-size: 11px; color: #94a3b8;"
                          :style="{ left: `${getTwoBarMonthLabelLeftPercent(gi, card.xAxisLabels.length, card.shape)}%` }"
                        >
                          {{ label.split('/')[0] }}
                        </span>
                        <span
                          style="position: absolute; top: 50%; transform: translate(-50%, -50%); width: 6px; text-align: center; color: #cbd5e1; display: inline-block; font-size: 11px;"
                          :style="{ left: `${getTwoBarTickCenterPercent(gi, card.xAxisLabels.length)}%` }"
                        >
                          /
                        </span>
                        <span
                          style="position: absolute; top: 50%; transform: translate(-50%, -50%); width: 18px; text-align: center; display: inline-block; font-size: 11px; color: #94a3b8;"
                          :style="{ left: `${getTwoBarDayLabelLeftPercent(gi, card.xAxisLabels.length, card.shape)}%` }"
                        >
                          {{ label.split('/')[1] }}
                        </span>
                      </template>
                    </template>
                    <template v-else>
                      <div style="display: flex; height: 100%; align-items: center;">
                        <span
                          v-for="label in card.xAxisLabels"
                          :key="label"
                          style="flex: 1; text-align: center; white-space: nowrap; font-size: 11px; color: #94a3b8; position: relative; display: block;"
                        >
                          <span style="display: inline-block; width: 18px; text-align: center;">{{ label.split('/')[0] }}</span>
                          <span style="width: 6px; text-align: center; color: #cbd5e1;">/</span>
                          <span style="display: inline-block; width: 18px; text-align: center;">{{ label.split('/')[1] }}</span>
                        </span>
                      </div>
                    </template>
                  </div>
                </template>
              </div>
              <div
                v-else
                class="trend-x-axis trend-x-axis--small"
                :class="{ 'trend-x-axis-scroll': shouldBarXScroll(card) }"
                style="padding: 0; display: block; margin-top: 2px;"
                :data-bar-scroll-axis="card.id"
                @scroll="handleBarXScroll(card, 'axis', $event)"
              >
                <template v-if="['horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(card.chartType)">
                  <div class="trend-x-axis-abs-wrap" style="position: relative; margin-left: 46px; width: calc(100% - 46px); height: 16px;" :style="getVerticalBarXAxisInnerStyle(card)">
                    <template v-if="card.chartType === 'percent-stack-horizontal-bar'">
                      <span
                        v-for="(tick, idx) in [0, 30, 60, 90, 120, 150]"
                        :key="`x-small-${card.id}-${idx}`"
                        style="position: absolute; transform: translateX(-50%); font-size: 10px; color: #94a3b8;"
                        :style="{ left: `${(tick / 150) * 100}%` }"
                      >
                        {{ tick }}%
                      </span>
                    </template>
                    <template v-else>
                      <span
                        v-for="(tick, idx) in [0, 1000, 2000, 3000, 4000, 5000, 6000]"
                        :key="`x-${card.id}-${idx}`"
                        style="position: absolute; transform: translateX(-50%); font-size: 10px; color: #94a3b8;"
                        :style="{ left: `${(tick / 6000) * 100}%` }"
                      >
                        {{ tick === 0 ? '0' : (tick >= 1000 ? (tick / 1000) + t('千万') : tick) }}
                      </span>
                    </template>
                  </div>
                </template>
                <template v-else-if="['stack-bar', 'percent-stack-bar'].includes(card.chartType)">
                  <div style="position: relative; margin-left: 46px; width: calc(100% - 46px); height: 16px;" :style="getVerticalBarXAxisInnerStyle(card)">
                    <span
                      v-for="(label, idx) in card.xAxisLabels"
                      :key="label"
                      class="trend-x-axis-abs-item"
                      :style="{ left: `${getStackBarCenterPercent(idx, card.xAxisLabels.length)}%` }"
                      style="position: absolute; top: 0; transform: translateX(-50%); text-align: center; white-space: nowrap; font-size: 10px; color: #94a3b8; display: flex; justify-content: center; align-items: center;"
                    >
                      <span style="display: inline-block; width: 14px; text-align: center;">{{ label.split('/')[0] }}</span>
                      <span style="width: 4px; text-align: center; color: #cbd5e1;">/</span>
                      <span style="display: inline-block; width: 14px; text-align: center;">{{ label.split('/')[1] }}</span>
                    </span>
                  </div>
                </template>
                <template v-else>
                  <div style="position: relative; height: 16px; margin-left: 46px; width: calc(100% - 46px); box-sizing: border-box;" :style="getVerticalBarXAxisInnerStyle(card)">
                    <template v-if="card.chartType === 'bar' && card.metrics && card.metrics.length > 1">
                      <template v-for="(label, gi) in (card.xAxisLabels || [])" :key="`${label}-${gi}`">
                        <span
                          style="position: absolute; top: 50%; transform: translate(-50%, -50%); width: 14px; text-align: center; display: inline-block; font-size: 10px; color: #94a3b8;"
                          :style="{ left: `${getTwoBarMonthLabelLeftPercent(gi, card.xAxisLabels.length, card.shape)}%` }"
                        >
                          {{ label.split('/')[0] }}
                        </span>
                        <span
                          style="position: absolute; top: 50%; transform: translate(-50%, -50%); width: 4px; text-align: center; color: #cbd5e1; display: inline-block; font-size: 10px;"
                          :style="{ left: `${getTwoBarTickCenterPercent(gi, card.xAxisLabels.length)}%` }"
                        >
                          /
                        </span>
                        <span
                          style="position: absolute; top: 50%; transform: translate(-50%, -50%); width: 14px; text-align: center; display: inline-block; font-size: 10px; color: #94a3b8;"
                          :style="{ left: `${getTwoBarDayLabelLeftPercent(gi, card.xAxisLabels.length, card.shape)}%` }"
                        >
                          {{ label.split('/')[1] }}
                        </span>
                      </template>
                    </template>
                    <template v-else>
                      <div style="display: flex; height: 100%; align-items: center;">
                        <span
                          v-for="label in card.xAxisLabels"
                          :key="label"
                          style="flex: 1; text-align: center; white-space: nowrap; font-size: 10px; color: #94a3b8; position: relative; display: block;"
                        >
                          <span style="display: inline-block; width: 14px; text-align: center;">{{ label.split('/')[0] }}</span>
                          <span style="width: 4px; text-align: center; color: #cbd5e1;">/</span>
                          <span style="display: inline-block; width: 14px; text-align: center;">{{ label.split('/')[1] }}</span>
                        </span>
                      </div>
                    </template>
                  </div>
                </template>
              </div>
              <div v-if="card.shape === 'large'" class="trend-datazoom" aria-hidden="true">
                <div class="trend-datazoom-track">
                  <div class="trend-datazoom-spark" />
                  <div class="trend-datazoom-window" />
                </div>
              </div>
              <div class="trend-legend-wrap">
                <div class="trend-legend" style="display: flex; justify-content: center; gap: 16px; flex-wrap: wrap;">
                  <template v-if="card.chartType === 'bar'">
                    <!-- 分组聚合：展示“部门名称”图例 -->
                    <template v-if="card.groupAggregation">
                      <div v-for="i in [1, 2, 3, 4, 5]" :key="i" class="trend-legend-item" style="display: flex; align-items: center; gap: 8px;">
                        <span class="trend-legend-swatch" :style="{ backgroundColor: ['#1890ff', '#faad14', '#52c41a', '#722ed1', '#13c2c2'][i-1], width: '12px', height: '12px', borderRadius: '2px' }" />
                        <span style="font-size: 12px; color: #3d4e68;">{{ t('部门名称') }}_{{ i * 4 }}</span>
                      </div>
                    </template>
                    <!-- 非分组聚合：双指标/单指标图例 -->
                    <template v-else-if="card.metrics && card.metrics.length > 0">
                      <div v-for="(mKey, mIdx) in card.metrics.slice(0, 2)" :key="mKey" class="trend-legend-item" style="display: flex; align-items: center; gap: 8px;">
                        <span class="trend-legend-swatch" :style="{ backgroundColor: ['#1890ff', '#faad14'][mIdx], width: '12px', height: '12px', borderRadius: '2px' }" />
                        <span style="font-size: 13px; color: #3d4e68;">{{ getMetricLabel(mKey) }}</span>
                      </div>
                    </template>
                    <!-- fallback -->
                    <template v-else>
                      <div class="trend-legend-item" style="display: flex; align-items: center; gap: 8px;">
                        <span class="trend-legend-swatch" style="background-color: #1890ff; width: 12px; height: 12px; border-radius: 2px;" />
                        <span style="font-size: 13px; color: #3d4e68;">{{ t('花费') }}</span>
                      </div>
                    </template>
                  </template>
                  <template v-else-if="['stack-area', 'percent-stack-area', 'stack-bar', 'percent-stack-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(card.chartType)">
                    <div v-for="i in [1, 2, 3, 4, 5, 6]" :key="i" class="trend-legend-item" style="display: flex; align-items: center; gap: 8px;">
                      <span class="trend-legend-swatch" :style="{ backgroundColor: ['#1890ff', '#faad14', '#52c41a', '#722ed1', '#13c2c2', '#91d5ff'][i-1], width: '12px', height: '12px', borderRadius: '2px' }" />
                      <span style="font-size: 12px; color: #3d4e68;">{{ i <= 5 ? `${t('部门名称')}_${i * 4}` : t('其他') }}</span>
                    </div>
                  </template>
                  <template v-else-if="card.metrics && card.metrics.length > 0">
                    <div v-for="(mKey, mIdx) in card.metrics.slice(0, 2)" :key="mKey" class="trend-legend-item" style="display: flex; align-items: center; gap: 8px;">
                      <span class="trend-legend-swatch" :style="{ backgroundColor: ['#1890ff', '#faad14'][mIdx], width: '12px', height: '12px', borderRadius: '2px' }" />
                      <span style="font-size: 13px; color: #3d4e68;">{{ getMetricLabel(mKey) }}</span>
                    </div>
                  </template>
                  <template v-else>
                    <div class="trend-legend-item" style="display: flex; align-items: center; gap: 8px;">
                      <span class="trend-legend-swatch" style="background-color: #1890ff; width: 12px; height: 12px; border-radius: 2px;" />
                      <span style="font-size: 13px; color: #3d4e68;">{{ t('花费') }}</span>
                    </div>
                  </template>
                </div>
              </div>
            </div>
          </template>
        <template v-else>
          <div class="card-toolbar">
            <div class="card-filter-row line-card-filters" :class="{ compact: card.shape === 'large' }">
              <div class="filter-box date-box">
                <div class="label">
                  <span>{{ t('日') }}</span>
                  <span>{{ t('期') }}</span>
                </div>
                <a-range-picker
                  v-model:value="card.dateRange"
                  format="YYYY/MM/DD"
                  size="small"
                  :bordered="false"
                  :separator="'→'"
                  @change="handleCardFilterChange(card)"
                />
              </div>
              <div v-if="hasChannelFilter(card)" class="filter-box channel-box">
                <div class="label">
                  <span>{{ t('渠') }}</span>
                  <span>{{ t('道') }}</span>
                </div>
                <a-select
                  v-model:value="card.channel"
                  size="small"
                  :bordered="false"
                  style="width: 100px"
                  @change="handleCardFilterChange(card)"
                >
                  <a-select-option value="summary">{{ t('汇总') }}</a-select-option>
                  <a-select-option value="meta">Meta</a-select-option>
                  <a-select-option value="google">Google</a-select-option>
                </a-select>
              </div>
              <template v-for="item in getCardEnabledFiltersWithoutChannel(card)" :key="`${card.id}-${item.key}`">
                <div class="filter-box" style="min-width: 140px;">
                  <div class="label">
                    <span>{{ item.label }}</span>
                  </div>
                  <a-select
                    v-model:value="item.value"
                    size="small"
                    :bordered="false"
                    style="width: 140px"
                    show-search
                    :filter-option="(input, option) => String(option?.label || '').toLowerCase().includes(input.toLowerCase())"
                    :options="item.options"
                    @change="handleCardFilterChange(card)"
                  />
                </div>
              </template>
              <a-button size="small" class="card-filter-action-btn" @click="openCardFilterModal(card)">
                <filter-outlined />
              </a-button>
            </div>
          </div>
          <div class="card-chart-mock" :class="`chart-${card.chartType}`">
            <template v-if="card.chartPreviewData?.length">
              <div class="chart-preview-data" :class="`preview-${card.chartType}`">
                <div
                  v-for="(val, idx) in card.chartPreviewData"
                  :key="`${card.id}-pv-${idx}`"
                  class="chart-preview-row"
                >
                  <span class="row-dot" />
                  <span class="row-line" :style="{ width: `${(idx + 1) * 10}%` }" />
                </div>
              </div>
            </template>
            <template v-else>
              <div class="card-chart-empty">
                <span class="chart-empty-icon" :class="`chart-opt-${card.chartType}`" />
                <div class="chart-empty-text">{{ t('暂无数据') }}</div>
              </div>
            </template>
          </div>
        </template>
      </div>
          </template>
      </template>
    </div>
          </div>
        </div>

        <a-drawer
          :visible="showAddCardDrawer"
          :title="addCardDrawerTitle"
          placement="right"
          width="720"
          wrap-class-name="add-card-drawer"
          @close="closeAddCardDrawer"
        >
          <a-form
            layout="horizontal"
            class="add-card-form-advanced"
            :label-col="{ style: { width: '88px' } }"
            :wrapper-col="{ style: { width: '560px' } }"
          >
            <a-form-item :label="t('卡片名称')" required>
              <a-input v-model:value="addCardForm.name" :maxlength="50" :placeholder="t('请输入卡片名称')" show-count />
            </a-form-item>
            <a-form-item :label="t('渠道')" required>
              <a-select v-model:value="addCardForm.channel" :placeholder="t('请选择渠道')">
                <a-select-option value="summary">{{ t('汇总') }}</a-select-option>
              </a-select>
            </a-form-item>
            <a-form-item :label="t('数据源')" required>
              <a-radio-group v-model:value="addCardForm.dataSource" button-style="solid">
                <a-radio-button value="综合报表">{{ t('综合报表') }}</a-radio-button>
                <a-radio-button value="素材报表">{{ t('素材报表') }}</a-radio-button>
              </a-radio-group>
            </a-form-item>
            <a-form-item :label="t('图表类型')" required>
              <a-select
                v-model:value="addCardForm.chartType"
                :class="['chart-type-select', `chart-type-selected-${addCardForm.chartType}`]"
                :placeholder="t('请选择图表类型')"
                show-search
                :filter-option="filterChartTypeOption"
                option-label-prop="children"
                dropdown-class-name="chart-type-dropdown"
                :get-popup-container="(trigger: HTMLElement) => trigger.parentElement"
              >
                <a-select-option
                  v-for="item in cardChartTypeOptions"
                  :key="item.value"
                  :value="item.value"
