]);
const rootMyDashboards = computed(() => myDashboards.value.filter((item) => !item.folderId));
const normalizeText = (value: unknown) => String(value ?? '');
const filteredRootDashboards = computed(() => {
  const keyword = sidebarKeyword.value.trim().toLowerCase();
  return rootMyDashboards.value.filter((board) => !keyword || normalizeText(board.label).toLowerCase().includes(keyword));
});

const filteredFolders = computed(() => {
  const keyword = sidebarKeyword.value.trim().toLowerCase();
  return customFolders.value
    .map((folder) => {
      const folderBoards = myDashboards.value
        .filter((board) => board.folderId === folder.id)
        .filter((board) => !keyword || normalizeText(board.label).toLowerCase().includes(keyword));
      const folderMatched = !keyword || normalizeText(folder.name).toLowerCase().includes(keyword);
      if (!folderMatched && folderBoards.length === 0) {
        return null;
      }
      return {
        id: folder.id,
        name: normalizeText(folder.name),
        boards: folderBoards,
      };
    })
    .filter((node): node is NonNullable<typeof node> => Boolean(node));
});

const isNodeExpanded = (nodeKey: string) => expandedTreeKeys.value.includes(nodeKey);

const toggleSidebarNode = (nodeKey: string) => {
  if (expandedTreeKeys.value.includes(nodeKey)) {
    expandedTreeKeys.value = expandedTreeKeys.value.filter((key) => key !== nodeKey);
  } else {
    expandedTreeKeys.value = [...expandedTreeKeys.value, nodeKey];
  }
};

