                      @click="addCardForm.xAxisMetric = ''"
                    >×</span>
                  </div>
                  <a-button
                    style="flex-shrink: 0; display: inline-flex; align-items: center; gap: 6px; height: 32px; padding: 0 12px; border-radius: 4px; border: 1px solid #d9e1ef; color: #3d4e68; background: #fff;"
                    @click="handleScatterMetricClick('xAxis')"
                  >
                    <filter-outlined />
                    {{ t('指标') }}
                  </a-button>
                </div>
              </a-form-item>
              <a-form-item :label="t('纵轴')" required>
                <div style="display: flex; align-items: center; gap: 8px;">
                  <div
                    v-if="addCardForm.yAxisMetric"
                    style="display: inline-flex; align-items: center; height: 32px; padding: 0 8px; background: #f5f5f5; border: 1px solid #d9e1ef; border-radius: 4px; font-size: 13px; color: #3d4e68;"
                  >
                    <span style="line-height: 30px; white-space: nowrap;">{{ addCardMetricOptions.find(o => o.value === addCardForm.yAxisMetric)?.label || addCardForm.yAxisMetric }}</span>
                    <span
                      style="cursor: pointer; color: #94a3b8; font-size: 16px; margin-left: 8px; display: inline-flex; align-items: center; justify-content: center; width: 16px; height: 16px;"
                      @click="addCardForm.yAxisMetric = ''"
                    >×</span>
                  </div>
                  <a-button
                    style="flex-shrink: 0; display: inline-flex; align-items: center; gap: 6px; height: 32px; padding: 0 12px; border-radius: 4px; border: 1px solid #d9e1ef; color: #3d4e68; background: #fff;"
                    @click="handleScatterMetricClick('yAxis')"
                  >
                    <filter-outlined />
                    {{ t('指标') }}
                  </a-button>
                </div>
              </a-form-item>
              <a-form-item :label="t('排序')" required>
                <div style="display: flex; gap: 8px;">
                  <a-select v-model:value="addCardForm.sortField" style="flex: 1" show-search>
                    <a-select-option v-for="opt in visibleAddCardMetricOptions" :key="opt.value" :value="opt.value">
                      {{ opt.label }}
                    </a-select-option>
                  </a-select>
                  <a-select v-model:value="addCardForm.sortOrder" style="width: 100px;">
                    <a-select-option value="desc">{{ t('降序') }}</a-select-option>
                    <a-select-option value="asc">{{ t('升序') }}</a-select-option>
                  </a-select>
                </div>
              </a-form-item>
            </template>

            <!-- 趋势图 / 面积图 / 堆积面积图：参数配置 -->
            <template v-if="['line', 'area', 'stack-area', 'percent-stack-area'].includes(addCardForm.chartType)">
              <a-form-item v-if="addCardForm.chartType === 'line'" :label="t('对比模式')" required>
                <a-radio-group v-model:value="addCardForm.compareMode" button-style="solid">
                  <a-radio-button value="none">{{ t('关闭对比') }}</a-radio-button>
                  <a-radio-button value="day">{{ t('今日对比') }}</a-radio-button>
                </a-radio-group>
              </a-form-item>
              <a-form-item :label="t('日期')" required>
                <a-range-picker v-model:value="addCardForm.dateRange" style="width: 100%;" />
              </a-form-item>
              <a-form-item :label="t('横轴')" required>
                <a-select v-model:value="addCardForm.xAxis" :placeholder="t('请选择')" style="width: 100%">
                  <template #suffixIcon><filter-outlined /></template>
                  <a-select-option value="date">{{ t('日期') }}</a-select-option>
                </a-select>
              </a-form-item>
              <a-form-item :label="t('筛选')">
                <div class="add-card-filter-inline">
                  <div v-if="getAddFormActiveFilters().length" class="add-card-filter-tags">
                    <div v-for="item in getAddFormActiveFilters()" :key="item.key" class="add-card-filter-tag">
                      <span class="tag-label">{{ item.label }}:</span>
                      <a-select
                        v-model:value="item.value"
                        size="small"
                        class="tag-select"
                        show-search
                        :filter-option="(input, option) => String(option?.label || '').toLowerCase().includes(input.toLowerCase())"
                        :options="item.options"
                        @change="handleAddFormFilterChange"
                      />
                      <span class="tag-close" @click="removeAddFormFilter(item.key)">×</span>
                    </div>
                  </div>
                  <a-button class="add-card-filter-btn" @click="openCardFilterModalForAddForm">
                    <filter-outlined />
                    {{ t('筛选设置') }}
                  </a-button>
                </div>
              </a-form-item>
              <a-form-item :label="t('纵轴')" required>
                <div style="display: flex; align-items: center; flex-wrap: wrap; gap: 8px; width: 100%;">
                  <div style="display: flex; flex-wrap: wrap; gap: 8px; align-items: center;">
                    <div
                      v-for="mKey in addCardForm.metrics"
                      :key="mKey"
                      style="display: inline-flex; align-items: center; height: 32px; padding: 0 8px; background: #f5f5f5; border: 1px solid #d9e1ef; border-radius: 4px; font-size: 13px; color: #3d4e68;"
                    >
                      <span style="line-height: 30px; white-space: nowrap;">{{ addCardMetricOptions.find(o => o.value === mKey)?.label || mKey }}</span>
                      <span
                        style="cursor: pointer; color: #94a3b8; font-size: 16px; margin-left: 8px; display: inline-flex; align-items: center; justify-content: center; width: 16px; height: 16px;"
                        @click="addCardForm.metrics = addCardForm.metrics.filter(k => k !== mKey)"
                      >×</span>
                    </div>
                  </div>
                  <a-button
                    style="flex-shrink: 0; display: inline-flex; align-items: center; gap: 6px; height: 32px; padding: 0 12px; border-radius: 4px; border: 1px solid #d9e1ef; color: #3d4e68; background: #fff;"
                    @click="handleTrendCardMetricClick"
                  >
                    <filter-outlined />
                    {{ t('指标') }}
                  </a-button>
                </div>
              </a-form-item>
              <!-- 堆积面积图显示分组聚合、排序、最大行数 -->
              <template v-if="['stack-area', 'percent-stack-area'].includes(addCardForm.chartType)">
                <a-form-item :label="t('分组聚合')">
                  <a-select
                    v-model:value="addCardForm.groupAggregation"
                    allow-clear
                    :placeholder="t('请选择')"
                    :options="groupAggregationOptions"
                    style="width: 100%"
                  >
                    <template #suffixIcon><filter-outlined /></template>
                  </a-select>
                </a-form-item>
                <a-form-item :label="t('排序')" required>
                  <div style="display: flex; gap: 8px;">
                    <a-select v-model:value="addCardForm.sortField" style="flex: 1">
                      <a-select-option v-for="mKey in addCardForm.metrics" :key="mKey" :value="mKey">
                        {{ addCardMetricOptions.find(o => o.value === mKey)?.label || mKey }}
                      </a-select-option>
                    </a-select>
                    <a-select v-model:value="addCardForm.sortOrder" style="width: 100px;">
                      <a-select-option value="desc">{{ t('降序') }}</a-select-option>
                      <a-select-option value="asc">{{ t('升序') }}</a-select-option>
                    </a-select>
                  </div>
                </a-form-item>
                <a-form-item :label="t('最大行数')" v-if="!addCardForm.dimension.some(d => d !== 'date')">
                  <a-select v-model:value="addCardForm.maxRows" style="width: 100%">
                    <a-select-option :value="5">5</a-select-option>
                    <a-select-option :value="10">10</a-select-option>
                    <a-select-option :value="20">20</a-select-option>
                  </a-select>
                </a-form-item>
              </template>
              <!-- 仅趋势图显示分组聚合 -->
              <a-form-item v-else-if="addCardForm.chartType === 'line'" :label="t('分组聚合')">
                <a-select
                  v-model:value="addCardForm.groupAggregation"
                  allow-clear
                  :placeholder="t('请选择')"
                  :options="groupAggregationOptions"
                  style="width: 100%"
                />
              </a-form-item>
              
              <a-form-item :label="t('图表尺寸')" required>
                <a-radio-group v-model:value="addCardForm.chartSize" button-style="solid">
                  <a-radio-button value="small">{{ t('小图') }}</a-radio-button>
                  <a-radio-button value="large">{{ t('大图') }}</a-radio-button>
                </a-radio-group>
              </a-form-item>
            </template>

            <!-- 非趋势图/面积图：保留原有通用参数
              已有独立“参数配置”的图表类型（含 tile/pie/scatter/bar/horizontal-bar 等）需排除，避免重复渲染两套字段
            -->
            <template v-else-if="!['card-stat', 'tile', 'pie', 'scatter', 'bar', 'stack-bar', 'percent-stack-bar', 'horizontal-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(addCardForm.chartType)">
              <a-form-item :label="t('对比模式')">
                <a-radio-group v-model:value="addCardForm.compareMode" button-style="solid">
                  <a-radio-button value="none">{{ t('关闭对比') }}</a-radio-button>
                  <a-radio-button value="day">{{ t('今日对比') }}</a-radio-button>
                </a-radio-group>
              </a-form-item>
              <a-form-item :label="t('日期')" required>
                <a-range-picker v-model:value="addCardForm.dateRange" style="width: 100%;" />
              </a-form-item>
              <a-form-item :label="t('维度')" required>
                <a-select
                  v-model:value="addCardForm.dimension"
                  mode="multiple"
                  :placeholder="t('请选择维度')"
                  style="width: 100%"
                >
                  <template #suffixIcon><filter-outlined /></template>
                  <a-select-option value="date">{{ t('日期') }}</a-select-option>
                  <a-select-option value="department">{{ t('部门') }}</a-select-option>
                  <a-select-option value="optimizer">{{ t('优化师') }}</a-select-option>
                  <a-select-option value="channel">{{ t('渠道') }}</a-select-option>
                  <a-select-option value="ad_account">{{ t('广告账户') }}</a-select-option>
                  <a-select-option value="campaign">{{ t('系列') }}</a-select-option>
                  <a-select-option value="ad_group">{{ t('广告组') }}</a-select-option>
                  <a-select-option value="creative">{{ t('创意') }}</a-select-option>
                  <a-select-option value="region">{{ t('地区') }}</a-select-option>
                </a-select>
              </a-form-item>
              <a-form-item :label="t('筛选')">
                <div class="add-card-filter-inline">
                  <div v-if="getAddFormActiveFilters().length" class="add-card-filter-tags">
                    <div v-for="item in getAddFormActiveFilters()" :key="item.key" class="add-card-filter-tag">
                      <span class="tag-label">{{ item.label }}:</span>
                      <a-select
                        v-model:value="item.value"
                        size="small"
                        class="tag-select"
                        show-search
                        :filter-option="(input, option) => String(option?.label || '').toLowerCase().includes(input.toLowerCase())"
                        :options="item.options"
                        @change="handleAddFormFilterChange"
                      />
                      <span class="tag-close" @click="removeAddFormFilter(item.key)">×</span>
                    </div>
                  </div>
                  <a-button class="add-card-filter-btn" @click="openCardFilterModalForAddForm">
                    <filter-outlined />
                    {{ t('筛选设置') }}
                  </a-button>
                </div>
              </a-form-item>
              <a-form-item :label="t('指标')" required>
                <div style="display: flex; align-items: center; flex-wrap: wrap; gap: 8px; width: 100%;">
                  <div style="display: flex; flex-wrap: wrap; gap: 8px; align-items: center;">
                    <div
                      v-for="mKey in addCardForm.metrics"
                      :key="mKey"
                      style="display: inline-flex; align-items: center; height: 32px; padding: 0 8px; background: #f5f5f5; border: 1px solid #d9e1ef; border-radius: 4px; font-size: 13px; color: #3d4e68;"
                    >
                      <span style="line-height: 30px; white-space: nowrap;">{{ addCardMetricOptions.find(o => o.value === mKey)?.label || mKey }}</span>
                      <span
                        style="cursor: pointer; color: #94a3b8; font-size: 16px; margin-left: 8px; display: inline-flex; align-items: center; justify-content: center; width: 16px; height: 16px;"
                        @click="addCardForm.metrics = addCardForm.metrics.filter(k => k !== mKey)"
                      >×</span>
                    </div>
                  </div>
                  <a-button
                    style="flex-shrink: 0; display: inline-flex; align-items: center; gap: 6px; height: 32px; padding: 0 12px; border-radius: 4px; border: 1px solid #d9e1ef; color: #3d4e68; background: #fff;"
                    @click="handleTrendCardMetricClick"
                  >
                    <filter-outlined />
                    {{ t('指标') }}
                  </a-button>
                </div>
              </a-form-item>
              <a-form-item :label="t('表格颜色')">
                <div class="add-card-color-list">
                  <span
                    v-for="color in addCardColorOptions"
                    :key="color.value"
                    class="add-card-color-item"
                    :class="{ active: addCardForm.tableColor === color.value }"
                    :style="{ background: color.gradient }"
                    @click="addCardForm.tableColor = color.value"
                  />
                </div>
              </a-form-item>
              <a-form-item :label="t('图表尺寸')" required>
                <a-radio-group v-model:value="addCardForm.chartSize" button-style="solid">
                  <a-radio-button value="small">{{ t('小图') }}</a-radio-button>
                  <a-radio-button value="large">{{ t('大图') }}</a-radio-button>
                </a-radio-group>
              </a-form-item>
              <a-form-item :label="t('预览形状')">
                <div class="shape-preview" :class="`shape-${resolveCardShape(addCardForm.chartType)}`">
                  {{ getChartTypeLabel(addCardForm.chartType) }}
                </div>
              </a-form-item>
            </template>
          </a-form>
          <template #footer>
            <div class="add-card-footer">
              <a-button @click="closeAddCardDrawer">{{ t('取消') }}</a-button>
              <a-button type="primary" @click="submitAddCard">{{ t('保存') }}</a-button>
            </div>
          </template>
        </a-drawer>

        <a-modal
          v-model:visible="showMetricSettingModal"
          :title="t('指标设置')"
          width="820px"
          @cancel="showMetricSettingModal = false"
          @ok="() => {
            if (addCardForm.chartType === 'scatter') {
              // 散点图逻辑：根据目标设置指标，且限制为1个
              const selected = addCardForm.metrics[0];
              if (selected) {
                if ((scatterMetricTarget as any).value === 'xAxis') {
                  addCardForm.xAxisMetric = selected;
                  if (addCardForm.yAxisMetric === selected) {
                    addCardForm.yAxisMetric = getNextScatterMetric(selected);
                  }
                } else {
                  addCardForm.yAxisMetric = selected;
                  if (addCardForm.xAxisMetric === selected) {
                    addCardForm.xAxisMetric = getNextScatterMetric(selected);
                  }
                }
                ensureScatterMetrics();
              }
              // 清空临时 metrics 数组，避免干扰其他图表
              addCardForm.metrics = [];
            }
            showMetricSettingModal = false;
          }"
        >
          <div class="metric-setting-content">
            <div class="metric-setting-left">
              <a-input :placeholder="t('请输入列名称')" allow-clear class="mb16" />
              <a-tabs default-active-key="1">
                <a-tab-pane key="1" :tab="t('汇总')">
                  <div class="metric-group">
                    <div class="group-title">{{ t('基础数据') }}</div>
                    <div class="group-items">
        <a-checkbox-group
        v-model:value="addCardForm.metrics"
        class="metric-checkbox-group"
        :disabled="['card-stat', 'pie', 'scatter', 'line', 'area', 'bar', 'horizontal-bar', 'stack-area', 'percent-stack-area', 'stack-bar', 'percent-stack-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(addCardForm.chartType) && addCardForm.metrics.length >= (['card-stat', 'pie', 'scatter', 'stack-area', 'percent-stack-area', 'stack-bar', 'percent-stack-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(addCardForm.chartType) ? 1 : 2) || (addCardForm.chartType === 'tile' && addCardForm.metrics.length >= 10)"
      >
        <a-row :gutter="[16, 16]">
          <a-col v-for="opt in visibleAddCardMetricOptions" :key="opt.value" :span="8">
            <a-checkbox
              :value="opt.value"
              :disabled="(['card-stat', 'pie', 'scatter', 'line', 'area', 'bar', 'horizontal-bar', 'stack-area', 'percent-stack-area', 'stack-bar', 'percent-stack-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(addCardForm.chartType) && addCardForm.metrics.length >= (['card-stat', 'pie', 'scatter', 'stack-area', 'percent-stack-area', 'stack-bar', 'percent-stack-bar', 'stack-horizontal-bar', 'percent-stack-horizontal-bar'].includes(addCardForm.chartType) ? 1 : 2)) && !addCardForm.metrics.includes(opt.value)"
            >{{ opt.label }}</a-checkbox>
          </a-col>
        </a-row>
      </a-checkbox-group>
                    </div>
                  </div>
                </a-tab-pane>
                <a-tab-pane key="2" :tab="t('电商平台')" disabled />
                <a-tab-pane key="3" :tab="t('S2S(电商)')" disabled />
                <a-tab-pane key="4" :tab="t('自定义公式')" disabled />
              </a-tabs>
            </div>
            <div class="metric-setting-right">
              <div class="right-head">
                <span>{{ t('已选择') }} {{ addCardForm.metrics.length }} {{ t('列') }}</span>
                <a-button type="link" size="small" @click="addCardForm.metrics = []">{{ t('清除') }}</a-button>
              </div>
              <div class="selected-metrics-list">
                <div v-for="mKey in addCardForm.metrics" :key="mKey" class="selected-metric-item">
                  <span class="drag-icon">⋮⋮</span>
                  <span class="metric-label">{{ addCardMetricOptions.find(o => o.value === mKey)?.label }}</span>
                  <span class="remove-icon" @click="addCardForm.metrics = addCardForm.metrics.filter(k => k !== mKey)">×</span>
                </div>
              </div>
            </div>
          </div>
        </a-modal>

        <a-modal
          v-model:visible="showCardManagerModal"
          :title="t('卡片管理')"
          width="820px"
          wrap-class-name="card-manager-modal"
          @cancel="showCardManagerModal = false"
          :footer="null"
        >
          <div class="card-manager-list">
            <div v-if="cardManagerLoading" class="card-manager-empty">
              {{ t('加载中...') }}
            </div>
            <div v-else-if="customBoardCards.length === 0" class="card-manager-empty">
              {{ t('当前看板暂无卡片') }}
            </div>
            <div v-else class="card-manager-table">
              <div class="card-manager-head">
                <div>{{ t('卡片名称') }}</div>
                <div>{{ t('数据源') }}</div>
                <div>{{ t('渠道') }}</div>
                <div>{{ t('图表类型') }}</div>
                <div>{{ t('操作') }}</div>
              </div>
              <drag-container
                lockAxis="y"
                dragClass="card-manager-drag-ghost"
                dropClass="card-manager-drop-ghost"
                dragHandleSelector=".drag-icon"
                nonDragAreaSelector=".action-cell"
                @drop="handleCardManagerDrop"
              >
                <template v-for="card in customBoardCards" :key="card.id">
                  <draggable>
                    <div class="card-manager-row">
                      <div class="name-cell">
                        <span class="drag-icon">⋮⋮</span>
                        <span class="name-text">{{ card.iconName }}</span>
                        <span class="name-subtitle">{{ card.title }}</span>
                      </div>
                      <div class="cell-text">{{ card.dataSource }}</div>
                      <div class="cell-text">{{ card.channel }}</div>
                      <div class="cell-text">{{ card.typeLabel }}</div>
                      <div class="action-cell">
                        <a-button type="link" size="small" @click="handleCardManagerAction('edit', card)">
                          {{ t('编辑') }}
                        </a-button>
                        <a-button type="link" size="small" @click="handleCardManagerAction('copy', card)">
                          {{ t('复制') }}
                        </a-button>
                        <a-button type="link" size="small" @click="handleCardManagerAction('push', card)">
                          {{ t('推送') }}
                        </a-button>
                        <a-button type="link" size="small" danger @click="handleCardManagerAction('delete', card)">
                          {{ t('删除') }}
                        </a-button>
                      </div>
                    </div>
                  </draggable>
                </template>
              </drag-container>
            </div>
          </div>
        </a-modal>

        <a-modal
          v-model:visible="cardFilterModalVisible"
          title="筛选设置"
          width="900px"
          @ok="handleCardFilterModalOk"
          ok-text="确定"
          cancel-text="取消"
        >
          <a-alert
            message="勾选筛选条件确定后将会在界面显示"
            type="info"
            show-icon
            style="margin-bottom: 20px"
          />
          <div class="card-filter-modal-grid">
            <div v-for="item in cardFilterOptionsDraft" :key="item.key" class="card-filter-modal-row">
              <a-checkbox v-model:checked="item.enabled" />
              <span class="card-filter-modal-label">{{ item.label }}:</span>
              <a-select
                v-model:value="item.value"
                placeholder="请选择"
                style="flex: 1"
                show-search
                :filter-option="(input, option) => String(option?.label || '').toLowerCase().includes(input.toLowerCase())"
                :options="item.options"
                allow-clear
              />
            </div>
          </div>
          <template #footer>
            <div class="modal-footer-between">
              <a @click="clearCardFilterDraft">清除已选</a>
              <div>
                <a-button @click="cardFilterModalVisible = false">取消</a-button>
                <a-button type="primary" @click="handleCardFilterModalOk">确定</a-button>
              </div>
            </div>
          </template>
        </a-modal>

        <a-modal
          v-model:visible="showCreateDashboardModal"
          :title="t('新建看板')"
          width="480px"
          @ok="submitCreateDashboard"
          @cancel="resetCreateDashboardForm"
        >
          <a-form layout="vertical">
            <a-form-item :label="t('看板名称')" required>
              <a-input
                v-model:value="createDashboardForm.name"
                :placeholder="t('请输入看板名称')"
                :maxlength="200"
                show-count
              />
            </a-form-item>
            <a-form-item :label="t('看板位置')">
              <a-select
                v-model:value="createDashboardFolderValue"
                :placeholder="t('请选择看板位置')"
              >
                <a-select-option :value="ROOT_FOLDER_VALUE">{{ t('我的看板') }}</a-select-option>
                <a-select-option
                  v-for="folder in customFolders"
                  :key="folder.id"
                  :value="folder.id"
                >
                  {{ folder.name }}
                </a-select-option>
              </a-select>
            </a-form-item>
            <a-form-item :label="t('渠道')">
              <a-select v-model:value="createDashboardForm.channel">
                <a-select-option value="summary">{{ t('汇总') }}</a-select-option>
              </a-select>
            </a-form-item>
            <a-form-item :label="t('看板类型')" required>
              <a-radio-group v-model:value="createDashboardForm.boardType" button-style="solid">
                <a-radio-button value="comprehensive">{{ t('综合报表') }}</a-radio-button>
                <a-radio-button value="custom">{{ t('自定义看板') }}</a-radio-button>
              </a-radio-group>
            </a-form-item>
            <a-form-item :label="t('分组对比')">
              <a-radio-group v-model:value="createDashboardForm.groupCompare">
                <a-radio :value="false">{{ t('关闭') }}</a-radio>
                <a-radio :value="true">{{ t('开启') }}</a-radio>
              </a-radio-group>
            </a-form-item>
          </a-form>
        </a-modal>

        <a-modal
          v-model:visible="showCreateFolderModal"
          :title="t('新建文件夹')"
          width="480px"
          @ok="submitCreateFolder"
          @cancel="resetCreateFolderForm"
        >
          <a-form layout="vertical">
            <a-form-item :label="t('文件夹名称')" required>
              <a-input
                v-model:value="createFolderForm.name"
                :placeholder="t('请输入文件夹名称')"
                :maxlength="200"
                show-count
              />
            </a-form-item>
          </a-form>
        </a-modal>

        <a-modal
          v-model:visible="showRenameFolderModal"
          :title="t('重命名文件夹')"
          width="480px"
          @ok="submitRenameFolder"
          @cancel="resetRenameFolderForm"
        >
          <a-form layout="vertical">
            <a-form-item :label="t('文件夹名称')" required>
              <a-input
                v-model:value="renameFolderForm.name"
                :placeholder="t('请输入文件夹名称')"
                :maxlength="200"
                show-count
              />
            </a-form-item>
          </a-form>
        </a-modal>

        <a-modal
          v-model:visible="showDeleteFolderModal"
          :title="t('删除文件夹')"
          width="520px"
          :confirm-loading="folderDeleteLoading"
          ok-text="删除"
          cancel-text="取消"
          @ok="confirmDeleteFolder"
          @cancel="resetDeleteFolderModal"
        >
          <div>{{ t('确认删除该文件夹？该文件夹下的看板将移动到“我的看板”。') }}</div>
        </a-modal>

        <a-modal
          v-model:visible="showDeleteDashboardModal"
          :title="t('删除看板')"
          width="520px"
          :confirm-loading="dashboardDeleteLoading"
          ok-text="删除"
          cancel-text="取消"
          @ok="confirmDeleteDashboard"
          @cancel="resetDeleteDashboardModal"
        >
          <div>{{ t('确认删除该看板？') }}</div>
        </a-modal>

        <a-modal
          v-model:visible="showRenameDashboardModal"
          :title="t('重命名看板')"
