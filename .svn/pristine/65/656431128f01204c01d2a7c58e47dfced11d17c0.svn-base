  name: '',
  folder: 'mine',
});
const createdBoardLastSaveTime = ref(dayjs().format('YYYY-MM-DD HH:mm:ss'));
const showAddCardDrawer = ref(false);
const editingCardId = ref<string | null>(null);
const addCardDrawerTitle = computed(() => (editingCardId.value ? t('编辑卡片') : t('添加卡片')));
const showMetricSettingModal = ref(false);
const showCardManagerModal = ref(false);
const cardManagerLoading = ref(false);
const cardChartTypeOptions = [
  { value: 'table', label: '表格', icon: 'table' },
  { value: 'line', label: '趋势图', icon: 'line' },
  { value: 'area', label: '面积图', icon: 'area' },
  { value: 'stack-area', label: '堆积面积图', icon: 'stack-area' },
  { value: 'percent-stack-area', label: '%堆积面积图', icon: 'percent-stack-area' },
  { value: 'bar', label: '柱状图', icon: 'bar' },
  { value: 'stack-bar', label: '堆积柱状图', icon: 'stack-bar' },
  { value: 'percent-stack-bar', label: '%堆积柱状图', icon: 'percent-stack-bar' },
  { value: 'horizontal-bar', label: '条形图', icon: 'horizontal-bar' },
  { value: 'stack-horizontal-bar', label: '堆积条形图', icon: 'stack-horizontal-bar' },
  { value: 'percent-stack-horizontal-bar', label: '%堆积条形图', icon: 'percent-stack-horizontal-bar' },
  { value: 'scatter', label: '散点图', icon: 'scatter' },
  { value: 'pie', label: '饼图', icon: 'pie' },
  { value: 'tile', label: '平铺', icon: 'tile' },
  { value: 'card-stat', label: '卡片-统计数字', icon: 'card-stat' },
];
const addCardMetricOptions = [
  { value: 'cost', label: t('花费') },
  { value: 'impressions', label: t('展示数') },
  { value: 'cpm', label: t('千次展示成本') },
  { value: 'clicks', label: t('点击数') },
  { value: 'cpc', label: t('点击成本') },
  { value: 'ctr', label: t('点击率') },
  { value: 'conversions', label: t('转化数') },
  { value: 'cpa', label: t('转化成本') },
  { value: 'conversionRate', label: t('转化率') },
  { value: 'register', label: t('注册数') },
  { value: 'payOrder', label: t('付费次数') },
];

/** 趋势图 — 分组聚合下拉（顺序与设计稿一致） */
const currentUserPermissionSlugs = computed(() => collectUserPermissionSlugs(userStore.permissions));
const visibleAddCardMetricOptions = computed(() => {
  if (userStore.is_super === 1) {
    return addCardMetricOptions;
  }

  const allowedMetricValues = addCardMetricOptions
    .filter((option) => currentUserPermissionSlugs.value.includes(dashboardMetricPermissionMap[option.value]))
    .map((option) => option.value);

  if (allowedMetricValues.length === 0) {
    return addCardMetricOptions;
  }

  return addCardMetricOptions.filter((option) => allowedMetricValues.includes(option.value));
});

const getAvailableMetricOptions = () => {
  return visibleAddCardMetricOptions.value.length ? visibleAddCardMetricOptions.value : addCardMetricOptions;
};

const groupAggregationOptions = [
  { value: 'department', label: t('部门') },
  { value: 'optimizer', label: t('优化师') },
  { value: 'channel', label: t('渠道') },
  { value: 'ad_account', label: t('广告账户') },
  { value: 'campaign', label: t('系列') },
  { value: 'ad_group', label: t('广告组') },
  { value: 'creative', label: t('创意') },
  { value: 'region', label: t('地区') },
];
const addCardColorOptions = [
  { value: 'none', gradient: 'linear-gradient(180deg, #f5f7fb 0%, #edf1f8 100%)' },
  { value: 'green', gradient: 'linear-gradient(180deg, #e9f9ee 0%, #d3f0dc 100%)' },
  { value: 'red', gradient: 'linear-gradient(180deg, #ffecef 0%, #ffd8df 100%)' },
  { value: 'mixed', gradient: 'linear-gradient(135deg, #e6f4ff 0%, #f9e9ff 100%)' },
];
// 已经不再使用的工具函数
// const formatPreviewMoney = (value: number) => `¥${value.toFixed(2)}`;
// const formatPreviewNumber = (value: number) => value.toLocaleString();
// const tablePreviewRows = []; // 不再直接使用，数据现在绑定在每个 card 对象上
const addCardForm = ref({
  name: '',
  channel: 'summary',
  dataSource: '综合报表',
  chartType: 'table',
  compareMode: 'none',
  dateRange: [dayjs().subtract(6, 'day'), dayjs()] as [Dayjs, Dayjs],
  dimension: ['date'] as string | string[],
  xAxis: 'date',
  xAxisMetric: getAvailableMetricOptions()[0]?.value ?? 'cost',
  yAxisMetric: getAvailableMetricOptions()[1]?.value ?? getAvailableMetricOptions()[0]?.value ?? 'impressions',
  // 默认筛选：渠道=汇总(summary)，避免用户不点“筛选设置”也没有 filter_channel
  filterChannel: 'summary' as string | undefined,
  metrics: ['cost'] as string[],
  groupAggregation: undefined,
  chartSize: 'small',
  tableColor: '#1890ff',
  sortField: 'cost',
  sortOrder: 'desc',
  maxRows: 5,
  compareDateRange: [dayjs().subtract(13, 'day'), dayjs().subtract(7, 'day')] as [Dayjs, Dayjs],
});
type CustomBoardCard = {
  id: string;
  title: string;
  iconName: string;
  dataSource: string;
  channel: string;
  chartType: string;
  typeLabel: string;
  shape: 'large' | 'medium' | 'small';
  chartPreviewData?: number[];
  metrics?: string[];
  dateRangeLabel?: string;
  startDate?: string;
  endDate?: string;
  xAxisLabels?: string[];
  dateRange: [Dayjs, Dayjs];
  tableData?: any[];
  groupAggregation?: string;
  tooltip?: {
    show: boolean;
    x: number;
    y: number;
    title: string;
    items: Array<{ color: string; label: string; value: string }>;
  };
  activeIndex?: number | null;
  /** 用于编辑时回填表单 */
  queryConfigRaw?: Record<string, unknown> | null;
  filterOptions?: Array<{
    key: string;
    label: string;
    enabled: boolean;
    value?: string;
    options: Array<{ label: string; value: string }>;
  }>;
};
const customBoardCards = ref<CustomBoardCard[]>([]);

const buildDefaultCardFilterOptions = () => [
  { key: 'dept', label: '部门', enabled: false, value: undefined, options: [{ label: '部门A', value: 'dept_a' }, { label: '部门B', value: 'dept_b' }] },
  { key: 'optimizer', label: '优化师', enabled: false, value: undefined, options: [{ label: '优化师A', value: 'optimizer_a' }, { label: '优化师B', value: 'optimizer_b' }] },
  // 默认筛选：渠道开启且预填为“汇总”
  { key: 'channel', label: '渠道', enabled: true, value: 'summary', options: [{ label: '汇总', value: 'summary' }, { label: 'Meta', value: 'meta' }, { label: 'Google', value: 'google' }] },
  { key: 'account', label: '广告账户', enabled: false, value: undefined, options: [{ label: '账户A', value: 'account_a' }, { label: '账户B', value: 'account_b' }] },
  { key: 'campaign', label: '广告系列', enabled: false, value: undefined, options: [{ label: '系列A', value: 'campaign_a' }, { label: '系列B', value: 'campaign_b' }] },
  { key: 'adgroup', label: '广告组', enabled: false, value: undefined, options: [{ label: '广告组A', value: 'adgroup_a' }, { label: '广告组B', value: 'adgroup_b' }] },
  { key: 'creative', label: '创意', enabled: false, value: undefined, options: [{ label: '创意A', value: 'creative_a' }, { label: '创意B', value: 'creative_b' }] },
  { key: 'region', label: '地区', enabled: false, value: undefined, options: [{ label: '北美', value: 'na' }, { label: '欧洲', value: 'eu' }] },
];

/** 统计数字卡片同一展示块最多 4 张（2×2）；连续多张每满 4 张拆成新的 stat-group */
const STAT_GROUP_MAX = 4;

/** 连续统计数字合并为一格（占 4/8 列），内部 2×2，避免自动网格把第 3、4 张排到左侧饼图下方 */
type CustomBoardCardSegment =
  | { type: 'stat-group'; key: string; cards: CustomBoardCard[]; gridColumn?: string }
  | { type: 'card'; key: string; card: CustomBoardCard };

/** 末尾连续「统计数字」卡片数量（用于限制同一区域最多 4 张） */
const countTrailingCardStats = (cards: CustomBoardCard[]) => {
  let n = 0;
  for (let j = cards.length - 1; j >= 0; j--) {
    if (cards[j].chartType === 'card-stat') n++;
    else break;
  }
  return n;
};

const customBoardCardSegments = computed((): CustomBoardCardSegment[] => {
  const cards = customBoardCards.value;
  const segments: CustomBoardCardSegment[] = [];
  let i = 0;
  while (i < cards.length) {
    if (cards[i].chartType === 'card-stat') {
      const group: CustomBoardCard[] = [];
      while (
        i < cards.length &&
        cards[i].chartType === 'card-stat' &&
        group.length < STAT_GROUP_MAX
      ) {
        group.push(cards[i]);
        i++;
      }
      // 当一组正好 4 张时：
      // - 如果紧挨着前一个是「占 4 列」的小卡片（shape 为 small/medium），则放在同一行右半区：第 5~8 列
      // - 否则横跨整行 8 列：左两张 + 右两张
      const prev = segments[segments.length - 1] as CustomBoardCardSegment | undefined;
      const prevIsHalfRowCard =
        prev &&
        prev.type === 'card' &&
        (prev.card.shape === 'small' || prev.card.shape === 'medium');
      const gridColumn =
        group.length === STAT_GROUP_MAX && prevIsHalfRowCard
          ? '5 / span 4'
          // 视觉需求：删掉 1 张后（剩 3 张），仍希望保持“4 列占位”
          // 避免从 4 列布局退化为 2 列导致第三张下移。
          : group.length >= STAT_GROUP_MAX - 1
            ? 'span 8'
            : 'span 4';
      segments.push({
        type: 'stat-group',
        key: `stat-${group.map((c) => c.id).join('-')}`,
        cards: group,
        gridColumn,
      });
    } else {
      segments.push({ type: 'card', key: cards[i].id, card: cards[i] });
      i++;
    }
  }
  return segments;
});

