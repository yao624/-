              size="small"
              @change="handleMaterialsTableChange"
            >
              <template #bodyCell="{ column, record }">
                <template v-if="column.dataIndex === 'materialName'">
                  <div class="material-name-cell">
                    <a-checkbox :checked="selectedMaterials.includes(record.id)" />
                    <span style="margin-left: 8px">{{ record.materialName }}</span>
                  </div>
                </template>
                <template v-else-if="column.dataIndex === 'spend'">
                  <span :class="getMaterialValueClass(record.spend, 'spend')">
                    {{ formatCurrency(record.spend) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'impressions'">
                  <span :class="getMaterialValueClass(record.impressions, 'impressions')">
                    {{ formatNumber(record.impressions) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'cpm'">
                  <span :class="getMaterialValueClass(record.cpm, 'cpm', true)">
                    {{ formatCurrency(record.cpm) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'clicks'">
                  <span :class="getMaterialValueClass(record.clicks, 'clicks')">
                    {{ formatNumber(record.clicks) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'ctr'">
                  <span :class="getMaterialValueClass(record.ctr, 'ctr')">
                    {{ formatPercent(record.ctr) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'conversions'">
                  <span :class="getMaterialValueClass(record.conversions, 'conversions')">
                    {{ formatNumber(record.conversions) }}
                  </span>
                </template>
              </template>
            </s-table>
          </div>
        </div>

