          @ok="submitSaveAsDashboard"
          @cancel="resetSaveAsDashboardForm"
        >
          <a-form layout="vertical">
            <a-form-item :label="t('看板路径')">
              <div>{{ t('我的看板') }} / {{ selectedCreatedBoard?.label || t('综合看板') }}</div>
            </a-form-item>
            <a-form-item :label="t('看板名称')" required>
              <a-input
                v-model:value="saveAsDashboardForm.name"
                :placeholder="t('请输入看板名称')"
                :maxlength="200"
