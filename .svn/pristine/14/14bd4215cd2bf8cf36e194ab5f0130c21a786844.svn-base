<template>
  <div class="material-table">
    <a-table
      :columns="visibleColumns"
      :data-source="dataSource"
      :loading="loading"
      :pagination="pagination"
      :row-selection="rowSelection"
      :scroll="{ x: 2000 }"
      row-key="id"
      @change="handleTableChange"
    >
      <template #bodyCell="{ column, record }">
        <!-- 名称 -->
        <template v-if="column.dataIndex === 'name'">
          <div class="name-cell">
            <span class="name-text">{{ record.name }}</span>
          </div>
        </template>

        <!-- 渠道 -->
        <template v-else-if="column.dataIndex === 'channel'">
          <div class="platform-cell">
            <component :is="getPlatformIcon(record.channel)" class="platform-icon" />
            <span>{{ getPlatformLabel(record.channel) }}</span>
          </div>
        </template>

        <!-- 形状 -->
        <template v-else-if="column.dataIndex === 'shape'">
          <a-tag :color="getShapeColor(record.shape)">
            {{ record.shape }}
          </a-tag>
        </template>

        <!-- 格式 -->
        <template v-else-if="column.dataIndex === 'format'">
          <a-tag>{{ record.format?.toUpperCase() }}</a-tag>
        </template>

        <!-- 来源 -->
        <template v-else-if="column.dataIndex === 'source'">
          <span v-if="record.source">{{ getSourceLabel(record.source) }}</span>
          <span v-else>-</span>
        </template>

        <!-- 素材备注 -->
        <template v-else-if="column.dataIndex === 'materialNote'">
          <a-tooltip v-if="record.materialNote" :title="record.materialNote">
            <span class="ellipsis-text">{{ record.materialNote }}</span>
          </a-tooltip>
          <span v-else>-</span>
        </template>

        <!-- 拒审信息 -->
        <template v-else-if="column.dataIndex === 'rejectInfo'">
          <a-tooltip v-if="record.rejectInfo" :title="record.rejectInfo">
            <a-tag color="error">{{ t('pages.channelManage.table.reject') }}</a-tag>
          </a-tooltip>
          <span v-else>-</span>
        </template>
      </template>
    </a-table>
  </div>
</template>

<script setup lang="ts">
import { computed } from 'vue';
import { useI18n } from 'vue-i18n';
import type { TableProps, TableColumnType } from 'ant-design-vue';
import {
  FacebookOutlined,
  GoogleOutlined,
  ThunderboltOutlined,
} from '@ant-design/icons-vue';
import type { Material } from '../types';

const props = defineProps<{
  dataSource: Material[];
  loading: boolean;
  pagination: {
    current: number;
    pageSize: number;
    total: number;
    showSizeChanger: boolean;
    showQuickJumper: boolean;
    showTotal: (total: number) => string;
  };
  selectedRowKeys?: string[];
  visibleColumnKeys?: string[];
}>();

const emit = defineEmits<{
  (e: 'update:selectedRowKeys', keys: string[]): void;
  (e: 'pageChange', page: number, pageSize: number): void;
}>();

const { t, locale } = useI18n();

const isZh = computed(() => locale.value.startsWith('zh'));

// 所有可用列
const allColumns = computed<TableColumnType<Material>[]>(() => [
  {
    title: t('pages.channelManage.table.materialName'),
    dataIndex: 'name',
    key: 'name',
    width: 180,
    fixed: 'left' as const,
    ellipsis: true,
  },
  {
    title: t('pages.channelManage.table.materialId'),
    dataIndex: 'materialId',
    key: 'materialId',
    width: 120,
  },
  {
    title: t('pages.channelManage.table.channel'),
    dataIndex: 'channel',
    key: 'channel',
    width: 100,
  },
  {
    title: t('pages.channelManage.table.useAccount'),
    dataIndex: 'useAccountName',
    key: 'useAccountName',
    width: 120,
  },
  {
    title: t('pages.channelManage.table.belongAccount'),
    dataIndex: 'belongAccountName',
    key: 'belongAccountName',
    width: 120,
  },
  {
    title: t('pages.channelManage.table.size'),
    dataIndex: 'size',
    key: 'size',
    width: 100,
    align: 'center' as const,
  },
  {
    title: t('pages.channelManage.table.duration'),
    dataIndex: 'duration',
    key: 'duration',
    width: 80,
    align: 'center' as const,
  },
  {
    title: t('pages.channelManage.table.shape'),
    dataIndex: 'shape',
    key: 'shape',
    width: 100,
    align: 'center' as const,
  },
  {
    title: t('pages.channelManage.table.format'),
    dataIndex: 'format',
    key: 'format',
    width: 80,
    align: 'center' as const,
  },
  {
    title: t('pages.channelManage.table.source'),
    dataIndex: 'source',
    key: 'source',
    width: 100,
    align: 'center' as const,
  },
  {
    title: t('pages.channelManage.table.materialNote'),
    dataIndex: 'materialNote',
    key: 'materialNote',
    width: 150,
    ellipsis: true,
  },
  {
    title: t('pages.channelManage.table.createTime'),
    dataIndex: 'createTime',
    key: 'createTime',
    width: 160,
  },
  {
    title: t('pages.channelManage.table.rejectInfo'),
    dataIndex: 'rejectInfo',
    key: 'rejectInfo',
    width: 100,
    align: 'center' as const,
  },
]);

// 可见列
const visibleColumns = computed(() => {
  if (!props.visibleColumnKeys || props.visibleColumnKeys.length === 0) {
    return allColumns.value;
  }
  return allColumns.value.filter(col => col.key && props.visibleColumnKeys.includes(col.key as string));
});

const rowSelection = computed(() => ({
  selectedRowKeys: props.selectedRowKeys || [],
  onChange: (selectedRowKeys: string[]) => {
    emit('update:selectedRowKeys', selectedRowKeys);
  },
}));

const getPlatformLabel = (channel: string) => {
  const keyMap: Record<string, string> = {
    meta: 'facebook',
    google: 'google',
    tiktok: 'tiktok',
    kwai: 'kwai',
    fb: 'facebook',
  };
  const key = keyMap[channel];
  return key ? t(`pages.channelManage.channel.${key}`) : channel;
};

const getPlatformIcon = (channel: string) => {
  const icons: Record<string, any> = {
    meta: FacebookOutlined,
    fb: FacebookOutlined,
    google: GoogleOutlined,
    tiktok: ThunderboltOutlined,
    kwai: ThunderboltOutlined,
  };
  return icons[channel] || FacebookOutlined;
};

const getShapeColor = (shape: string): string => {
  const colorMap: Record<string, string> = {
    '正方形': 'blue',
    square: 'blue',
    landscape: 'green',
    portrait: 'orange',
    unknown: 'default',
  };
  return colorMap[shape] || 'default';
};

const getSourceLabel = (source: string): string => {
  return t(`pages.channelManage.source.${source}`) || source;
};

const handleTableChange: TableProps['onChange'] = (pagination) => {
  emit('pageChange', pagination.current, pagination.pageSize);
};
</script>

<style scoped lang="less">
.material-table {
  .name-cell {
    display: flex;
    align-items: center;
    gap: 8px;

    .name-text {
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  }

  .platform-cell {
    display: flex;
    align-items: center;
    gap: 8px;

    .platform-icon {
      font-size: 16px;
    }
  }

  .ellipsis-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    display: block;
  }
}
</style>
