import type { AxiosRequestConfig, AxiosError, AxiosInstance } from 'axios';
import axios, { AxiosResponse } from 'axios';
import { localStorage } from '@/utils/local-storage';
import { notification } from 'ant-design-vue';
import { STORAGE_TOKEN_KEY, STORAGE_LANG_KEY } from '@/store/app';
import i18n from '@/locales';
import { resolveApiBaseUrl } from '@/utils/api-base';

// import { loginRoutePath } from '@/router/define-meta';

// 这里是用于设定请求后端时，所用的 Token KEY
// 可以根据自己的需要修改，常见的如 Access-Token，Authorization
// 需要注意的是，请尽量保证使用中横线`-` 来作为分隔符，
// 避免被 nginx 等负载均衡器丢弃了自定义的请求头
export const REQUEST_TOKEN_KEY = 'Authorization';
export const REQUEST_LANG_KEY = 'Lang';

const lang = i18n.global.locale.value;

// 与 .env / .env.production 对齐；开发环境见 resolveApiBaseUrl（避免直连生产域名触发 CORS）
const apiBase = resolveApiBaseUrl();

// 创建 axios 实例
const request: AxiosInstance = axios.create({
  // API 请求的默认前缀
  baseURL: apiBase,
  timeout: 360000, // 请求超时时间, 120s
  headers: {
    'Accept-Language': lang,
  },
});
export type RequestError = AxiosError<{
  message?: string;
  result?: any;
  errorMessage?: string;
  errors?: any;
}>;
// 异常拦截处理器
const errorHandler = (error: RequestError): Promise<any> => {
  if (error.response) {
    const { data = {}, status, statusText } = error.response;
    // 403 无权限
    if (status === 403) {
      notification.error({
        message: 'Forbidden',
        description: (data && data.message) || statusText,
      });
    }
    // 401 未登录/未授权
    if (status === 401 && data.result && data.result.isLogin) {
      notification.error({
        message: 'Unauthorized',
        description: 'Authorization verification failed',
      });
      // 如果你需要直接跳转登录页面
      // location.replace(
      //   `${process.env.VUE_APP_PUBLIC_PATH} + ${loginRoutePath}`.replaceAll('//', '/'),
      // );
    }
    if (data.errors && data.message) {
      notification.error({
        message: 'Forbidden',
        description: (data && data.message) || statusText,
      });
    }
  }
  return Promise.reject(error);
};

// 请求拦截器
const requestHandler = (
  config: AxiosRequestConfig,
): AxiosRequestConfig | Promise<AxiosRequestConfig> => {
  if (!config.headers) {
    config.headers = {};
  }
  // 登录接口仅允许 POST；若误用 GET+params，纠正为 POST+body（axios 默认无 method 时为 GET）
  const url = config.url || '';
  if (url === '/user/login' || url.endsWith('/user/login')) {
    config.method = 'post';
    if (config.params && !config.data) {
      config.data = config.params;
      config.params = undefined;
    }
  }
  const savedToken = localStorage.get(STORAGE_TOKEN_KEY);
  const savedLang = localStorage.get(STORAGE_LANG_KEY);
  // 如果 token 存在
  // 让每个请求携带自定义 token, 请根据实际情况修改
  if (savedToken) {
    config.headers[REQUEST_TOKEN_KEY] = `Bearer ${savedToken}`;
  }
  if (savedToken) {
    config.headers[REQUEST_LANG_KEY] = savedLang;
  }
  return config;
};

// Add a request interceptor
request.interceptors.request.use(requestHandler, errorHandler);

// 响应拦截器
const responseHandler = (response: AxiosResponse<any>) => {
  return response.data;
};

// Add a response interceptor
request.interceptors.response.use(responseHandler, errorHandler);

export { AxiosResponse };

export default request;
