const handleAddCustomCard = () => {
  addCardForm.value = {
    name: `${t('卡片')} ${customBoardCards.value.length + 1}`,
    channel: 'summary',
    dataSource: '综合报表',
    chartType: 'table',
    compareMode: 'none',
    dateRange: [dayjs().subtract(6, 'day'), dayjs()],
    dimension: 'date',
    filterChannel: undefined,
    metrics: ['spend', 'impressions', 'clicks', 'conversions'],
    tableColor: 'mixed',
    chartSize: 'large',
  };
  showAddCardDrawer.value = true;
};

const closeAddCardDrawer = () => {
  showAddCardDrawer.value = false;
};

const getChartTypeLabel = (chartType: string) => {
  return cardChartTypeOptions.find((item) => item.value === chartType)?.label ?? t('图表');
};

const resolveCardShape = (chartType: string): 'large' | 'medium' | 'small' => {
  if (addCardForm.value.chartSize === 'large') return 'large';
  if (chartType === 'table') return 'small';
  return 'medium';
};

const filterChartTypeOption = (input: string, option: any) => {
  const value = String(option?.value ?? '');
  const label = getChartTypeLabel(value);
  return label.toLowerCase().includes(input.toLowerCase());
};

const submitAddCard = async () => {
  const name = addCardForm.value.name.trim();
  if (!name) {
    message.error(t('请输入卡片名称'));
    return;
  }
  if (!selectedCreatedBoard.value) {
    message.warning(t('请先选择看板'));
    return;
  }

  const chartType = addCardForm.value.chartType;
  try {
    const res = await createMetaReportCard(selectedCreatedBoard.value.key, {
      title: name,
      chart_type: chartType,
      shape: resolveCardShape(chartType),
      sort_order: customBoardCards.value.length,
      query_config: {
        icon_name: name,
        data_source: addCardForm.value.dataSource,
        channel: addCardForm.value.channel === 'summary' ? t('汇总') : addCardForm.value.channel,
        compare_mode: addCardForm.value.compareMode,
        date_range: addCardForm.value.dateRange.map((item) => item.format('YYYY-MM-DD')),
        dimension: addCardForm.value.dimension,
        filter_channel: addCardForm.value.filterChannel,
        metrics: addCardForm.value.metrics,
        table_color: addCardForm.value.tableColor,
        chart_size: addCardForm.value.chartSize,
      },
    });
    const card = res?.data;
    if (!card) {
      throw new Error('empty card response');
    }
    customBoardCards.value.push(mapCardRowToLocal(card));
    showAddCardDrawer.value = false;
    message.success(t('卡片添加成功'));
  } catch (error) {
    console.error('添加卡片失败:', error);
    message.error(t('添加卡片失败'));
  }
};

const handleRefreshCustomBoardCards = async (showToast = false) => {
  if (!selectedCreatedBoard.value || selectedCreatedBoard.value.boardType !== 'custom') {
    return;
  }
  cardManagerLoading.value = true;
  try {
    const res = await fetchMetaReportCards(selectedCreatedBoard.value.key);
    customBoardCards.value = (res?.data ?? []).map(mapCardRowToLocal);
    if (showToast) {
      message.success(t('刷新成功'));
    }
  } catch (error) {
    console.error('刷新卡片失败:', error);
    message.error(t('刷新失败'));
  } finally {
    cardManagerLoading.value = false;
  }
};

const openCardManagerModal = async () => {
  if (!selectedCreatedBoard.value || selectedCreatedBoard.value.boardType !== 'custom') {
    message.warning(t('请先选择自定义看板'));
    return;
  }
  showCardManagerModal.value = true;
  await handleRefreshCustomBoardCards();
};

const handleCardManagerAction = (action: 'edit' | 'copy' | 'push' | 'delete', card: CustomBoardCard, idx: number) => {
  if (action === 'edit') {
    message.info(t('编辑功能开发中'));
    return;
  }
  if (action === 'copy') {
    message.info(t('复制功能开发中'));
    return;
  }
  if (action === 'push') {
    message.info(t('推送功能开发中'));
    return;
  }
  if (action === 'delete') {
    message.info(t('删除功能开发中'));
  }
};

const handleCreatedBoardMenuClick = ({ key }: { key: string }) => {
  if (!selectedCreatedBoard.value) {
    message.warning(t('请先选择看板'));
    return;
  }

  if (key === 'delete') {
    deleteDashboardId.value = selectedCreatedBoard.value.key;
    showDeleteDashboardModal.value = true;
    return;
  }

  if (key === 'rename') {
    renameDashboardForm.value.name = selectedCreatedBoard.value.label;
    showRenameDashboardModal.value = true;
    return;
  }

  if (key === 'save-as') {
    saveAsDashboardForm.value = {
      name: `${selectedCreatedBoard.value.label}-${t('副本')}`,
      folder: 'mine',
    };
    showSaveAsDashboardModal.value = true;
  }
};

const resetRenameDashboardForm = () => {
  showRenameDashboardModal.value = false;
  renameDashboardForm.value = {
    name: '',
  };
};

const submitRenameDashboard = async () => {
  if (!selectedCreatedBoard.value) {
    resetRenameDashboardForm();
    return;
  }
  const name = renameDashboardForm.value.name.trim();
  if (!name) {
    message.error(t('请输入看板名称'));
    return;
  }
  try {
    await updateMetaReportDashboard(selectedCreatedBoard.value.key, { name });
    const target = myDashboards.value.find((item) => item.key === selectedCreatedBoard.value?.key);
    if (target) {
      target.label = name;
    }
    selectedCreatedBoard.value = {
      ...selectedCreatedBoard.value,
      label: name,
    };
    message.success(t('重命名成功'));
    resetRenameDashboardForm();
  } catch (error) {
    console.error('重命名看板失败:', error);
    message.error(t('重命名看板失败'));
  }
};

const resetSaveAsDashboardForm = () => {
  showSaveAsDashboardModal.value = false;
  saveAsDashboardForm.value = {
    name: '',
    folder: 'mine',
  };
};

const submitSaveAsDashboard = async () => {
  if (!selectedCreatedBoard.value) {
    resetSaveAsDashboardForm();
    return;
  }
  const name = saveAsDashboardForm.value.name.trim();
  if (!name) {
    message.error(t('请输入看板名称'));
    return;
  }

  try {
    const sourceFolderId = myDashboards.value.find((item) => item.key === selectedCreatedBoard.value?.key)?.folderId ?? null;
    const res = await duplicateMetaReportDashboard(selectedCreatedBoard.value.key, {
      name,
      folder_id: sourceFolderId,
    });
    const row = res?.data;
    if (!row) {
      throw new Error('empty duplicate response');
    }
    const board = toLocalBoard(row);
    myDashboards.value.unshift(board);
    selectedCreatedBoard.value = {
      key: board.key,
      label: board.label,
      boardType: board.boardType,
    };
    selectedSidebarNode.value = {
      type: 'board',
      folderId: board.folderId,
    };
    selectedReport.value = board.boardType === 'comprehensive' ? 'created-comprehensive' : 'created-custom';
    customBoardCards.value = (row.cards ?? []).map(mapCardRowToLocal);
    message.success(t('另存为成功'));
    resetSaveAsDashboardForm();
  } catch (error) {
    console.error('另存为失败:', error);
    message.error(t('另存为失败'));
  }
};

const openDashboard = (key: string) => {
  const target = myDashboards.value.find((item) => item.key === key) ?? null;
  if (target) {
    if (target.folderId) {
      const folderKey = `folder:${target.folderId}`;
      if (!expandedTreeKeys.value.includes(SIDEBAR_ROOT_KEY)) {
        expandedTreeKeys.value = [...expandedTreeKeys.value, SIDEBAR_ROOT_KEY];
      }
      if (!expandedTreeKeys.value.includes(folderKey)) {
        expandedTreeKeys.value = [...expandedTreeKeys.value, folderKey];
      }
    }
    selectedCreatedBoard.value = target;
    selectedSidebarNode.value = {
      type: 'board',
      folderId: target.folderId ?? null,
    };
    selectedReport.value = target.boardType === 'comprehensive' ? 'created-comprehensive' : 'created-custom';
    if (target.boardType === 'custom') {
      fetchMetaReportCards(key)
        .then((res) => {
          customBoardCards.value = (res?.data ?? []).map(mapCardRowToLocal);
        })
        .catch((error) => {
          console.error('加载卡片失败:', error);
          customBoardCards.value = [];
        });
    }
    return;
  }
  selectReport(key);
};

const handleRefresh = () => {
  loadSummaryData();
};

const handleExport = () => {
  // TODO: 导出数据
  console.log('导出数据');
};

const handleSummaryTableChange = (pag: any) => {
  summaryPagination.value.current = pag.current;
  summaryPagination.value.pageSize = pag.pageSize;
  loadSummaryData();
};

const filterMetricOption = (input: string, option: any) => {
  return option.children.toLowerCase().indexOf(input.toLowerCase()) >= 0;
};

const toggleChartCollapse = () => {
  chartCollapsed.value = !chartCollapsed.value;
  if (!chartCollapsed.value && previewChart.value) {
    nextTick(() => {
      initPreviewChart();
    });
  }
};

const initPreviewChart = async () => {
  if (!previewChart.value || chartCollapsed.value) return;
  
  if (previewChartInstance) {
    previewChartInstance.dispose();
  }
  
  previewChartInstance = echarts.init(previewChart.value);
  
  // 根据选中的指标和图表类型生成数据
  const chartData = await getPreviewChartData({
    metric1: previewMetrics.value.metric1,
    metric2: previewMetrics.value.metric2,
    topN: parseInt(previewTopN.value),
    chartType: previewChartType.value,
  });
  
  const option: echarts.EChartOption = {
    tooltip: {
      trigger: 'axis',
      axisPointer: {
        type: 'cross',
      },
    },
    legend: {
      data: chartData.legend,
    },
    grid: {
      left: '3%',
      right: '4%',
      bottom: '3%',
      containLabel: true,
    },
    xAxis: {
      type: 'category',
      boundaryGap: previewChartType.value === 'bar',
      data: chartData.categories,
    },
    yAxis: {
      type: 'value',
      name: chartData.yAxisName,
    },
    series: chartData.series,
  };
  
  previewChartInstance.setOption(option);
};

const selectReport = (key: string) => {
  selectedReport.value = key;
  // 根据选择的报表加载对应数据
  if (key === 'summary') {
    loadSummaryData();
  } else if (key === 'quality-materials') {
    loadMaterialsData();
  } else if (key === 'overall-performance') {
    loadData();
  } else if (key === 'top-accounts') {
    loadTopAccountsData();
  } else if (key === 'top-materials') {
    loadTopMaterialsData();
  }
};

const handleLeftFilter = () => {
  loadMaterialsTableData();
};

const selectMaterial = (materialId: string) => {
  selectedMaterialId.value = materialId;
};

const loadMaterialsTableData = async () => {
  materialsLoading.value = true;
  try {
    const result = await getMaterialsTableData({
      page: materialsPagination.value.current,
      pageSize: materialsPagination.value.pageSize,
      ...filters.value,
    });
    materialsTableData.value = result.data;
    materialsPagination.value.total = result.total;
  } catch (error) {
    console.error('加载素材表格数据失败:', error);
  } finally {
    materialsLoading.value = false;
  }
};

const handleMaterialsTableChange = (pag: any) => {
  materialsPagination.value.current = pag.current;
  materialsPagination.value.pageSize = pag.pageSize;
  loadMaterialsTableData();
};

// 加载 TOP 广告账户数据
const loadTopAccountsData = async () => {
  try {
    await loadTopAccountsTableData();
    await loadTopAccountsChartData();
  } catch (error) {
    console.error('加载TOP广告账户数据失败:', error);
  }
};

const loadTopAccountsTableData = async () => {
  topAccountsLoading.value = true;
  try {
    const result = await getTopAdAccountsData({
      page: topAccountsPagination.value.current,
      pageSize: topAccountsPagination.value.pageSize,
      ...topAccountsFilters.value,
    });
    topAccountsTableData.value = result.data;
    topAccountsPagination.value.total = result.total;
  } catch (error) {
    console.error('加载TOP广告账户表格数据失败:', error);
  } finally {
    topAccountsLoading.value = false;
  }
};

const loadTopAccountsChartData = async () => {
  await nextTick();
  if (!topAccountsChart.value) return;
  
  const trendData = await getTopAdAccountsTrendData();
  
  // 初始化图例
  topAccountsLegend.value = trendData.accounts.map((account: any, index: number) => ({
    name: account.name,
    checked: index < 6, // 默认选中前6个
  }));
  
  initTopAccountsChart(trendData);
};

const initTopAccountsChart = (trendData: any) => {
  if (!topAccountsChart.value) return;
  
  if (topAccountsChartInstance) {
    topAccountsChartInstance.dispose();
  }
  
  topAccountsChartInstance = echarts.init(topAccountsChart.value);
  
  const colors = ['#1890ff', '#fa8c16', '#52c41a', '#722ed1', '#eb2f96', '#13c2c2', '#f5222d', '#faad14'];
  const series = trendData.accounts
    .filter((_account: any, index: number) => topAccountsLegend.value[index]?.checked)
    .map((account: any, index: number) => ({
      name: account.name,
      type: 'line',
      smooth: true,
      data: account.data,
      itemStyle: {
        color: colors[index % colors.length],
      },
    }));
  
  const option: echarts.EChartOption = {
    tooltip: {
      trigger: 'axis',
      axisPointer: {
        type: 'cross',
      },
    },
    legend: {
      show: false,
    },
    grid: {
      left: '3%',
      right: '25%',
      bottom: '3%',
      containLabel: true,
    },
    xAxis: {
      type: 'category',
      boundaryGap: false,
      data: trendData.dates.map((date: string) => dayjs(date).format('MM/DD')),
    },
    yAxis: {
      type: 'value',
      name: t('花费'),
      axisLabel: {
        formatter: (value: number) => {
          return (value / 10000).toFixed(0) + t('万');
        },
      },
    },
    series,
  };
  
  topAccountsChartInstance.setOption(option);
};

const updateTopAccountsChart = () => {
  if (topAccountsChartInstance) {
    const trendData = {
      dates: ['2025-12-30', '2025-12-31', '2026-01-01', '2026-01-02', '2026-01-03', '2026-01-04', '2026-01-05'],
      accounts: [
        {
          name: '广告账户名称_1',
          data: [45000, 48000, 50000, 49000, 51000, 52000, 49948],
        },
        {
          name: '广告账户名称_2',
          data: [40000, 42000, 44000, 43000, 45000, 46000, 43964],
        },
        {
          name: '广告账户名称_3',
          data: [30000, 32000, 33000, 31000, 34000, 35000, 32833],
        },
        {
          name: '广告账户名称_4',
          data: [20000, 21000, 22000, 20000, 23000, 24000, 20615],
        },
        {
          name: '广告账户名称_5',
          data: [28000, 29000, 30000, 28000, 31000, 32000, 29194],
        },
        {
          name: '广告账户名称_6',
          data: [31000, 32000, 33000, 31000, 34000, 35000, 31878],
        },
        {
          name: '广告账户名称_7',
          data: [25000, 26000, 27000, 25000, 28000, 29000, 27000],
        },
        {
          name: '广告账户名称_8',
          data: [22000, 23000, 24000, 22000, 25000, 26000, 24000],
        },
      ],
    };
    initTopAccountsChart(trendData);
  }
};

const handleTopAccountsFilter = () => {
  loadTopAccountsTableData();
};

const handleTopAccountsTableChange = (pag: any) => {
  topAccountsPagination.value.current = pag.current;
  topAccountsPagination.value.pageSize = pag.pageSize;
  loadTopAccountsTableData();
};

const getTopAccountsValueClass = (_value: number, type: string, _inverse: boolean = false) => {
  // 根据业务规则设置颜色类
  if (type === 'cpm' && _value > 20) {
    return 'value-negative';
  }
  if (type === 'ctr' && _value > 0.1) {
    return 'value-positive';
  }
  return '';
};

// 加载 TOP 素材数据
const loadTopMaterialsData = async () => {
  try {
    const [thumbnails] = await Promise.all([
      getTopMaterialsThumbnails(),
      loadTopMaterialsTableData(),
    ]);
    topMaterialsThumbnails.value = thumbnails;
  } catch (error) {
    console.error('加载TOP素材数据失败:', error);
  }
};

const loadTopMaterialsTableData = async () => {
  topMaterialsLoading.value = true;
  try {
    const result = await getTopMaterialsData({
      page: topMaterialsPagination.value.current,
      pageSize: topMaterialsPagination.value.pageSize,
      ...topMaterialsFilters.value,
    });
    topMaterialsTableData.value = result.data;
    topMaterialsPagination.value.total = result.total;
  } catch (error) {
    console.error('加载TOP素材表格数据失败:', error);
  } finally {
    topMaterialsLoading.value = false;
  }
};

const handleTopMaterialsFilter = () => {
  loadTopMaterialsTableData();
};

const handleTopMaterialsTableChange = (pag: any) => {
  topMaterialsPagination.value.current = pag.current;
  topMaterialsPagination.value.pageSize = pag.pageSize;
  loadTopMaterialsTableData();
};

const getTopMaterialsValueClass = (_value: number, type: string, _inverse: boolean = false) => {
  // 根据业务规则设置颜色类（绿色表示好，红色表示差）
  if (type === 'spend' || type === 'impressions' || type === 'clicks' || type === 'conversions') {
    // 正向指标：值越大越好，绿色
    return 'value-positive';
  } else if (type === 'cpm' || type === 'cpc') {
    // 反向指标：值越小越好，绿色
    return 'value-negative';
  } else if (type === 'ctr' || type === 'conversionRate') {
    // 正向指标：值越大越好
    return 'value-positive';
  }
  return '';
};

// 初始化花费趋势图
const initSpendTrendChart = async () => {
  if (!spendTrendChart.value) return;
  
  spendTrendChartInstance = echarts.init(spendTrendChart.value);
  const trendData = await getSpendTrendData();
  
  const option: echarts.EChartOption = {
    tooltip: {
      trigger: 'axis',
      axisPointer: {
        type: 'cross',
      },
    },
    legend: {
      data: [t('花费')],
    },
    grid: {
      left: '3%',
      right: '4%',
      bottom: '3%',
      containLabel: true,
    },
    xAxis: {
      type: 'category',
      boundaryGap: false,
      data: trendData.map(item => dayjs(item.date).format('MM/DD')),
    },
    yAxis: {
      type: 'value',
      name: t('花费'),
      axisLabel: {
        formatter: (value: number) => {
          return (value / 10000).toFixed(0) + t('万');
        },
      },
    },
    series: [
      {
        name: t('花费'),
        type: 'line',
        smooth: true,
        data: trendData.map(item => item.spend),
        itemStyle: {
          color: '#1890ff',
        },
        areaStyle: {
          color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
            { offset: 0, color: 'rgba(24, 144, 255, 0.3)' },
            { offset: 1, color: 'rgba(24, 144, 255, 0.1)' },
          ]),
        },
      },
    ],
  };
  
  spendTrendChartInstance.setOption(option);
};

// 初始化渠道分布图
const initChannelChart = async () => {
  if (!channelChart.value) return;
  
  channelChartInstance = echarts.init(channelChart.value);
  const channelData = await getChannelDistributionData();
  
  const option: echarts.EChartOption = {
    tooltip: {
      trigger: 'item',
      formatter: '{a} <br/>{b}: {c} ({d}%)',
    },
    legend: {
      orient: 'vertical',
      left: 'left',
      data: channelData.map(item => item.name),
    },
    series: [
      {
        name: t('花费'),
        type: 'pie',
        radius: ['40%', '70%'],
        avoidLabelOverlap: false,
        itemStyle: {
          borderRadius: 10,
          borderColor: '#fff',
          borderWidth: 2,
        },
        label: {
          show: false,
          position: 'center',
        },
        emphasis: {
          label: {
            show: true,
            fontSize: 20,
            fontWeight: 'bold' as any,
          },
        },
        labelLine: {
          show: false,
        },
        data: channelData.map(item => ({
          value: item.value,
          name: item.name,
          itemStyle: { color: item.color },
        })),
      },
    ],
  };
  
  channelChartInstance.setOption(option);
};

// 初始化地区分布图
const initRegionChart = async () => {
  if (!regionChart.value) return;
  
  regionChartInstance = echarts.init(regionChart.value);
  const regionData = await getRegionDistributionData();
  
  const option: echarts.EChartOption = {
    tooltip: {
      trigger: 'axis',
      axisPointer: {
        type: 'shadow',
      },
    },
    grid: {
      left: '3%',
      right: '4%',
      bottom: '3%',
      containLabel: true,
    },
    xAxis: {
      type: 'category',
      data: regionData.map(item => item.name),
      axisLabel: {
        rotate: 45,
      },
    },
    yAxis: {
      type: 'value',
      name: t('花费'),
      axisLabel: {
        formatter: (value: number) => {
          return (value / 10000).toFixed(0) + t('万');
        },
      },
    },
    series: [
      {
        name: t('花费'),
        type: 'bar',
        data: regionData.map(item => item.spend),
        itemStyle: {
          color: '#1890ff',
        },
      },
    ],
  };
  
  regionChartInstance.setOption(option);
};

// 初始化优化师分布图
const initOptimizerChart = async () => {
  if (!optimizerChart.value) return;
  
  optimizerChartInstance = echarts.init(optimizerChart.value);
  const optimizerData = await getOptimizerDistributionData();
  
  const option: echarts.EChartOption = {
    tooltip: {
      trigger: 'axis',
      axisPointer: {
        type: 'shadow',
      },
    },
    grid: {
      left: '3%',
      right: '4%',
      bottom: '3%',
      containLabel: true,
    },
    xAxis: {
      type: 'value',
      name: t('花费'),
      axisLabel: {
        formatter: (value: number) => {
          return (value / 10000).toFixed(0) + t('万');
        },
      },
    },
    yAxis: {
      type: 'category',
      data: optimizerData.map(item => item.name),
    },
    series: [
      {
        name: t('花费'),
        type: 'bar',
        data: optimizerData.map(item => item.spend),
        itemStyle: {
          color: '#1890ff',
        },
      },
    ],
  };
  
  optimizerChartInstance.setOption(option);
};

// 初始化所有图表
const initCharts = async () => {
  await nextTick();
  await Promise.all([
    initSpendTrendChart(),
    initChannelChart(),
    initRegionChart(),
    initOptimizerChart(),
  ]);
  
  // 监听窗口大小变化，自动调整图表大小
  window.addEventListener('resize', handleResize);
};

const handleResize = () => {
  spendTrendChartInstance?.resize();
  channelChartInstance?.resize();
  regionChartInstance?.resize();
  optimizerChartInstance?.resize();
  previewChartInstance?.resize();
};

// 销毁图表
const disposeCharts = () => {
  spendTrendChartInstance?.dispose();
  channelChartInstance?.dispose();
  regionChartInstance?.dispose();
  optimizerChartInstance?.dispose();
  previewChartInstance?.dispose();
  window.removeEventListener('resize', handleResize);
};

onMounted(() => {
  loadFoldersAndDashboards();
  // Initial load based on default selectedReport
  if (selectedReport.value === 'summary') {
    loadSummaryData();
  } else if (selectedReport.value === 'quality-materials') {
    loadMaterialsData();
  } else if (selectedReport.value === 'overall-performance') {
    loadData();
  } else if (selectedReport.value === 'top-accounts') {
    loadTopAccountsData();
  } else if (selectedReport.value === 'top-materials') {
    loadTopMaterialsData();
  }
  // Charts are only initialized for 'overall-performance'
  if (selectedReport.value === 'overall-performance') {
    setTimeout(() => {
      initCharts();
    }, 100);
  }
});

onUnmounted(() => {
  disposeCharts();
});
</script>

<style lang="less" scoped>
.promotion-dashboard {
  --card-bg: #ffffff;
  --card-border: #e9edf5;
  --text-main: #1f2533;
  --text-sub: #667089;
  --primary: #2f7cff;
  --page-bg: #f6f8fc;
  --radius: 8px;

  padding: 16px;
  min-height: calc(100vh - 120px);
  color: var(--text-main);

  .page-header {
    margin-bottom: 12px;

    h2 {
      margin: 0 0 4px;
      font-size: 18px;
      font-weight: 600;
      line-height: 1.4;
    }

    .breadcrumb {
      font-size: 12px;
      color: var(--text-sub);
    }
  }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    background: var(--card-bg);
    margin-bottom: 12px;
  }

  .dashboard-layout {
    display: grid;
    grid-template-columns: 252px minmax(0, 1fr);
    gap: 12px;
    min-height: calc(100vh - 210px);
  }

  .left-sidebar,
  .right-content {
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    background: var(--card-bg);
  }

  .left-sidebar {
    padding: 8px;
    overflow: auto;
    background: #fff;

    .sidebar-top {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 32px;
      gap: 6px;
      margin-bottom: 8px;
    }

    .sidebar-search-input {
      :deep(.ant-input-affix-wrapper) {
        height: 28px;
        border-color: #e2e5ec;
        border-radius: 2px;
        background: #fff;
      }
      :deep(.ant-input) {
        font-size: 12px;
      }
    }

    .sidebar-plus-btn {
      height: 28px;
      padding: 0;
      border: 1px solid #e2e5ec;
      border-radius: 2px;
      background: #fff;
      color: #9aa3b3;
      display: inline-flex;
      align-items: center;
      justify-content: center;

      :deep(.ant-btn) {
        width: 100%;
      }

      &:hover,
      &:focus {
        color: #4e5969;
        border-color: #c6ceda;
      }
    }

    .sidebar-list {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .sidebar-custom-list {
      margin-top: 2px;
      display: flex;
      flex-direction: column;
      gap: 2px;

      .sidebar-item {
        min-height: 34px;
        border-radius: 4px;
        padding: 0 6px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: #4f586b;
        cursor: pointer;

        &:hover {
          background: #f6f8fc;
        }

        &.active {
          background: #cfe2fb;
          box-shadow: inset 2px 0 0 #1677ff;
        }

        &.level-1 {
          padding-left: 22px;
        }

        &.level-2 {
          padding-left: 40px;
        }
      }

      .item-left {
        min-width: 0;
        flex: 1;
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      .item-title {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 13px;
      }

      .item-switcher {
        width: 14px;
        min-width: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #aab2c2;
        font-size: 11px;

        &.placeholder {
          color: transparent;
        }
      }

      .item-icon,
      .tree-emoji-icon {
        width: 14px;
        min-width: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        color: #a7b0c2;
      }

      .item-actions {
        margin-left: auto;
        display: inline-flex;
        align-items: center;
        gap: 2px;
        opacity: 0;
        transition: opacity 0.15s ease;
      }

      .sidebar-item.hover-actions:hover .item-actions,
      .sidebar-item.hover-actions.active .item-actions {
        opacity: 1;
      }
    }

    .tree-node-action-btn {
      width: 20px;
      min-width: 20px;
      height: 20px;
      padding: 0;
      color: #8f99ad;
    }
  }

  .right-content {
    padding: 8px;
    overflow: auto;
    background: #f5f5f5;
  }

  .report-content,
  .summary-layout,
  .summary-main-content {
    min-width: 0;
  }

  .home-dashboard {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: 250px 250px;
    gap: 8px;
    min-height: calc(100vh - 190px);
  }

  .home-card {
    border: 1px solid #e8edf5;
    border-radius: 4px;
    background: #fff;
    padding: 14px 16px;
    overflow: hidden;
  }

  .card-title {
    font-size: 13px;
    font-weight: 600;
    color: #333b4d;
    margin-bottom: 12px;
  }

  .mt16 {
    margin-top: 16px;
  }

  .profile-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #f2b736;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
  }

  .name {
    font-size: 14px;
    font-weight: 600;
    color: #2f3442;
    line-height: 1.2;
  }

  .email {
    font-size: 11px;
    color: #97a1b4;
    line-height: 1.2;
    margin-top: 2px;
  }

  .profile-metrics {
    margin-top: 4px;
  }

  .metric-row {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    font-size: 12px;
    line-height: 26px;
    color: #5a647a;
  }

  .overview-card {
    background: linear-gradient(180deg, #fbfcff 0%, #ffffff 65%);
  }

  .channel-icons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 28px;
    height: calc(100% - 36px);

    img {
      width: 34px;
      height: 34px;
      object-fit: contain;
      opacity: 0.95;
    }
  }

  .notice-card {
    .link-list {
      margin: 0;
      padding: 0;
      list-style: none;

      li {
        margin-bottom: 8px;
      }

      a {
        color: #2f7cff;
        font-size: 12px;
        text-decoration: none;
      }
    }
  }

  .banner-card {
    .banner-image {
      width: 100%;
      height: calc(100% - 34px);
      object-fit: contain;
      border-radius: 3px;
      background: #f8f9fc;
    }
  }

  .report-header {
    margin-bottom: 10px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;

    h2 {
      margin: 0;
      font-size: 18px;
      font-weight: 600;
    }

    .breadcrumb,
    .save-time {
      font-size: 12px;
      color: var(--text-sub);
      margin-top: 2px;
    }
  }

  .created-board-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .report-filters,
  .summary-header,
  .summary-filters,
  .table-actions-bar,
  .data-controls,
  .preview-metrics,
  .chart-top-controls,
  .chart-filters,
  .table-filters {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .report-filters,
  .summary-header,
  .summary-filters,
  .summary-tabs,
  .data-preview,
  .detailed-data,
  .table-section,
  .materials-table-view,
  .chart-section,
  .charts-section .chart-card {
    margin-bottom: 12px;
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    background: var(--card-bg);
    padding: 12px;
  }

  .summary-layout {
    display: grid;
    grid-template-columns: 140px minmax(0, 1fr);
    gap: 12px;
  }

  .platform-sidebar {
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    padding: 8px;
    background: #fbfcff;

    .platform-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px;
      border-radius: 6px;
      color: #4a5368;
      cursor: pointer;
      margin-bottom: 4px;

      &.active {
        background: #ebf2ff;
        color: var(--primary);
      }
    }
  }

  .preview-header,
  .data-header,
  .chart-header,
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;

    h3,
    .preview-title {
      margin: 0;
      font-size: 15px;
      font-weight: 600;
    }
  }

  .preview-icons,
  .view-modes {
    display: flex;
    align-items: center;
    gap: 10px;

    :deep(svg) {
      font-size: 16px;
      color: #7f8aa2;
      cursor: pointer;
    }

    :deep(svg.active),
    :deep(svg:hover) {
      color: var(--primary);
    }
  }

  .preview-chart {
    width: 100%;
    height: 320px;
  }

  .chart-container {
    width: 100%;
    height: 320px;
  }

  .chart-container-small {
    width: 100%;
    height: 240px;
  }

  .chart-container-large {
    width: 100%;
    height: 360px;
  }

  .channel-distribution {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 200px;
    gap: 12px;
    align-items: center;
  }

  .channel-list {
    .channel-item {
      display: grid;
      grid-template-columns: 12px minmax(0, 1fr) auto;
      gap: 8px;
      align-items: center;
      margin-bottom: 8px;
      font-size: 12px;

      .channel-color {
        width: 12px;
        height: 12px;
        border-radius: 2px;
      }

      .channel-percent {
        font-weight: 600;
      }
    }
  }

  .kpi-cards {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 12px;

    .kpi-card {
      border: 1px solid var(--card-border);
      border-radius: var(--radius);
      background: var(--card-bg);
      padding: 12px;

      .kpi-label {
        font-size: 12px;
        color: var(--text-sub);
      }

      .kpi-value {
        margin-top: 6px;
        font-size: 22px;
        font-weight: 600;
      }
    }
  }

  .charts-section {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .materials-grid-view {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(132px, 1fr));
    gap: 10px;
    margin-bottom: 12px;
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    background: #fafcff;
    padding: 10px;

    .material-card-grid {
      border: 1px solid var(--card-border);
      border-radius: 6px;
      background: #fff;
      overflow: hidden;
      cursor: pointer;

      &.active {
        border-color: #cfe0ff;
        box-shadow: 0 0 0 1px #cfe0ff;
      }

      .material-thumbnail-grid {
        width: 100%;
        height: 98px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f2f4f8;
        overflow: hidden;

        img {
          width: 100%;
          height: 100%;
          object-fit: cover;
        }

        .material-placeholder {
          font-size: 24px;
          color: #a4adbf;
        }
      }

      .material-name-grid,
      .material-cost-grid {
        padding: 6px 8px;
        line-height: 1.2;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .material-name-grid {
        font-size: 12px;
        font-weight: 500;
      }

      .material-cost-grid {
        font-size: 11px;
        color: var(--text-sub);
        padding-top: 0;
      }
    }
  }

  .created-board-page {
    .board-chart-panel {
      position: relative;
      height: 250px;
      border: 1px solid var(--card-border);
      border-radius: var(--radius);
      background: #fff;
      margin-bottom: 12px;
      padding: 14px 16px 24px;
      overflow: hidden;

      .chart-axis-line {
        position: absolute;
        left: 14px;
        right: 14px;
        bottom: 28px;
        height: 1px;
        background: #cfd7e6;
      }

      .chart-grid-line {
        height: 1px;
        margin-top: 30px;
        background: #eef2f8;
      }

      .chart-empty-label {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: #99a3b6;
        font-size: 12px;
      }
    }
  }

  .created-custom-board-page {
    min-height: calc(100vh - 220px);

    .report-header {
      margin-bottom: 8px;
      align-items: center;
      background:#f5f5f5;
      padding: 8px 10px;
      border-radius: 4px;
    }

    .custom-board-panel {
      margin-top: 0;
      background: transparent;
      border: 0;
      border-radius: var(--radius);
      min-height: calc(100vh - 300px);
      padding: 12px;
    }

    .custom-board-title-wrap {
      min-width: 0;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .custom-board-title-line {
      display: flex;
      align-items: center;

      h2 {
        margin: 0;
        font-size: 30px;
        font-weight: 600;
        color: #273142;
        line-height: 1.2;
      }
    }

    .custom-board-meta {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
      color: #6f7c92;
      font-weight: 500;
    }

    .custom-header-actions {
      gap: 10px;
      margin-left: auto;
    }

    .header-icon-btn {
      width: 36px;
      min-width: 36px;
      height: 36px;
      border: 1px solid #d9dfeb;
      color: #7d889c;
      border-radius: 4px;
      background: #fff;
      padding: 0;
      font-size: 16px;

      &:hover,
      &:focus {
        border-color: #c8d0de;
        color: #6b778f;
      }
    }

    .manage-card-btn {
      height: 36px;
      border-radius: 4px;
      padding: 0 14px;
      font-size: 14px;
      border: 1px solid #d9dfeb;
      color: #51607a;
      background: #fff;
    }

    .add-card-btn {
      height: 36px;
      border-radius: 4px;
      padding: 0 14px;
      font-size: 14px;
      font-weight: 500;
    }

    .custom-board-empty {
      height: calc(100vh - 340px);
      min-height: 300px;
      border-radius: var(--radius);
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: center;

      .custom-empty-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      .custom-empty-illustration {
        width: 86px;
        height: 86px;
        border-radius: 50%;
        background: #f4f7fc;
        color: #c1cbdd;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 10px;

        :deep(svg) {
          font-size: 34px;
        }
      }

      .custom-empty-text {
        color: #7f8aa2;
        font-size: 12px;
        margin-bottom: 10px;
      }
    }

    .custom-board-cards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .custom-card-item {
      border-radius: 8px;
      background: #fff;
      border: 1px solid #e2e8f3;
      box-shadow: 0 1px 3px rgba(31, 51, 81, 0.05);
      padding: 16px;
      min-height: 120px;

      &.shape-large {
        grid-column: span 2;
        min-height: 220px;
      }

      &.shape-medium {
        grid-column: span 1;
        min-height: 180px;
      }

      &.shape-small {
        grid-column: span 1;
        min-height: 170px;
      }
    }

    .custom-card-title-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
      gap: 8px;
    }

    .custom-card-title {
      font-size: 16px;
      font-weight: 600;
      color: #273142;
    }

    .custom-card-type {
      font-size: 13px;
      color: #8a94a6;
    }

    .card-toolbar {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 13px;
      color: #7f8aa2;
      margin-bottom: 10px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .card-filter-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 240px;
      gap: 10px;
      margin-bottom: 10px;

      &.compact {
        grid-template-columns: 260px 140px;
        gap: 8px;
      }
    }

    .filter-box {
      height: 30px;
      border: 1px solid #e7ebf3;
      border-radius: 4px;
      background: #fff;
      display: inline-flex;
      align-items: center;
      padding: 0 10px;
      font-size: 13px;
      color: #7a859b;
      min-width: 0;

      .label {
        margin-right: 4px;
        color: #5c6881;
      }

      .value {
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: #2f3a4d;
      }

      .suffix {
        margin-left: 6px;
        color: #a1abba;
        font-size: 12px;
      }
    }

    .card-table-mock {
      border: 1px solid #edf1f7;
      border-radius: 6px;
      background: #fff;
      overflow: hidden;
      min-height: 140px;

      &.table-small {
        min-height: 300px;
      }

      &.table-large {
        min-height: 260px;
      }
    }

    .card-manager-list {
      max-height: 420px;
      overflow: auto;
      border: 1px solid #edf1f7;
      border-radius: 8px;
      background: #fff;
    }

    .card-manager-empty {
      padding: 30px 0;
      text-align: center;
      color: #97a1b4;
      font-size: 13px;
    }

    .card-manager-table {
      min-width: 780px;
    }

    .card-manager-head,
    .card-manager-row {
      display: grid;
      grid-template-columns: 2.2fr 1.2fr 1fr 1fr 1.8fr;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      border-bottom: 1px solid #edf1f7;
    }

    .card-manager-head {
      position: sticky;
      top: 0;
      z-index: 1;
      background: #f3f8f4;
      color: #2f3a4d;
      font-size: 13px;
      font-weight: 600;
    }

    .card-manager-row {
      font-size: 13px;
      color: #2f3a4d;
      background: #fff;
    }

    .name-cell {
      display: flex;
      align-items: center;
      gap: 6px;
      min-width: 0;
    }

    .drag-icon {
      color: #b2bccd;
      letter-spacing: -1px;
      font-size: 12px;
      cursor: grab;
      user-select: none;
      margin-right: 2px;
    }

    .name-text {
      color: #2f3a4d;
      font-weight: 500;
      white-space: nowrap;
    }

    .name-subtitle {
      color: #8c96a8;
      font-size: 12px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .cell-text {
      color: #4f5c72;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .action-cell {
      display: inline-flex;
      align-items: center;
      gap: 2px;
    }

    .table-head {
      display: grid;
      grid-template-columns: 1.1fr repeat(4, 1fr);
      gap: 8px;
      padding: 10px 12px;
      background: #fafcff;
      border-bottom: 1px solid #edf1f7;
      font-size: 13px;
      color: #59657e;
    }

    .table-head-small {
      grid-template-columns: 1.2fr repeat(3, 1fr);
      gap: 6px;
      font-size: 12px;
    }

    .table-head-large {
      grid-template-columns: 1fr repeat(8, minmax(52px, 1fr));
      gap: 6px;
      font-size: 12px;
      color: #5f6c85;
    }

    .table-empty {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 90px;
      font-size: 12px;
      color: #a0a9ba;
    }

    .table-empty-small {
      min-height: 80px;
    }

    .table-empty-large {
      min-height: 78px;
      border-bottom: 1px solid #f2f5fb;
    }

    .table-body-small,
    .table-body-large {
      background: #fff;
    }

    .table-row-small {
      display: grid;
      grid-template-columns: 1.2fr repeat(3, 1fr);
      gap: 6px;
      padding: 8px 12px;
      font-size: 12px;
      color: #4f5c72;
      border-bottom: 1px solid #f4f6fb;
    }

    .table-row-large {
      display: grid;
      grid-template-columns: 1fr repeat(8, minmax(52px, 1fr));
      gap: 6px;
      padding: 7px 12px;
      font-size: 12px;
      color: #4f5c72;
      border-bottom: 1px solid #f4f6fb;
    }

    .table-footer {
      height: 30px;
      padding: 0 10px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 10px;
      font-size: 12px;
      color: #8b96aa;

      .pager {
        min-width: 18px;
        height: 18px;
        border: 1px solid #d5ddeb;
        border-radius: 2px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #5d6a83;
        background: #fff;
      }
    }

    .card-chart-mock {
