        <!-- TOP 广告账户报表 -->
        <div v-else-if="selectedReport === 'top-accounts'" class="report-content">
          <div class="report-header">
            <h2>{{ t('TOP 广告账户') }} ({{ t('示例数据') }})</h2>
            <div class="breadcrumb">{{ t('综合报表') }}, {{ t('汇总') }}</div>
            <div class="save-time">{{ t('上次保存时间') }}: {{ lastSaveTime }}</div>
          </div>

          <!-- 筛选栏 -->
          <div class="report-filters">
            <a-select
              v-model:value="topAccountsFilters.dimension"
              style="width: 120px; margin-right: 8px"
            >
              <a-select-option value="date">{{ t('维度: 日期') }}</a-select-option>
              <a-select-option value="account">{{ t('维度: 广告账户') }}</a-select-option>
            </a-select>
            <a-range-picker
              v-model:value="dateRange"
