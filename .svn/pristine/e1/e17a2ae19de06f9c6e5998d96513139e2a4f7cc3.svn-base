                    <div class="filter-box channel-box">
                      <span class="label">{{ t('渠道') }}:</span>
                      <span class="value">{{ t('请选择') }}</span>
                      <span class="suffix">⌄</span>
                    </div>
                  </div>
                  <div v-if="card.shape === 'small'" class="card-table-mock table-small">
                    <div class="table-head table-head-small">
                      <span>{{ t('日期') }}</span>
                      <span>{{ t('花费') }}</span>
                      <span>{{ t('点击') }}</span>
                      <span>{{ t('转化') }}</span>
                    </div>
                    <div class="table-body-small">
                      <div v-for="row in tablePreviewRows" :key="`small-${card.id}-${row.key}`" class="table-row-small">
                        <span>{{ row.date }}</span>
