}));

const formatCurrency = (value: number) => {
  if (!value && value !== 0) return '-';
  return new Intl.NumberFormat('zh-CN', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 3,
    maximumFractionDigits: 3,
  }).format(value);
};

const formatNumber = (value: number) => {
  if (!value && value !== 0) return '-';
  return new Intl.NumberFormat('zh-CN').format(value);
};

const formatPercent = (value: number) => {
  if (!value && value !== 0) return '-';
  return (value * 100).toFixed(2) + '%';
};

const getValueClass = (_value: number, _type: string, _inverse: boolean = false) => {
  // 这里可以根据业务逻辑设置颜色类
  // 简化处理，实际应该根据平均值或阈值来判断
  return '';
};

const getMaterialValueClass = (_value: number, type: string, _inverse: boolean = false) => {
  // 根据值的大小设置颜色类（绿色表示好，红色表示差）
  // 这里简化处理，实际应该根据业务规则计算
  if (type === 'spend' || type === 'impressions' || type === 'clicks' || type === 'conversions') {
    // 正向指标：值越大越好，绿色
    return 'value-positive';
  } else if (type === 'cpm' || type === 'cpc') {
    // 反向指标：值越小越好，绿色
    return 'value-negative';
  } else if (type === 'ctr') {
    // 正向指标：值越大越好
    return 'value-positive';
  }
  return '';
};

const handleFilter = () => {
  loadData();
};

const handleTableChange = (pag: any) => {
  pagination.value.current = pag.current;
  pagination.value.pageSize = pag.pageSize;
  loadStoreData();
};

const loadData = async () => {
  loading.value = true;
  try {
    const [kpi, channels] = await Promise.all([
      getKpiData(),
      getChannelDistributionData(),
    ]);
    kpiData.value = kpi;
    channelData.value = channels;
    loadStoreData();
    loadMaterialsData();
  } catch (error) {
    console.error('加载数据失败:', error);
  } finally {
    loading.value = false;
  }
};

const loadStoreData = async () => {
  try {
    const result = await getStoreDistributionData({
      page: pagination.value.current,
      pageSize: pagination.value.pageSize,
      ...filters.value,
    });
    storeData.value = result.data;
    pagination.value.total = result.total;
  } catch (error) {
    console.error('加载商店数据失败:', error);
  }
};

const loadMaterialsData = async () => {
  try {
    materialsData.value = await getQualityMaterialsData();
    // 同时加载表格数据
    await loadMaterialsTableData();
    // 加载左侧素材数据（显示14个）
    leftMaterialsData.value = materialsData.value.slice(0, 14);
  } catch (error) {
    console.error('加载素材数据失败:', error);
  }
};

// 加载汇总数据
const loadSummaryData = async () => {
  summaryLoading.value = true;
  try {
    const result = await getSummaryData({
      page: summaryPagination.value.current,
      pageSize: summaryPagination.value.pageSize,
      platform: selectedSummaryPlatform.value,
      tab: summaryActiveTab.value,
      ...summaryFilters.value,
    });
    summaryTableData.value = result.data;
    summaryPagination.value.total = result.total;
    
    // 加载数据后初始化图表
    if (!chartCollapsed.value) {
      await nextTick();
      initPreviewChart();
    }
  } catch (error) {
    console.error('加载汇总数据失败:', error);
  } finally {
    summaryLoading.value = false;
  }
};

const selectSummaryPlatform = (platform: string) => {
  selectedSummaryPlatform.value = platform;
  loadSummaryData();
};

const handleSummaryTabChange = (key: string) => {
  summaryActiveTab.value = key;
  loadSummaryData();
};

// 监听指标变化，更新图表
watch([() => previewMetrics.value.metric1, () => previewMetrics.value.metric2, () => previewTopN.value, () => previewChartType.value], () => {
  if (!chartCollapsed.value) {
    initPreviewChart();
  }
});

