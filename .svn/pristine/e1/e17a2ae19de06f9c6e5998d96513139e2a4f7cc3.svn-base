          width="720"
          wrap-class-name="add-card-drawer"
          @close="closeAddCardDrawer"
        >
          <a-form
            layout="horizontal"
            class="add-card-form-advanced"
            :label-col="{ style: { width: '88px' } }"
            :wrapper-col="{ style: { width: '560px' } }"
          >
            <a-form-item :label="t('卡片名称')" required>
              <a-input v-model:value="addCardForm.name" :maxlength="50" :placeholder="t('请输入卡片名称')" show-count />
            </a-form-item>
            <a-form-item :label="t('渠道')" required>
              <a-select v-model:value="addCardForm.channel" :placeholder="t('请选择渠道')">
                <a-select-option value="summary">{{ t('汇总') }}</a-select-option>
              </a-select>
            </a-form-item>
            <a-form-item :label="t('数据源')" required>
              <a-radio-group v-model:value="addCardForm.dataSource" button-style="solid">
                <a-radio-button value="综合报表">{{ t('综合报表') }}</a-radio-button>
                <a-radio-button value="素材报表">{{ t('素材报表') }}</a-radio-button>
              </a-radio-group>
            </a-form-item>
            <a-form-item :label="t('图表类型')" required>
              <a-select
                v-model:value="addCardForm.chartType"
                :class="['chart-type-select', `chart-type-selected-${addCardForm.chartType}`]"
                :placeholder="t('请选择图表类型')"
                show-search
                :filter-option="filterChartTypeOption"
                option-label-prop="children"
                dropdown-class-name="chart-type-dropdown"
                :get-popup-container="(trigger: HTMLElement) => trigger.parentElement || document.body"
              >
                <a-select-option
                  v-for="item in cardChartTypeOptions"
                  :key="item.value"
                  :value="item.value"
                  :class="`chart-opt-${item.icon}`"
                >
                  {{ item.label }}
                </a-select-option>
              </a-select>
            </a-form-item>
            <a-form-item :label="t('对比模式')">
              <a-radio-group v-model:value="addCardForm.compareMode" button-style="solid">
                <a-radio-button value="none">{{ t('关闭对比') }}</a-radio-button>
                <a-radio-button value="day">{{ t('今日对比') }}</a-radio-button>
              </a-radio-group>
            </a-form-item>
            <a-form-item :label="t('日期')" required>
              <a-range-picker v-model:value="addCardForm.dateRange" style="width: 100%;" />
            </a-form-item>
            <a-form-item :label="t('维度')" required>
              <a-select v-model:value="addCardForm.dimension" :placeholder="t('请选择维度')">
                <a-select-option value="date">{{ t('日期') }}</a-select-option>
              </a-select>
            </a-form-item>
            <a-form-item :label="t('筛选')">
              <a-select v-model:value="addCardForm.filterChannel" :placeholder="t('渠道: 请选择')" allow-clear>
                <a-select-option value="summary">{{ t('汇总') }}</a-select-option>
              </a-select>
            </a-form-item>
            <a-form-item :label="t('指标')" required>
              <a-select
                v-model:value="addCardForm.metrics"
                mode="multiple"
                :max-tag-count="6"
                :placeholder="t('请选择指标')"
                :options="addCardMetricOptions"
              />
