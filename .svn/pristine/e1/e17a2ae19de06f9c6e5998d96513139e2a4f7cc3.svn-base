                        <span>{{ row.clicks }}</span>
                        <span>{{ row.conversions }}</span>
                      </div>
                    </div>
                  </div>
                  <div v-else class="card-table-mock table-large">
                    <div class="table-head table-head-large">
                      <span>{{ t('日期') }}</span>
                      <span>{{ t('花费') }}</span>
                      <span>{{ t('花费(AdsPolar运营百利)') }}</span>
                      <span>{{ t('展示数') }}</span>
                      <span>{{ t('千次展示成本') }}</span>
                      <span>{{ t('点击数') }}</span>
                      <span>{{ t('点击成本') }}</span>
                      <span>{{ t('点击率') }}</span>
                      <span>{{ t('转化数') }}</span>
                    </div>
                    <div class="table-body-large">
                      <div v-for="row in tablePreviewRows" :key="`large-${card.id}-${row.key}`" class="table-row-large">
                        <span>{{ row.date }}</span>
                        <span>{{ row.spend }}</span>
                        <span>{{ row.spendPlatform }}</span>
                        <span>{{ row.impressions }}</span>
                        <span>{{ row.cpm }}</span>
                        <span>{{ row.clicks }}</span>
                        <span>{{ row.cpc }}</span>
                        <span>{{ row.ctr }}</span>
                        <span>{{ row.conversions }}</span>
                      </div>
                    </div>
                    <div class="table-footer">
                      <span>{{ t('10条/页') }}</span>
                      <span>{{ t('共') }} 10 {{ t('条') }}</span>
                      <span class="pager">1</span>
                    </div>
                  </div>
                </template>
                <template v-else>
                  <div class="card-toolbar">
                    <span>{{ t('日期') }}: 2026/03/21 - 2026/03/27</span>
                    <span>{{ t('汇总') }}</span>
                  </div>
                  <div class="card-chart-mock" :class="`chart-${card.chartType}`">
                    <template v-if="card.chartPreviewData?.length">
                      <div class="chart-preview-data" :class="`preview-${card.chartType}`">
                        <div
                          v-for="(val, idx) in card.chartPreviewData"
                          :key="`${card.id}-pv-${idx}`"
                          class="chart-preview-row"
                        >
                          <span class="row-dot" />
                          <span class="row-line" :style="{ width: `${(idx + 1) * 10}%` }" />
                        </div>
                      </div>
                    </template>
                    <template v-else>
                      <div class="card-chart-empty">
                        <span class="chart-empty-icon" :class="`chart-opt-${card.chartType}`" />
