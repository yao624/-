];
const addCardMetricOptions = [
  { value: 'spend', label: t('花费') },
  { value: 'impressions', label: t('展示数') },
  { value: 'cpm', label: t('千次展示成本') },
  { value: 'clicks', label: t('点击数') },
  { value: 'cpc', label: t('点击成本') },
  { value: 'ctr', label: t('点击率') },
  { value: 'conversions', label: t('转化数') },
  { value: 'cpa', label: t('转化成本') },
  { value: 'conversionRate', label: t('转化率') },
  { value: 'register', label: t('注册数') },
  { value: 'payOrder', label: t('付费次数') },
];
const addCardColorOptions = [
  { value: 'none', gradient: 'linear-gradient(180deg, #f5f7fb 0%, #edf1f8 100%)' },
  { value: 'green', gradient: 'linear-gradient(180deg, #e9f9ee 0%, #d3f0dc 100%)' },
  { value: 'red', gradient: 'linear-gradient(180deg, #ffecef 0%, #ffd8df 100%)' },
  { value: 'mixed', gradient: 'linear-gradient(135deg, #e6f4ff 0%, #f9e9ff 100%)' },
];
const formatPreviewMoney = (value: number) => `¥${value.toFixed(2)}`;
const formatPreviewNumber = (value: number) => value.toLocaleString();
const tablePreviewRows = Array.from({ length: 10 }, (_, idx) => {
  const day = (idx % 7) + 21;
  const spend = 1200 + idx * 137;
  const clicks = 100 + idx * 9;
  const impressions = 18000 + idx * 1320;
  const conversions = 12 + (idx % 6);
  return {
    key: idx + 1,
    date: `2026/03/${String(day).padStart(2, '0')}`,
    spend: formatPreviewMoney(spend),
    spendPlatform: formatPreviewMoney(Math.round(spend * 0.82)),
    impressions: formatPreviewNumber(impressions),
    cpm: formatPreviewMoney((spend / impressions) * 1000),
    clicks: formatPreviewNumber(clicks),
    cpc: formatPreviewMoney(spend / clicks),
    ctr: `${((clicks / impressions) * 100).toFixed(2)}%`,
    conversions: formatPreviewNumber(conversions),
  };
});
const addCardForm = ref({
  name: '',
  channel: 'summary',
  dataSource: '综合报表',
  chartType: 'table',
  compareMode: 'none',
  dateRange: [dayjs().subtract(6, 'day'), dayjs()] as [Dayjs, Dayjs],
  dimension: 'date',
  filterChannel: undefined as string | undefined,
  metrics: ['spend', 'impressions', 'clicks', 'conversions'],
  tableColor: 'mixed',
  chartSize: 'large' as 'small' | 'large',
});
type CustomBoardCard = {
  id: string;
  title: string;
  iconName: string;
  dataSource: string;
  channel: string;
  chartType: string;
  typeLabel: string;
  shape: 'large' | 'medium' | 'small';
  chartPreviewData?: number[];
};
const customBoardCards = ref<CustomBoardCard[]>([]);
const customFolders = ref<Array<{ id: string; name: string }>>([]);
const SIDEBAR_ROOT_KEY = 'mine-root';
const ROOT_FOLDER_VALUE = '__root__';
const expandedTreeKeys = ref<string[]>([SIDEBAR_ROOT_KEY]);
const selectedSidebarNode = ref<{ type: 'mine' | 'folder' | 'board'; folderId: string | null }>({
  type: 'mine',
  folderId: null,
});
const myDashboards = ref<Array<{ key: string; label: string; boardType: 'comprehensive' | 'custom'; folderId: string | null }>>([]);
const selectedCreatedBoard = ref<{ key: string; label: string; boardType: 'comprehensive' | 'custom' } | null>(null);
const createdBoardMetricTab = ref('spend');
const createdBoardDateRange = ref<[Dayjs, Dayjs]>([
  dayjs().subtract(7, 'day'),
  dayjs(),
]);
const createdBoardFilters = ref({
  channel: 'summary',
});
const createdBoardTableData = ref<any[]>([]);
const createdBoardPagination = ref({
  current: 1,
  pageSize: 10,
  total: 0,
  showTotal: (total: number) => t('共') + total + t('条'),
});
const createdBoardColumns = ref<any[]>([
  { title: t('日期'), dataIndex: 'date', key: 'date' },
  { title: t('消耗'), dataIndex: 'spend', key: 'spend', align: 'right' as const },
  { title: t('展示数'), dataIndex: 'impressions', key: 'impressions', align: 'right' as const },
  { title: t('点击数'), dataIndex: 'clicks', key: 'clicks', align: 'right' as const },
  { title: t('点击率'), dataIndex: 'ctr', key: 'ctr', align: 'right' as const },
  { title: t('转化数'), dataIndex: 'conversions', key: 'conversions', align: 'right' as const },
]);
const rootMyDashboards = computed(() => myDashboards.value.filter((item) => !item.folderId));
const normalizeText = (value: unknown) => String(value ?? '');
const filteredRootDashboards = computed(() => {
  const keyword = sidebarKeyword.value.trim().toLowerCase();
  return rootMyDashboards.value.filter((board) => !keyword || normalizeText(board.label).toLowerCase().includes(keyword));
});

const filteredFolders = computed(() => {
  const keyword = sidebarKeyword.value.trim().toLowerCase();
  return customFolders.value
    .map((folder) => {
      const folderBoards = myDashboards.value
        .filter((board) => board.folderId === folder.id)
        .filter((board) => !keyword || normalizeText(board.label).toLowerCase().includes(keyword));
      const folderMatched = !keyword || normalizeText(folder.name).toLowerCase().includes(keyword);
      if (!folderMatched && folderBoards.length === 0) {
        return null;
      }
      return {
        id: folder.id,
        name: normalizeText(folder.name),
        boards: folderBoards,
      };
    })
    .filter((node): node is NonNullable<typeof node> => Boolean(node));
});

const isNodeExpanded = (nodeKey: string) => expandedTreeKeys.value.includes(nodeKey);

const toggleSidebarNode = (nodeKey: string) => {
  if (expandedTreeKeys.value.includes(nodeKey)) {
    expandedTreeKeys.value = expandedTreeKeys.value.filter((key) => key !== nodeKey);
  } else {
    expandedTreeKeys.value = [...expandedTreeKeys.value, nodeKey];
  }
};

const handleSidebarHomeClick = () => {
  selectReport('summary');
  selectedSidebarNode.value = { type: 'mine', folderId: null };
};

const handleSidebarMineClick = () => {
  selectedSidebarNode.value = { type: 'mine', folderId: null };
  toggleSidebarNode(SIDEBAR_ROOT_KEY);
};

const handleSidebarFolderClick = (folderId: string) => {
  selectedSidebarNode.value = {
    type: 'folder',
    folderId,
  };
  toggleSidebarNode(`folder:${folderId}`);
};

const createDashboardFolderValue = computed({
  get: () => createDashboardForm.value.folderId ?? ROOT_FOLDER_VALUE,
  set: (value: string) => {
    createDashboardForm.value.folderId = value === ROOT_FOLDER_VALUE ? null : value;
  },
});

const flattenFolders = (nodes: MetaReportFolderNode[]): Array<{ id: string; name: string }> => {
  const list: Array<{ id: string; name: string }> = [];
  const walk = (arr: MetaReportFolderNode[]) => {
    arr.forEach((node) => {
      list.push({ id: node.id, name: node.name });
      if (node.children?.length) {
        walk(node.children);
      }
    });
  };
  walk(nodes);
  return list;
};

