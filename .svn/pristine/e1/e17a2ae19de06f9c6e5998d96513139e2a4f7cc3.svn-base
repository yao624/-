        </a-drawer>

        <a-modal
          v-model:visible="showCardManagerModal"
          :title="t('卡片管理')"
          width="820px"
          wrap-class-name="card-manager-modal"
          @cancel="showCardManagerModal = false"
          :footer="null"
        >
          <div class="card-manager-list">
            <div v-if="cardManagerLoading" class="card-manager-empty">
              {{ t('加载中...') }}
            </div>
            <div v-else-if="customBoardCards.length === 0" class="card-manager-empty">
              {{ t('当前看板暂无卡片') }}
            </div>
            <div v-else class="card-manager-table">
              <div class="card-manager-head">
                <div>{{ t('卡片名称') }}</div>
                <div>{{ t('数据源') }}</div>
                <div>{{ t('渠道') }}</div>
                <div>{{ t('图表类型') }}</div>
                <div>{{ t('操作') }}</div>
              </div>
              <div v-for="(card, idx) in customBoardCards" :key="card.id" class="card-manager-row">
                <div class="name-cell">
                  <span class="drag-icon">⋮⋮</span>
                  <span class="name-text">{{ card.iconName }}</span>
                  <span class="name-subtitle">{{ card.title }}</span>
                </div>
                <div class="cell-text">{{ card.dataSource }}</div>
                <div class="cell-text">{{ card.channel }}</div>
                <div class="cell-text">{{ card.typeLabel }}</div>
                <div class="action-cell">
                  <a-button type="link" size="small" @click="handleCardManagerAction('edit', card, idx)">
                    {{ t('编辑') }}
                  </a-button>
                  <a-button type="link" size="small" @click="handleCardManagerAction('copy', card, idx)">
                    {{ t('复制') }}
                  </a-button>
                  <a-button type="link" size="small" @click="handleCardManagerAction('push', card, idx)">
                    {{ t('推送') }}
                  </a-button>
                  <a-button type="link" size="small" danger @click="handleCardManagerAction('delete', card, idx)">
                    {{ t('删除') }}
                  </a-button>
                </div>
              </div>
            </div>
          </div>
        </a-modal>

        <a-modal
          v-model:visible="showCreateDashboardModal"
          :title="t('新建看板')"
          width="480px"
          @ok="submitCreateDashboard"
          @cancel="resetCreateDashboardForm"
        >
          <a-form layout="vertical">
            <a-form-item :label="t('看板名称')" required>
              <a-input
                v-model:value="createDashboardForm.name"
                :placeholder="t('请输入看板名称')"
                :maxlength="200"
                show-count
              />
            </a-form-item>
            <a-form-item :label="t('看板位置')">
              <a-select
                v-model:value="createDashboardFolderValue"
                :placeholder="t('请选择看板位置')"
              >
                <a-select-option :value="ROOT_FOLDER_VALUE">{{ t('我的看板') }}</a-select-option>
                <a-select-option
                  v-for="folder in customFolders"
                  :key="folder.id"
                  :value="folder.id"
                >
                  {{ folder.name }}
                </a-select-option>
              </a-select>
            </a-form-item>
            <a-form-item :label="t('渠道')">
              <a-select v-model:value="createDashboardForm.channel">
                <a-select-option value="summary">{{ t('汇总') }}</a-select-option>
              </a-select>
            </a-form-item>
            <a-form-item :label="t('看板类型')" required>
              <a-radio-group v-model:value="createDashboardForm.boardType" button-style="solid">
                <a-radio-button value="comprehensive">{{ t('综合报表') }}</a-radio-button>
                <a-radio-button value="custom">{{ t('自定义看板') }}</a-radio-button>
              </a-radio-group>
            </a-form-item>
            <a-form-item :label="t('分组对比')">
              <a-radio-group v-model:value="createDashboardForm.groupCompare">
                <a-radio :value="false">{{ t('关闭') }}</a-radio>
                <a-radio :value="true">{{ t('开启') }}</a-radio>
              </a-radio-group>
            </a-form-item>
          </a-form>
        </a-modal>

        <a-modal
          v-model:visible="showCreateFolderModal"
          :title="t('新建文件夹')"
          width="480px"
          @ok="submitCreateFolder"
          @cancel="resetCreateFolderForm"
        >
          <a-form layout="vertical">
            <a-form-item :label="t('文件夹名称')" required>
              <a-input
                v-model:value="createFolderForm.name"
                :placeholder="t('请输入文件夹名称')"
                :maxlength="200"
                show-count
              />
            </a-form-item>
          </a-form>
        </a-modal>

        <a-modal
          v-model:visible="showRenameFolderModal"
          :title="t('重命名文件夹')"
          width="480px"
          @ok="submitRenameFolder"
          @cancel="resetRenameFolderForm"
        >
          <a-form layout="vertical">
            <a-form-item :label="t('文件夹名称')" required>
              <a-input
                v-model:value="renameFolderForm.name"
                :placeholder="t('请输入文件夹名称')"
                :maxlength="200"
                show-count
              />
            </a-form-item>
          </a-form>
        </a-modal>

        <a-modal
          v-model:visible="showDeleteFolderModal"
          :title="t('删除文件夹')"
          width="520px"
          :confirm-loading="folderDeleteLoading"
          ok-text="删除"
          cancel-text="取消"
          @ok="confirmDeleteFolder"
          @cancel="resetDeleteFolderModal"
        >
          <div>{{ t('确认删除该文件夹？该文件夹下的看板将移动到“我的看板”。') }}</div>
        </a-modal>

        <a-modal
          v-model:visible="showDeleteDashboardModal"
          :title="t('删除看板')"
          width="520px"
          :confirm-loading="dashboardDeleteLoading"
          ok-text="删除"
          cancel-text="取消"
          @ok="confirmDeleteDashboard"
          @cancel="resetDeleteDashboardModal"
        >
          <div>{{ t('确认删除该看板？') }}</div>
        </a-modal>

        <a-modal
          v-model:visible="showRenameDashboardModal"
          :title="t('重命名看板')"
          width="480px"
          @ok="submitRenameDashboard"
          @cancel="resetRenameDashboardForm"
        >
          <a-form layout="vertical">
            <a-form-item :label="t('看板名称')" required>
              <a-input
                v-model:value="renameDashboardForm.name"
                :placeholder="t('请输入看板名称')"
                :maxlength="200"
                show-count
              />
            </a-form-item>
          </a-form>
        </a-modal>

        <a-modal
          v-model:visible="showSaveAsDashboardModal"
          :title="t('看板另存为')"
          width="560px"
          @ok="submitSaveAsDashboard"
          @cancel="resetSaveAsDashboardForm"
        >
          <a-form layout="vertical">
            <a-form-item :label="t('看板路径')">
              <div>{{ t('我的看板') }} / {{ selectedCreatedBoard?.label || t('综合看板') }}</div>
            </a-form-item>
            <a-form-item :label="t('看板名称')" required>
              <a-input
                v-model:value="saveAsDashboardForm.name"
                :placeholder="t('请输入看板名称')"
                :maxlength="200"
                show-count
              />
            </a-form-item>
            <a-form-item :label="t('看板位置')" required>
              <a-select v-model:value="saveAsDashboardForm.folder">
                <a-select-option value="mine">{{ t('我的看板') }}</a-select-option>
              </a-select>
            </a-form-item>
          </a-form>
        </a-modal>

        <!-- 优质素材报表 -->
        <div v-if="selectedReport === 'quality-materials'" class="report-content">
          <div class="report-header">
            <h2>{{ t('优质素材') }} ({{ t('示例数据') }})</h2>
            <div class="breadcrumb">{{ t('素材报表') }}, Google, {{ t('素材ID') }}</div>
            <div class="save-time">{{ t('上次保存时间') }}: {{ lastSaveTime }}</div>
          </div>

          <!-- 筛选栏 -->
          <div class="report-filters">
            <a-select
              v-model:value="leftFilters.dimension"
              style="width: 120px; margin-right: 8px"
            >
              <a-select-option value="material">{{ t('维度: 素材') }}</a-select-option>
            </a-select>
            <a-tabs v-model:activeKey="leftActiveTab" class="filter-tabs">
              <a-tab-pane key="spend" :tab="t('花费')" />
              <a-tab-pane key="metrics" :tab="t('指标')" />
            </a-tabs>
            <a-range-picker
              v-model:value="dateRange"
              format="YYYY/MM/DD"
              size="small"
              style="width: 240px; margin-right: 8px"
            />
            <a-select
              v-model:value="leftFilters.materialId"
              :placeholder="t('素材ID: 请选择')"
              size="small"
              style="width: 150px; margin-right: 8px"
              allow-clear
            />
            <a-button size="small" type="primary" @click="handleLeftFilter">
              {{ t('筛选') }}
            </a-button>
            <div class="view-modes">
              <bar-chart-outlined />
              <appstore-outlined class="active" />
              <fullscreen-outlined />
            </div>
          </div>

          <!-- 素材网格 -->
          <div class="materials-grid-view">
            <div
              v-for="material in leftMaterialsData"
              :key="material.id"
              class="material-card-grid"
              :class="{ active: selectedMaterialId === material.id }"
              @click="selectMaterial(material.id)"
            >
              <div class="material-thumbnail-grid">
                <img v-if="material.thumbnail" :src="material.thumbnail" :alt="material.name" />
                <div v-else class="material-placeholder">
                  <play-circle-outlined v-if="material.type === 'video'" />
                  <exclamation-circle-outlined v-else />
                </div>
              </div>
              <div class="material-name-grid">{{ material.name }}</div>
              <div class="material-cost-grid">{{ formatCurrency(material.spend) }}</div>
            </div>
          </div>

          <!-- 素材表格 -->
          <div class="materials-table-view">
            <div class="table-actions-bar">
              <a-dropdown>
                <template #overlay>
                  <a-menu>
                    <a-menu-item>{{ t('批量操作') }}</a-menu-item>
                  </a-menu>
                </template>
                <a-button size="small">{{ t('批量操作') }}</a-button>
              </a-dropdown>
              <a-button size="small">{{ t('指标设置') }}</a-button>
              <a-dropdown>
                <template #overlay>
                  <a-menu>
                    <a-menu-item>{{ t('导出') }}</a-menu-item>
                    <a-menu-item>{{ t('刷新') }}</a-menu-item>
                  </a-menu>
                </template>
                <a-button size="small">{{ t('更多') }}</a-button>
              </a-dropdown>
            </div>
            <a-table
              :loading="materialsLoading"
              :columns="materialsColumns"
              :data-source="materialsTableData"
              :pagination="materialsPagination"
              :row-key="record => record.id"
              :row-selection="materialsRowSelection"
              size="small"
              @change="handleMaterialsTableChange"
            >
              <template #bodyCell="{ column, record }">
                <template v-if="column.dataIndex === 'materialName'">
                  <div class="material-name-cell">
                    <a-checkbox :checked="selectedMaterials.includes(record.id)" />
                    <span style="margin-left: 8px">{{ record.materialName }}</span>
                  </div>
                </template>
                <template v-else-if="column.dataIndex === 'spend'">
                  <span :class="getMaterialValueClass(record.spend, 'spend')">
                    {{ formatCurrency(record.spend) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'impressions'">
                  <span :class="getMaterialValueClass(record.impressions, 'impressions')">
                    {{ formatNumber(record.impressions) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'cpm'">
                  <span :class="getMaterialValueClass(record.cpm, 'cpm', true)">
                    {{ formatCurrency(record.cpm) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'clicks'">
                  <span :class="getMaterialValueClass(record.clicks, 'clicks')">
                    {{ formatNumber(record.clicks) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'ctr'">
                  <span :class="getMaterialValueClass(record.ctr, 'ctr')">
                    {{ formatPercent(record.ctr) }}
                  </span>
                </template>
                <template v-else-if="column.dataIndex === 'conversions'">
                  <span :class="getMaterialValueClass(record.conversions, 'conversions')">
                    {{ formatNumber(record.conversions) }}
                  </span>
                </template>
              </template>
            </a-table>
          </div>
        </div>

        <!-- 整体表现仪表盘 -->
        <div v-else-if="selectedReport === 'overall-performance'" class="report-content">
          <!-- KPI 卡片 -->
          <div class="kpi-cards">
            <div class="kpi-card">
              <div class="kpi-label">{{ t('今日花费') }}</div>
              <div class="kpi-value">{{ formatCurrency(kpiData.todaySpend) }}</div>
            </div>
            <div class="kpi-card">
              <div class="kpi-label">{{ t('昨日花费') }}</div>
              <div class="kpi-value">{{ formatCurrency(kpiData.yesterdaySpend) }}</div>
            </div>
            <div class="kpi-card">
              <div class="kpi-label">{{ t('最近7天花费') }}</div>
              <div class="kpi-value">{{ formatCurrency(kpiData.last7DaysSpend) }}</div>
            </div>
            <div class="kpi-card">
              <div class="kpi-label">{{ t('最近14天花费') }}</div>
              <div class="kpi-value">{{ formatCurrency(kpiData.last14DaysSpend) }}</div>
            </div>
          </div>

          <!-- 图表区域 -->
          <div class="charts-section">
            <!-- 花费趋势图 -->
            <div class="chart-card">
              <div class="chart-header">
                <h3>{{ t('近7天花费趋势') }}</h3>
                <div class="chart-filters">
                  <a-range-picker
                    v-model:value="dateRange"
                    format="YYYY/MM/DD"
                    size="small"
                    style="width: 240px; margin-right: 8px"
                  />
                  <a-select
                    v-model:value="filters.channel"
                    :placeholder="t('渠道: 请选择')"
                    size="small"
                    style="width: 150px; margin-right: 8px"
                    allow-clear
                  >
                    <a-select-option value="meta">Meta</a-select-option>
                    <a-select-option value="google">Google</a-select-option>
                    <a-select-option value="tiktok">TikTok</a-select-option>
                  </a-select>
                  <a-select
                    v-model:value="filters.adAccount"
                    :placeholder="t('广告账户: 请选择')"
                    size="small"
                    style="width: 150px"
                    allow-clear
                  />
                </div>
              </div>
              <div class="chart-content">
                <div ref="spendTrendChart" class="chart-container"></div>
              </div>
            </div>

            <!-- 渠道分布图 -->
            <div class="chart-card">
              <div class="chart-header">
                <h3>{{ t('近7天花费top 5渠道分布') }}</h3>
                <div class="chart-filters">
                  <a-range-picker
                    v-model:value="dateRange"
                    format="YYYY/MM/DD"
                    size="small"
                    style="width: 240px; margin-right: 8px"
                  />
                  <a-select
                    v-model:value="filters.channel"
                    :placeholder="t('渠道: 请选择')"
                    size="small"
                    style="width: 150px; margin-right: 8px"
                    allow-clear
                  />
                  <a-select
                    v-model:value="filters.adAccount"
                    :placeholder="t('广告账户: 请选择')"
                    size="small"
                    style="width: 150px"
                    allow-clear
                  />
                </div>
              </div>
              <div class="chart-content">
                <div class="channel-distribution">
                  <div ref="channelChart" class="chart-container-small"></div>
                  <div class="channel-list">
                    <div
                      v-for="(item, index) in channelData"
                      :key="index"
                      class="channel-item"
                    >
                      <div class="channel-color" :style="{ background: item.color }"></div>
                      <div class="channel-name">{{ item.name }}</div>
                      <div class="channel-percent">{{ item.percent }}%</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- 商店分布表格 -->
          <div class="table-section">
      <div class="section-header">
        <h3>{{ t('近7天花费top 10商店分布') }}</h3>
        <div class="table-filters">
          <a-range-picker
            v-model:value="dateRange"
            format="YYYY/MM/DD"
            size="small"
            style="width: 240px; margin-right: 8px"
          />
          <a-select
            v-model:value="filters.adAccount"
            :placeholder="t('广告账户: 请选择')"
            size="small"
            style="width: 150px; margin-right: 8px"
            allow-clear
          />
          <a-select
            v-model:value="filters.campaign"
            :placeholder="t('推广系列: 请选择')"
            size="small"
            style="width: 150px; margin-right: 8px"
            allow-clear
          />
          <a-select
            v-model:value="filters.adGroup"
            :placeholder="t('广告组: 请选择')"
            size="small"
            style="width: 150px; margin-right: 8px"
            allow-clear
          />
          <a-select
            v-model:value="filters.ad"
            :placeholder="t('广告: 请选择')"
            size="small"
            style="width: 150px; margin-right: 8px"
            allow-clear
          />
          <a-select
            v-model:value="filters.region"
            :placeholder="t('地区: 请选择')"
            size="small"
            style="width: 150px"
            allow-clear
          />
        </div>
      </div>
      <a-table
        :loading="loading"
        :columns="storeColumns"
        :data-source="storeData"
        :pagination="pagination"
        :row-key="record => record.id"
        @change="handleTableChange"
      >
        <template #bodyCell="{ column, record }">
          <template v-if="column.dataIndex === 'spend'">
            <span :class="getValueClass(record.spend, 'spend')">
              {{ formatCurrency(record.spend) }}
            </span>
          </template>
          <template v-else-if="column.dataIndex === 'impressions'">
            <span :class="getValueClass(record.impressions, 'impressions')">
              {{ formatNumber(record.impressions) }}
            </span>
          </template>
          <template v-else-if="column.dataIndex === 'clicks'">
            <span :class="getValueClass(record.clicks, 'clicks')">
              {{ formatNumber(record.clicks) }}
            </span>
          </template>
          <template v-else-if="column.dataIndex === 'ctr'">
            <span :class="getValueClass(record.ctr, 'ctr')">
              {{ formatPercent(record.ctr) }}
            </span>
          </template>
          <template v-else-if="column.dataIndex === 'cpc'">
            <span :class="getValueClass(record.cpc, 'cpc', true)">
              {{ formatCurrency(record.cpc) }}
            </span>
          </template>
          <template v-else-if="column.dataIndex === 'cpm'">
            <span :class="getValueClass(record.cpm, 'cpm', true)">
              {{ formatCurrency(record.cpm) }}
            </span>
          </template>
          <template v-else-if="column.dataIndex === 'conversions'">
            <span :class="getValueClass(record.conversions, 'conversions')">
              {{ formatNumber(record.conversions) }}
            </span>
          </template>
          <template v-else-if="column.dataIndex === 'costPerConversion'">
            <span :class="getValueClass(record.costPerConversion, 'costPerConversion', true)">
              {{ formatCurrency(record.costPerConversion) }}
            </span>
          </template>
          <template v-else-if="column.dataIndex === 'conversionRate'">
            <span :class="getValueClass(record.conversionRate, 'conversionRate')">
              {{ formatPercent(record.conversionRate) }}
            </span>
          </template>
        </template>
      </a-table>
          </div>

          <!-- 地区分布和优化师分布 -->
          <div class="charts-section">
            <div class="chart-card">
              <div class="chart-header">
                <h3>{{ t('近7天花费top 10地区分布') }}</h3>
                <div class="chart-filters">
                  <a-range-picker
                    v-model:value="dateRange"
