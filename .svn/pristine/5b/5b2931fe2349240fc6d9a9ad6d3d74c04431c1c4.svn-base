export interface MaterialEditState {
  width: number;
  height: number;
  bgColor: string;
  bgMode: 'solid' | 'image';
  bgImageUrl: string;
  blurAmount: number;
  fillMode: 'contain' | 'cover' | 'custom';
  cropX: number;
  cropY: number;
  cropW: number;
  cropH: number;
}

export interface CreateTaskForm {
  materialType: 'image' | 'video';
  materials: CreateTaskMaterialItem[];
  folderOption: 'original' | 'new';
  targetFolderId?: string;
  tags: string[];
  designerId?: string;
  creativeId?: string;
  materialName: string;
  uploadedMaterialIds?: string[];
}

export interface CreateTaskMaterialItem {
  id: string;
  name: string;
  previewUrl: string;           // 原素材预览 URL
  editContent: string;          // 编辑内容描述
  uploadedMaterialId?: number;  // 上传后新素材 ID
  folderId?: string;
  tags?: string[];
  designerId?: string;
  creatorId?: string;
}

export type MaterialType = 'image' | 'video';
export type FieldMode = 'original' | 'unified' | 'smart';
export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed';
export type MaterialEditStatus = 'success' | 'failed' | 'pending';

export interface MaterialItem {
  id: string;
  name: string;
  type: MaterialType;
  previewUrl: string;
  folderId?: string;
  tags?: string[];
  designerId?: string;
  creatorId?: string;
}

export interface FolderInfo {
  id: string;
  name: string;
}

export interface DesignerInfo { 
  id: string;
  name: string;
}

export interface CreativeInfo {
  id: string;
  name: string;
}

export interface TagInfo {
  id: string;
  name: string;
  color: string;
}

export interface MaterialEditorTask {
  id: string;
  status: TaskStatus;
  createdAt: string;
  createdBy: string;
  folderId?: string;
  folderName?: string;
}

export interface MaterialEditItem {
  id: number;
  materialId: number;
  uploadedMaterialId?: number;
  materialName: string;
  originalMaterialName: string;
  previewUrl: string;
  originalPreviewUrl: string;
  status: MaterialEditStatus;
  editContent: string;
  reason: string;
  createdAt?: string;
  updatedAt?: string;
}

export interface TaskDetail {
  id: string;
  status: TaskStatus;
  createdAt: string;
  creator?: string;
  taskName?: string;
  designerName?: string;
  materialType?: 'image' | 'video';
  tags?: string[];
  folderName?: string;
  totalCount?: number;
  successCount?: number;
  failedCount?: number;
  pendingCount?: number;
}