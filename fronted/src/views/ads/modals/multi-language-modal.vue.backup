<template>
  <a-modal
    v-model:open="visible"
    :title="t('Edit ads')"
    width="90%"
    :style="{ maxWidth: '1400px', top: '60px' }"
    @cancel="handleCancel"
    @ok="handleOk"
    :mask-closable="false"
    destroy-on-close
    :centered="false"
  >
    <div class="multi-language-content">
      <a-row :gutter="16" style="height: 700px">
        <!-- 左侧：Tab列表 -->
        <a-col :span="6">
          <div class="tab-navigation">
            <!-- 批量编辑Tab -->
            <div
              class="nav-tab batch-disabled"
              :class="{ active: activeTabKey === 'batch', disabled: true }"
              @click="handleBatchTabClick"
            >
              <div class="tab-content">
                <div class="tab-title">{{ t('Batch Edit') }}</div>
                <div class="tab-subtitle">{{ t('Edit all selected ads') }} ({{ t('Coming Soon') }})</div>
                <div class="tab-info">
                  <div class="ads-summary">
                    <span class="ads-count">{{ compatibleAds.length }}{{ t('ads') }}</span>
                    <span class="ads-detail">
                      ({{ getImageAdsCount() > 0 ? t('Image') + getImageAdsCount() : ''
                      }}{{ getImageAdsCount() > 0 && getVideoAdsCount() > 0 ? ', ' : ''
                      }}{{ getVideoAdsCount() > 0 ? t('Video') + getVideoAdsCount() : '' }})
                    </span>
                  </div>
                  <a-tag v-if="incompatibleTypes" color="orange" size="small">
                    {{ t('Mixed Types') }}
                  </a-tag>
                  <a-tag color="gray" size="small">
                    {{ t('Disabled') }}
                  </a-tag>
                </div>
              </div>
            </div>

            <!-- 单个广告Tabs -->
            <div class="ads-section">
              <div class="section-header">
                <span>{{ t('Individual Ads') }}</span>
              </div>

              <div class="ads-list">
                <div
                  v-for="(ad, index) in compatibleAds"
                  :key="ad.ad_id"
                  class="nav-tab ad-tab"
                  :class="{ active: activeTabKey === ad.ad_id }"
                  @click="selectTab(ad.ad_id)"
                >
                  <div class="tab-content">
                    <div class="ad-info">
                      <div class="ad-title">
                        <span class="ad-name">{{ getAdDisplayName(ad, index) }}</span>
                        <a-tag :color="getAdTypeColor(ad)" size="small">
                          {{ getAdTypeText(ad) }}
                        </a-tag>
                      </div>
                      <div class="ad-subtitle">{{ ad.ad_name }}</div>
                      <div class="ad-id">ID: {{ ad.ad_id }}</div>
                    </div>
                    <div class="ad-status">
                      <a-tag v-if="hasMultiLanguageConfig(ad)" color="green" size="small">
                        {{ t('Multi-language Configured') }}
                      </a-tag>
                      <a-tag v-else color="orange" size="small">
                        {{ t('Multi-language Not Configured') }}
                      </a-tag>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </a-col>

        <!-- 右侧：内容区域 -->
        <a-col :span="18">
          <div class="content-area">
            <!-- 批量编辑内容 -->
            <div v-if="activeTabKey === 'batch'" class="batch-edit-content">
              <div class="content-header">
                <h3>{{ t('Batch Edit Settings') }}</h3>
              </div>

              <!-- 混合类型警告 -->
              <div v-if="incompatibleTypes" class="mixed-type-warning">
                <a-alert
                  :message="t('Cannot batch edit mixed ad types')"
                  type="warning"
                  show-icon
                  style="margin-bottom: 24px"
                >
                  <template #description>
                    <div>
                      <p>{{ t('Selected ads contain different types') }}:</p>
                      <ul style="margin: 8px 0; padding-left: 20px">
                        <li>{{ getVideoAdsCount() }} {{ t('video ads') }}</li>
                        <li>{{ getImageAdsCount() }} {{ t('image ads') }}</li>
                      </ul>
                      <p style="margin-bottom: 0">
                        {{ t('Please edit ads individually using the ad tabs on the left') }}
                      </p>
                    </div>
                  </template>
                </a-alert>
              </div>

              <!-- 批量编辑语言管理 -->
              <div v-else class="batch-language-management">
                <!-- 默认语言选择 -->
                <div class="default-language-selector">
                  <label class="selector-label">{{ t('Default Language') }}:</label>
                  <a-select
                    :value="batchDefaultLanguage"
                    style="width: 280px"
                    @change="handleBatchDefaultLanguageChange"
                    :loading="languagesLoading"
                  >
                    <a-select-option
                      v-for="lang in availableLanguages"
                      :key="lang.code"
                      :value="lang.code"
                    >
                      {{ lang.displayName }}
                    </a-select-option>
                  </a-select>

                  <a-button
                    v-if="batchAdditionalLanguages.length > 0"
                    type="default"
                    size="small"
                    @click="copyBatchDefaultToOthers"
                  >
                    <copy-outlined />
                    {{ t('Copy to other languages') }}
                  </a-button>

                  <a-button type="primary" size="small" @click="showBatchLanguageModal = true">
                    <plus-outlined />
                    {{ t('Add Language') }}
                  </a-button>
                </div>

                <!-- 批量编辑应用按钮区域 -->
                <div class="batch-apply-section">
                  <div class="apply-info">
                    <InfoCircleOutlined style="color: #1890ff; margin-right: 8px;" />
                    <span class="apply-description">
                      {{ t('Changes will only affect individual ads after clicking Apply') }}
                    </span>
                  </div>
                  <div class="apply-actions">
                    <a-button
                      type="primary"
                      @click="applyBatchChanges"
                      :disabled="!hasBatchChanges"
                      :loading="applyingBatchChanges"
                    >
                      {{ t('Apply to All Ads') }}
                    </a-button>
                    <a-button
                      v-if="hasBatchChanges"
                      @click="resetBatchChanges"
                    >
                      {{ t('Reset Changes') }}
                    </a-button>
                  </div>
                </div>

                <!-- 批量编辑语言Tab列表 -->
                <a-tabs
                  v-model:activeKey="batchActiveLanguageKey"
                  type="card"
                  size="small"
                  class="language-tabs"
                >
                  <!-- 默认语言Tab -->
                  <a-tab-pane
                    :key="batchDefaultLanguage"
                    :tab="getLanguageName(batchDefaultLanguage) + ' (' + t('Default') + ')'"
                    v-bind:title="getLanguageNativeName(batchDefaultLanguage)"
                  >
                    <div class="language-content">
                      <a-row :gutter="24">
                        <!-- 左侧：表单编辑 -->
                        <a-col :span="14">
                          <div class="form-panel">
                            <div class="form-header">
                              <h5>
                                {{ t('Batch Content Editor') }} -
                                {{ getLanguageName(batchActiveLanguageKey) }}
                              </h5>
                            </div>
                            <a-form layout="vertical">
                              <a-form-item :label="t('Website URL')">
                                <a-input
                                  :value="
                                    batchLanguageSettings[batchActiveLanguageKey]?.websiteUrl || ''
                                  "
                                  @update:value="(value: string) => updateBatchLanguageContent('websiteUrl', value)"
                                  :placeholder="
                                    t('Enter website URL for') +
                                    ' ' +
                                    getLanguageName(batchActiveLanguageKey)
                                  "
                                />
                              </a-form-item>

                              <a-form-item :label="t('Headline')">
                                <a-input
                                  :value="
                                    batchLanguageSettings[batchActiveLanguageKey]?.headline || ''
                                  "
                                  @update:value="(value: string) => updateBatchLanguageContent('headline', value)"
                                  :placeholder="
                                    t('Enter headline for') +
                                    ' ' +
                                    getLanguageName(batchActiveLanguageKey)
                                  "
                                />
                              </a-form-item>

                              <a-form-item :label="t('Primary Text')">
                                <a-textarea
                                  :value="
                                    batchLanguageSettings[batchActiveLanguageKey]?.primaryText || ''
                                  "
                                  @update:value="(value: string) => updateBatchLanguageContent('primaryText', value)"
                                  :placeholder="
                                    t('Enter primary text for') +
                                    ' ' +
                                    getLanguageName(batchActiveLanguageKey)
                                  "
                                  :rows="4"
                                />
                              </a-form-item>

                              <a-form-item :label="t('Description')">
                                <a-textarea
                                  :value="
                                    batchLanguageSettings[batchActiveLanguageKey]?.description || ''
                                  "
                                  @update:value="(value: string) => updateBatchLanguageContent('description', value)"
                                  :placeholder="
                                    t('Enter description for') +
                                    ' ' +
                                    getLanguageName(batchActiveLanguageKey)
                                  "
                                  :rows="3"
                                />
                              </a-form-item>
                            </a-form>
                          </div>
                        </a-col>

                        <!-- 右侧：广告预览 -->
                        <a-col :span="10">
                          <div class="preview-panel">
                            <div class="preview-header">
                              <div class="preview-title">
                                <h5>
                                  {{ t('Preview') }} - {{ getLanguageName(batchActiveLanguageKey) }}
                                </h5>
                              </div>
                              <div class="preview-actions">
                                <a-button
                                  type="text"
                                  size="small"
                                  class="preview-btn"
                                  @click="handleMediaEdit()"
                                >
                                  <edit-outlined />
                                </a-button>
                                <a-button
                                  v-if="getCurrentAdType().includes('Video') && hasVideoForCurrentLanguage() && activeTabKey !== 'batch'"
                                  type="text"
                                  size="small"
                                  class="preview-btn"
                                  @click="handleThumbnailClick()"
                                >
                                  {{ t('Thumbnail') }}
                                </a-button>
                              </div>
                            </div>
                            <div class="preview-container">
                              <div class="ad-preview">
                                <div class="preview-header">
                                  <div class="brand-info">
                                    <div class="brand-avatar">📱</div>
                                    <div class="brand-details">
                                      <div class="brand-name-container">
                                        <div class="brand-name">{{ getCurrentBrandName() }}</div>
                                        <a-button
                                          v-if="activeTabKey !== 'batch'"
                                          type="text"
                                          size="small"
                                          class="page-edit-btn"
                                          @click="handlePageEdit"
                                        >
                                          <edit-outlined />
                                        </a-button>
                                      </div>
                                      <div class="sponsored-text">{{ t('Sponsored') }}</div>
                                    </div>
                                  </div>
                                </div>

                                <div class="ad-content">
                                  <!-- 顶部显示的正文样式 -->
                                  <div class="ad-primary-text-top">
                                    {{ getBatchCurrentLanguagePreview('primaryText') }}
                                  </div>

                                  <div class="ad-media">
                                    <!-- 对于已配置多语言的单个广告，显示媒体加载控制 -->
                                    <div
                                      v-if="
                                        activeTabKey !== 'batch' &&
                                        hasUnloadedMedia(activeLanguageKey, activeTabKey)
                                      "
                                      class="media-placeholder media-loadable"
                                      @click="handleLoadMedia(activeLanguageKey, activeTabKey)"
                                    >
                                      <div class="media-load-container">
                                        <div
                                          v-if="
                                            getMediaPreviewState(activeLanguageKey, activeTabKey)
                                              .loading
                                          "
                                          class="loading-state"
                                        >
                                          <a-spin size="large" />
                                          <div class="loading-text">
                                            {{ t('Loading media...') }}
                                          </div>
                                        </div>
                                        <div v-else class="load-prompt">
                                          <div class="load-icon">
                                            <picture-outlined
                                              v-if="
                                                getCurrentContextMediaType(
                                                  activeLanguageKey,
                                                  activeTabKey,
                                                ) === 'image'
                                              "
                                              style="font-size: 48px; color: #1890ff"
                                            />
                                            <play-circle-outlined
                                              v-else
                                              style="font-size: 48px; color: #1890ff"
                                            />
                                          </div>
                                          <div class="load-text">
                                            {{ t('Click to load') }}
                                            {{
                                              getCurrentContextMediaType(
                                                activeLanguageKey,
                                                activeTabKey,
                                              ) === 'image'
                                                ? t('image')
                                                : t('video')
                                            }}
                                          </div>
                                          <a-button
                                            type="primary"
                                            ghost
                                            size="small"
                                            class="load-button"
                                          >
                                            <cloud-download-outlined />
                                            {{ t('Load Media') }}
                                          </a-button>
                                        </div>
                                      </div>
                                    </div>
                                    <!-- 对于已加载媒体的单个广告，显示实际媒体 -->
                                    <div
                                      v-else-if="
                                        activeTabKey !== 'batch' &&
                                        getMediaPreviewState(activeLanguageKey, activeTabKey).show
                                      "
                                      class="media-content"
                                    >
                                      <img
                                        v-if="
                                          getMediaPreviewState(activeLanguageKey, activeTabKey)
                                            .type === 'image'
                                        "
                                        :src="
                                          getMediaPreviewState(activeLanguageKey, activeTabKey).url
                                        "
                                        alt="Ad Image"
                                        class="media-image"
                                      />
                                      <!-- 视频直接显示 -->
                                      <video
                                        v-else-if="
                                          getMediaPreviewState(activeLanguageKey, activeTabKey)
                                            .type === 'video'
                                        "
                                        class="video-player"
                                        :src="getMediaPreviewState(activeLanguageKey, activeTabKey).url"
                                        :poster="getCurrentLanguageContent('thumbnailUrl')"
                                        controls
                                        preload="none"
                                        playsinline
                                        controlsList="nodownload"
                                      >
                                        {{ t('Your browser does not support the video tag.') }}
                                      </video>
                                    </div>
                                    <!-- 默认占位符（用于批量编辑或无媒体的情况） -->
                                    <div v-else class="media-placeholder">
                                      <picture-outlined
                                        v-if="getCurrentAdType().includes('Image')"
                                        style="font-size: 48px; color: #fff"
                                      />
                                      <play-circle-outlined
                                        v-else
                                        style="font-size: 48px; color: #fff"
                                      />
                                      <div class="media-info">{{ getCurrentAdType() }}</div>
                                      <div v-if="activeTabKey === 'batch'" class="batch-media-hint">
                                        {{ t('Batch editing - media preview not available') }}
                                      </div>
                                    </div>
                                  </div>

                                  <div class="ad-text-content">
                                    <div class="ad-headline">
                                      {{ getBatchCurrentLanguagePreview('headline') }}
                                    </div>
                                    <div class="ad-description">
                                      {{ getBatchCurrentLanguagePreview('description') }}
                                    </div>

                                    <div class="cta-section">
                                      <span class="website-url">
                                        {{ getBatchCurrentLanguagePreview('websiteUrl') }}
                                      </span>
                                      <a-button type="primary" size="small">
                                        {{ t('Learn more') }}
                                      </a-button>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                        </a-col>
                      </a-row>
                    </div>
                  </a-tab-pane>

                  <!-- 附加语言Tabs -->
                  <a-tab-pane
                    v-for="lang in batchAdditionalLanguages"
                    :key="lang"
                    :tab="getLanguageName(lang)"
                    v-bind:title="getLanguageNativeName(lang)"
                  >
                    <div class="language-content">
                      <div class="language-action-header">
                        <h5>{{ getLanguageName(lang) }} {{ t('Batch Translation') }}</h5>
                        <a-button
                          type="text"
                          danger
                          size="small"
                          @click="removeBatchLanguage(lang)"
                        >
                          <delete-outlined />
                          {{ t('Remove Language') }}
                        </a-button>
                      </div>

                      <a-row :gutter="24">
                        <!-- 左侧：表单编辑 -->
                        <a-col :span="14">
                          <div class="form-panel">
                            <div class="form-header">
                              <h5>{{ t('Batch Content Editor') }} - {{ getLanguageName(lang) }}</h5>
                              <a-button
                                type="default"
                                size="small"
                                @click="copyBatchDefaultToCurrentLanguage(lang)"
                              >
                                <copy-outlined />
                                {{ t('Copy from default language') }}
                              </a-button>
                            </div>
                            <a-form layout="vertical">
                              <a-form-item :label="t('Website URL')">
                                <a-input
                                  :value="batchLanguageSettings[lang]?.websiteUrl || ''"
                                  @update:value="(value: string) => updateBatchLanguageContentForTab(lang, 'websiteUrl', value)"
                                  :placeholder="
                                    t('Enter website URL for') + ' ' + getLanguageName(lang)
                                  "
                                />
                              </a-form-item>

                              <a-form-item :label="t('Headline')">
                                <a-input
                                  :value="batchLanguageSettings[lang]?.headline || ''"
                                  @update:value="(value: string) => updateBatchLanguageContentForTab(lang, 'headline', value)"
                                  :placeholder="
                                    t('Enter headline for') + ' ' + getLanguageName(lang)
                                  "
                                />
                              </a-form-item>

                              <a-form-item :label="t('Primary Text')">
                                <a-textarea
                                  :value="batchLanguageSettings[lang]?.primaryText || ''"
                                  @update:value="(value: string) => updateBatchLanguageContentForTab(lang, 'primaryText', value)"
                                  :placeholder="
                                    t('Enter primary text for') + ' ' + getLanguageName(lang)
                                  "
                                  :rows="4"
                                />
                              </a-form-item>

                              <a-form-item :label="t('Description')">
                                <a-textarea
                                  :value="batchLanguageSettings[lang]?.description || ''"
                                  @update:value="(value: string) => updateBatchLanguageContentForTab(lang, 'description', value)"
                                  :placeholder="
                                    t('Enter description for') + ' ' + getLanguageName(lang)
                                  "
                                  :rows="3"
                                />
                              </a-form-item>
                            </a-form>
                          </div>
                        </a-col>

                        <!-- 右侧：广告预览 -->
                        <a-col :span="10">
                          <div class="preview-panel">
                            <div class="preview-header">
                              <div class="preview-title">
                                <h5>{{ t('Preview') }} - {{ getLanguageName(lang) }}</h5>
                              </div>
                              <div class="preview-actions">
                                <a-button
                                  type="text"
                                  size="small"
                                  class="preview-btn"
                                  @click="handleMediaEdit(lang)"
                                >
                                  <edit-outlined />
                                </a-button>
                                <a-button
                                  v-if="getCurrentAdType().includes('Video') && hasVideoForCurrentLanguage(lang) && activeTabKey !== 'batch'"
                                  type="text"
                                  size="small"
                                  class="preview-btn"
                                  @click="handleThumbnailClick(lang)"
                                >
                                  {{ t('Thumbnail') }}
                                </a-button>
                              </div>
                            </div>
                            <div class="preview-container">
                              <div class="ad-preview">
                                <div class="preview-header">
                                  <div class="brand-info">
                                    <div class="brand-avatar">📱</div>
                                    <div class="brand-details">
                                      <div class="brand-name-container">
                                        <div class="brand-name">{{ getCurrentBrandName() }}</div>
                                        <a-button
                                          v-if="activeTabKey !== 'batch'"
                                          type="text"
                                          size="small"
                                          class="page-edit-btn"
                                          @click="handlePageEdit"
                                        >
                                          <edit-outlined />
                                        </a-button>
                                      </div>
                                      <div class="sponsored-text">{{ t('Sponsored') }}</div>
                                    </div>
                                  </div>
                                </div>

                                <div class="ad-content">
                                  <!-- 顶部显示的正文样式 -->
                                  <div class="ad-primary-text-top">
                                    {{ getBatchPreviewForLanguage(lang, 'primaryText') }}
                                  </div>

                                  <div class="ad-media">
                                    <!-- 批量编辑模式下直接显示占位符 -->
                                    <div class="media-placeholder">
                                      <picture-outlined
                                        v-if="getCurrentAdType().includes('Image')"
                                        style="font-size: 48px; color: #fff"
                                      />
                                      <play-circle-outlined
                                        v-else
                                        style="font-size: 48px; color: #fff"
                                      />
                                      <div class="media-info">{{ getCurrentAdType() }}</div>
                                      <div class="batch-media-hint">
                                        {{ t('Batch editing - media preview not available') }}
                                      </div>
                                    </div>
                                  </div>

                                  <div class="ad-text-content">
                                    <div class="ad-headline">
                                      {{ getBatchPreviewForLanguage(lang, 'headline') }}
                                    </div>
                                    <div class="ad-description">
                                      {{ getBatchPreviewForLanguage(lang, 'description') }}
                                    </div>

                                    <div class="cta-section">
                                      <span class="website-url">
                                        {{ getBatchPreviewForLanguage(lang, 'websiteUrl') }}
                                      </span>
                                      <a-button type="primary" size="small">
                                        {{ t('Learn more') }}
                                      </a-button>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                        </a-col>
                      </a-row>
                    </div>
                  </a-tab-pane>
                </a-tabs>
              </div>
            </div>

            <!-- 单个广告编辑内容 -->
            <div v-else class="single-ad-edit-content">
              <div class="content-header">
                <div class="header-line">
                  <h3>{{ getCurrentAdDisplayTitle() }}</h3>
                  <div class="ad-meta">
                    <a-tag :color="getCurrentAdTypeColor()" size="small">
                      {{ getCurrentAdTypeText() }}
                    </a-tag>
                    <!-- 目录广告 Product Set 标签 -->
                    <a-tag
                      v-if="isCurrentAdCatalog && getCurrentProductSet"
                      color="cyan"
                      size="small"
                      class="product-set-tag"
                      @click="handleProductSetEdit"
                      style="cursor: pointer;"
                    >
                      <template #icon>
                        <edit-outlined v-show="false" class="edit-icon" />
                      </template>
                      {{ getCurrentProductSet.name }}
                    </a-tag>
                    <span class="ad-id">ID: {{ activeTabKey }}</span>
                  </div>
                </div>

                <!-- 多语言开关 -->
                <div class="multi-language-switch-section">
                  <div class="switch-and-controls-container">
                    <!-- 左侧：多语言开关 -->
                    <div class="switch-container">
                      <label class="switch-label">{{ t('Multi-language') }}:</label>
                      <a-switch
                        :checked="getAdMultiLanguageEnabled(activeTabKey)"
                        @change="handleMultiLanguageToggle"
                        size="default"
                      />
                      <span class="switch-description">
                        {{ getAdMultiLanguageEnabled(activeTabKey) ? t('Enabled') : t('Disabled') }}
                      </span>
                    </div>

                    <!-- 右侧：语言控制器（仅在启用多语言时显示） -->
                    <div v-if="getAdMultiLanguageEnabled(activeTabKey)" class="language-controls-inline">
                      <div class="default-language-section">
                        <label class="control-label">{{ t('Default Language') }}:</label>
                        <a-select
                          :value="getCurrentAdDefaultLanguage()"
                          style="width: 200px"
                          @change="handleCurrentAdDefaultLanguageChange"
                          :loading="languagesLoading"
                        >
                          <a-select-option
                            v-for="lang in availableLanguages"
                            :key="lang.code"
                            :value="lang.code"
                          >
                            {{ lang.displayName }}
                          </a-select-option>
                        </a-select>
                      </div>

                      <div class="language-actions">
                        <a-button
                          v-if="getCurrentAdAdditionalLanguages().length > 0"
                          type="default"
                          size="small"
                          @click="copyCurrentAdDefaultToOthers"
                        >
                          <copy-outlined />
                          {{ t('Copy to other languages') }}
                        </a-button>

                        <a-button type="primary" size="small" @click="showLanguageModal = true">
                          <plus-outlined />
                          {{ t('Add Language') }}
                        </a-button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- 单语言模式界面 -->
              <div v-if="!getAdMultiLanguageEnabled(activeTabKey)" class="single-language-content">
                <a-row :gutter="24">
                  <!-- 左侧：表单编辑 -->
                  <a-col :span="14">
                    <div class="form-panel">
                      <div class="form-header">
                        <h5>{{ t('Content Editor') }} - {{ t('Default Language') }}</h5>
                      </div>
                      <a-form layout="vertical">
                        <a-form-item :label="t('Website URL')">
                          <a-row :gutter="[6, 0]" :wrap="false">
                            <a-col :flex="1">
                              <a-input
                                :value="getSingleLanguageContent('websiteUrl')"
