                            <div class="brand-info">
                              <div class="brand-avatar">📱</div>
                              <div class="brand-details">
                                <div class="brand-name-container">
                                  <div class="brand-name">{{ getCurrentBrandName() }}</div>
                                  <a-button
                                    v-if="activeTabKey !== 'batch'"
                                    type="text"
                                    size="small"
                                    class="page-edit-btn"
                                    @click="handlePageEdit"
                                  >
                                    <edit-outlined />
                                  </a-button>
                                </div>
                                <div class="sponsored-text">{{ t('Sponsored') }}</div>
                              </div>
                            </div>
                          </div>

                          <div class="ad-content">
                            <!-- 顶部显示的正文样式 -->
                            <div class="ad-primary-text-top">
                              {{ getPreviewPrimaryText() }}
                            </div>

                            <div class="ad-media">
                              <!-- 单语言模式的媒体预览 -->
                              <div
                                v-if="hasSingleLanguageMedia()"
                                class="media-placeholder media-loadable"
                                @click="handleLoadSingleLanguageMedia()"
                              >
                                <div class="media-load-container">
                                  <div
                                    v-if="getSingleLanguageMediaState().loading"
                                    class="loading-state"
                                  >
                                    <a-spin size="large" />
                                    <div class="loading-text">{{ t('Loading media...') }}</div>
                                  </div>
                                  <div v-else class="load-prompt">
                                    <div class="load-icon">
                                      <picture-outlined
                                        v-if="getCurrentAdType().includes('Image')"
                                        style="font-size: 48px; color: #1890ff"
                                      />
                                      <play-circle-outlined
                                        v-else
                                        style="font-size: 48px; color: #1890ff"
                                      />
                                    </div>
                                    <div class="load-text">
                                      {{ t('Click to load') }}
                                      {{ getCurrentAdType().includes('Image') ? t('image') : t('video') }}
                                    </div>
                                    <a-button type="primary" ghost size="small" class="load-button">
                                      <cloud-download-outlined />
                                      {{ t('Load Media') }}
                                    </a-button>
                                  </div>
                                </div>
                              </div>
                              <!-- 已加载的媒体 -->
                              <div
                                v-else-if="getSingleLanguageMediaState().show"
                                class="media-content"
                              >
                                <img
                                  v-if="getSingleLanguageMediaState().type === 'image'"
                                  :src="getSingleLanguageMediaState().url"
                                  alt="Ad Image"
                                  class="media-image"
                                />
                                <!-- 视频直接显示 -->
                                <video
                                  v-else-if="getSingleLanguageMediaState().type === 'video'"
                                  class="video-player"
                                  :src="getSingleLanguageMediaState().url"
                                  :poster="getSingleLanguageContent('thumbnailUrl')"
                                  controls
                                  preload="none"
                                  playsinline
                                  controlsList="nodownload"
                                >
                                  {{ t('Your browser does not support the video tag.') }}
                                </video>
                              </div>
                              <!-- 默认占位符 -->
                              <div v-else class="media-placeholder">
                                <picture-outlined
                                  v-if="getCurrentAdType().includes('Image')"
                                  style="font-size: 48px; color: #fff"
                                />
                                <play-circle-outlined
                                  v-else
                                  style="font-size: 48px; color: #fff"
                                />
                                <div class="media-info">{{ getCurrentAdType() }}</div>
                              </div>
                            </div>

