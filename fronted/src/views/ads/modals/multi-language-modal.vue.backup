                          <!-- 右侧：广告预览 -->
                          <a-col :span="10">
                            <div class="preview-panel">
                              <div class="preview-header">
                                <div class="preview-title">
                                  <h5>{{ t('Preview') }} - {{ getLanguageName(activeLanguageKey) }}</h5>
                                </div>
                                <div class="preview-actions">
                                  <a-button
                                    type="text"
                                    size="small"
                                    class="preview-btn"
                                    @click="handleMediaEdit()"
                                  >
                                    <edit-outlined />
                                  </a-button>
                                  <a-button
                                    v-if="getCurrentAdType().includes('Video') && hasVideoForCurrentLanguage() && activeTabKey !== 'batch'"
                                    type="text"
                                    size="small"
                                    class="preview-btn"
                                    @click="handleThumbnailClick()"
                                  >
                                    {{ t('Thumbnail') }}
                                  </a-button>
                                </div>
                              </div>
                              <div class="preview-container">
                                <div class="ad-preview">
                                  <div class="preview-header">
                                    <div class="brand-info">
                                      <div class="brand-avatar">📱</div>
                                      <div class="brand-details">
                                        <div class="brand-name-container">
                                          <div class="brand-name">{{ getCurrentBrandName() }}</div>
                                          <a-button
                                            v-if="activeTabKey !== 'batch'"
                                            type="text"
                                            size="small"
                                            class="page-edit-btn"
                                            @click="handlePageEdit"
                                          >
                                            <edit-outlined />
                                          </a-button>
                                        </div>
                                        <div class="sponsored-text">{{ t('Sponsored') }}</div>
                                      </div>
                                    </div>
                                  </div>

                                  <div class="ad-content">
                                    <!-- 顶部显示的正文样式 -->
                                    <div class="ad-primary-text-top">
                                      {{ getPreviewPrimaryText() }}
                                    </div>

                                    <div class="ad-media">
                                      <!-- 对于已配置多语言的单个广告，显示媒体加载控制 -->
                                      <div
                                        v-if="
                                          activeTabKey !== 'batch' &&
                                          hasUnloadedMedia(activeLanguageKey, activeTabKey)
                                        "
                                        class="media-placeholder media-loadable"
                                        @click="handleLoadMedia(activeLanguageKey, activeTabKey)"
                                      >
                                        <div class="media-load-container">
                                          <div
                                            v-if="
                                              getMediaPreviewState(activeLanguageKey, activeTabKey)
                                                .loading
                                            "
                                            class="loading-state"
                                          >
                                            <a-spin size="large" />
                                            <div class="loading-text">
                                              {{ t('Loading media...') }}
                                            </div>
                                          </div>
                                          <div v-else class="load-prompt">
                                            <div class="load-icon">
                                              <picture-outlined
                                                v-if="
                                                  getCurrentContextMediaType(
                                                    activeLanguageKey,
                                                    activeTabKey,
                                                  ) === 'image'
                                                "
                                                style="font-size: 48px; color: #1890ff"
                                              />
                                              <play-circle-outlined
                                                v-else
                                                style="font-size: 48px; color: #1890ff"
                                              />
                                            </div>
                                            <div class="load-text">
                                              {{ t('Click to load') }}
                                              {{
                                                getCurrentContextMediaType(
                                                  activeLanguageKey,
                                                  activeTabKey,
                                                ) === 'image'
                                                  ? t('image')
                                                  : t('video')
                                              }}
                                            </div>
                                            <a-button
                                              type="primary"
                                              ghost
                                              size="small"
                                              class="load-button"
                                            >
                                              <cloud-download-outlined />
                                              {{ t('Load Media') }}
                                            </a-button>
                                          </div>
                                        </div>
                                      </div>
                                      <!-- 对于已加载媒体的单个广告，显示实际媒体 -->
                                      <div
                                        v-else-if="
                                          activeTabKey !== 'batch' &&
                                          getMediaPreviewState(activeLanguageKey, activeTabKey).show
                                        "
                                        class="media-content"
                                      >
                                        <img
                                          v-if="
                                            getMediaPreviewState(activeLanguageKey, activeTabKey)
                                              .type === 'image'
                                          "
                                          :src="
                                            getMediaPreviewState(activeLanguageKey, activeTabKey).url
                                          "
                                          alt="Ad Image"
                                          class="media-image"
                                        />
                                        <!-- 视频直接显示 -->
                                        <video
                                          v-else-if="
                                            getMediaPreviewState(activeLanguageKey, activeTabKey)
                                              .type === 'video'
                                          "
                                          class="video-player"
                                          :src="getMediaPreviewState(activeLanguageKey, activeTabKey).url"
                                          :poster="getCurrentLanguageContent('thumbnailUrl')"
                                          controls
                                          preload="none"
                                          playsinline
                                          controlsList="nodownload"
                                        >
                                          {{ t('Your browser does not support the video tag.') }}
                                        </video>
                                      </div>
                                      <!-- 默认占位符（用于批量编辑或无媒体的情况） -->
                                      <div v-else class="media-placeholder">
                                        <picture-outlined
                                          v-if="getCurrentAdType().includes('Image')"
                                          style="font-size: 48px; color: #fff"
                                        />
                                        <play-circle-outlined
                                          v-else
                                          style="font-size: 48px; color: #fff"
                                        />
                                        <div class="media-info">{{ getCurrentAdType() }}</div>
                                        <div v-if="activeTabKey === 'batch'" class="batch-media-hint">
                                          {{ t('Batch editing - media preview not available') }}
                                        </div>
                                      </div>
                                    </div>

                                    <div class="ad-text-content">
                                      <div class="ad-headline">{{ getPreviewHeadline() }}</div>
                                      <div class="ad-description">{{ getPreviewDescription() }}</div>

                                      <div class="cta-section">
                                        <span class="website-url">{{ getPreviewWebsiteUrl() }}</span>
                                        <a-button type="primary" size="small">
                                          {{ t('Learn more') }}
                                        </a-button>
                                      </div>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </a-col>
                        </a-row>
                      </div>
                    </a-tab-pane>

                    <!-- 附加语言Tabs -->
                    <a-tab-pane
                      v-for="lang in getCurrentAdAdditionalLanguages()"
                      :key="lang"
                      :tab="getLanguageName(lang)"
                      v-bind:title="getLanguageNativeName(lang)"
                    >
                      <div class="language-content">
                        <div class="language-action-header">
                          <h5>{{ getLanguageName(lang) }} {{ t('Translation') }}</h5>
                          <a-button
                            type="text"
                            danger
                            size="small"
                            @click="removeLanguageFromCurrentAd(lang)"
                          >
                            <delete-outlined />
                            {{ t('Remove Language') }}
                          </a-button>
                        </div>

                        <a-row :gutter="24">
                          <!-- 左侧：表单编辑 -->
                          <a-col :span="14">
                            <div class="form-panel">
                              <div class="form-header">
                                <h5>{{ t('Content Editor') }} - {{ getLanguageName(lang) }}</h5>
                                <a-button
                                  type="default"
                                  size="small"
                                  @click="copyCurrentAdDefaultToCurrentLanguage(lang)"
                                >
                                  <copy-outlined />
                                  {{ t('Copy from default language') }}
                                </a-button>
                              </div>
                              <a-form layout="vertical">
                                <a-form-item :label="t('Website URL')">
                                  <a-row :gutter="[6, 0]" :wrap="false">
                                    <a-col :flex="1">
                                      <a-input
                                        :value="getLanguageContentForTab(lang, 'websiteUrl')"
                                        @update:value="(value: string) => updateLanguageContentForTab(lang, 'websiteUrl', value)"
                                        :placeholder="
                                          t('Enter website URL for') + ' ' + getLanguageName(lang)
                                        "
                                      />
                                    </a-col>
                                    <a-col>
                                      <a-button
                                        type="text"
                                        size="small"
                                        @click="openLinkPicker"
                                        class="preview-btn"
                                      >
                                        <edit-outlined />
                                      </a-button>
                                    </a-col>
                                  </a-row>
                                </a-form-item>

                                <a-form-item :label="t('Headline')">
                                  <a-row :gutter="[6, 0]" :wrap="false">
                                    <a-col :flex="1">
                                      <a-input
                                        :value="getLanguageContentForTab(lang, 'headline')"
                                        @update:value="(value: string) => updateLanguageContentForTab(lang, 'headline', value)"
                                        :placeholder="
                                          t('Enter headline for') + ' ' + getLanguageName(lang)
                                        "
                                      />
                                    </a-col>
                                    <a-col>
                                      <a-button
                                        type="text"
                                        size="small"
                                        @click="openCopywritingPicker"
                                        class="preview-btn"
                                      >
                                        <edit-outlined />
                                      </a-button>
                                    </a-col>
                                  </a-row>
                                </a-form-item>

                                <a-form-item :label="t('Primary Text')">
                                  <a-row :gutter="[6, 0]" :wrap="false">
                                    <a-col :flex="1">
                                      <a-textarea
                                        :value="getLanguageContentForTab(lang, 'primaryText')"
                                        @update:value="(value: string) => updateLanguageContentForTab(lang, 'primaryText', value)"
                                        :placeholder="
                                          t('Enter primary text for') + ' ' + getLanguageName(lang)
                                        "
                                        :rows="4"
                                      />
                                    </a-col>
                                    <a-col style="align-self: flex-start; padding-top: 8px;">
                                      <a-button
                                        type="text"
                                        size="small"
                                        @click="openCopywritingPicker"
                                        class="preview-btn"
                                      >
                                        <edit-outlined />
                                      </a-button>
                                    </a-col>
                                  </a-row>
                                </a-form-item>

                                <a-form-item :label="t('Description')">
                                  <a-row :gutter="[6, 0]" :wrap="false">
                                    <a-col :flex="1">
                                      <a-textarea
                                        :value="getLanguageContentForTab(lang, 'description')"
                                        @update:value="(value: string) => updateLanguageContentForTab(lang, 'description', value)"
                                        :placeholder="
                                          t('Enter description for') + ' ' + getLanguageName(lang)
                                        "
                                        :rows="3"
                                      />
                                    </a-col>
                                    <a-col style="align-self: flex-start; padding-top: 8px;">
                                      <a-button
                                        type="text"
                                        size="small"
                                        @click="openCopywritingPicker"
                                        class="preview-btn"
                                      >
                                        <edit-outlined />
                                      </a-button>
                                    </a-col>
                                  </a-row>
                                </a-form-item>
                              </a-form>
                            </div>
                          </a-col>

                          <!-- 右侧：广告预览 -->
                          <a-col :span="10">
                            <div class="preview-panel">
                              <div class="preview-header">
                                <div class="preview-title">
                                  <h5>{{ t('Preview') }} - {{ getLanguageName(lang) }}</h5>
                                </div>
                                <div class="preview-actions">
                                  <a-button
                                    type="text"
                                    size="small"
                                    class="preview-btn"
                                    @click="handleMediaEdit(lang)"
                                  >
                                    <edit-outlined />
                                  </a-button>
                                  <a-button
                                    v-if="getCurrentAdType().includes('Video') && hasVideoForCurrentLanguage(lang) && activeTabKey !== 'batch'"
                                    type="text"
                                    size="small"
                                    class="preview-btn"
                                    @click="handleThumbnailClick(lang)"
                                  >
                                    {{ t('Thumbnail') }}
                                  </a-button>
                                </div>
                              </div>
                              <div class="preview-container">
                                <div class="ad-preview">
                                  <div class="preview-header">
                                    <div class="brand-info">
                                      <div class="brand-avatar">📱</div>
                                      <div class="brand-details">
                                        <div class="brand-name-container">
                                          <div class="brand-name">{{ getCurrentBrandName() }}</div>
                                          <a-button
                                            v-if="activeTabKey !== 'batch'"
                                            type="text"
                                            size="small"
                                            class="page-edit-btn"
                                            @click="handlePageEdit"
                                          >
                                            <edit-outlined />
                                          </a-button>
                                        </div>
                                        <div class="sponsored-text">{{ t('Sponsored') }}</div>
                                      </div>
                                    </div>
                                  </div>

                                  <div class="ad-content">
                                    <!-- 顶部显示的正文样式 -->
                                    <div class="ad-primary-text-top">
                                      {{ getPreviewForLanguage(lang, 'primaryText') }}
                                    </div>

                                    <div class="ad-media">
                                      <!-- 对于已配置多语言的单个广告，显示媒体加载控制 -->
                                      <div
                                        v-if="
                                          activeTabKey !== 'batch' &&
                                          hasUnloadedMedia(lang, activeTabKey)
                                        "
                                        class="media-placeholder media-loadable"
                                        @click="handleLoadMedia(lang, activeTabKey)"
                                      >
                                        <div class="media-load-container">
                                          <div
                                            v-if="getMediaPreviewState(lang, activeTabKey).loading"
                                            class="loading-state"
                                          >
                                            <a-spin size="large" />
                                            <div class="loading-text">
                                              {{ t('Loading media...') }}
                                            </div>
                                          </div>
                                          <div v-else class="load-prompt">
                                            <div class="load-icon">
                                              <picture-outlined
                                                v-if="
                                                  getCurrentContextMediaType(lang, activeTabKey) ===
                                                  'image'
                                                "
                                                style="font-size: 48px; color: #1890ff"
                                              />
                                              <play-circle-outlined
                                                v-else
                                                style="font-size: 48px; color: #1890ff"
                                              />
                                            </div>
                                            <div class="load-text">
                                              {{ t('Click to load') }}
                                              {{
                                                getCurrentContextMediaType(lang, activeTabKey) ===
                                                'image'
                                                  ? t('image')
                                                  : t('video')
                                              }}
                                            </div>
                                            <a-button
                                              type="primary"
                                              ghost
                                              size="small"
                                              class="load-button"
                                            >
                                              <cloud-download-outlined />
                                              {{ t('Load Media') }}
                                            </a-button>
                                          </div>
                                        </div>
                                      </div>
                                      <!-- 对于已加载媒体的单个广告，显示实际媒体 -->
                                      <div
                                        v-else-if="
                                          activeTabKey !== 'batch' &&
                                          getMediaPreviewState(lang, activeTabKey).show
                                        "
                                        class="media-content"
                                      >
                                        <img
                                          v-if="
                                            getMediaPreviewState(lang, activeTabKey).type === 'image'
                                          "
                                          :src="getMediaPreviewState(lang, activeTabKey).url"
                                          alt="Ad Image"
                                          class="media-image"
                                        />
                                        <!-- 视频直接显示 -->
                                        <video
                                          v-else-if="
                                            getMediaPreviewState(lang, activeTabKey).type === 'video'
                                          "
                                          class="video-player"
                                          :src="getMediaPreviewState(lang, activeTabKey).url"
                                          :poster="getLanguageContentForTab(lang, 'thumbnailUrl')"
                                          controls
                                          preload="none"
                                          playsinline
                                          controlsList="nodownload"
                                        >
                                          {{ t('Your browser does not support the video tag.') }}
                                        </video>
                                      </div>
                                      <!-- 默认占位符（用于批量编辑或无媒体的情况） -->
                                      <div v-else class="media-placeholder">
                                        <picture-outlined
                                          v-if="getCurrentAdType().includes('Image')"
                                          style="font-size: 48px; color: #fff"
                                        />
                                        <play-circle-outlined
                                          v-else
                                          style="font-size: 48px; color: #fff"
                                        />
                                        <div class="media-info">{{ getCurrentAdType() }}</div>
                                        <div v-if="activeTabKey === 'batch'" class="batch-media-hint">
                                          {{ t('Batch editing - media preview not available') }}
                                        </div>
                                      </div>
                                    </div>

                                    <div class="ad-text-content">
                                      <div class="ad-headline">
                                        {{ getPreviewForLanguage(lang, 'headline') }}
                                      </div>
                                      <div class="ad-description">
                                        {{ getPreviewForLanguage(lang, 'description') }}
                                      </div>

                                      <div class="cta-section">
                                        <span class="website-url">
                                          {{ getPreviewForLanguage(lang, 'websiteUrl') }}
                                        </span>
                                        <a-button type="primary" size="small">
                                          {{ t('Learn more') }}
                                        </a-button>
                                      </div>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </a-col>
                        </a-row>
                      </div>
                    </a-tab-pane>
                  </a-tabs>
                </div>
              </div>
            </div>
          </div>
        </a-col>
      </a-row>
    </div>

    <!-- 添加语言Modal -->
    <a-modal
      v-model:open="showLanguageModal"
      :title="t('Add Language')"
      :width="750"
      :z-index="1010"
      @ok="addLanguageToCurrentAd"
      @cancel="showLanguageModal = false"
      class="language-selection-modal-optimized"
      :mask-closable="false"
    >
      <div class="language-selection-content-optimized">
        <!-- 搜索栏 -->
        <div class="language-search-section">
          <a-input
            v-model:value="languageSearchQuery"
            :placeholder="t('Search languages...')"
            allow-clear
            class="language-search-input"
          >
            <template #prefix>
              <search-outlined />
            </template>
          </a-input>
          <div class="search-stats">
            {{ filteredAvailableLanguagesForCurrentAd.length }} {{ t('languages available') }}
            <span v-if="selectedLanguagesToAdd.length > 0" class="selected-count">
              ({{ selectedLanguagesToAdd.length }} {{ t('selected') }})
            </span>
          </div>
        </div>

        <!-- 快速选择按钮 -->
        <div class="quick-actions">
          <a-button
            size="small"
            @click="selectAllFilteredLanguages"
            :disabled="filteredAvailableLanguagesForCurrentAd.length === 0"
          >
            {{ t('Select All') }}
          </a-button>
          <a-button
            size="small"
            @click="clearLanguageSelection"
            :disabled="selectedLanguagesToAdd.length === 0"
          >
            {{ t('Clear All') }}
          </a-button>
        </div>

        <!-- 语言列表 -->
        <div class="language-list-container">
          <a-checkbox-group
            v-model:value="selectedLanguagesToAdd"
            class="language-checkbox-group-optimized"
          >
            <div
              v-for="lang in filteredAvailableLanguagesForCurrentAd"
              :key="lang.code"
              class="language-item-optimized"
            >
              <a-checkbox
                :value="lang.code"
                class="language-checkbox-optimized"
              >
                <div class="language-info">
                  <span class="language-name">{{ lang.name }}</span>
                  <span class="language-native">{{ lang.nativeName }}</span>
                </div>
              </a-checkbox>
            </div>
          </a-checkbox-group>

          <!-- 空状态 -->
          <div v-if="filteredAvailableLanguagesForCurrentAd.length === 0" class="empty-state">
            <div class="empty-icon">🔍</div>
            <div class="empty-text">{{ t('No languages found') }}</div>
            <div class="empty-hint">{{ t('Try different search terms') }}</div>
          </div>
        </div>
      </div>

      <template #footer>
        <div class="modal-footer-optimized">
          <div class="selection-summary">
            <span v-if="selectedLanguagesToAdd.length > 0" class="summary-text">
              {{ selectedLanguagesToAdd.length }} {{ t('language(s) selected') }}
            </span>
          </div>
          <div class="footer-actions">
            <a-button @click="handleLanguageModalCancel">{{ t('Cancel') }}</a-button>
            <a-button
              type="primary"
              @click="addLanguageToCurrentAd"
              :disabled="selectedLanguagesToAdd.length === 0"
            >
              {{ t('Add Selected Languages') }}
            </a-button>
          </div>
        </div>
      </template>
    </a-modal>

    <!-- 批量编辑添加语言Modal -->
    <a-modal
      v-model:open="showBatchLanguageModal"
      :title="t('Add Language')"
      :width="750"
      :z-index="1010"
      @ok="addBatchLanguage"
      @cancel="showBatchLanguageModal = false"
      class="language-selection-modal-optimized"
      :mask-closable="false"
    >
      <div class="language-selection-content-optimized">
        <!-- 搜索栏 -->
        <div class="language-search-section">
          <a-input
            v-model:value="batchLanguageSearchQuery"
            :placeholder="t('Search languages...')"
            allow-clear
            class="language-search-input"
          >
            <template #prefix>
              <search-outlined />
            </template>
          </a-input>
          <div class="search-stats">
            {{ filteredAvailableBatchLanguages.length }} {{ t('languages available') }}
            <span v-if="selectedBatchLanguagesToAdd.length > 0" class="selected-count">
              ({{ selectedBatchLanguagesToAdd.length }} {{ t('selected') }})
            </span>
          </div>
        </div>

        <!-- 快速选择按钮 -->
        <div class="quick-actions">
          <a-button
            size="small"
            @click="selectAllFilteredBatchLanguages"
            :disabled="filteredAvailableBatchLanguages.length === 0"
          >
            {{ t('Select All') }}
          </a-button>
          <a-button
            size="small"
            @click="clearBatchLanguageSelection"
            :disabled="selectedBatchLanguagesToAdd.length === 0"
          >
            {{ t('Clear All') }}
          </a-button>
        </div>

        <!-- 语言列表 -->
        <div class="language-list-container">
          <a-checkbox-group
            v-model:value="selectedBatchLanguagesToAdd"
            class="language-checkbox-group-optimized"
          >
            <div
              v-for="lang in filteredAvailableBatchLanguages"
              :key="lang.code"
              class="language-item-optimized"
            >
              <a-checkbox
                :value="lang.code"
                class="language-checkbox-optimized"
              >
                <div class="language-info">
                  <span class="language-name">{{ lang.name }}</span>
                  <span class="language-native">{{ lang.nativeName }}</span>
                </div>
              </a-checkbox>
            </div>
          </a-checkbox-group>

          <!-- 空状态 -->
          <div v-if="filteredAvailableBatchLanguages.length === 0" class="empty-state">
            <div class="empty-icon">🔍</div>
            <div class="empty-text">{{ t('No languages found') }}</div>
            <div class="empty-hint">{{ t('Try different search terms') }}</div>
          </div>
        </div>
      </div>

      <template #footer>
        <div class="modal-footer-optimized">
          <div class="selection-summary">
            <span v-if="selectedBatchLanguagesToAdd.length > 0" class="summary-text">
              {{ selectedBatchLanguagesToAdd.length }} {{ t('language(s) selected') }}
            </span>
          </div>
          <div class="footer-actions">
            <a-button @click="handleBatchLanguageModalCancel">{{ t('Cancel') }}</a-button>
            <a-button
              type="primary"
              @click="addBatchLanguage"
              :disabled="selectedBatchLanguagesToAdd.length === 0"
            >
              {{ t('Add Selected Languages') }}
            </a-button>
          </div>
        </div>
      </template>
    </a-modal>

    <template #footer>
      <a-button @click="handleCancel">{{ t('Cancel') }}</a-button>
      <a-button type="primary" @click="handleOk">
        {{ t('Save') }}
      </a-button>
    </template>
  </a-modal>

  <!-- 媒体编辑Modal -->
  <media-edit-modal
    :open="showMediaEditModal"
    :media-type="mediaEditContext.mediaType"
    :ad-account-id="mediaEditContext.adAccountId"
    :ad-id="mediaEditContext.adId"
    :ad-name="mediaEditContext.adName"
    :language-name="mediaEditContext.languageName"
    @cancel="handleMediaEditCancel"
    @confirm="handleMediaEditConfirm"
  />

  <!-- 视频缩略图Modal -->
  <video-thumbnail-modal
    v-model:visible="showVideoThumbnailModal"
    :ad-account="thumbnailContext.adAccount"
    :video-id="thumbnailContext.videoId"
    :upload-notes="thumbnailContext.uploadNotes"
    :is-multi-language="thumbnailContext.isMultiLanguage"
    @thumbnail-selected="handleThumbnailSelected"
  />

  <!-- Page编辑Modal -->
  <page-edit-modal
    :open="showPageEditModal"
    :ad-account-id="pageEditContext.adAccountId"
    :current-page-info="pageEditContext.currentPageInfo"
    @cancel="handlePageEditCancel"
    @confirm="handlePageEditConfirm"
  />

  <!-- 链接选择Modal -->
  <pick-objects
    ref="linkPickerRef"
    :multiple="false"
    :api="queryLinksApi"
    :allow-empty="false"
    :columns="linkColumns"
    :title="t('Select Link')"
    @confirm:items-selected="handleLinkSelection"
    style="display: none"
    :hide-trigger-button="true"
  />

  <!-- 文案选择Modal -->
  <pick-objects
    ref="copywritingPickerRef"
    :multiple="false"
    :api="queryCopywritingsApi"
    :allow-empty="false"
    :columns="copywritingColumns"
    :title="t('Select Copywriting')"
    @confirm:items-selected="handleCopywritingSelection"
    style="display: none"
    :hide-trigger-button="true"
  />
</template>

<script lang="ts">
import { defineComponent, ref, computed, reactive, watch, nextTick, onMounted } from 'vue';
import { useI18n } from 'vue-i18n';
import { message, Modal } from 'ant-design-vue';
import {
  EditOutlined,
  DeleteOutlined,
  PlusOutlined,
  PlayCircleOutlined,
  CopyOutlined,
  PictureOutlined,
  CloudDownloadOutlined,
  InfoCircleOutlined,
  SearchOutlined,
  SelectOutlined,
} from '@ant-design/icons-vue';
import { getLanguages, getAdsMedia } from '@/api/ads';
import { queryCopywritingsApi } from '@/api/copywritings';
import { queryLinksApi } from '@/api/links';
import PickObjects from '../create-ads-v2/pick-objects.vue';
import MediaEditModal from './media-edit-modal.vue';
import VideoThumbnailModal from './video-thumbnail-modal.vue';
import PageEditModal from './page-edit-modal.vue';
import './multi-language-modal.less';

interface LanguageOption {
  code: string;
  name: string;
  nativeName: string;
  displayName: string; // 用于显示，格式为 "English (English)"
  locales?: number[];
}

interface ApiLanguageItem {
  english_name: string;
  native_name: string;
  label_name: string;
  locales: number[];
}

interface AdLanguageContent {
  websiteUrl?: string;
  headline?: string;
  primaryText?: string;
  description?: string;
  deepLink?: string; // 添加深度链接字段（目录广告使用）
  mediaType?: 'image' | 'video';
  imageUrl?: string;
  videoUrl?: string;
  mediaName?: string;
  mediaId?: string;
  mediaHash?: string; // 添加媒体hash字段, image 是 image_hash, video 是 video_id
  loading?: boolean; // 添加加载状态字段
  // 缩略图相关字段
  thumbnailUrl?: string; // 缩略图URL
  thumbnailHash?: string; // 自定义缩略图的hash
  thumbnailId?: string; // 系统缩略图的ID
  thumbnailType?: 'system' | 'custom'; // 缩略图类型
}

interface AdSettings {
  defaultLanguage: string;
  additionalLanguages: string[];
  languageContent: { [key: string]: AdLanguageContent };
  isMultiLanguageEnabled?: boolean; // 多语言开关状态
}

interface BatchSettings {
  websiteUrl?: string;
  headline?: string;
  primaryText?: string;
  description?: string;
}

interface AdData {
  ad_id: string;
  ad_name: string;
  ad_account_id: string;
  creative: any;
  post?: {
    primary_text?: string;
    headline?: string;
    description?: string;
    post_type?: string;
    url?: string;
    url_tags?: string;
  };
  product_set?: {
    id: string;
    source_id: string;
    name: string;
    filter: any;
    products: {
      id: string;
      currency: string;
      name: string;
      source_id: string;
      description: string;
      url: string;
      image_url: string;
      retailer_id: string;
      price: string;
      video_url: string | null;
      brand?: string;
      tags: any[];
    }[];
    tags: any[];
  };
}

export default defineComponent({
  name: 'MultiLanguageModal',
  components: {
    EditOutlined,
    DeleteOutlined,
    PlusOutlined,
    PlayCircleOutlined,
    CopyOutlined,
    PictureOutlined,
    CloudDownloadOutlined,
    InfoCircleOutlined,
    SearchOutlined,
    SelectOutlined,
    PickObjects,
    MediaEditModal,
    VideoThumbnailModal,
    PageEditModal,
  },
  props: {
    open: {
      type: Boolean,
      default: false,
    },
    selectedAds: {
      type: Array as () => AdData[],
      default: () => [],
    },
  },
  emits: ['cancel', 'ok'],
  setup(props, { emit }) {
    const { t } = useI18n();

    const visible = computed({
      get: () => props.open,
      set: value => {
        if (!value) {
          emit('cancel');
        }
      },
    });

    // 重置所有数据状态
    const resetAllData = () => {
      // 清空所有广告的状态
      Object.keys(adLanguageSettings).forEach(key => {
        delete adLanguageSettings[key];
      });
      Object.keys(adMultiLanguageEnabled).forEach(key => {
        delete adMultiLanguageEnabled[key];
      });
      Object.keys(adSingleLanguageContents).forEach(key => {
        delete adSingleLanguageContents[key];
      });
      Object.keys(singleLanguageMediaStates).forEach(key => {
        delete singleLanguageMediaStates[key];
      });
      Object.keys(adLanguageContents).forEach(key => {
        delete adLanguageContents[key];
      });

      // 清空用户修改记录
      userModifiedAds.clear();

      // 重置Tab状态 - 由于批量编辑已禁用，不再设置为batch
      activeTabKey.value = '';
      activeLanguageKey.value = 'en_XX';

      // 重置批量编辑状态
      batchActiveLanguageKey.value = 'en_XX';
      batchDefaultLanguage.value = 'en_XX';
      batchAdditionalLanguages.value = [];

      // 清空批量语言设置
      Object.keys(batchLanguageSettings).forEach(key => {
        delete batchLanguageSettings[key];
      });

      // 重新初始化批量编辑默认语言
      batchLanguageSettings['en_XX'] = {
        websiteUrl: '',
        headline: '',
        primaryText: '',
        description: '',
      };

      // 重置Modal状态
      showLanguageModal.value = false;
      showBatchLanguageModal.value = false;
      selectedLanguagesToAdd.value = [];
      selectedBatchLanguagesToAdd.value = [];

      // 重置批量编辑应用状态
      applyingBatchChanges.value = false;
      batchChangesApplied.value = false;

      console.log('已重置所有多语言数据状态');
    };

    // 初始化广告数据（包括单语言数据解析）
    const initializeAdData = (ad: AdData) => {
      const adId = ad.ad_id;

      // 检查是否已配置多语言
      const { hasAssetFeedSpec } = checkAdMultiLanguageSupport(ad);

      if (hasAssetFeedSpec) {
        // 已配置多语言，设置开关为启用
        adMultiLanguageEnabled[adId] = true;

        // 重新解析多语言数据，确保数据来自原始广告数据
        const parsedData = parseMultiLanguageData(ad);
        if (parsedData) {
          // 直接设置新的语言配置，不保留之前的状态
          adLanguageSettings[adId] = {
            defaultLanguage: parsedData.defaultLanguage,
            additionalLanguages: [...parsedData.languages], // 创建新数组
            languageContent: {},
            isMultiLanguageEnabled: true,
          };

          // 直接设置新的语言内容，不保留之前的媒体URL
          adLanguageContents[adId] = {};
          Object.keys(parsedData.languageData).forEach(langCode => {
            adLanguageContents[adId][langCode] = {
              ...parsedData.languageData[langCode]
            };
          });

          console.log(`重新解析广告 ${ad.ad_name} 的多语言数据:`, {
            defaultLanguage: parsedData.defaultLanguage,
            languages: parsedData.languages,
            languageData: adLanguageContents[adId],
          });
        }
      } else {
        // 未配置多语言，设置开关为禁用，重新解析单语言数据
        adMultiLanguageEnabled[adId] = false;

        // 重新解析单语言数据
        adSingleLanguageContents[adId] = parseSingleLanguageData(ad);

        // 🔧 修复：不要硬编码默认语言，而是根据可用语言智能选择
        // 如果已经有设置，保持不变；如果没有，使用第一个可用语言作为默认
        if (!adLanguageSettings[adId]) {
          // 智能选择默认语言：优先使用en_XX，如果不可用则使用第一个可用语言
          const firstAvailableLanguage = availableLanguages.value.length > 0 ? availableLanguages.value[0].code : 'en_XX';
          const preferredDefault = availableLanguages.value.find(lang => lang.code === 'en_XX') ? 'en_XX' : firstAvailableLanguage;

          adLanguageSettings[adId] = {
            defaultLanguage: preferredDefault,
            additionalLanguages: [],
            languageContent: {},
            isMultiLanguageEnabled: false,
          };
        } else {
          // 只更新多语言开关状态，保持现有的语言设置
          adLanguageSettings[adId].isMultiLanguageEnabled = false;
        }

        console.log(`重新解析广告 ${ad.ad_name} 的单语言数据:`, {
          singleLanguageContent: adSingleLanguageContents[adId],
          defaultLanguage: adLanguageSettings[adId].defaultLanguage,
        });

      }
    };

    // 监听Modal打开状态，每次打开时重新初始化数据
    watch(() => props.open, (newOpen) => {
      if (newOpen) {
        console.log('Modal打开，重新初始化数据');
        resetAllData();

        // 重新获取语言列表
        fetchLanguages();

        // 初始化所有选中广告的数据
        if (compatibleAds.value.length > 0) {
          console.log(`开始初始化 ${compatibleAds.value.length} 个广告的数据`);
          compatibleAds.value.forEach(ad => {
            initializeAdData(ad);
          });

          // 延迟设置默认Tab，确保DOM已更新
          nextTick(() => {
            // 由于批量编辑已禁用，默认选中第一个广告
            if (compatibleAds.value.length > 0) {
              selectTab(compatibleAds.value[0].ad_id);
            }
          });
        }
      }
    });

    // 语言管理相关状态
    const defaultLanguage = ref('english');
    const selectedLanguage = ref('english');
    const additionalLanguages = ref<string[]>([]);
    const showLanguageModal = ref(false);
    const selectedLanguagesToAdd = ref<string[]>([]);

    // 多语言内容存储 - 按广告ID组织
    const adLanguageContents = reactive<{ [adId: string]: { [lang: string]: AdLanguageContent } }>(
      {},
    );

    // 广告语言设置 - 每个广告的语言配置
    const adLanguageSettings = reactive<{
      [adId: string]: AdSettings;
    }>({});

    // 多语言开关状态 - 每个广告的多语言开关状态
    const adMultiLanguageEnabled = reactive<{ [adId: string]: boolean }>({});

    // 单语言内容存储 - 按广告ID组织
    const adSingleLanguageContents = reactive<{ [adId: string]: AdLanguageContent }>({});

    // 单语言媒体状态管理
    const singleLanguageMediaStates = reactive<{
      [adId: string]: {
        loading: boolean;
        show: boolean;
        type?: 'image' | 'video';
        url?: string;
        hash?: string;
      };
    }>({});

    // 新增：跟踪用户实际操作过的广告
    const userModifiedAds = reactive<Set<string>>(new Set());

    // 新增：标记广告被用户修改的函数
    const markAdAsModified = (adId: string) => {
      userModifiedAds.add(adId);
      console.log(`标记广告 ${adId} 为已修改状态`);
    };

    // 原有状态保留
    const activeTabKey = ref('');
    const activeLanguageKey = ref('english');
    const batchLanguages = ref<string[]>([]);
    const batchTargetLanguages = ref<string[]>([]);

    // 批量编辑语言管理状态
    const batchActiveLanguageKey = ref('english');
    const batchDefaultLanguage = ref('english');
    const batchAdditionalLanguages = ref<string[]>([]);
    const showBatchLanguageModal = ref(false);
    const selectedBatchLanguagesToAdd = ref<string[]>([]);
    const batchLanguageSettings = reactive<{ [lang: string]: AdLanguageContent }>({
      english: {
        websiteUrl: '',
        headline: '',
        primaryText: '',
        description: '',
      },
    });

    // 批量编辑设置（保留原有的）
    const batchSettings = reactive<BatchSettings>({
      websiteUrl: '',
      headline: '',
      primaryText: '',
      description: '',
    });

    // 当前广告设置
    const currentAdSettings = reactive<AdSettings>({
      defaultLanguage: 'english',
      additionalLanguages: [],
      languageContent: {},
    });

    // 可用语言列表 - 从API获取
    const availableLanguages = ref<LanguageOption[]>([]);
    const languagesLoading = ref(false);

    // 获取语言列表
    const fetchLanguages = async () => {
      try {
        languagesLoading.value = true;
        const response = (await getLanguages()) as any;

        if (response.success && response.data) {
          availableLanguages.value = response.data.map((item: ApiLanguageItem) => ({
            code: item.label_name,
            name: item.english_name,
            nativeName: item.native_name,
            displayName: `${item.english_name} (${item.native_name})`,
            locales: item.locales,
          }));
        }
      } catch (error) {
        console.error('Failed to fetch languages:', error);
        message.error(t('Failed to load languages'));
        // 如果API失败，使用默认语言列表作为备选
        availableLanguages.value = [
          {
            code: 'en_XX',
            name: 'English',
            nativeName: 'English',
            displayName: 'English (English)',
            locales: [],
          },
          {
            code: 'zh_CN',
            name: 'Chinese (Simplified)',
            nativeName: '中文 (简体)',
            displayName: 'Chinese (Simplified) (中文 (简体))',
            locales: [],
          },
          {
            code: 'es_XX',
            name: 'Spanish',
            nativeName: 'Español',
            displayName: 'Spanish (Español)',
            locales: [],
          },
          {
            code: 'fr_XX',
            name: 'French',
            nativeName: 'Français',
            displayName: 'French (Français)',
            locales: [],
          },
          { code: 'de_DE', name: 'German', nativeName: 'Deutsch', displayName: 'German (Deutsch)', locales: [] },
          {
            code: 'ja_JP',
            name: 'Japanese',
            nativeName: '日本語',
            displayName: 'Japanese (日本語)',
            locales: [],
          },
          { code: 'ko_KR', name: 'Korean', nativeName: '한국어', displayName: 'Korean (한국어)', locales: [] },
          { code: 'ar_AR', name: 'Arabic', nativeName: 'العربية', displayName: 'Arabic (العربية)', locales: [] },
          {
            code: 'pt_XX',
            name: 'Portuguese',
            nativeName: 'Português',
            displayName: 'Portuguese (Português)',
            locales: [],
          },
          {
            code: 'ru_RU',
            name: 'Russian',
            nativeName: 'Русский',
            displayName: 'Russian (Русский)',
            locales: [],
          },
        ];
      } finally {
        languagesLoading.value = false;
      }
    };

    // 映射语言标签名称到语言代码（处理特殊情况）
    const mapLanguageLabelToCode = (labelName: string): string => {
      // 处理特殊情况
      if (labelName === 'swedish') {
        const lang = availableLanguages.value.find(l => l.name === 'Swedish');
        return lang ? lang.code : 'sv_SE';
      }
      if (labelName === 'afrikaans') {
        const lang = availableLanguages.value.find(l => l.name === 'Afrikaans');
        return lang ? lang.code : 'af_ZA';
      }

      // 查找匹配的语言
      const lang = availableLanguages.value.find(l => l.code === labelName);
      return lang ? lang.code : labelName;
    };

    // 解析目录广告多语言数据
    const parseCatalogMultiLanguageData = (ad: AdData) => {
      const creative = ad.creative;
      const customizationRulesSpec = creative?.object_story_spec?.template_data?.customization_rules_spec;

      if (!customizationRulesSpec || customizationRulesSpec.length === 0) {
        return null;
      }

      const languageData: Record<string, any> = {};
      const languages: string[] = [];
      let defaultLanguage = 'en_XX';

      // 处理每个语言的自定义规则
      customizationRulesSpec.forEach((spec: any) => {
        const langCode = spec.customization_spec?.language;
        if (langCode) {
          const mappedLangCode = mapLanguageLabelToCode(langCode);

          if (!languages.includes(mappedLangCode)) {
            languages.push(mappedLangCode);
          }

          languageData[mappedLangCode] = {
            websiteUrl: spec.link || '',
            headline: spec.name || '',
            primaryText: spec.message || '',
            description: spec.description || '',
            deepLink: spec.template_url_spec?.web?.url || '',
            mediaType: getCatalogAdType(ad),
          };

          // 设置媒体资源
          const firstProduct = ad.product_set?.products?.[0];
          if (languageData[mappedLangCode].mediaType === 'video' && firstProduct?.video_url) {
            languageData[mappedLangCode].mediaHash = firstProduct.video_url;
          } else if (languageData[mappedLangCode].mediaType === 'image' && firstProduct?.image_url) {
            languageData[mappedLangCode].mediaHash = firstProduct.image_url;
          }
        }
      });

      // 设置默认语言（第一个语言）
      if (languages.length > 0) {
        defaultLanguage = languages[0];
      }

      return {
        languageData,
        languages: languages.slice(1), // 除了默认语言外的其他语言
        defaultLanguage,
      };
    };

    // 解析多语言数据
    const parseMultiLanguageData = (ad: AdData) => {
      const { isCatalog } = checkAdMultiLanguageSupport(ad);

      if (isCatalog) {
        return parseCatalogMultiLanguageData(ad);
      }

      // 普通广告的多语言解析
      const assetFeedSpec = ad?.creative?.asset_feed_spec;
      if (!assetFeedSpec) return null;

      const {
        bodies = [],
        titles = [],
        descriptions = [],
        link_urls: linkUrls = [],
        images = [],
        videos = [],
        asset_customization_rules: customizationRules = [],
      } = assetFeedSpec;

      const languageData: Record<string, any> = {};
      const languages: string[] = [];

      // 确定默认语言
      let defaultLanguage = 'en_XX';
      const defaultRule = customizationRules.find((rule: any) => rule.is_default === true);
      if (defaultRule?.body_label?.name) {
        defaultLanguage = mapLanguageLabelToCode(defaultRule.body_label.name);
      }

      // 🔍 添加调试信息
      console.log('🔍 解析多语言数据 - 基础信息:', {
        adId: ad.ad_id,
        adName: ad.ad_name,
        bodiesCount: bodies.length,
        videosCount: videos.length,
        imagesCount: images.length,
        customizationRulesCount: customizationRules.length,
        defaultLanguage,
      });

      // 处理每种语言的内容 - 保留所有在bodies中存在的语言
      bodies.forEach((body: any) => {
        if (body.adlabels && body.adlabels.length > 0) {
          const labelName = body.adlabels[0].name;
          const langCode = mapLanguageLabelToCode(labelName);

          if (!languages.includes(langCode)) {
            languages.push(langCode);
          }

          if (!languageData[langCode]) {
            languageData[langCode] = {};
          }

          languageData[langCode].primaryText = body.text || '';
        }
      });

      // 处理标题
      titles.forEach((title: any) => {
        if (title.adlabels && title.adlabels.length > 0) {
          const labelName = title.adlabels[0].name;
          const langCode = mapLanguageLabelToCode(labelName);

          if (languageData[langCode]) {
            languageData[langCode].headline = title.text || '';
          }
        }
      });

      // 处理描述
      descriptions.forEach((desc: any) => {
        if (desc.adlabels && desc.adlabels.length > 0) {
          const labelName = desc.adlabels[0].name;
          const langCode = mapLanguageLabelToCode(labelName);

          if (languageData[langCode]) {
            languageData[langCode].description = desc.text || '';
          }
        }
      });

      // 处理链接URL
      linkUrls.forEach((linkUrl: any) => {
        if (linkUrl.adlabels && linkUrl.adlabels.length > 0) {
          const labelName = linkUrl.adlabels[0].name;
          const langCode = mapLanguageLabelToCode(labelName);

          if (languageData[langCode]) {
            languageData[langCode].websiteUrl = linkUrl.website_url || '';
          }
        }
      });

      // 🔧 优化：媒体处理逻辑 - 通过 asset_customization_rules 映射媒体
      customizationRules.forEach((rule: any) => {
        if (rule.body_label?.name) {
          const originalLabelName = rule.body_label.name; // 保存原始标签名称
          const langCode = mapLanguageLabelToCode(originalLabelName);

          // 只处理实际存在的语言
          if (languageData[langCode]) {
            // 处理图片媒体 - 通过image_label找到对应的image对象
            if (rule.image_label?.name) {
              const imageLabel = rule.image_label.name;
              const matchedImage = images.find((img: any) =>
                img.adlabels?.some((label: any) => label.name === imageLabel),
              );

              if (matchedImage) {
                languageData[langCode].mediaType = 'image';

                // 🔧 修复：使用原始标签名称进行比较，而不是映射后的语言代码
                if (originalLabelName === imageLabel) {
                  // 这个语言拥有自己的媒体
                  languageData[langCode].mediaHash = matchedImage.hash || '';
                  console.log(`🔍 语言 ${langCode} (${originalLabelName}) 拥有自己的图片媒体:`, matchedImage.hash);
                } else {
                  // 这个语言共享其他语言的媒体，不设置mediaHash
                  languageData[langCode].sharedImageLabel = imageLabel;
                  languageData[langCode].sharedImageHash = matchedImage.hash || '';
                  console.log(`🔍 语言 ${langCode} (${originalLabelName}) 共享语言 ${imageLabel} 的图片媒体:`, matchedImage.hash);
                }
              } else {
                console.log(`⚠️ 语言 ${langCode} (${originalLabelName}) 的图片标签 ${imageLabel} 未找到对应的image对象`);
              }
            }

            // 处理视频媒体 - 通过video_label找到对应的video对象
            if (rule.video_label?.name) {
              const videoLabel = rule.video_label.name;
              const matchedVideo = videos.find((video: any) =>
                video.adlabels?.some((label: any) => label.name === videoLabel),
              );

              if (matchedVideo) {
                languageData[langCode].mediaType = 'video';

                // 🔧 修复：使用原始标签名称进行比较，而不是映射后的语言代码
                if (originalLabelName === videoLabel) {
                  // 这个语言拥有自己的媒体
                  languageData[langCode].mediaHash = matchedVideo.video_id || '';
                  languageData[langCode].mediaId = matchedVideo.video_id || '';

                  // 添加视频缩略图URL处理
                  if (matchedVideo.thumbnail_url) {
                    languageData[langCode].thumbnailUrl = matchedVideo.thumbnail_url;
                    languageData[langCode].thumbnailType = 'system';

                    // 尝试从URL中提取ID（用于比较）
                    const urlMatch = matchedVideo.thumbnail_url.match(/\/(\d+)_/);
                    if (urlMatch && urlMatch[1]) {
                      languageData[langCode].thumbnailId = urlMatch[1];
                    }
                  }

                  console.log(`🔍 语言 ${langCode} (${originalLabelName}) 拥有自己的视频媒体:`, {
                    videoId: matchedVideo.video_id,
                    thumbnailUrl: matchedVideo.thumbnail_url || 'none'
                  });
                } else {
                  // 这个语言共享其他语言的媒体，不设置mediaHash
                  languageData[langCode].sharedVideoLabel = videoLabel;
                  languageData[langCode].sharedVideoId = matchedVideo.video_id || '';

                  // 共享媒体也需要缩略图信息用于显示
                  if (matchedVideo.thumbnail_url) {
                    languageData[langCode].thumbnailUrl = matchedVideo.thumbnail_url;
                    languageData[langCode].thumbnailType = 'system';
                  }

                  console.log(`🔍 语言 ${langCode} (${originalLabelName}) 共享语言 ${videoLabel} 的视频媒体:`, {
                    sharedVideoId: matchedVideo.video_id,
                    thumbnailUrl: matchedVideo.thumbnail_url || 'none'
                  });
                }
              } else {
                console.log(`⚠️ 语言 ${langCode} (${originalLabelName}) 的视频标签 ${videoLabel} 未找到对应的video对象`);
              }
            }
          }
        }
      });

      // 🔍 添加最终结果调试信息
      console.log('🔍 parseMultiLanguageData 最终结果:', {
        adId: ad.ad_id,
        defaultLanguage,
        allLanguages: languages,
        filteredLanguages: languages.filter(lang => lang !== defaultLanguage),
        mediaOwnership: Object.keys(languageData).map(lang => ({
          language: lang,
          hasText: !!languageData[lang].primaryText,
          ownsMedia: !!languageData[lang].mediaHash, // 只有拥有自己媒体的语言才有mediaHash
          mediaType: languageData[lang].mediaType,
          mediaHash: languageData[lang].mediaHash || 'shared',
          sharedFrom: languageData[lang].sharedVideoLabel || languageData[lang].sharedImageLabel || null,
          hasThumbnail: !!languageData[lang].thumbnailUrl
        }))
      });

      return {
        defaultLanguage,
        languages: languages.filter(lang => lang !== defaultLanguage),
        languageData,
      };
    };

    // 加载广告媒体
    const loadAdMedia = async (hash: string, langCode: string, adId: string) => {
      if (!hash) return;

      // 从传入的广告列表中获取 ad_account_id
      const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === adId);
      if (!currentAd || !currentAd.ad_account_id) {
        console.error('无法获取广告的 ad_account_id');
        return;
      }

      // 获取媒体类型
      const content = adLanguageContents[adId]?.[langCode];
      const mediaType = content?.mediaType || 'image';

      // 对于视频类型，获取actor_id作为page参数
      let pageParam: string | undefined;
      if (mediaType === 'video' && currentAd.creative?.actor_id) {
        pageParam = currentAd.creative.actor_id;
      }

      try {
        const response = (await getAdsMedia(
          hash,
          currentAd.ad_account_id,
          mediaType,
          pageParam,
        )) as any;
        if (response.success && response.data && response.data.url) {
          // 更新对应语言的媒体URL
          if (adLanguageContents[adId] && adLanguageContents[adId][langCode]) {
            if (mediaType === 'image') {
              adLanguageContents[adId][langCode].imageUrl = response.data.url;
            } else if (mediaType === 'video') {
              adLanguageContents[adId][langCode].videoUrl = response.data.url;
            }
          }
        }
      } catch (error) {
        console.error('Failed to load media:', error);
        // 移除这里的消息提示，避免重复
        throw error; // 重新抛出错误，让handleLoadMedia处理
      }
    };

    // 在组件挂载时获取语言列表
    onMounted(() => {
      fetchLanguages();
    });

    // 计算可以添加的语言列表
    const availableLanguagesToAdd = computed(() => {
      const usedLanguages = [defaultLanguage.value, ...additionalLanguages.value];
      return availableLanguages.value.filter(lang => !usedLanguages.includes(lang.code));
    });

    // Tab选择方法
    const selectTab = (tabKey: string) => {
      // 禁用批量编辑功能
      if (tabKey === 'batch') {
        return;
      }

      activeTabKey.value = tabKey;

      if (tabKey !== 'batch') {
        // 获取当前广告
        const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === tabKey);
        if (!currentAd) return;

        // 初始化广告数据（如果尚未初始化）
        if (!adMultiLanguageEnabled.hasOwnProperty(tabKey)) {
          initializeAdData(currentAd);
        }

        // 根据多语言开关状态设置活跃语言
        if (adMultiLanguageEnabled[tabKey]) {
          // 多语言模式
          const defaultLang = adLanguageSettings[tabKey]?.defaultLanguage || 'en_XX';
          activeLanguageKey.value = defaultLang;
        } else {
          // 单语言模式，不需要设置activeLanguageKey
        }

        console.log(`已切换到广告 ${currentAd.ad_name}`, {
          adId: tabKey,
          multiLanguageEnabled: adMultiLanguageEnabled[tabKey],
          singleLanguageContent: adSingleLanguageContents[tabKey],
          multiLanguageContent: adLanguageContents[tabKey],
        });

      }
    };

    // 广告相关方法
    const getAdDisplayName = (ad: AdData, index: number) => {
      const { adType } = checkAdMultiLanguageSupport(ad);
      const typeText = adType === 'video' ? t('Video') : t('Image');
      return `${typeText} ${index + 1}`;
    };

    const getCurrentAdName = () => {
      const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === activeTabKey.value);
      return currentAd ? currentAd.ad_name : '';
    };

    const getCurrentAdTypeColor = () => {
      const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === activeTabKey.value);
      return currentAd ? getAdTypeColor(currentAd) : '';
    };

    const getCurrentAdTypeText = () => {
      const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === activeTabKey.value);
      return currentAd ? getAdTypeText(currentAd) : '';
    };

    const getCurrentAdDisplayTitle = () => {
      const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === activeTabKey.value);
      if (!currentAd) return '';

      // 只返回广告名称
      return currentAd.ad_name;
    };

    // 当前广告的语言管理
    const getCurrentAdAdditionalLanguages = () => {
      if (activeTabKey.value === 'batch') return [];
      return adLanguageSettings[activeTabKey.value]?.additionalLanguages || [];
    };

    const addLanguageToCurrentAd = () => {
      if (activeTabKey.value === 'batch') return;

      const currentSettings = adLanguageSettings[activeTabKey.value];
      if (!currentSettings) return;

      // 获取默认语言的内容作为模板
      const defaultLanguageContent = adLanguageContents[activeTabKey.value]?.[currentSettings.defaultLanguage];
      const hasDefaultContent = defaultLanguageContent && (
        defaultLanguageContent.websiteUrl ||
        defaultLanguageContent.headline ||
        defaultLanguageContent.primaryText ||
        defaultLanguageContent.description ||
        defaultLanguageContent.mediaHash ||
        defaultLanguageContent.imageUrl ||
        defaultLanguageContent.videoUrl
      );

      const addedLanguages: string[] = [];

      selectedLanguagesToAdd.value.forEach(langCode => {
        if (currentSettings && !currentSettings.additionalLanguages.includes(langCode)) {
          currentSettings.additionalLanguages.push(langCode);
          addedLanguages.push(langCode);

          // 初始化该语言的内容
          if (!adLanguageContents[activeTabKey.value][langCode]) {
            if (hasDefaultContent) {
              // 如果默认语言有内容，复制默认语言的内容（包括媒体信息）
              adLanguageContents[activeTabKey.value][langCode] = {
                websiteUrl: defaultLanguageContent.websiteUrl || '',
                headline: defaultLanguageContent.headline || '',
                primaryText: defaultLanguageContent.primaryText || '',
                description: defaultLanguageContent.description || '',
                // 复制媒体信息
                mediaType: defaultLanguageContent.mediaType,
                imageUrl: defaultLanguageContent.imageUrl || '',
                videoUrl: defaultLanguageContent.videoUrl || '',
                mediaName: defaultLanguageContent.mediaName || '',
                mediaId: defaultLanguageContent.mediaId || '',
                mediaHash: defaultLanguageContent.mediaHash || '',
              };

              // 输出提示信息
              console.log(`已将默认语言 (${getLanguageName(currentSettings.defaultLanguage)}) 的内容复制到 ${getLanguageName(langCode)}`);
            } else {
              // 如果默认语言没有内容，初始化为空
              adLanguageContents[activeTabKey.value][langCode] = {
                websiteUrl: '',
                headline: '',
                primaryText: '',
                description: '',
              };
            }
          }
        }
      });

      // 如果添加了语言，标记为用户修改
      if (addedLanguages.length > 0) {
        markAdAsModified(activeTabKey.value);
      }

      selectedLanguagesToAdd.value = [];
      showLanguageModal.value = false;

      // 如果有复制内容，显示提示消息
      if (hasDefaultContent && addedLanguages.length > 0) {
        message.success(t('Default language content has been copied to new language'));
      }
    };

    const removeLanguageFromCurrentAd = (langCode: string) => {
      if (activeTabKey.value === 'batch') return;

      const currentSettings = adLanguageSettings[activeTabKey.value];
      if (currentSettings) {
        const index = currentSettings.additionalLanguages.indexOf(langCode);
        if (index > -1) {
          currentSettings.additionalLanguages.splice(index, 1);

          // 标记为用户修改
          markAdAsModified(activeTabKey.value);

          // 删除该语言的内容
          if (
            adLanguageContents[activeTabKey.value] &&
            adLanguageContents[activeTabKey.value][langCode]
          ) {
            delete adLanguageContents[activeTabKey.value][langCode];
          }

          // 如果删除的是当前选中的语言，切换到默认语言
          if (activeLanguageKey.value === langCode) {
            activeLanguageKey.value = currentSettings.defaultLanguage;
          }

          // 强制更新界面显示
          nextTick(() => {
            // 确保界面状态正确更新
            console.log('Language removed, current active language:', activeLanguageKey.value);
            console.log('Current default language:', currentSettings.defaultLanguage);
          });
        }
      }
    };

    const getAvailableLanguagesForCurrentAd = () => {
      if (activeTabKey.value === 'batch') return availableLanguages.value;

      const currentSettings = adLanguageSettings[activeTabKey.value];
      if (!currentSettings) return availableLanguages.value;

      const usedLanguages = [
        currentSettings.defaultLanguage,
        ...currentSettings.additionalLanguages,
      ];
      return availableLanguages.value.filter(lang => !usedLanguages.includes(lang.code));
    };

    // 当前语言内容管理
    const getCurrentLanguageContent = (field: keyof AdLanguageContent): string => {
      if (activeTabKey.value === 'batch') return '';

      const adContents = adLanguageContents[activeTabKey.value];
      if (!adContents || !adContents[activeLanguageKey.value]) {
        return '';
      }

      const value = adContents[activeLanguageKey.value][field];
      // 确保返回字符串类型
      return typeof value === 'string' ? value : '';
    };

    const updateCurrentLanguageContent = (
      field: keyof AdLanguageContent,
      value: string | boolean | 'image' | 'video',
    ) => {
      if (activeTabKey.value === 'batch') return;

      if (!adLanguageContents[activeTabKey.value]) {
        adLanguageContents[activeTabKey.value] = {};
      }

      if (!adLanguageContents[activeTabKey.value][activeLanguageKey.value]) {
        adLanguageContents[activeTabKey.value][activeLanguageKey.value] = {};
      }

      (adLanguageContents[activeTabKey.value][activeLanguageKey.value] as any)[field] = value;

      // 标记为用户修改
      markAdAsModified(activeTabKey.value);
    };

    // 媒体内容相关方法
    const getCurrentMediaType = (): 'image' | 'video' => {
      const content = getCurrentLanguageContent('mediaType');
      if (content === 'image' || content === 'video') {
        return content;
      }

      // 如果没有设置，根据广告类型推断
      const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === activeTabKey.value);
      if (currentAd) {
        const { adType } = checkAdMultiLanguageSupport(currentAd);
        return adType === 'video' ? 'video' : 'image';
      }

      return 'image';
    };

    const getCurrentMediaUrl = () => {
      const mediaType = getCurrentMediaType();
      if (mediaType === 'video') {
        return getCurrentLanguageContent('videoUrl') || '';
      } else {
        return getCurrentLanguageContent('imageUrl') || '';
      }
    };

    // 存储每个广告的自定义页面信息
    const adCustomPages = ref<Record<string, { id: string; name: string }>>({});

    // 更新媒体内容
    const updateCurrentMediaContent = (type: 'image' | 'video', url: string) => {
      if (activeTabKey.value === 'batch') return;

      updateCurrentLanguageContent('mediaType', type);
      if (type === 'image') {
        updateCurrentLanguageContent('imageUrl', url);
      } else {
        updateCurrentLanguageContent('videoUrl', url);
      }
    };

    // 预览相关方法
    const getCurrentBrandName = () => {
      // 批量编辑模式下直接使用 Brand Name
      if (activeTabKey.value === 'batch') {
        return 'Brand Name';
      }

      // 单个广告模式下，动态获取页面名称
      const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === activeTabKey.value);

      if (!currentAd) {
        console.log('getCurrentBrandName: No current ad found, using fallback');
        return 'Brand Name'; // fallback
      }

            // 检查是否有自定义页面
      const customPage = adCustomPages.value[activeTabKey.value];
      if (customPage) {
        console.log('getCurrentBrandName: Using custom page:', customPage.name);
        return customPage.name;
      }

      // 使用原始的page_id
      const originalPageId = currentAd.creative?.object_story_spec?.page_id;
      if (!originalPageId) {
        console.log('getCurrentBrandName: No page_id found, using fallback');
        return 'Brand Name'; // fallback
      }

      console.log('getCurrentBrandName: Found original page_id:', originalPageId);

      // 在 pages 数组中查找对应的页面
      if ((currentAd as any).pages && Array.isArray((currentAd as any).pages)) {
        console.log('getCurrentBrandName: Available pages:', (currentAd as any).pages);
        const matchedPage = (currentAd as any).pages.find((page: any) => page.source_id === originalPageId);
        if (matchedPage && matchedPage.name) {
          console.log('getCurrentBrandName: Found matched page with name:', matchedPage.name);
          return matchedPage.name;
        } else {
          console.log('getCurrentBrandName: No matched page found for page_id:', originalPageId);
        }
      } else {
        console.log('getCurrentBrandName: No pages array found or pages is not an array');
      }

      console.log('getCurrentBrandName: Using fallback Brand Name');
      return 'Brand Name'; // fallback
    };

    const getCurrentAdType = () => {
      // 如果是单个广告模式，获取当前广告的类型
      if (activeTabKey.value !== 'batch') {
        const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === activeTabKey.value);
        if (currentAd) {
          const { adType } = checkAdMultiLanguageSupport(currentAd);
          return adType === 'video' ? 'Video Ad' : 'Image Ad';
        }
      }

      // 批量模式下，返回第一个广告的类型
      if (compatibleAds.value.length === 0) return 'Advertisement';
      const { adType } = checkAdMultiLanguageSupport(compatibleAds.value[0]);
      return adType === 'video' ? 'Video Ad' : 'Image Ad';
    };

    // 获取当前上下文的媒体类型（用于媒体预览）
    const getCurrentContextMediaType = (langCode?: string, adId?: string): 'image' | 'video' => {
      // 如果是单个广告模式，尝试从语言内容中获取媒体类型
      if (activeTabKey.value !== 'batch' && langCode && adId) {
        const content = adLanguageContents[adId]?.[langCode];
        if (content && content.mediaType) {
          return content.mediaType;
        }
      }

      // 如果没有具体的媒体类型信息，从广告类型推断
      if (activeTabKey.value !== 'batch') {
        const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === activeTabKey.value);
        if (currentAd) {
          const { adType } = checkAdMultiLanguageSupport(currentAd);
          return adType === 'video' ? 'video' : 'image';
        }
      }

      // 批量模式下，从第一个广告类型推断
      if (compatibleAds.value.length > 0) {
        const { adType } = checkAdMultiLanguageSupport(compatibleAds.value[0]);
        return adType === 'video' ? 'video' : 'image';
      }

      return 'image'; // 默认值
    };

    // 已在上面定义了预览相关函数

    const getPreviewMediaUrl = () => {
      return getCurrentMediaUrl() || '';
    };

    const getPreviewMediaType = () => {
      return getCurrentMediaType();
    };

    // 批量预览相关方法
    const getBatchPreviewHeadline = () => {
      return batchSettings.headline || t('Enter headline for selected languages');
    };

    const getBatchPreviewPrimaryText = () => {
      return batchSettings.primaryText || t('Enter primary text for selected languages');
    };

    const getBatchPreviewDescription = () => {
      return batchSettings.description || t('Enter description for selected languages');
    };

    const getBatchPreviewWebsiteUrl = () => {
      return batchSettings.websiteUrl || 'website.com';
    };

    // 批量编辑当前语言预览方法
    const getBatchCurrentLanguagePreview = (field: keyof AdLanguageContent) => {
      const content = batchLanguageSettings[batchActiveLanguageKey.value];
      if (!content || !content[field]) {
        return (
          t('Enter') +
          ' ' +
          field +
          ' ' +
          t('for') +
          ' ' +
          getLanguageName(batchActiveLanguageKey.value)
        );
      }
      return content[field] || '';
    };

    // 移除批量编辑语言
    const removeBatchLanguage = (langCode: string) => {
      const index = batchAdditionalLanguages.value.indexOf(langCode);
      if (index > -1) {
        batchAdditionalLanguages.value.splice(index, 1);

        // 删除该语言的设置
        if (batchLanguageSettings[langCode]) {
          delete batchLanguageSettings[langCode];
        }

        // 如果删除的是当前选中的语言，切换到默认语言
        if (batchActiveLanguageKey.value === langCode) {
          batchActiveLanguageKey.value = batchDefaultLanguage.value;
        }
      }
    };

    // 添加批量编辑语言
    const addBatchLanguage = () => {
      // 获取默认语言的内容作为模板
      const defaultLanguageContent = batchLanguageSettings[batchDefaultLanguage.value];
      const hasDefaultContent = defaultLanguageContent && (
        defaultLanguageContent.websiteUrl ||
        defaultLanguageContent.headline ||
        defaultLanguageContent.primaryText ||
        defaultLanguageContent.description
      );

      const addedLanguages: string[] = [];

      selectedBatchLanguagesToAdd.value.forEach(langCode => {
        if (
          !batchAdditionalLanguages.value.includes(langCode) &&
          langCode !== batchDefaultLanguage.value
        ) {
          batchAdditionalLanguages.value.push(langCode);
          addedLanguages.push(langCode);

          // 初始化该语言的内容
          if (!batchLanguageSettings[langCode]) {
            if (hasDefaultContent) {
              // 如果默认语言有内容，复制默认语言的内容
              batchLanguageSettings[langCode] = {
                websiteUrl: defaultLanguageContent.websiteUrl || '',
                headline: defaultLanguageContent.headline || '',
                primaryText: defaultLanguageContent.primaryText || '',
                description: defaultLanguageContent.description || '',
              };

              // 输出提示信息
              console.log(`已将默认语言 (${getLanguageName(batchDefaultLanguage.value)}) 的内容复制到 ${getLanguageName(langCode)}`);
            } else {
              // 如果默认语言没有内容，初始化为空
              batchLanguageSettings[langCode] = {
                websiteUrl: '',
                headline: '',
                primaryText: '',
                description: '',
              };
            }
          }
        }
      });

      selectedBatchLanguagesToAdd.value = [];
      showBatchLanguageModal.value = false;

      // 如果有复制内容，显示提示消息
      if (hasDefaultContent && addedLanguages.length > 0) {
        message.success(t('Default language content has been copied to new languages'));
      }
    };

    // 更新批量编辑语言内容
    const updateBatchLanguageContent = (field: keyof AdLanguageContent, value: string) => {
      if (!batchLanguageSettings[batchActiveLanguageKey.value]) {
        batchLanguageSettings[batchActiveLanguageKey.value] = {
          websiteUrl: '',
          headline: '',
          primaryText: '',
          description: '',
        };
      }

      (batchLanguageSettings[batchActiveLanguageKey.value] as any)[field] = value;
    };

    // 批量编辑默认语言变更
    const handleBatchDefaultLanguageChange = (newLanguage: string) => {
      const oldLanguage = batchDefaultLanguage.value;

      // 保存旧语言的数据
      const oldData = batchLanguageSettings[oldLanguage];

      // 更新默认语言
      batchDefaultLanguage.value = newLanguage;
      batchActiveLanguageKey.value = newLanguage;

      // 迁移数据到新的默认语言
      if (oldData && !batchLanguageSettings[newLanguage]) {
        batchLanguageSettings[newLanguage] = { ...oldData };
      }

      // 如果新默认语言在附加语言中，将其移除
      const index = batchAdditionalLanguages.value.indexOf(newLanguage);
      if (index > -1) {
        batchAdditionalLanguages.value.splice(index, 1);
      }

      // 将旧的默认语言添加到附加语言（如果不是同一个语言）
      if (oldLanguage !== newLanguage && !batchAdditionalLanguages.value.includes(oldLanguage)) {
        batchAdditionalLanguages.value.push(oldLanguage);
      }
    };

    // 获取当前广告的默认语言
    const getCurrentAdDefaultLanguage = () => {
      if (activeTabKey.value === 'batch') return 'english';
      return adLanguageSettings[activeTabKey.value]?.defaultLanguage || 'english';
    };

    // 当前广告默认语言变更
    const handleCurrentAdDefaultLanguageChange = (newLanguage: string) => {
      if (activeTabKey.value === 'batch') return;

      const currentSettings = adLanguageSettings[activeTabKey.value];
      if (!currentSettings) return;

      const oldLanguage = currentSettings.defaultLanguage;

      // 保存旧语言的数据
      const oldData = adLanguageContents[activeTabKey.value]?.[oldLanguage];

      // 更新默认语言
      currentSettings.defaultLanguage = newLanguage;
      activeLanguageKey.value = newLanguage;

      // 标记为用户修改
      markAdAsModified(activeTabKey.value);

      // 迁移数据到新的默认语言
      if (oldData && !adLanguageContents[activeTabKey.value]?.[newLanguage]) {
        if (!adLanguageContents[activeTabKey.value]) {
          adLanguageContents[activeTabKey.value] = {};
        }
        adLanguageContents[activeTabKey.value][newLanguage] = { ...oldData };
      }

      // 如果新默认语言在附加语言中，将其移除
      const index = currentSettings.additionalLanguages.indexOf(newLanguage);
      if (index > -1) {
        currentSettings.additionalLanguages.splice(index, 1);
      }

      // 将旧的默认语言添加到附加语言（如果不是同一个语言）
      if (
        oldLanguage !== newLanguage &&
        !currentSettings.additionalLanguages.includes(oldLanguage)
      ) {
        currentSettings.additionalLanguages.push(oldLanguage);
      }
    };

    // 检查是否是目录广告
    const isCatalogAd = (ad: AdData) => {
      return !!(ad.product_set && Object.keys(ad.product_set).length > 0);
    };

    // 检查目录广告是否有多语言配置
    const hasCatalogMultiLanguage = (ad: AdData) => {
      const creative = ad.creative;
      if (!creative?.object_story_spec?.template_data) return false;
      return !!(creative.object_story_spec.template_data.customization_rules_spec &&
        creative.object_story_spec.template_data.customization_rules_spec.length > 0);
    };

    // 获取目录广告类型（基于product的video_url）
    const getCatalogAdType = (ad: AdData) => {
      const firstProduct = ad.product_set?.products?.[0];
      return firstProduct?.video_url ? 'video' : 'image';
    };

    // 目录广告占位符处理
    const catalogPlaceholders = [
      { key: '{{product.name}}', label: 'Product Name', value: (ad: AdData) => ad.product_set?.products?.[0]?.name || '' },
      { key: '{{product.description}}', label: 'Product Description', value: (ad: AdData) => ad.product_set?.products?.[0]?.description || '' },
      { key: '{{product.url}}', label: 'Product URL', value: (ad: AdData) => ad.product_set?.products?.[0]?.url || '' },
      { key: '{{product.brand}}', label: 'Product Brand', value: (ad: AdData) => ad.product_set?.products?.[0]?.brand || '' },
    ];

    // 替换占位符
    const replacePlaceholders = (text: string, ad: AdData) => {
      if (!text || !isCatalogAd(ad)) return text;

      let result = text;
      catalogPlaceholders.forEach(placeholder => {
        const value = placeholder.value(ad);
        result = result.replace(new RegExp(placeholder.key.replace(/[{}]/g, '\\$&'), 'g'), value);
      });
      return result;
    };

    // 检查广告多语言支持的函数（从主组件复制）
    const checkAdMultiLanguageSupport = (ad: AdData) => {
      const creative = ad.creative;
      if (!creative || !creative.object_story_spec) {
        return {
          supportsMultiLanguage: false,
          hasAssetFeedSpec: false,
          adType: null,
          isCatalog: false,
        };
      }

      const isCatalog = isCatalogAd(ad);
      let hasAssetFeedSpec = false;
      let adType = null;

      if (isCatalog) {
        // 目录广告
        hasAssetFeedSpec = hasCatalogMultiLanguage(ad);
        adType = getCatalogAdType(ad);
      } else {
        // 普通广告
        hasAssetFeedSpec = !!creative.asset_feed_spec;

        if (hasAssetFeedSpec) {
          const adFormats = creative.asset_feed_spec.ad_formats;
          if (adFormats && Array.isArray(adFormats)) {
            if (adFormats.includes('SINGLE_VIDEO')) {
              adType = 'video';
            } else if (adFormats.includes('SINGLE_IMAGE')) {
              adType = 'image';
            }
          }
        } else {
          if (creative.object_story_spec.video_data) {
            adType = 'video';
          } else {
            adType = 'image';
          }
        }
      }

      return {
        supportsMultiLanguage: true,
        hasAssetFeedSpec,
        adType,
        isCatalog,
      };
    };

    // 获取兼容的广告（支持多语言的）
    const compatibleAds = computed(() => {
      return props.selectedAds.filter((ad: AdData) => {
        const { supportsMultiLanguage } = checkAdMultiLanguageSupport(ad);
        return supportsMultiLanguage;
      });
    });

    // 检查是否有不兼容的类型
    const incompatibleTypes = computed(() => {
      if (compatibleAds.value.length === 0) return false;

      const types = new Set();
      compatibleAds.value.forEach((ad: AdData) => {
        const { adType } = checkAdMultiLanguageSupport(ad);
        types.add(adType);
      });

      return types.size > 1;
    });

    // 错误描述
    const errorDescription = computed(() => {
      const videoCount = compatibleAds.value.filter((ad: AdData) => {
        const { adType } = checkAdMultiLanguageSupport(ad);
        return adType === 'video';
      }).length;

      const imageCount = compatibleAds.value.filter((ad: AdData) => {
        const { adType } = checkAdMultiLanguageSupport(ad);
        return adType === 'image';
      }).length;

      return (
        t('Selected ads contain') +
        ` ${videoCount} ` +
        t('video ads and') +
        ` ${imageCount} ` +
        t('image ads') +
        '. ' +
        t('Please select ads of the same type.')
      );
    });

    // 获取广告类型文本
    const adTypeText = computed(() => {
      if (compatibleAds.value.length === 0) return '';
      const { adType } = checkAdMultiLanguageSupport(compatibleAds.value[0]);
      return adType === 'video' ? t('Video Ads') : t('Image Ads');
    });

    // 获取广告类型颜色
    const getAdTypeColor = (ad: AdData) => {
      const { adType, isCatalog } = checkAdMultiLanguageSupport(ad);
      if (isCatalog) {
        return adType === 'video' ? 'purple' : 'orange';
      }
      return adType === 'video' ? 'blue' : 'green';
    };

    // 获取广告类型文本
    const getAdTypeText = (ad: AdData) => {
      const { adType, isCatalog } = checkAdMultiLanguageSupport(ad);
      const baseType = adType === 'video' ? t('Video') : t('Image');
      return isCatalog ? t('Catalog') + ' ' + baseType : baseType;
    };

    // 当前活动广告是否为目录广告
    const isCurrentAdCatalog = computed(() => {
      if (activeTabKey.value === 'batch') {
        return compatibleAds.value.some(ad => {
          const { isCatalog } = checkAdMultiLanguageSupport(ad);
          return isCatalog;
        });
      }
      const currentAd = compatibleAds.value.find(ad => ad.ad_id === activeTabKey.value);
      if (!currentAd) return false;
      const { isCatalog } = checkAdMultiLanguageSupport(currentAd);
      return isCatalog;
    });

    // 获取当前广告的product_set信息
    const getCurrentProductSet = computed(() => {
      if (activeTabKey.value === 'batch') return null;
      const currentAd = compatibleAds.value.find(ad => ad.ad_id === activeTabKey.value);
      return currentAd?.product_set || null;
    });

    // 插入占位符
    const insertPlaceholder = (field: string, placeholder: string) => {
      if (adMultiLanguageEnabled[activeTabKey.value]) {
        // 多语言模式
        const currentValue = getCurrentLanguageContent(field as keyof AdLanguageContent) as string || '';
        const newValue = currentValue + placeholder;
        updateCurrentLanguageContent(field as keyof AdLanguageContent, newValue);
      } else {
        // 单语言模式
        const currentValue = adSingleLanguageContents[activeTabKey.value]?.[field as keyof AdLanguageContent] as string || '';
        const newValue = currentValue + placeholder;
        if (!adSingleLanguageContents[activeTabKey.value]) {
          adSingleLanguageContents[activeTabKey.value] = {};
        }
        (adSingleLanguageContents[activeTabKey.value] as any)[field] = newValue;
        markAdAsModified(activeTabKey.value);
      }
    };

    // 处理Product Set编辑
    const handleProductSetEdit = () => {
      message.info(t('Product Set editing - Coming Soon'));
      // TODO: 实现Product Set编辑功能
    };

    // 构建目录广告的自定义规则
    const buildCatalogCustomizationRules = (_ad: AdData, adSettings: any, adContents: any) => {
      const allLanguages = [adSettings.defaultLanguage, ...adSettings.additionalLanguages];

      return allLanguages.map((lang, index) => {
        const content = adContents[lang] || {};
        const rule: any = {
          customization_spec: {
            language: lang
          }
        };

        // 添加各种字段
        if (content.websiteUrl) {
          rule.link = content.websiteUrl;
        }
        if (content.headline) {
          rule.name = content.headline;
        }
        if (content.primaryText) {
          rule.message = content.primaryText;
        }
        if (content.description) {
          rule.description = content.description;
        }
        if (content.deepLink) {
          rule.template_url_spec = {
            web: {
              url: content.deepLink
            }
          };
        }

        // 第一个语言需要添加customization_spec.locales
        if (index === 0) {
          const language = availableLanguages.value.find(l => l.code === lang);
          if (language && language.locales && language.locales.length > 0) {
            rule.customization_spec.locales = [language.locales[0]];
          }
        }

        return rule;
      });
    };

        // 获取预览文字（带占位符替换）
    const getPreviewText = (field: keyof AdLanguageContent, language?: string): string => {
      const currentAd = activeTabKey.value === 'batch'
        ? compatibleAds.value[0]
        : compatibleAds.value.find(ad => ad.ad_id === activeTabKey.value);

      if (!currentAd) return '';

      const { isCatalog } = checkAdMultiLanguageSupport(currentAd);
      let text = '';

      if (adMultiLanguageEnabled[activeTabKey.value]) {
        // 多语言模式
        text = getCurrentLanguageContent(field) as string || '';
      } else {
        // 单语言模式
        text = adSingleLanguageContents[activeTabKey.value]?.[field] as string || '';
      }

      // 如果是目录广告，替换占位符
      if (isCatalog && text) {
        return replacePlaceholders(text, currentAd);
      }

      return text;
    };

    // 预览相关函数
    const getPreviewPrimaryText = (language?: string) => getPreviewText('primaryText', language) || t('Enter primary text');
    const getPreviewHeadline = (language?: string) => getPreviewText('headline', language) || t('Enter headline');
    const getPreviewDescription = (language?: string) => getPreviewText('description', language) || t('Enter description');
    const getPreviewWebsiteUrl = (language?: string) => getPreviewText('websiteUrl', language) || t('Enter website URL');
    const getPreviewDeepLink = (language?: string) => getPreviewText('deepLink', language) || t('Enter deep link URL');

    // 检查是否已配置多语言
    const hasMultiLanguageConfig = (ad: AdData) => {
      const { hasAssetFeedSpec } = checkAdMultiLanguageSupport(ad);
      return hasAssetFeedSpec;
    };

    // 获取所有选中的语言
    const getAllSelectedLanguages = () => {
      const languages = [currentAdSettings.defaultLanguage];
      return [...new Set([...languages, ...currentAdSettings.additionalLanguages])];
    };

    // 获取语言名称
    const getLanguageName = (code: string) => {
      const lang = availableLanguages.value.find(l => l.code === code);
      return lang ? lang.name : code;
    };

    // 获取语言本地名称（用于hover提示）
    const getLanguageNativeName = (code: string) => {
      const lang = availableLanguages.value.find(l => l.code === code);
      return lang ? lang.nativeName : code;
    };

    // 获取广告Tab标题
    const getAdTabTitle = (ad: AdData, index: number) => {
      const { adType } = checkAdMultiLanguageSupport(ad);
      const typeText = adType === 'video' ? t('Video') : t('Image');
      return `${typeText} ${index + 1}`;
    };

    // 获取视频广告数量
    const getVideoAdsCount = () => {
      return compatibleAds.value.filter((ad: AdData) => {
        const { adType } = checkAdMultiLanguageSupport(ad);
        return adType === 'video';
      }).length;
    };

    // 获取图片广告数量
    const getImageAdsCount = () => {
      return compatibleAds.value.filter((ad: AdData) => {
        const { adType } = checkAdMultiLanguageSupport(ad);
        return adType === 'image';
      }).length;
    };

    // 处理取消
    const handleCancel = () => {
      console.log('Modal关闭，清理数据状态');
      // 关闭Modal时不需要清理状态，因为下次打开时会重新初始化
      emit('cancel');
    };

    // 处理确定
    const handleOk = async () => {
      // 如果当前在批量编辑模式且检测到混合类型，提示用户
      if (activeTabKey.value === 'batch' && incompatibleTypes.value) {
        message.warning(t('Cannot batch edit mixed ad types. Please edit ads individually.'));
        return;
      }

      try {
        // 验证必填字段
        const validationResult = validateRequiredFields();
        if (!validationResult.isValid) {
          message.error(validationResult.message);
          return;
        }

        // 构建更新广告的参数
        const updateParams = buildUpdateAdParams();

        // 检查是否有广告需要更新
        if (updateParams.length === 0) {
          message.info(t('No modifications detected'));
          // 没有修改时直接关闭modal
          emit('ok');
          return;
        }

        // 提示用户将要保存多少个广告
        if (activeTabKey.value !== 'batch' && updateParams.length > 1) {
          message.info(`${t('Detected modifications in')} ${updateParams.length} ${t('ads have been modified and will be saved')}`);
        }

        // 输出构建的参数用于调试
        // console.log('构建的更新广告参数:', JSON.stringify(updateParams, null, 2));

        // 调用更新广告接口
        console.log('Saving multi-language settings...');

        // 导入API函数
        const { updateFbAds } = await import('@/api/ads');

        // 调用接口
        const response = await updateFbAds(updateParams);
        console.log('更新广告响应:', response);

        if (activeTabKey.value === 'batch') {
          console.log('Batch settings:', batchLanguageSettings);
          message.success(t('Batch language settings saved successfully'));
        } else {
          if (updateParams.length > 1) {
            message.success(`${updateParams.length} ${t('ads have been modified and will be saved')} - ${t('All modified ads have been saved successfully')}`);
          } else {
            message.success(t('Ad language settings saved successfully'));
          }

          console.log('Current ad settings:', {
            savedAdsCount: updateParams.length,
            savedAdIds: updateParams.map(p => p.id),
          });
        }

        // 提交成功后清除自定义页面信息，让前端恢复显示原来的值
        // 因为API提交成功只是后台在处理，前端应该保持显示原来的数据
        adCustomPages.value = {};
        console.log('✅ 提交成功后已清除自定义页面信息，前端恢复显示原来的值');

        emit('ok');
      } catch (error) {
        console.error('保存多语言设置失败:', error);
        message.error(t('Failed to save language settings'));
      }
    };

    // 验证必填字段
    const validateRequiredFields = () => {
      if (activeTabKey.value === 'batch') {
        // 批量编辑模式验证
        const allLanguages = [batchDefaultLanguage.value, ...batchAdditionalLanguages.value];

        for (const lang of allLanguages) {
          const content = batchLanguageSettings[lang];
          if (!content) {
            return {
              isValid: false,
              message: t('Please fill in content for') + ' ' + getLanguageName(lang)
            };
          }

          if (!content.websiteUrl || !content.headline || !content.primaryText) {
            const missingFields = [];
            if (!content.websiteUrl) missingFields.push(t('Website URL'));
            if (!content.headline) missingFields.push(t('Headline'));
            if (!content.primaryText) missingFields.push(t('Primary Text'));

            return {
              isValid: false,
              message: `${getLanguageName(lang)}: ${t('Missing required fields')}: ${missingFields.join(', ')}`
            };
          }
        }
      } else {
        // 单个广告编辑模式验证
        const adId = activeTabKey.value;
        const isMultiLanguageEnabled = adMultiLanguageEnabled[adId];

        if (isMultiLanguageEnabled) {
          // 多语言模式 - headline, primaryText 不能为空
          const adSettings = adLanguageSettings[adId];
          const adContents = adLanguageContents[adId];

          if (!adSettings || !adContents) {
            return {
              isValid: false,
              message: t('Language settings not found')
            };
          }

          const allLanguages = [adSettings.defaultLanguage, ...adSettings.additionalLanguages];

          // 验证文案必填字段
          for (const lang of allLanguages) {
            const content = adContents[lang];
            if (!content) {
              return {
                isValid: false,
                message: t('Please fill in content for') + ' ' + getLanguageName(lang)
              };
            }

            if (!content.websiteUrl || !content.headline || !content.primaryText) {
              const missingFields = [];
              if (!content.websiteUrl) missingFields.push(t('Website URL'));
              if (!content.headline) missingFields.push(t('Headline'));
              if (!content.primaryText) missingFields.push(t('Primary Text'));

              return {
                isValid: false,
                message: `${getLanguageName(lang)}: ${t('Missing required fields')}: ${missingFields.join(', ')}`
              };
            }
          }

          // 验证媒体必填字段 - 至少默认语言需要有媒体，其他语言可以共享
          const hasAnyMedia = allLanguages.some(lang => adContents[lang]?.mediaHash);
          if (!hasAnyMedia) {
            const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === adId);
            const mediaType = currentAd ? checkAdMultiLanguageSupport(currentAd).adType : 'image';
            const mediaTypeText = mediaType === 'video' ? t('Video') : t('Image');

            return {
              isValid: false,
              message: t('At least one language must have') + ' ' + mediaTypeText.toLowerCase() + '. ' + t('Other languages can share the same media.')
            };
          }

          // 如果默认语言没有媒体，建议用户为默认语言添加媒体
          const defaultLanguageContent = adContents[adSettings.defaultLanguage];
          if (!defaultLanguageContent?.mediaHash) {
            const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === adId);
            const mediaType = currentAd ? checkAdMultiLanguageSupport(currentAd).adType : 'image';
            const mediaTypeText = mediaType === 'video' ? t('video') : t('image');

            message.warning(t('Recommend adding') + ' ' + mediaTypeText + ' ' + t('to default language') + ' (' + getLanguageName(adSettings.defaultLanguage) + ') ' + t('for better organization'));
          }
        } else {
          // 单语言模式 - headline, primaryText, description 都允许为空
          const singleContent = adSingleLanguageContents[adId];
          if (!singleContent) {
            return {
              isValid: false,
              message: t('Content not found')
            };
          }

          // 只验证websiteUrl为必填字段，headline, primaryText, description允许为空
          if (!singleContent.websiteUrl) {
            return {
              isValid: false,
              message: `${t('Missing required fields')}: ${t('Website URL')}`
            };
          }

          // 验证媒体必填字段
          if (!singleContent.mediaHash) {
            const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === adId);
            const mediaType = currentAd ? checkAdMultiLanguageSupport(currentAd).adType : 'image';
            const mediaTypeText = mediaType === 'video' ? t('Video') : t('Image');

            return {
              isValid: false,
              message: `${t('Missing required media')}: ${mediaTypeText}`
            };
          }
        }
      }

      return { isValid: true, message: '' };
    };

    // 批量编辑应用相关状态
    const applyingBatchChanges = ref(false);
    const batchChangesApplied = ref(false);

    // 检查是否有批量编辑的更改
    const hasBatchChanges = computed(() => {
      const allLanguages = [batchDefaultLanguage.value, ...batchAdditionalLanguages.value];

      for (const lang of allLanguages) {
        const content = batchLanguageSettings[lang];
        if (content && (content.websiteUrl || content.headline || content.primaryText || content.description)) {
          return true;
        }
      }

      return false;
    });

    // 应用批量编辑更改到所有广告
    const applyBatchChanges = async () => {
      try {
        applyingBatchChanges.value = true;

        // 验证批量编辑的必填字段
        const allLanguages = [batchDefaultLanguage.value, ...batchAdditionalLanguages.value];

        for (const lang of allLanguages) {
          const content = batchLanguageSettings[lang];
          if (!content || !content.websiteUrl || !content.headline || !content.primaryText) {
            const missingFields = [];
            if (!content?.websiteUrl) missingFields.push(t('Website URL'));
            if (!content?.headline) missingFields.push(t('Headline'));
            if (!content?.primaryText) missingFields.push(t('Primary Text'));

            message.error(`${getLanguageName(lang)}: ${t('Missing required fields')}: ${missingFields.join(', ')}`);
            return;
          }
        }

        // 应用批量更改到所有兼容的广告
        compatibleAds.value.forEach(ad => {
          const adId = ad.ad_id;

          // 启用多语言模式
          adMultiLanguageEnabled[adId] = true;

          // 设置语言配置
          adLanguageSettings[adId] = {
            defaultLanguage: batchDefaultLanguage.value,
            additionalLanguages: [...batchAdditionalLanguages.value],
            languageContent: {},
            isMultiLanguageEnabled: true,
          };

          // 设置语言内容
          if (!adLanguageContents[adId]) {
            adLanguageContents[adId] = {};
          }

          allLanguages.forEach(lang => {
            const batchContent = batchLanguageSettings[lang];
            if (batchContent) {
              // 保留原有的媒体信息（如果有的话）
              const existingContent = adLanguageContents[adId][lang] || {};

              adLanguageContents[adId][lang] = {
                websiteUrl: batchContent.websiteUrl || '',
                headline: batchContent.headline || '',
                primaryText: batchContent.primaryText || '',
                description: batchContent.description || '',
                // 保留现有的媒体信息
                mediaType: existingContent.mediaType,
                imageUrl: existingContent.imageUrl,
                videoUrl: existingContent.videoUrl,
                mediaName: existingContent.mediaName,
                mediaId: existingContent.mediaId,
                mediaHash: existingContent.mediaHash,
              };
            }
          });

          // 标记为用户修改
          markAdAsModified(adId);
        });


        batchChangesApplied.value = true;

        // 提醒用户检查媒体
        const mediaType = compatibleAds.value.length > 0 ?
          (checkAdMultiLanguageSupport(compatibleAds.value[0]).adType === 'video' ? t('videos') : t('images')) :
          t('media');

        message.success(t('Batch changes applied to all ads successfully'));
        message.info(t('Please ensure each language has the required') + ' ' + mediaType + ' ' + t('before saving'));

      } catch (error) {
        console.error('Failed to apply batch changes:', error);
        message.error(t('Failed to apply batch changes'));
      } finally {
        applyingBatchChanges.value = false;
      }
    };

    // 重置批量编辑更改
    const resetBatchChanges = () => {
      const { confirm } = Modal;
      confirm({
        title: t('Confirm Reset'),
        content: t('This will reset all batch editing changes. Continue?'),
        okText: t('Yes'),
        cancelText: t('Cancel'),
        onOk() {
          // 重置批量语言设置
          Object.keys(batchLanguageSettings).forEach(key => {
            delete batchLanguageSettings[key];
          });

          // 重新初始化默认语言
          batchLanguageSettings[batchDefaultLanguage.value] = {
            websiteUrl: '',
            headline: '',
            primaryText: '',
            description: '',
          };

          batchChangesApplied.value = false;
          message.success(t('Batch changes reset successfully'));
        },
      });
    };

    // 检查广告是否有修改的函数
    const hasAdBeenModified = (ad: AdData) => {
      const adId = ad.ad_id;

      // 基于用户实际操作记录来判断，而不是检查数据内容
      return userModifiedAds.has(adId);
    };

    // 构建更新广告参数的函数
    const buildUpdateAdParams = () => {
      const updateParams: Array<{
        ad_account: string;
        id: string;
        payload: any;
      }> = [];

      if (activeTabKey.value === 'batch') {
        // 批量编辑模式 - 检查是否已经应用了批量更改
        if (!batchChangesApplied.value) {
          message.warning(t('Please apply batch changes first before saving'));
          return [];
        }

        compatibleAds.value.forEach(ad => {
          const param = buildAdUpdateParam(ad);
          if (param) {
            updateParams.push(param);
          }
        });

      } else {
        // 单个广告编辑模式 - 检查所有广告是否有修改
        let modifiedAdsCount = 0;
        let checkedAdsCount = 0;

        compatibleAds.value.forEach(ad => {
          checkedAdsCount++;
          if (hasAdBeenModified(ad)) {
            const param = buildAdUpdateParam(ad);
            if (param) {
              updateParams.push(param);
              modifiedAdsCount++;
              console.log(`广告 ${ad.ad_name} (${ad.ad_id}) 检测到修改，将被提交`);
            }
          } else {
            console.log(`广告 ${ad.ad_name} (${ad.ad_id}) 未检测到修改，跳过`);
          }
        });


        // 输出检测结果
        if (updateParams.length > 0) {
          console.log(`检测到 ${modifiedAdsCount}/${checkedAdsCount} 个广告有修改，将全部提交`);
        } else {
          console.log(`检测到 0/${checkedAdsCount} 个广告有修改，无需提交`);
        }
      }

      return updateParams;
    };

    // 构建 asset_feed_spec
    const buildAssetFeedSpec = (ad: AdData, adSettings: any, adContents: any) => {
      const adType = checkAdMultiLanguageSupport(ad).adType;
      const isVideoAd = adType === 'video';

      const allLanguages = [adSettings.defaultLanguage, ...adSettings.additionalLanguages];

      // 🔍 添加调试信息
      console.log('🔍 buildAssetFeedSpec 调试信息:', {
        adId: ad.ad_id,
        adName: ad.ad_name,
        allLanguages,
        defaultLanguage: adSettings.defaultLanguage,
        additionalLanguages: adSettings.additionalLanguages,
        adContents: Object.keys(adContents),
        isVideoAd
      });

      // 构建 bodies (primaryText)
      const bodies = allLanguages.map(lang => ({
        text: adContents[lang]?.primaryText || '',
        adlabels: [{ name: lang }],
      }));

      // 构建 titles (headline)
      const titles = allLanguages.map(lang => ({
        text: adContents[lang]?.headline || '',
        adlabels: [{ name: lang }],
      }));

      // 构建 descriptions
      const descriptions = allLanguages.map(lang => ({
        text: adContents[lang]?.description || '',
        adlabels: [{ name: lang }],
      }));

      // 构建 link_urls
      const linkUrls = allLanguages.map(lang => ({
        website_url: adContents[lang]?.websiteUrl || '',
        adlabels: [{ name: lang }],
      }));

      // 构建媒体资源和媒体标签映射
      let mediaArray: any[] = [];
      const languageToMediaLabelMap = new Map<string, string>(); // 语言 -> 实际的媒体标签映射

      if (isVideoAd) {
        // 视频广告 - 构建 videos 数组
        const uniqueVideoObjects = new Map<string, any>(); // key: hash+thumbnailUrl, value: videoObj

        // 第一步：收集所有实际有媒体的语言，但每个唯一的视频+缩略图组合只创建一个video对象
        allLanguages.forEach(lang => {
          const content = adContents[lang];
          console.log(`🔍 检查语言 ${lang} 的媒体:`, {
            hasContent: !!content,
            mediaHash: content?.mediaHash,
            thumbnailUrl: content?.thumbnailUrl,
          });

          if (content?.mediaHash) {
            // 创建唯一标识：视频hash + 缩略图URL（如果有的话）
            const uniqueKey = `${content.mediaHash}_${content.thumbnailUrl || 'no-thumbnail'}`;

            console.log(`🔍 语言 ${lang} 创建uniqueKey: ${uniqueKey}`);

            if (!uniqueVideoObjects.has(uniqueKey)) {
              const videoObj: any = {
                video_id: content.mediaHash,
                adlabels: [{ name: lang }], // 只设置第一个语言
              };

              // 如果有缩略图，添加 thumbnail_url
              if (content.thumbnailUrl) {
                videoObj.thumbnail_url = content.thumbnailUrl;
              }

              uniqueVideoObjects.set(uniqueKey, videoObj);
              mediaArray.push(videoObj);

              // 记录这个语言有自己的媒体
              languageToMediaLabelMap.set(lang, lang);

              console.log(`✅ 为语言 ${lang} 创建了新的video对象:`, videoObj);
            } else {
              // 如果已经存在相同的视频+缩略图组合，不添加到adlabels，而是通过video_label共享
              // 获取第一个创建这个视频对象的语言作为媒体标签
              const existingVideoObj = uniqueVideoObjects.get(uniqueKey);
              const firstLanguageForThisVideo = existingVideoObj.adlabels[0].name;

              // 记录这个语言应该使用第一个语言的媒体标签
              languageToMediaLabelMap.set(lang, firstLanguageForThisVideo);

              console.log(`🔄 语言 ${lang} 将共享语言 ${firstLanguageForThisVideo} 的媒体`);
            }
          } else {
            console.log(`⚠️ 语言 ${lang} 没有媒体hash`);
          }
        });

        // 第二步：为没有媒体的语言分配媒体标签
        allLanguages.forEach(lang => {
          if (!languageToMediaLabelMap.has(lang)) {
            // 优先使用默认语言的媒体标签
            if (languageToMediaLabelMap.has(adSettings.defaultLanguage)) {
              languageToMediaLabelMap.set(lang, adSettings.defaultLanguage);
              console.log(`🔄 语言 ${lang} 将使用默认语言 ${adSettings.defaultLanguage} 的图片媒体`);
            } else if (mediaArray.length > 0) {
              // 如果默认语言也没有媒体，使用第一个可用的媒体标签
              const firstMediaLabel = mediaArray[0].adlabels[0].name;
              languageToMediaLabelMap.set(lang, firstMediaLabel);
              console.log(`🔄 语言 ${lang} 将使用第一个可用语言 ${firstMediaLabel} 的图片媒体`);
            }
          }
        });

        console.log('🔍 最终的images数组:', mediaArray);
        console.log('🔍 语言到图片媒体标签映射:', Object.fromEntries(languageToMediaLabelMap));
      }

      // 构建 asset_customization_rules - 每种语言都必须有媒体标签
      const assetCustomizationRules = allLanguages.map((lang) => {
        const rule: any = {
          body_label: { name: lang },
          title_label: { name: lang },
          description_label: { name: lang },
          link_url_label: { name: lang },
          is_default: lang === adSettings.defaultLanguage,
        };

        // 获取该语言应该使用的媒体标签
        const mediaLabelName = languageToMediaLabelMap.get(lang);
        if (mediaLabelName) {
          if (isVideoAd) {
            rule.video_label = { name: mediaLabelName };
          } else {
            rule.image_label = { name: mediaLabelName };
          }
        }

        // 第一个语言需要添加customization_spec
        if (lang === adSettings.defaultLanguage) {
          const language = availableLanguages.value.find(l => l.code === lang);
          if (language && language.locales && language.locales.length > 0) {
            rule.customization_spec = {
              locales: [language.locales[0]]
            };
          }
        }

        return rule;
      });

      return {
        bodies,
        titles,
        descriptions,
        link_urls: linkUrls,
        [isVideoAd ? 'videos' : 'images']: mediaArray,
        ad_formats: [isVideoAd ? 'SINGLE_VIDEO' : 'SINGLE_IMAGE'],
        call_to_action_types: ['LEARN_MORE'],
        asset_customization_rules: assetCustomizationRules,
      };
    };

    // 构建单个广告的更新参数
    const buildAdUpdateParam = (ad: AdData): { ad_account: string; id: string; payload: any } | null => {
      const creative = ad.creative;
      if (!creative) return null;

      const isMultiLanguageEnabled = adMultiLanguageEnabled[ad.ad_id];
      const { isCatalog } = checkAdMultiLanguageSupport(ad);

      // 🔍 添加调试信息
      console.log(`🔍 构建广告 ${ad.ad_name} (${ad.ad_id}) 的更新参数:`, {
        isMultiLanguageEnabled,
        hasUserModified: userModifiedAds.has(ad.ad_id),
        adSettings: adLanguageSettings[ad.ad_id],
        adContents: isMultiLanguageEnabled ? adLanguageContents[ad.ad_id] : adSingleLanguageContents[ad.ad_id]
      });

      // 按优先级获取 url_tags：creative.url_tags -> ad.post.url_tags -> 空字符串
      let urlTags = '';
      if (creative.url_tags) {
        urlTags = creative.url_tags;
      } else if (ad.post && ad.post.url_tags) {
        urlTags = ad.post.url_tags;
      }

      const payload: any = {
        url_tags: urlTags,
      };

      if (isMultiLanguageEnabled) {
        // 多语言模式
        const adSettings = adLanguageSettings[ad.ad_id];
        const adContents = adLanguageContents[ad.ad_id];

        if (adSettings && adContents) {
          // 构建 object_story_spec 和 asset_feed_spec
          const originalObjectStorySpec = creative.object_story_spec;
          if (originalObjectStorySpec) {
            // 检查是否有自定义页面
            const customPage = adCustomPages.value[ad.ad_id];
            const targetPageId = customPage ? customPage.id : originalObjectStorySpec.page_id;

            if (isCatalog) {
              // 多语言目录广告
              const adType = checkAdMultiLanguageSupport(ad).adType;

              payload.object_story_spec = {
                page_id: targetPageId,
                template_data: {
                  link: 'https://www.amazon.com/Good-Energy-Surprising-Connection-Metabolism/dp/0593712641',
                  name: '{{product.name}}',
                  message: '{{product.description}}',
                  description: '{{product.brand}}',
                  format_option: adType === 'video' ? 'single_video' : 'single_image',
                  call_to_action: {
                    type: 'LEARN_MORE'
                  },
                  customization_rules_spec: buildCatalogCustomizationRules(ad, adSettings, adContents)
                }
              };

              // 添加product_set_id
              if (ad.product_set?.source_id) {
                payload.product_set_id = ad.product_set.source_id;
              }

              // 添加固定的template_url_spec
              payload.template_url_spec = {
                web: {
                  url: '{{product.url}}'
                }
              };
            } else {
              // 普通多语言广告
              payload.object_story_spec = {
                page_id: targetPageId,
              };

              // 如果有 instagram_user_id，并且没有选择新的page，才添加到 object_story_spec
              if (originalObjectStorySpec.instagram_user_id && !customPage) {
                payload.object_story_spec.instagram_user_id = originalObjectStorySpec.instagram_user_id;
              }

              // 构建 asset_feed_spec
              payload.asset_feed_spec = buildAssetFeedSpec(ad, adSettings, adContents);
            }
          } else {
            // 普通多语言广告 - 没有originalObjectStorySpec的情况
            if (!isCatalog) {
              payload.asset_feed_spec = buildAssetFeedSpec(ad, adSettings, adContents);
            }
        }
      } else {
        // 单语言模式
        const singleContent = adSingleLanguageContents[ad.ad_id];
        if (singleContent) {
          const originalObjectStorySpec = creative.object_story_spec;
          if (originalObjectStorySpec) {
            // 检查是否有自定义页面
            const customPage = adCustomPages.value[ad.ad_id];
            const targetPageId = customPage ? customPage.id : originalObjectStorySpec.page_id;

            payload.object_story_spec = {
              page_id: targetPageId,
            };

            // 如果有 instagram_user_id，并且没有选择新的page，才添加到 object_story_spec
            // 因为新的page的instagram_user_id和原来的不一样，暂时不获取新的page的instagram_user_id
            if (originalObjectStorySpec.instagram_user_id && !customPage) {
              payload.object_story_spec.instagram_user_id = originalObjectStorySpec.instagram_user_id;
            }

            const adType = checkAdMultiLanguageSupport(ad).adType;

            if (isCatalog) {
              // 目录广告 - 单语言
              payload.object_story_spec.template_data = {
                link: singleContent.websiteUrl || '',
                name: singleContent.headline || '',
                message: singleContent.primaryText || '',
                description: singleContent.description || '',
                format_option: adType === 'video' ? 'single_video' : 'single_image',
                call_to_action: {
                  type: 'LEARN_MORE'
                }
              };

              // 添加product_set_id
              if (ad.product_set?.source_id) {
                payload.product_set_id = ad.product_set.source_id;
              }

              // 添加深度链接
              if (singleContent.deepLink) {
                payload.template_url_spec = {
                  web: {
                    url: singleContent.deepLink
                  }
                };
              }
            } else {
              // 普通广告
              if (adType === 'video') {
                // 视频广告
                const videoData: any = {
                  title: singleContent.headline || '',
                  message: singleContent.primaryText || '',
                  video_id: singleContent.mediaHash || '',
                  call_to_action: {
                    type: 'LEARN_MORE',
                    value: {
                      link: singleContent.websiteUrl || '',
                    },
                  },
                  link_description: singleContent.description || '',
                };

                // 添加缩略图支持（单语言广告使用 image_url）
                if (singleContent.thumbnailUrl) {
                  videoData.image_url = singleContent.thumbnailUrl;
                }

                payload.object_story_spec.video_data = videoData;
              } else {
                // 图片广告
                payload.object_story_spec.link_data = {
                  link: singleContent.websiteUrl || '',
                  name: singleContent.headline || '',
                  message: singleContent.primaryText || '',
                  image_hash: singleContent.mediaHash || '',
                  call_to_action: {
                    type: 'LEARN_MORE',
                  },
                  description: singleContent.description || '',
                };
              }
            }
          }
        }
      }

      console.log(`✅ 广告 ${ad.ad_name} 构建的payload:`, payload);

      return {
        ad_account: ad.ad_account_id,
        id: ad.ad_id,
        payload,
      };
    };

    // 删除重复的buildAssetFeedSpec函数定义 - 已在上面定义

    // 监听选中的语言变化，初始化语言内容
    watch(
      () => getAllSelectedLanguages(),
      newLanguages => {
        newLanguages.forEach(lang => {
          if (!currentAdSettings.languageContent[lang]) {
            currentAdSettings.languageContent[lang] = {
              websiteUrl: '',
              headline: '',
              primaryText: '',
              description: '',
            };
          }
        });


        // 设置第一个语言为活跃语言
        if (newLanguages.length > 0 && !newLanguages.includes(activeLanguageKey.value)) {
          activeLanguageKey.value = newLanguages[0];
        }
      },
      { immediate: true },
    );

    // 获取批量编辑可用语言列表
    const getAvailableBatchLanguages = () => {
      const usedLanguages = [batchDefaultLanguage.value, ...batchAdditionalLanguages.value];
      return availableLanguages.value.filter(lang => !usedLanguages.includes(lang.code));
    };

    const copyBatchDefaultToOthers = () => {
      if (batchAdditionalLanguages.value.length === 0) {
        message.warning(t('No additional languages to copy to'));
        return;
      }

      const defaultLanguageContent = batchLanguageSettings[batchDefaultLanguage.value];
      if (
        !defaultLanguageContent ||
        (!defaultLanguageContent.websiteUrl &&
          !defaultLanguageContent.headline &&
          !defaultLanguageContent.primaryText &&
          !defaultLanguageContent.description)
      ) {
        message.warning(t('Default language has no content to copy'));
        return;
      }

      const { confirm } = Modal;
      confirm({
        title: t('Confirm Copy'),
        content: t(
          'This will overwrite the content in all other languages with the default language content. Continue?',
        ),
        okText: t('Yes'),
        cancelText: t('Cancel'),
        onOk() {
          batchAdditionalLanguages.value.forEach(langCode => {
            if (!batchLanguageSettings[langCode]) {
              batchLanguageSettings[langCode] = {};
            }

            batchLanguageSettings[langCode] = {
              websiteUrl: defaultLanguageContent.websiteUrl || '',
              headline: defaultLanguageContent.headline || '',
              primaryText: defaultLanguageContent.primaryText || '',
              description: defaultLanguageContent.description || '',
            };
          });

          message.success(
            t('Content copied to') +
              ' ' +
              batchAdditionalLanguages.value.length +
              ' ' +
              t('languages'),
          );
        },
      });
    };

    const copyCurrentAdDefaultToOthers = () => {
      if (activeTabKey.value === 'batch') return;

      const currentAdSettings = adLanguageSettings[activeTabKey.value];
      if (!currentAdSettings || currentAdSettings.additionalLanguages.length === 0) {
        message.warning(t('No additional languages to copy to'));
        return;
      }

      const defaultLanguageContent =
        adLanguageContents[activeTabKey.value]?.[currentAdSettings.defaultLanguage];
      if (
        !defaultLanguageContent ||
        (!defaultLanguageContent.websiteUrl &&
          !defaultLanguageContent.headline &&
          !defaultLanguageContent.primaryText &&
          !defaultLanguageContent.description)
      ) {
        message.warning(t('Default language has no content to copy'));
        return;
      }

      const { confirm } = Modal;
      confirm({
        title: t('Confirm Copy'),
        content: t(
          'This will overwrite the content in all other languages with the default language content. Continue?',
        ),
        okText: t('Yes'),
        cancelText: t('Cancel'),
        onOk() {
          currentAdSettings.additionalLanguages.forEach(langCode => {
            if (!adLanguageContents[activeTabKey.value]) {
              adLanguageContents[activeTabKey.value] = {};
            }
            if (!adLanguageContents[activeTabKey.value][langCode]) {
              adLanguageContents[activeTabKey.value][langCode] = {};
            }

            adLanguageContents[activeTabKey.value][langCode] = {
              websiteUrl: defaultLanguageContent.websiteUrl || '',
              headline: defaultLanguageContent.headline || '',
              primaryText: defaultLanguageContent.primaryText || '',
              description: defaultLanguageContent.description || '',
              mediaType: defaultLanguageContent.mediaType,
              imageUrl: defaultLanguageContent.imageUrl,
              videoUrl: defaultLanguageContent.videoUrl,
              mediaName: defaultLanguageContent.mediaName,
              mediaId: defaultLanguageContent.mediaId,
            };
          });

          message.success(
            t('Content copied to') +
              ' ' +
              currentAdSettings.additionalLanguages.length +
              ' ' +
              t('languages'),
          );
        },
      });
    };

    // 批量编辑：从默认语言复制到当前语言
    const copyBatchDefaultToCurrentLanguage = (targetLanguage: string) => {
      if (targetLanguage === batchDefaultLanguage.value) {
        message.warning(t('Cannot copy to default language itself'));
        return;
      }

      const defaultLanguageContent = batchLanguageSettings[batchDefaultLanguage.value];
      if (
        !defaultLanguageContent ||
        (!defaultLanguageContent.websiteUrl &&
          !defaultLanguageContent.headline &&
          !defaultLanguageContent.primaryText &&
          !defaultLanguageContent.description)
      ) {
        message.warning(t('Default language has no content to copy'));
        return;
      }

      if (!batchLanguageSettings[targetLanguage]) {
        batchLanguageSettings[targetLanguage] = {};
      }

      batchLanguageSettings[targetLanguage] = {
        websiteUrl: defaultLanguageContent.websiteUrl || '',
        headline: defaultLanguageContent.headline || '',
        primaryText: defaultLanguageContent.primaryText || '',
        description: defaultLanguageContent.description || '',
      };

      message.success(t('Content copied from default language'));
    };

    // 单个广告编辑：从默认语言复制到当前语言
    const copyCurrentAdDefaultToCurrentLanguage = (targetLanguage: string) => {
      if (activeTabKey.value === 'batch') return;

      const currentAdSettings = adLanguageSettings[activeTabKey.value];
      if (!currentAdSettings) return;

      if (targetLanguage === currentAdSettings.defaultLanguage) {
        message.warning(t('Cannot copy to default language itself'));
        return;
      }

      const defaultLanguageContent =
        adLanguageContents[activeTabKey.value]?.[currentAdSettings.defaultLanguage];
      if (
        !defaultLanguageContent ||
        (!defaultLanguageContent.websiteUrl &&
          !defaultLanguageContent.headline &&
          !defaultLanguageContent.primaryText &&
          !defaultLanguageContent.description)
      ) {
        message.warning(t('Default language has no content to copy'));
        return;
      }

      if (!adLanguageContents[activeTabKey.value]) {
        adLanguageContents[activeTabKey.value] = {};
      }
      if (!adLanguageContents[activeTabKey.value][targetLanguage]) {
        adLanguageContents[activeTabKey.value][targetLanguage] = {};
      }

      adLanguageContents[activeTabKey.value][targetLanguage] = {
        websiteUrl: defaultLanguageContent.websiteUrl || '',
        headline: defaultLanguageContent.headline || '',
        primaryText: defaultLanguageContent.primaryText || '',
        description: defaultLanguageContent.description || '',
        mediaType: defaultLanguageContent.mediaType,
        imageUrl: defaultLanguageContent.imageUrl,
        videoUrl: defaultLanguageContent.videoUrl,
        mediaName: defaultLanguageContent.mediaName,
        mediaId: defaultLanguageContent.mediaId,
      };

      // 标记为用户修改
      markAdAsModified(activeTabKey.value);

      message.success(t('Content copied from default language'));
    };

    const getPreviewForLanguage = (lang: string, field: keyof AdLanguageContent) => {
      const content = adLanguageContents[activeTabKey.value]?.[lang]?.[field] || '';
      return content;
    };

    const getBatchPreviewForLanguage = (lang: string, field: keyof AdLanguageContent) => {
      const content = batchLanguageSettings[lang]?.[field] || '';
      return content;
    };

    // 更新特定语言Tab的批量编辑内容
    const updateBatchLanguageContentForTab = (
      lang: string,
      field: keyof AdLanguageContent,
      value: string,
    ) => {
      if (!batchLanguageSettings[lang]) {
        batchLanguageSettings[lang] = {
          websiteUrl: '',
          headline: '',
          primaryText: '',
          description: '',
        };
      }

      (batchLanguageSettings[lang] as any)[field] = value;
    };

    // 处理媒体加载
    const handleLoadMedia = async (langCode: string, adId: string) => {
      if (!adLanguageContents[adId] || !adLanguageContents[adId][langCode]) {
        return;
      }

      const content = adLanguageContents[adId][langCode];
      const hash = content.mediaHash;

      if (!hash) {
        message.warning(t('No media hash available'));
        return;
      }

      try {
        // 显示加载状态
        content.loading = true;
        await loadAdMedia(hash, langCode, adId);
        message.success(t('Media loaded successfully'));
      } catch (error) {
        console.error('Failed to load media:', error);
        message.error(t('Failed to load media'));
      } finally {
        content.loading = false;
      }
    };

    // 检查是否有媒体hash但没有URL
    const hasUnloadedMedia = (langCode: string, adId: string): boolean => {
      if (!adLanguageContents[adId] || !adLanguageContents[adId][langCode]) {
        return false;
      }

      const content = adLanguageContents[adId][langCode];
      const hasHash = !!content.mediaHash;
      const hasUrl = !!(content.imageUrl || content.videoUrl);

      return hasHash && !hasUrl;
    };

    // 获取媒体预览显示状态
    const getMediaPreviewState = (langCode: string, adId: string) => {
      if (!adLanguageContents[adId] || !adLanguageContents[adId][langCode]) {
        return { show: false, type: 'image', url: '', loading: false };
      }

      const content = adLanguageContents[adId][langCode];
      const mediaType = content.mediaType || 'image';
      const url = mediaType === 'video' ? content.videoUrl || '' : content.imageUrl || '';

      return {
        show: !!url,
        type: mediaType,
        url,
        loading: content.loading || false,
        hasUnloaded: hasUnloadedMedia(langCode, adId),
      };
    };

    // 解析单语言广告数据
    const parseSingleLanguageData = (ad: AdData): AdLanguageContent => {
      const creative = ad.creative;
      const objectStorySpec = creative?.object_story_spec;
      const { isCatalog } = checkAdMultiLanguageSupport(ad);

      if (!objectStorySpec) {
        return {
          websiteUrl: '',
          headline: '',
          primaryText: '',
          description: '',
        };
      }

      const result: AdLanguageContent = {
        websiteUrl: '',
        headline: '',
        primaryText: '',
        description: '',
      };

      if (isCatalog) {
        // 目录广告 - 单语言
        const templateData = objectStorySpec.template_data;
        if (templateData) {
          result.websiteUrl = templateData.link || '';
          result.headline = templateData.name || '';
          result.primaryText = templateData.message || '';
          result.description = templateData.description || '';
          // 添加深度链接
          result.deepLink = creative.template_url_spec?.web?.url || '';
        }

        // 设置媒体类型
        const firstProduct = ad.product_set?.products?.[0];
        result.mediaType = firstProduct?.video_url ? 'video' : 'image';

        if (result.mediaType === 'video' && firstProduct?.video_url) {
          result.mediaHash = firstProduct.video_url;
        } else if (result.mediaType === 'image' && firstProduct?.image_url) {
          result.mediaHash = firstProduct.image_url;
        }
      } else {
        // 普通广告 - 根据广告类型解析数据
        if (objectStorySpec.video_data) {
          // 视频广告
          const videoData = objectStorySpec.video_data;
          result.primaryText = videoData.message || '';
          result.headline = videoData.title || '';
          result.description = videoData.link_description || '';
          result.websiteUrl = videoData.call_to_action?.value?.link || '';
          result.mediaType = 'video';
          // 🔧 修复：正确获取视频ID，应该从videoData.video_id获取
          result.mediaHash = videoData.video_id || '';
          // 添加视频缩略图URL处理
          if (videoData.image_url) {
            result.thumbnailUrl = videoData.image_url;
          }
        } else if (objectStorySpec.link_data) {
          // 图片广告
          const linkData = objectStorySpec.link_data;
          result.primaryText = linkData.message || '';
          result.headline = linkData.name || '';
          result.description = linkData.description || '';
          result.websiteUrl = linkData.link || '';
          result.mediaType = 'image';
          result.mediaHash = creative.image_hash || '';
        }
      }

      return result;
    };

    // 获取广告多语言开关状态
    const getAdMultiLanguageEnabled = (adId: string): boolean => {
      return adMultiLanguageEnabled[adId] || false;
    };

    // 处理多语言开关切换
    const handleMultiLanguageToggle = (enabled: boolean) => {
      const adId = activeTabKey.value;
      if (adId === 'batch') return;

      const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === adId);
      if (!currentAd) return;

      adMultiLanguageEnabled[adId] = enabled;

      // 标记为用户修改
      markAdAsModified(adId);

      if (enabled) {
        // 启用多语言模式
        // 从单语言内容转换到多语言结构
        const singleContent = adSingleLanguageContents[adId];

        if (!adLanguageSettings[adId]) {
          // 🔧 修复：智能选择默认语言，不要硬编码en_XX
          const firstAvailableLanguage = availableLanguages.value.length > 0 ? availableLanguages.value[0].code : 'en_XX';
          const preferredDefault = availableLanguages.value.find(lang => lang.code === 'en_XX') ? 'en_XX' : firstAvailableLanguage;

          adLanguageSettings[adId] = {
            defaultLanguage: preferredDefault,
            additionalLanguages: [],
            languageContent: {},
            isMultiLanguageEnabled: true,
          };
        } else {
          adLanguageSettings[adId].isMultiLanguageEnabled = enabled;
        }

        const defaultLang = adLanguageSettings[adId].defaultLanguage;

        if (!adLanguageContents[adId]) {
          adLanguageContents[adId] = {};
        }

        // 将单语言内容复制到默认语言
        if (singleContent) {
          adLanguageContents[adId][defaultLang] = { ...singleContent };
        } else {
          adLanguageContents[adId][defaultLang] = parseSingleLanguageData(currentAd);
        }

        activeLanguageKey.value = defaultLang;
      } else {
        // 关闭多语言模式
        // 从多语言内容转换到单语言结构
        const defaultLang = adLanguageSettings[adId]?.defaultLanguage || 'en_XX';
        const multiContent = adLanguageContents[adId]?.[defaultLang];

        if (multiContent) {
          adSingleLanguageContents[adId] = { ...multiContent };
        } else {
          adSingleLanguageContents[adId] = parseSingleLanguageData(currentAd);
        }
      }
    };

    // 获取单语言内容
    const getSingleLanguageContent = (field: keyof AdLanguageContent): string => {
      const adId = activeTabKey.value;
      if (adId === 'batch') return '';

      const content = adSingleLanguageContents[adId];
      if (!content) {
        // 如果没有单语言内容，解析广告数据
        const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === adId);
        if (currentAd) {
          adSingleLanguageContents[adId] = parseSingleLanguageData(currentAd);
          return (adSingleLanguageContents[adId][field] as string) || '';
        }
        return '';
      }

      return (content[field] as string) || '';
    };

    // 更新单语言内容
    const updateSingleLanguageContent = (field: keyof AdLanguageContent, value: string) => {
      const adId = activeTabKey.value;
      if (adId === 'batch') return;

      if (!adSingleLanguageContents[adId]) {
        const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === adId);
        if (currentAd) {
          adSingleLanguageContents[adId] = parseSingleLanguageData(currentAd);
        } else {
          adSingleLanguageContents[adId] = {
            websiteUrl: '',
            headline: '',
            primaryText: '',
            description: '',
          };
        }
      }

      (adSingleLanguageContents[adId] as any)[field] = value;

      // 标记为用户修改
      markAdAsModified(adId);
    };

    // 检查是否有单语言媒体需要加载
    const hasSingleLanguageMedia = (): boolean => {
      const adId = activeTabKey.value;
      if (adId === 'batch') return false;

      const content = adSingleLanguageContents[adId];
      if (!content) return false;

      const hasHash = !!content.mediaHash;
      const hasUrl = !!(content.imageUrl || content.videoUrl);
      const isLoading = !!singleLanguageMediaStates[adId]?.loading;

      return hasHash && !hasUrl && !isLoading;
    };

    // 获取单语言媒体状态
    const getSingleLanguageMediaState = () => {
      const adId = activeTabKey.value;
      if (adId === 'batch') {
        return { loading: false, show: false, type: 'image', url: '' };
      }

      const state = singleLanguageMediaStates[adId];
      const content = adSingleLanguageContents[adId];

      // 如果有媒体状态，直接返回
      if (state && state.show && state.url) {
        return state;
      }

      // 如果媒体状态不存在但有内容数据，从内容中构建状态
      if (content) {
        const mediaType = content.mediaType || 'image';
        const url = mediaType === 'video' ? content.videoUrl : content.imageUrl;

        if (url) {
          return {
            loading: false,
            show: true,
            type: mediaType,
            url: url,
            hash: content.mediaHash,
          };
        }
      }

      // 默认返回空状态
      return { loading: false, show: false, type: 'image', url: '' };
    };

    // 处理单语言媒体加载
    const handleLoadSingleLanguageMedia = async () => {
      const adId = activeTabKey.value;
      if (adId === 'batch') return;

      const content = adSingleLanguageContents[adId];
      if (!content?.mediaHash) {
        message.warning(t('No media hash available'));
        return;
      }

      const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === adId);
      if (!currentAd?.ad_account_id) {
        message.error(t('Cannot find ad account information'));
        return;
      }

      // 初始化媒体状态
      if (!singleLanguageMediaStates[adId]) {
        singleLanguageMediaStates[adId] = {
          loading: false,
          show: false,
          type: content.mediaType || 'image',
          url: '',
          hash: content.mediaHash,
        };
      }

      try {
        // 显示加载状态
        singleLanguageMediaStates[adId].loading = true;

        const mediaType = content.mediaType || 'image';

        // 对于视频类型，获取actor_id作为page参数
        let pageParam: string | undefined;
        if (mediaType === 'video' && currentAd.creative?.actor_id) {
          pageParam = currentAd.creative.actor_id;
        }

        const response = (await getAdsMedia(
          content.mediaHash,
          currentAd.ad_account_id,
          mediaType,
          pageParam,
        )) as any;

        if (response.success && response.data && response.data.url) {
          // 更新媒体URL
          if (mediaType === 'image') {
            content.imageUrl = response.data.url;
          } else if (mediaType === 'video') {
            content.videoUrl = response.data.url;
          }

          // 更新状态
          singleLanguageMediaStates[adId].show = true;
          singleLanguageMediaStates[adId].url = response.data.url;

          message.success(t('Media loaded successfully'));
        } else {
          message.error(t('Failed to load media'));
        }
      } catch (error) {
        console.error('Failed to load single language media:', error);
        message.error(t('Failed to load media'));
      } finally {
        singleLanguageMediaStates[adId].loading = false;
      }
    };

    // 移动到前面定义 - 已在上面定义了initializeAdData

    // 媒体编辑Modal状态
    const showMediaEditModal = ref(false);
    const mediaEditContext = reactive({
      adId: '',
      adAccountId: '',
      adName: '',
      languageName: '',
      mediaType: 'image' as 'image' | 'video',
      currentLanguage: '',
    });

    // 处理媒体编辑
    const handleMediaEdit = (language?: string) => {
      if (activeTabKey.value === 'batch') {
        message.warning(t('Batch editing does not support media editing'));
        return;
      }

      const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === activeTabKey.value);
      if (!currentAd) return;

      const { adType } = checkAdMultiLanguageSupport(currentAd);
      const currentLang = language || (adMultiLanguageEnabled[activeTabKey.value] ? activeLanguageKey.value : 'en_XX');
      const langName = getLanguageName(currentLang);

      mediaEditContext.adId = currentAd.ad_id;
      mediaEditContext.adAccountId = currentAd.ad_account_id;
      mediaEditContext.adName = currentAd.ad_name;
      mediaEditContext.languageName = getAdMultiLanguageEnabled(activeTabKey.value) ? langName : '';
      mediaEditContext.mediaType = adType === 'video' ? 'video' : 'image';
      mediaEditContext.currentLanguage = currentLang;

      showMediaEditModal.value = true;
    };

    // 处理媒体编辑确认
    const handleMediaEditConfirm = (mediaData: any) => {
      const { materialId, mediaHash, mediaUrl, mediaName } = mediaData;

      if (getAdMultiLanguageEnabled(activeTabKey.value)) {
        // 多语言模式：更新当前语言的媒体信息
        updateCurrentLanguageContent('mediaId', materialId);
        updateCurrentLanguageContent('mediaHash', mediaHash);
        updateCurrentLanguageContent('mediaName', mediaName);

        if (mediaEditContext.mediaType === 'video') {
          updateCurrentLanguageContent('videoUrl', mediaUrl);
        } else {
          updateCurrentLanguageContent('imageUrl', mediaUrl);
        }
      } else {
        // 单语言模式：更新单语言内容
        updateSingleLanguageContent('mediaId', materialId);
        updateSingleLanguageContent('mediaHash', mediaHash);
        updateSingleLanguageContent('mediaName', mediaName);

        if (mediaEditContext.mediaType === 'video') {
          updateSingleLanguageContent('videoUrl', mediaUrl);
        } else {
          updateSingleLanguageContent('imageUrl', mediaUrl);
        }

        // 🔧 修复：同步更新单语言媒体状态，确保预览界面能够显示新的媒体
        const adId = activeTabKey.value;
        if (adId !== 'batch') {
          if (!singleLanguageMediaStates[adId]) {
            singleLanguageMediaStates[adId] = {
              loading: false,
              show: false,
              type: 'image',
              url: '',
            };
          }

          // 更新媒体状态为显示新的媒体
          singleLanguageMediaStates[adId].show = true;
          singleLanguageMediaStates[adId].type = mediaEditContext.mediaType;
          singleLanguageMediaStates[adId].url = mediaUrl;
          singleLanguageMediaStates[adId].hash = mediaHash;
        }
      }

      showMediaEditModal.value = false;
      // message.success(t('Media updated successfully')); // 移除多余的成功提示，已在MediaEditModal中显示
    };

    // 处理媒体编辑取消
    const handleMediaEditCancel = () => {
      showMediaEditModal.value = false;
    };

    // 添加语言搜索和过滤功能
    const languageSearchQuery = ref('');
    const batchLanguageSearchQuery = ref('');

    // 过滤可用语言列表
    const filteredAvailableLanguagesForCurrentAd = computed(() => {
      const availableForCurrentAd = getAvailableLanguagesForCurrentAd();
      return availableForCurrentAd.filter(lang =>
        lang.name.toLowerCase().includes(languageSearchQuery.value.toLowerCase()) ||
        lang.nativeName.toLowerCase().includes(languageSearchQuery.value.toLowerCase())
      );
    });

    const filteredAvailableBatchLanguages = computed(() => {
      const availableBatch = getAvailableBatchLanguages();
      return availableBatch.filter(lang =>
        lang.name.toLowerCase().includes(batchLanguageSearchQuery.value.toLowerCase()) ||
        lang.nativeName.toLowerCase().includes(batchLanguageSearchQuery.value.toLowerCase())
      );
    });

    // 快速选择功能
    const selectAllFilteredLanguages = () => {
      selectedLanguagesToAdd.value = filteredAvailableLanguagesForCurrentAd.value.map(lang => lang.code);
    };

    const clearLanguageSelection = () => {
      selectedLanguagesToAdd.value = [];
    };

    const selectAllFilteredBatchLanguages = () => {
      selectedBatchLanguagesToAdd.value = filteredAvailableBatchLanguages.value.map(lang => lang.code);
    };

    const clearBatchLanguageSelection = () => {
      selectedBatchLanguagesToAdd.value = [];
    };

    // Modal取消处理
    const handleLanguageModalCancel = () => {
      showLanguageModal.value = false;
      selectedLanguagesToAdd.value = [];
      languageSearchQuery.value = '';
    };

    const handleBatchLanguageModalCancel = () => {
      showBatchLanguageModal.value = false;
      selectedBatchLanguagesToAdd.value = [];
      batchLanguageSearchQuery.value = '';
    };

    const getLanguageContentForTab = (lang: string, field: keyof AdLanguageContent): string => {
      const content = adLanguageContents[activeTabKey.value]?.[lang]?.[field];
      return typeof content === 'string' ? content : '';
    };

    const updateLanguageContentForTab = (
      lang: string,
      field: keyof AdLanguageContent,
      value: string | 'image' | 'video',
    ) => {
      if (!adLanguageContents[activeTabKey.value]) {
        adLanguageContents[activeTabKey.value] = {};
      }
      if (!adLanguageContents[activeTabKey.value][lang]) {
        adLanguageContents[activeTabKey.value][lang] = {};
      }
      (adLanguageContents[activeTabKey.value][lang] as any)[field] = value;

      // 标记为用户修改
      if (activeTabKey.value !== 'batch') {
        markAdAsModified(activeTabKey.value);
      }
    };

    // 视频缩略图相关状态
    const showVideoThumbnailModal = ref(false);
    const thumbnailContext = reactive({
      adAccount: '',
      videoId: '',
      uploadNotes: '',
      isMultiLanguage: false,
      targetLanguage: '', // 当前编辑的语言
      targetAdId: '', // 当前编辑的广告ID
    });

    // Page编辑相关状态
    const showPageEditModal = ref(false);
    const pageEditContext = reactive({
      adAccountId: '',
      currentPageInfo: {
        id: '',
        name: ''
      }
    });

    // 存储每个广告的自定义页面信息 - 移动到前面
    // const adCustomPages = ref<Record<string, { id: string; name: string }>>({});

    // 检查当前语言是否有视频（用于控制缩略图按钮显示）
    const hasVideoForCurrentLanguage = (language?: string) => {
      const currentAd = activeTabKey.value === 'batch'
        ? compatibleAds.value[0]
        : compatibleAds.value.find(ad => ad.ad_id === activeTabKey.value);

      if (!currentAd) return false;

      const { adType } = checkAdMultiLanguageSupport(currentAd);
      if (adType !== 'video') return false;

      const isMultiLanguageEnabled = getAdMultiLanguageEnabled(currentAd.ad_id);

      if (isMultiLanguageEnabled) {
        // 多语言模式：检查当前语言是否有视频
        const targetLang = language || activeLanguageKey.value;
        const languageContent = adLanguageContents[currentAd.ad_id]?.[targetLang];
        return !!(languageContent?.mediaHash);
      } else {
        // 单语言模式：检查单语言内容是否有视频
        const singleContent = adSingleLanguageContents[currentAd.ad_id];
        return !!(singleContent?.mediaHash);
      }
    };

    // 处理缩略图按钮点击
    const handleThumbnailClick = (language?: string) => {
      // 获取当前广告和语言的视频信息
      const currentAd = activeTabKey.value === 'batch'
        ? compatibleAds.value[0]
        : compatibleAds.value.find(ad => ad.ad_id === activeTabKey.value);

      if (!currentAd) {
        message.error(t('No ad selected'));
        return;
      }

      const { adType } = checkAdMultiLanguageSupport(currentAd);
      if (adType !== 'video') {
        message.error(t('This feature is only available for video ads'));
        return;
      }

      // 检查当前语言是否有视频 - 移除fallback逻辑
      let videoId = '';
      const isMultiLanguageEnabled = getAdMultiLanguageEnabled(currentAd.ad_id);
      const targetLang = language || activeLanguageKey.value;

      if (isMultiLanguageEnabled) {
        // 多语言模式：只从当前语言获取视频ID
        const languageContent = adLanguageContents[currentAd.ad_id]?.[targetLang];
        if (languageContent?.mediaHash) {
          videoId = languageContent.mediaHash;
        }
      } else {
        // 单语言模式：从单语言内容获取
        const singleContent = adSingleLanguageContents[currentAd.ad_id];
        if (singleContent?.mediaHash) {
          videoId = singleContent.mediaHash;
        }
      }

      console.log('🔍 Thumbnail Click Debug:', {
        adId: currentAd.ad_id,
        adName: currentAd.ad_name,
        isMultiLanguageEnabled,
        targetLanguage: targetLang,
        foundVideoId: videoId,
        languageContent: isMultiLanguageEnabled ? adLanguageContents[currentAd.ad_id]?.[targetLang] : adSingleLanguageContents[currentAd.ad_id]
      });

      if (!videoId) {
        const langName = getLanguageName(targetLang);
        const errorMessage = isMultiLanguageEnabled
          ? t('Please upload a video for {{language}} language first before setting thumbnail', { language: langName })
          : t('Please upload a video first before setting thumbnail');
        message.error(errorMessage);
        return;
      }

      // 设置缩略图modal的上下文
      thumbnailContext.adAccount = currentAd.ad_account_id;
      thumbnailContext.videoId = videoId;
      thumbnailContext.uploadNotes = `Video thumbnail for ${currentAd.ad_name}${language ? ` (${getLanguageName(language)})` : ''}`;
      thumbnailContext.isMultiLanguage = isMultiLanguageEnabled;
      thumbnailContext.targetLanguage = targetLang;
      thumbnailContext.targetAdId = currentAd.ad_id;

      // 打开缩略图选择modal
      showVideoThumbnailModal.value = true;
    };

    // 处理缩略图选择完成
    const handleThumbnailSelected = (data: { type: 'system' | 'custom'; thumbnail: any }) => {
      const { type, thumbnail } = data;
      const { targetLanguage, targetAdId, isMultiLanguage } = thumbnailContext;

      // 辅助函数：去掉URL的查询参数
      const removeQueryParams = (url: string): string => {
        if (!url) return url;
        try {
          const urlObj = new URL(url);
          return `${urlObj.origin}${urlObj.pathname}`;
        } catch {
          // 如果URL格式不正确，返回原始字符串
          return url.split('?')[0];
        }
      };

      // 获取基准缩略图URL用于比较
      let baseThumbnailUrl = '';
      const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === targetAdId);

      if (isMultiLanguage) {
        // 多语言模式：获取该语言初始化时的缩略图URL
        const initialContent = adLanguageContents[targetAdId]?.[targetLanguage];

        if (initialContent && initialContent.thumbnailUrl) {
          // 如果该语言有初始缩略图URL，使用它作为基准
          baseThumbnailUrl = initialContent.thumbnailUrl;
        } else {
          // 如果该语言没有初始缩略图，检查是否能从原始单语言数据获取
          if (currentAd?.creative?.object_story_spec?.video_data?.image_url) {
            baseThumbnailUrl = currentAd.creative.object_story_spec.video_data.image_url;
          }
        }
      } else {
        // 单语言模式：直接从原始广告数据获取
        if (currentAd?.creative?.object_story_spec?.video_data?.image_url) {
          baseThumbnailUrl = currentAd.creative.object_story_spec.video_data.image_url;
        }
      }

      // 比较：新选择的URL与基准URL比较（都去掉查询参数）
      const baseUrlWithoutQuery = removeQueryParams(baseThumbnailUrl);
      const newUrlWithoutQuery = removeQueryParams(thumbnail.url || '');

      const hasChanged = baseUrlWithoutQuery !== newUrlWithoutQuery;

      console.log('🔍 缩略图URL与基准数据比较:', {
        adId: targetAdId,
        language: targetLanguage,
        isMultiLanguage,
        baseUrl: baseThumbnailUrl,
        newUrl: thumbnail.url,
        baseUrlWithoutQuery,
        newUrlWithoutQuery,
        hasChanged
      });

      // 只有在与基准数据真正发生变化时才执行更新
      if (!hasChanged) {
        console.log('✅ 缩略图与基准数据相同，跳过更新');
        return;
      }

      if (isMultiLanguage) {
        // 多语言模式：更新adLanguageContents
        if (!adLanguageContents[targetAdId]) {
          adLanguageContents[targetAdId] = {};
        }
        if (!adLanguageContents[targetAdId][targetLanguage]) {
          adLanguageContents[targetAdId][targetLanguage] = {};
        }

        const content = adLanguageContents[targetAdId][targetLanguage];

        if (type === 'custom') {
          // 自定义缩略图：保存URL和hash
          content.thumbnailUrl = thumbnail.url;
          content.thumbnailHash = thumbnail.hash;
          content.thumbnailType = 'custom';
        } else {
          // 系统缩略图：保存URL和ID
          content.thumbnailUrl = thumbnail.url;
          content.thumbnailId = thumbnail.id;
          content.thumbnailType = 'system';
        }
      } else {
        // 单语言模式：更新adSingleLanguageContents
        if (!adSingleLanguageContents[targetAdId]) {
          adSingleLanguageContents[targetAdId] = {};
        }

        const content = adSingleLanguageContents[targetAdId];

        if (type === 'custom') {
          // 自定义缩略图：保存URL和hash
          content.thumbnailUrl = thumbnail.url;
          content.thumbnailHash = thumbnail.hash;
          content.thumbnailType = 'custom';
        } else {
          // 系统缩略图：保存URL和ID
          content.thumbnailUrl = thumbnail.url;
          content.thumbnailId = thumbnail.id;
          content.thumbnailType = 'system';
        }
      }

      // 只有在与基准数据真正发生变化时才标记广告已修改
      markAdAsModified(targetAdId);

      console.log('✅ 缩略图更新完成（与基准数据不同）:', {
        adId: targetAdId,
        language: targetLanguage,
        isMultiLanguage,
        thumbnailType: type,
        thumbnailData: thumbnail,
      });

      message.success(t('Thumbnail updated successfully'));
    };

    // 处理视频缩略图点击播放
    const handleVideoThumbnailClick = (event: Event, langCode: string, adId: string) => {
      const mediaState = getMediaPreviewState(langCode, adId);
      const thumbnailUrl = getLanguageContentForTab ? getLanguageContentForTab(langCode, 'thumbnailUrl') : getCurrentLanguageContent('thumbnailUrl');

      console.log('🎥 Video Thumbnail Click:', {
        langCode,
        adId,
        mediaState,
        thumbnailUrl
      });

      if (mediaState.type === 'video' && mediaState.url) {
        const target = event.currentTarget as HTMLElement;
        const container = target.closest('.video-thumbnail-container');

        if (container) {
          try {
            // 创建video元素
            const video = document.createElement('video');
            video.className = 'video-player';
            video.src = mediaState.url;
            if (thumbnailUrl) {
              video.poster = thumbnailUrl;
            }
            video.controls = true;
            video.preload = 'metadata';
            video.setAttribute('playsinline', '');
            video.setAttribute('controlsList', 'nodownload');

            // 优化视频尺寸设置，确保控制按钮可见
            video.style.width = '100%';
            video.style.maxHeight = '400px';
            video.style.height = 'auto';
            video.style.borderRadius = '8px';
            video.style.backgroundColor = '#000';
            video.style.objectFit = 'contain';

            // 添加事件监听器
            video.addEventListener('loadstart', () => {
              console.log('🎥 Video loading started');
            });

            video.addEventListener('canplay', () => {
              console.log('🎥 Video can start playing');
            });

            video.addEventListener('error', (e) => {
              console.error('🎥 Video error:', e);
              message.error(t('Failed to load video. Please try again.'));

              // 恢复缩略图显示
              container.innerHTML = `
                <div class="video-error-state" style="
                  display: flex;
                  flex-direction: column;
                  align-items: center;
                  justify-content: center;
                  min-height: 200px;
                  background: #f5f5f5;
                  border-radius: 8px;
                  border: 2px dashed #d9d9d9;
                ">
                  ${thumbnailUrl ? `<img src="${thumbnailUrl}" alt="Video Thumbnail" style="max-width: 100px; max-height: 100px; border-radius: 4px; margin-bottom: 8px;" />` : ''}
                  <div style="font-size: 48px; color: #ff4d4f; margin-bottom: 8px;">⚠️</div>
                  <div style="color: #666; text-align: center;">
                    <div>Video unavailable</div>
                    <div style="font-size: 12px; margin-top: 4px;">Click to try again</div>
                  </div>
                </div>
              `;
            });

            // 替换容器内容
            container.innerHTML = '';
            container.appendChild(video);

            // 自动播放（如果浏览器允许）
            video.play().catch(error => {
              console.warn('🎥 Auto-play prevented:', error);
              // 自动播放被阻止是正常的，不需要显示错误消息
            });
          } catch (error) {
            console.error('🎥 Error creating video player:', error);
            message.error(t('Failed to create video player'));
          }
        }
      } else {
        console.warn('🎥 No video URL available for playback');
        message.warning(t('Video not available for playback'));
      }
    };

    // 设置视频缩略图点击事件监听器
    const setupVideoThumbnailClickListeners = () => {
      nextTick(() => {
        // 为所有video-thumbnail-container添加点击事件
        const containers = document.querySelectorAll('.video-thumbnail-container');
        containers.forEach(container => {
          container.addEventListener('click', (event: Event) => {
            // 检查是否点击的是播放按钮区域
            const target = event.target as HTMLElement;
            if (target.closest('.video-play-overlay') || container.contains(target)) {
              // 尝试从最近的预览容器中获取语言和广告信息
              const previewContainer = container.closest('.preview-container');
              if (previewContainer) {
                // 这里可以通过DOM结构推断当前的语言和广告ID
                // 由于DOM结构复杂，我们采用简化方式：使用当前活跃的tab信息
                const currentLang = activeLanguageKey.value;
                const currentAdId = activeTabKey.value;

                if (currentAdId !== 'batch') {
                  handleVideoThumbnailClick(event, currentLang, currentAdId);
                }
              }
            }
          });
        });

      });
    };

    // 处理单语言视频缩略图点击播放
    const handleSingleLanguageVideoThumbnailClick = (event: Event) => {
      const mediaState = getSingleLanguageMediaState();
      const thumbnailUrl = getSingleLanguageContent('thumbnailUrl');

      console.log('🎥 Single Language Video Thumbnail Click:', {
        mediaState,
        thumbnailUrl
      });

      if (mediaState.type === 'video' && mediaState.url) {
        const target = event.currentTarget as HTMLElement;
        const container = target.closest('.video-thumbnail-container');

        if (container) {
          try {
            // 创建video元素
            const video = document.createElement('video');
            video.className = 'video-player';
            video.src = mediaState.url;
            if (thumbnailUrl) {
              video.poster = thumbnailUrl;
            }
            video.controls = true;
            video.preload = 'metadata';
            video.setAttribute('playsinline', '');
            video.setAttribute('controlsList', 'nodownload');

            // 优化视频尺寸设置，确保控制按钮可见
            video.style.width = '100%';
            video.style.maxHeight = '400px';
            video.style.height = 'auto';
            video.style.borderRadius = '8px';
            video.style.backgroundColor = '#000';
            video.style.objectFit = 'contain';

            // 添加事件监听器
            video.addEventListener('loadstart', () => {
              console.log('🎥 Single language video loading started');
            });

            video.addEventListener('canplay', () => {
              console.log('🎥 Single language video can start playing');
            });

            video.addEventListener('error', (e) => {
              console.error('🎥 Single language video error:', e);
              message.error(t('Failed to load video. Please try again.'));

              // 恢复缩略图显示
              container.innerHTML = `
                <div class="video-error-state" style="
                  display: flex;
                  flex-direction: column;
                  align-items: center;
                  justify-content: center;
                  min-height: 200px;
                  background: #f5f5f5;
                  border-radius: 8px;
                  border: 2px dashed #d9d9d9;
                ">
                  ${thumbnailUrl ? `<img src="${thumbnailUrl}" alt="Video Thumbnail" style="max-width: 100px; max-height: 100px; border-radius: 4px; margin-bottom: 8px;" />` : ''}
                  <div style="font-size: 48px; color: #ff4d4f; margin-bottom: 8px;">⚠️</div>
                  <div style="color: #666; text-align: center;">
                    <div>Video unavailable</div>
                    <div style="font-size: 12px; margin-top: 4px;">Click to try again</div>
                  </div>
                </div>
              `;
            });

            // 替换容器内容
            container.innerHTML = '';
            container.appendChild(video);

            // 自动播放（如果浏览器允许）
            video.play().catch(error => {
              console.warn('🎥 Single language auto-play prevented:', error);
              // 自动播放被阻止是正常的，不需要显示错误消息
            });
          } catch (error) {
            console.error('🎥 Error creating single language video player:', error);
            message.error(t('Failed to create video player'));
          }
        }
      } else {
        console.warn('🎥 No video URL available for single language playback');
        message.warning(t('Video not available for playback'));
      }
    };

    // 删除未使用的getLanguageLocales函数

    // 处理批量编辑tab点击事件
    const handleBatchTabClick = () => {
      message.info(t('Batch edit feature is under development and will be available soon'));
    };

    // === 链接和文案选择功能 ===
    const linkPickerRef = ref<any>(null);
    const copywritingPickerRef = ref<any>(null);

    // 链接列配置
    const linkColumns = [
      {
        title: t('Link'),
        dataIndex: 'link',
        key: 'link',
        width: 350,
        ellipsis: true,
      },
      {
        title: t('Name'),
        dataIndex: 'name',
        key: 'name',
        width: 200,
      },
      {
        title: t('Notes'),
        dataIndex: 'notes',
        key: 'notes',
        width: 150,
      }
    ];

    // 文案列配置
    const copywritingColumns = [
      {
        title: t('Headline'),
        dataIndex: 'headline',
        key: 'headline',
        width: 200,
        ellipsis: true,
      },
      {
        title: t('Primary Text'),
        dataIndex: 'primary_text',
        key: 'primary_text',
        width: 300,
        ellipsis: true,
      },
      {
        title: t('Description'),
        dataIndex: 'description',
        key: 'description',
        width: 200,
        ellipsis: true,
      },
      {
        title: t('Notes'),
        dataIndex: 'notes',
        key: 'notes',
        width: 150,
      }
    ];

    // 处理链接选择
    const handleLinkSelection = (_keys: any[], rows: any[]) => {
      if (rows.length > 0) {
        const selectedLink = rows[0];
        const websiteUrl = selectedLink.link;

        // 更新当前语言的网站链接
        if (activeTabKey.value === 'batch') {
          // 批量编辑模式 - 暂不处理
          return;
        } else {
          // 单个广告编辑模式
          if (getAdMultiLanguageEnabled(activeTabKey.value)) {
            // 多语言模式
            updateCurrentLanguageContent('websiteUrl', websiteUrl);
          } else {
            // 单语言模式
            updateSingleLanguageContent('websiteUrl', websiteUrl);
          }
        }

        message.success(t('Link selected successfully'));
      }
    };

    // 处理文案选择
    const handleCopywritingSelection = (_keys: any[], rows: any[]) => {
      if (rows.length > 0) {
        const selectedCopywriting = rows[0];

        // 根据需求，选择文案后填充标题、正文、描述所有字段
        const headline = selectedCopywriting.headline || '';
        const primaryText = selectedCopywriting.primary_text || '';
        const description = selectedCopywriting.description || '';

        // 更新当前语言的文案内容
        if (activeTabKey.value === 'batch') {
          // 批量编辑模式 - 暂不处理
          return;
        } else {
          // 单个广告编辑模式
          if (getAdMultiLanguageEnabled(activeTabKey.value)) {
            // 多语言模式
            updateCurrentLanguageContent('headline', headline);
            updateCurrentLanguageContent('primaryText', primaryText);
            updateCurrentLanguageContent('description', description);
          } else {
            // 单语言模式
            updateSingleLanguageContent('headline', headline);
            updateSingleLanguageContent('primaryText', primaryText);
            updateSingleLanguageContent('description', description);
          }
        }

        message.success(t('Copywriting selected successfully'));
      }
    };

    // 打开链接选择模态框
    const openLinkPicker = () => {
      linkPickerRef.value?.openModal();
    };

    // 打开文案选择模态框
    const openCopywritingPicker = () => {
      copywritingPickerRef.value?.openModal();
    };

    return {
      t,
      visible,
      activeTabKey,
      activeLanguageKey,
      batchLanguages,
      batchTargetLanguages,
      batchSettings,
      currentAdSettings,
      availableLanguages,
      languagesLoading,
      compatibleAds,
      incompatibleTypes,
      errorDescription,
      adTypeText,
      getAdTypeColor,
      getAdTypeText,
      hasMultiLanguageConfig,
      getAllSelectedLanguages,
      getLanguageName,
      getLanguageNativeName,
      getAdTabTitle,
      getVideoAdsCount,
      getImageAdsCount,
      handleCancel,
      handleOk,

      // Tab选择
      selectTab,
      handleBatchTabClick,

      // 新增的语言管理相关
      defaultLanguage,
      selectedLanguage,
      additionalLanguages,
      showLanguageModal,
      selectedLanguagesToAdd,
      availableLanguagesToAdd,

      // 广告相关方法
      getAdDisplayName,
      getCurrentAdName,
      getCurrentAdTypeColor,
      getCurrentAdTypeText,
      getCurrentAdDisplayTitle,
      getCurrentAdAdditionalLanguages,
      addLanguageToCurrentAd,
      removeLanguageFromCurrentAd,
      getAvailableLanguagesForCurrentAd,
      getCurrentLanguageContent,
      updateCurrentLanguageContent,

      // 预览相关
      getCurrentBrandName,
      getCurrentAdType,
      getCurrentContextMediaType,
      getPreviewMediaUrl,
      getPreviewMediaType,

      // 批量预览相关
      getBatchPreviewHeadline,
      getBatchPreviewPrimaryText,
      getBatchPreviewDescription,
      getBatchPreviewWebsiteUrl,

      // 媒体内容相关
      getCurrentMediaType,
      getCurrentMediaUrl,
      updateCurrentMediaContent,

      // 批量编辑相关
      batchActiveLanguageKey,
      batchDefaultLanguage,
      batchAdditionalLanguages,
      showBatchLanguageModal,
      selectedBatchLanguagesToAdd,
      batchLanguageSettings,
      removeBatchLanguage,
      addBatchLanguage,
      getBatchCurrentLanguagePreview,

      // 更新批量编辑语言内容
      updateBatchLanguageContent,

      // 批量编辑默认语言变更
      handleBatchDefaultLanguageChange,

      // 获取当前广告的默认语言
      getCurrentAdDefaultLanguage,

      // 当前广告默认语言变更
      handleCurrentAdDefaultLanguageChange,

      // 获取批量编辑可用语言列表
      getAvailableBatchLanguages,

      copyBatchDefaultToOthers,
      copyCurrentAdDefaultToOthers,

      // 批量编辑：从默认语言复制到当前语言
      copyBatchDefaultToCurrentLanguage,

      // 单个广告编辑：从默认语言复制到当前语言
      copyCurrentAdDefaultToCurrentLanguage,

      getLanguageContentForTab,
      updateLanguageContentForTab,
      getPreviewForLanguage,
      getBatchPreviewForLanguage,

      // 更新特定语言Tab的批量编辑内容
      updateBatchLanguageContentForTab,

      // 处理媒体加载
      handleLoadMedia,

      // 检查是否有媒体hash但没有URL
      hasUnloadedMedia,

      // 获取媒体预览显示状态
      getMediaPreviewState,

      // 单语言功能相关方法
      getAdMultiLanguageEnabled,
      handleMultiLanguageToggle,
      getSingleLanguageContent,
      updateSingleLanguageContent,
      hasSingleLanguageMedia,
      getSingleLanguageMediaState,
      handleLoadSingleLanguageMedia,
      parseSingleLanguageData,
      initializeAdData,
      resetAllData,

      // 媒体编辑相关
      showMediaEditModal,
      mediaEditContext,
      handleMediaEdit,
      handleMediaEditConfirm,
      handleMediaEditCancel,

      // 批量编辑应用相关
      hasBatchChanges,
      applyingBatchChanges,
      applyBatchChanges,
      resetBatchChanges,
      validateRequiredFields,

      // 语言搜索和过滤功能
      languageSearchQuery,
      filteredAvailableLanguagesForCurrentAd,
      selectAllFilteredLanguages,
      clearLanguageSelection,
      handleLanguageModalCancel,

      // 批量编辑语言搜索功能
      batchLanguageSearchQuery,
      filteredAvailableBatchLanguages,
      selectAllFilteredBatchLanguages,
      clearBatchLanguageSelection,
      handleBatchLanguageModalCancel,

      // 缩略图相关
      showVideoThumbnailModal,
      thumbnailContext,
      hasVideoForCurrentLanguage,
      handleThumbnailClick,
      handleThumbnailSelected,

      // 视频播放判断函数
      shouldShowVideoPlayer: (langCode: string, adId: string) => {
        const mediaState = getMediaPreviewState(langCode, adId);
        return mediaState.type === 'video' && mediaState.url;
      },

      // 获取视频播放器属性
      getVideoPlayerProps: (langCode: string, adId: string) => {
        const mediaState = getMediaPreviewState(langCode, adId);
        const thumbnailUrl = getLanguageContentForTab ? getLanguageContentForTab(langCode, 'thumbnailUrl') : getCurrentLanguageContent('thumbnailUrl');

        return {
          src: mediaState.url,
          poster: thumbnailUrl || undefined,
        };
      },

      // 处理视频缩略图点击播放
      handleVideoThumbnailClick,

      // 设置视频缩略图点击事件监听器
      setupVideoThumbnailClickListeners,

      // 处理单语言视频缩略图点击播放
      handleSingleLanguageVideoThumbnailClick,

      // Page编辑相关方法
      handlePageEdit: () => {
        if (activeTabKey.value === 'batch') return;

        const currentAd = compatibleAds.value.find((ad: AdData) => ad.ad_id === activeTabKey.value);
        if (!currentAd) return;

        // 获取当前页面信息
        const pageId = currentAd.creative?.object_story_spec?.page_id;
        if (!pageId) {
          message.error(t('No page information found'));
          return;
        }

        // 查找页面名称
        let pageName = 'Brand Name';
        if ((currentAd as any).pages && Array.isArray((currentAd as any).pages)) {
          const matchedPage = (currentAd as any).pages.find((page: any) => page.source_id === pageId);
          if (matchedPage && matchedPage.name) {
            pageName = matchedPage.name;
          }
        }

        // 设置上下文
        pageEditContext.adAccountId = currentAd.ad_account_id;
        pageEditContext.currentPageInfo = {
          id: pageId,
          name: pageName
        };

        // 显示modal
        showPageEditModal.value = true;
      },

      handlePageEditCancel: () => {
        showPageEditModal.value = false;
      },

      handlePageEditConfirm: (newPageInfo: { id: string; name: string }) => {
        if (activeTabKey.value === 'batch') return;

        // 保存自定义页面信息
        adCustomPages.value[activeTabKey.value] = {
          id: newPageInfo.id,
          name: newPageInfo.name
        };

        // 标记广告已修改
        markAdAsModified(activeTabKey.value);

        showPageEditModal.value = false;
        message.success(t('Page updated successfully'));
      },

      showPageEditModal,
      pageEditContext,
      adCustomPages,

      // 链接和文案选择功能
      linkPickerRef,
      copywritingPickerRef,
      linkColumns,
      copywritingColumns,
      handleLinkSelection,
      handleCopywritingSelection,
      openLinkPicker,
      openCopywritingPicker,
      queryLinksApi,
      queryCopywritingsApi,

      // 目录广告相关
      isCurrentAdCatalog,
      getCurrentProductSet,
      catalogPlaceholders,
      insertPlaceholder,
      handleProductSetEdit,
      replacePlaceholders,
      buildCatalogCustomizationRules,
      getPreviewText,
      getPreviewPrimaryText,
      getPreviewHeadline,
      getPreviewDescription,
      getPreviewWebsiteUrl,
      getPreviewDeepLink,
    };
  },
});
</script>

<style lang="less" scoped>
@import './multi-language-modal.less';
</style>
