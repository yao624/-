                                <a-form-item :label="t('Description')">
                                  <a-row :gutter="[6, 0]" :wrap="false">
                                    <a-col :flex="1">
                                      <a-textarea
                                        :value="getCurrentLanguageContent('description')"
                                        @update:value="(value: string) => updateCurrentLanguageContent('description', value)"
                                        :placeholder="
                                          t('Enter description for') +
                                          ' ' +
                                          getLanguageName(activeLanguageKey)
                                        "
                                        :rows="3"
                                      />
                                    </a-col>
                                    <a-col style="align-self: flex-start; padding-top: 8px;">
                                      <a-button
