                                      <a-textarea
                                        :value="getCurrentLanguageContent('primaryText')"
                                        @update:value="(value: string) => updateCurrentLanguageContent('primaryText', value)"
                                        :placeholder="
                                          t('Enter primary text for') +
                                          ' ' +
                                          getLanguageName(activeLanguageKey)
                                        "
                                        :rows="4"
                                      />
                                    </a-col>
                                    <a-col style="align-self: flex-start; padding-top: 8px;">
                                      <a-button
