VUE_APP_PUBLIC_PATH=/
VUE_APP_PREVIEW=true
# 须与后端 routes/api.php 的 prefix /v2 一致，否则除 mock 外接口会 404
VUE_APP_API_BASE_URL=/api/v2
VUE_APP_PROXY_TARGET=http://www.sucai.com/

VITE_APP_PUBLIC_PATH=/
VITE_APP_PREVIEW=true
VITE_APP_API_BASE_URL=/api/v2
# 本地开发：phpstudy 站点根 URL（须能直接打开 Laravel）
VITE_PROXY_TARGET=http://www.sucai.com/
